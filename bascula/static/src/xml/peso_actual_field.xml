<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="bascula.PesoActualField" owl="1">
        <div class="o_field_widget o_field_peso_actual">
            <div class="alert alert-success" style="padding: 15px; background-color: #d4edda; border: 2px solid #28a745; margin: 0;">
                <div style="text-align: center;">
                    <strong style="font-size: 14px;">PESO ACTUAL DESDE BASCULA</strong><br/>
                    <span style="font-size: 48px; font-weight: bold; color: #28a745;">
                        <t t-esc="formattedPeso"/> Kg
                    </span><br/>
                    <small style="color: #666;">
                        Actualizado: <t t-esc="state.timestamp"/>
                    </small>
                    <div style="margin-top: 10px;">
                        <t t-if="!state.soportado">
                            <span class="text-danger" style="font-size: 12px;">
                                Este navegador no lee la báscula. Usa Chrome o Edge.
                            </span>
                        </t>
                        <t t-elif="state.conectado">
                            <span class="badge text-bg-success">
                                <i class="fa fa-link me-1"/> Báscula conectada
                            </span>
                        </t>
                        <t t-else="">
                            <button type="button" class="btn btn-primary btn-sm" t-on-click="() => this.conectar()">
                                <i class="fa fa-plug me-1"/> Conectar báscula
                            </button>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
