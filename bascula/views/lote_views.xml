<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista List de Lotes -->
        <record id="view_secadora_lote_list" model="ir.ui.view">
            <field name="name">secadora.lote.list</field>
            <field name="model">secadora.lote</field>
            <field name="arch" type="xml">
                <list string="Lotes">
                    <field name="name"/>
                    <field name="finca_id"/>
                    <field name="hectareas" optional="show"/>
                </list>
            </field>
        </record>

        <!-- Vista Form de Lotes -->
        <record id="view_secadora_lote_form" model="ir.ui.view">
            <field name="name">secadora.lote.form</field>
            <field name="model">secadora.lote</field>
            <field name="arch" type="xml">
                <form string="Lote">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="Ej: 180, El Bajo"/>
                                <field name="finca_id"/>
                            </group>
                            <group>
                                <field name="hectareas"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" placeholder="Notas adicionales..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista Search de Lotes -->
        <record id="view_secadora_lote_search" model="ir.ui.view">
            <field name="name">secadora.lote.search</field>
            <field name="model">secadora.lote</field>
            <field name="arch" type="xml">
                <search string="Buscar Lotes">
                    <field name="name"/>
                    <field name="finca_id"/>
                    <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Agrupar por">
                        <filter string="Finca" name="group_finca" context="{'group_by': 'finca_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción de Lotes -->
        <record id="action_secadora_lote" model="ir.actions.act_window">
            <field name="name">Lotes de Finca</field>
            <field name="res_model">secadora.lote</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1, 'search_default_group_finca': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo lote
                </p>
                <p>
                    Registre los lotes de cada finca para el reporte de producción.
                </p>
            </field>
        </record>

    </data>
</odoo>
