<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form de Pesaje -->
        <record id="view_secadora_pesaje_form" model="ir.ui.view">
            <field name="name">secadora.pesaje.form</field>
            <field name="model">secadora.pesaje</field>
            <field name="arch" type="xml">
                <form string="Pesaje">
                    <header>
                        <button name="action_primera_pesada" string="1ª Pesada" type="object"
                                class="oe_highlight" invisible="state != 'borrador'"/>
                        <button name="action_segunda_pesada" string="2ª Pesada" type="object"
                                class="oe_highlight" invisible="state != 'en_transito'"/>
                        <button name="action_crear_orden_servicio" string="Crear Orden de Servicio" type="object"
                                class="btn-secondary"
                                invisible="orden_servicio_id or not tipo_operacion_id or not tipo_operacion_id.es_servicio"/>
                        <button name="action_cancelar" string="Cancelar" type="object"
                                invisible="state in ['completado', 'cancelado']"/>
                        <button name="action_borrador" string="Volver a Borrador" type="object"
                                invisible="state != 'cancelado'" groups="bascula.group_bascula_admin"/>
                        <field name="state" widget="statusbar" statusbar_visible="borrador,en_transito,completado"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_crear_orden_servicio" type="object"
                                    class="oe_stat_button" icon="fa-file-text-o"
                                    invisible="orden_servicio_id or not tipo_operacion_id or not tipo_operacion_id.es_servicio">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Crear</span>
                                    <span class="o_stat_text">Orden</span>
                                </div>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="tipo_operacion_id"
                                       options="{'no_create': False, 'no_open': True}"
                                       readonly="orden_servicio_id"
                                       force_save="1"/>
                                <field name="orden_servicio_id"
                                       options="{'no_create': False, 'no_open': False}"
                                       placeholder="Seleccione la orden de servicio (opcional)"
                                       invisible="not tipo_operacion_id or not tipo_operacion_id.es_servicio"/>
                                <field name="direccion"/>
                                <field name="tipo_proceso" invisible="1"/>
                            </group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="fecha" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group string="Información del Vehículo">
                                <field name="vehiculo_id" string="Placa"/>
                                <field name="tercero_id"/>
                                <field name="empresa_arroz_id"/>
                                <field name="nit_tercero" readonly="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="conductor_id"/>
                                <field name="transportadora_id"/>
                                <field name="origen_id"/>
                                <field name="lote_finca" placeholder="Ej: 180, La Esperanza"/>
                                <field name="destino_id"/>
                            </group>

                            <group string="Pesaje">
                                <!-- Peso en vivo desde báscula con auto-refresh -->
                                <field name="peso_actual"
                                       widget="peso_actual_field"
                                       nolabel="1"
                                       invisible="state == 'completado' or state == 'cancelado'"/>
                                <field name="escuchando_bascula" invisible="1"/>

                                <field name="peso_bruto" readonly="1"
                                       help="ENTRADA: 1ª pesada (lleno) | SALIDA: 2ª pesada (lleno)"
                                       style="font-size: 18px; font-weight: bold;"/>
                                <field name="peso_tara" readonly="1"
                                       help="ENTRADA: 2ª pesada (vacío) | SALIDA: 1ª pesada (vacío)"
                                       style="font-size: 18px; font-weight: bold;"/>
                                <field name="peso_neto" readonly="1"
                                       style="font-size: 24px; font-weight: bold; color: #00A09D;"/>
                                <field name="hora_entrada" readonly="1"/>
                                <field name="hora_salida" readonly="1"/>
                            </group>
                        </group>

                        <group string="Producto y Calidad">
                            <group>
                                <field name="producto_id"/>
                                <field name="variedad_id"/>
                                <field name="es_semilla"/>
                            </group>
                            <group>
                                <field name="humedad"/>
                                <field name="grano_partido"/>
                                <field name="impurezas"/>
                            </group>
                        </group>

                        <group string="Remisión">
                            <group>
                                <field name="bultos"/>
                                <field name="precio"/>
                            </group>
                            <group>
                                <field name="plazo"/>
                            </group>
                        </group>

                        <field name="os_modalidad_salida" invisible="1"/>
                        <group string="Bultos a Despachar"
                               invisible="direccion != 'salida' or not tipo_operacion_id or not tipo_operacion_id.es_servicio">
                            <field name="despacho_bultos_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="registro_bultos_id"
                                           domain="[('orden_id.cliente_id', '=', parent.tercero_id), ('despachado', '=', False)]"
                                           options="{'no_create': True}"/>
                                    <field name="orden_id" readonly="1" string="OS"/>
                                    <field name="producto_id" readonly="1"/>
                                    <field name="cantidad_disponible"/>
                                    <field name="cantidad"/>
                                    <field name="producto_empaque_id" readonly="1"/>
                                    <field name="peso_promedio" readonly="1"/>
                                    <field name="peso_subtotal" sum="Peso Total"/>
                                </list>
                            </field>
                            <group invisible="direccion != 'salida' or not despacho_bultos_ids">
                                <group>
                                    <field name="peso_total_bultos_despacho" readonly="1"/>
                                    <field name="peso_neto" string="Peso Báscula (kg)" readonly="1"/>
                                </group>
                                <group>
                                    <field name="diferencia_bultos" readonly="1"
                                           decoration-danger="alerta_diferencia_bultos"
                                           decoration-success="not alerta_diferencia_bultos and diferencia_bultos != 0"/>
                                    <field name="diferencia_bultos_pct" readonly="1"
                                           decoration-danger="alerta_diferencia_bultos"/>
                                    <field name="alerta_diferencia_bultos" invisible="1"/>
                                </group>
                            </group>
                            <div class="alert alert-danger" role="alert"
                                 invisible="not alerta_diferencia_bultos">
                                <strong>Alerta:</strong> La diferencia entre el peso de báscula y el peso de bultos supera el 0,1%.
                                Verifique que los bultos están correctamente registrados.
                            </div>
                        </group>

                        <group>
                            <field name="observaciones" placeholder="Observaciones adicionales..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista List de Pesaje -->
        <record id="view_secadora_pesaje_list" model="ir.ui.view">
            <field name="name">secadora.pesaje.list</field>
            <field name="model">secadora.pesaje</field>
            <field name="arch" type="xml">
                <list string="Pesajes" decoration-success="state == 'completado'"
                      decoration-info="state == 'en_transito'"
                      decoration-muted="state == 'cancelado'">
                    <field name="name"/>
                    <field name="fecha"/>
                    <field name="tipo_operacion_id" widget="badge"/>
                    <field name="placa_texto"/>
                    <field name="direccion" widget="badge"/>
                    <field name="tipo_proceso" column_invisible="1"/>
                    <field name="tercero_id"/>
                    <field name="empresa_arroz_id" optional="hide"/>
                    <field name="producto_id"/>
                    <field name="orden_servicio_id" optional="show"/>
                    <field name="peso_neto"/>
                    <field name="company_id" optional="hide"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'completado'"
                           decoration-info="state == 'en_transito'"
                           decoration-muted="state == 'cancelado'"/>
                </list>
            </field>
        </record>

        <!-- Vista Search de Pesaje -->
        <record id="view_secadora_pesaje_search" model="ir.ui.view">
            <field name="name">secadora.pesaje.search</field>
            <field name="model">secadora.pesaje</field>
            <field name="arch" type="xml">
                <search string="Buscar Pesajes">
                    <field name="name"/>
                    <field name="vehiculo_id"/>
                    <field name="tercero_id"/>
                    <field name="placa_texto"/>
                    <field name="producto_id"/>

                    <filter string="Entradas" name="filter_entrada" domain="[('tipo_proceso', '=', 'entrada')]"/>
                    <filter string="Salidas" name="filter_salida" domain="[('tipo_proceso', '=', 'salida')]"/>
                    <separator/>
                    <filter string="En Tránsito" name="filter_en_transito" domain="[('state', '=', 'en_transito')]"/>
                    <filter string="Completados" name="filter_completado" domain="[('state', '=', 'completado')]"/>
                    <separator/>
                    <filter string="Hoy" name="filter_hoy" domain="[('fecha', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="Esta Semana" name="filter_semana"
                            domain="[('fecha', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                                     ('fecha', '&lt;=', (context_today() + datetime.timedelta(days=6-context_today().weekday())).strftime('%Y-%m-%d'))]"/>

                    <group expand="0" string="Agrupar por">
                        <filter string="Tipo" name="group_tipo" context="{'group_by': 'tipo_proceso'}"/>
                        <filter string="Estado" name="group_estado" context="{'group_by': 'state'}"/>
                        <filter string="Producto" name="group_producto" context="{'group_by': 'producto_id'}"/>
                        <filter string="Empresa Arroz" name="group_empresa_arroz" context="{'group_by': 'empresa_arroz_id'}"/>
                        <filter string="Fecha" name="group_fecha" context="{'group_by': 'fecha'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Vista Kanban de Vehículos en Tránsito -->
        <record id="view_secadora_pesaje_kanban" model="ir.ui.view">
            <field name="name">secadora.pesaje.kanban</field>
            <field name="model">secadora.pesaje</field>
            <field name="arch" type="xml">
                <kanban string="Vehículos en Tránsito" default_group_by="state">
                    <field name="name"/>
                    <field name="placa_texto"/>
                    <field name="tercero_id"/>
                    <field name="producto_id"/>
                    <field name="tipo_proceso"/>
                    <field name="peso_bruto"/>
                    <field name="hora_entrada"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="placa_texto"/>
                                            </strong>
                                            <br/>
                                            <span class="o_kanban_record_subtitle">
                                                <field name="name"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <field name="tercero_id"/>
                                        <br/>
                                        Producto: <field name="producto_id"/>
                                        <br/>
                                        Tipo: <field name="tipo_proceso"/>
                                        <br/>
                                        Peso Bruto: <field name="peso_bruto"/> Kg
                                        <br/>
                                        Entrada: <field name="hora_entrada"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Acción: Todos los Pesajes -->
        <record id="action_secadora_pesaje" model="ir.actions.act_window">
            <field name="name">Todos los Pesajes</field>
            <field name="res_model">secadora.pesaje</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo pesaje
                </p>
                <p>
                    Registre los pesajes de entrada (compra) y salida (venta/despacho) de arroz.
                </p>
            </field>
        </record>

        <!-- Acción: Vehículos en Tránsito -->
        <record id="action_secadora_pesaje_en_transito" model="ir.actions.act_window">
            <field name="name">Vehículos en Tránsito</field>
            <field name="res_model">secadora.pesaje</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('state', '=', 'en_transito')]</field>
            <field name="context">{'search_default_filter_en_transito': 1}</field>
        </record>

        <!-- Acción: Entradas -->
        <record id="action_secadora_pesaje_entrada" model="ir.actions.act_window">
            <field name="name">Entradas (Compra)</field>
            <field name="res_model">secadora.pesaje</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('tipo_proceso', '=', 'entrada')]</field>
            <field name="context">{'default_tipo_proceso': 'entrada', 'search_default_filter_entrada': 1}</field>
        </record>

        <!-- Acción: Salidas -->
        <record id="action_secadora_pesaje_salida" model="ir.actions.act_window">
            <field name="name">Salidas (Venta/Despacho)</field>
            <field name="res_model">secadora.pesaje</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('tipo_proceso', '=', 'salida')]</field>
            <field name="context">{'default_tipo_proceso': 'salida', 'search_default_filter_salida': 1}</field>
        </record>

    </data>
</odoo>
