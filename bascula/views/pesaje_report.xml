<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Formato de papel: Media Carta (5.5 x 8.5 pulgadas / 139.7 x 215.9 mm) -->
        <!-- IMPORTANTE: Debe ir ANTES del action_report para que la referencia funcione -->
        <record id="paperformat_tiquete_media_carta" model="report.paperformat">
            <field name="name">Tiquete Media Carta</field>
            <field name="default" eval="False"/>
            <field name="format">custom</field>
            <field name="page_height">216</field>
            <field name="page_width">140</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">6</field>
            <field name="margin_bottom">11</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <!-- Acción de impresión -->
        <record id="action_report_pesaje_tiquete" model="ir.actions.report">
            <field name="name">Tiquete de Pesaje</field>
            <field name="model">secadora.pesaje</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bascula.report_pesaje_tiquete_document</field>
            <field name="report_file">bascula.report_pesaje_tiquete_document</field>
            <field name="binding_model_id" ref="model_secadora_pesaje"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Tiquete - %s' % (object.name)</field>
            <field name="paperformat_id" ref="bascula.paperformat_tiquete_media_carta"/>
        </record>

        <!-- Plantilla del tiquete. Usa web.basic_layout: sin logo ni colores del
             tema estándar de Odoo; encabezado y pie propios del documento.

             Diseño editorial (certificado, no formulario):
             - Tres tamaños: 36px (nº tiquete, placa, conductor, peso neto),
               22px (tercero, pesos lleno/vacío, humedad, impurezas),
               12px (todo lo demás; etiquetas a 9px en mayúscula espaciada).
             - Un solo acento de color: rojo en el número del tiquete.
             - Separadores de línea fina, sin fondos ni bordes gruesos;
               la única caja es el bloque de pesos. -->
        <template id="report_pesaje_tiquete_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 1.4; color: #111;">

                            <!-- Encabezado -->
                            <div class="text-center" style="padding-bottom: 10px; border-bottom: 1px solid #ccc; margin-bottom: 12px;">
                                <div style="font-size: 13px; letter-spacing: 0.5px;"><strong t-field="o.company_id.name"/></div>
                                <div t-if="o.company_id.vat" style="font-size: 11px; color: #555;">NIT <span t-field="o.company_id.vat"/></div>
                                <div style="font-size: 10px; letter-spacing: 3px; color: #555; margin-top: 8px;">TIQUETE DE PESAJE</div>
                                <div style="font-size: 36px; line-height: 1.1; color: #cc0000; margin-top: 2px;">
                                    <strong>No. <span t-field="o.name"/></strong>
                                </div>
                            </div>

                            <!-- Primera fila: cinco columnas limpias -->
                            <table style="width: 100%; margin-bottom: 12px;">
                                <tr style="font-size: 9px; letter-spacing: 1px; color: #555;">
                                    <td style="width: 20%;">FECHA</td>
                                    <td style="width: 20%;">ENTRADA</td>
                                    <td style="width: 20%;">SALIDA</td>
                                    <td style="width: 20%;">TIPO</td>
                                    <td style="width: 20%;">ESTADO</td>
                                </tr>
                                <tr style="font-size: 12px;">
                                    <td><strong t-field="o.fecha"/></td>
                                    <td><strong t-field="o.hora_entrada"/></td>
                                    <td><strong t-field="o.hora_salida"/></td>
                                    <td><strong t-field="o.tipo_proceso"/></td>
                                    <td><strong t-field="o.state"/></td>
                                </tr>
                            </table>

                            <div style="border-top: 1px solid #ccc; margin-bottom: 10px;"/>

                            <!-- Vehículo y Conductor: dos columnas -->
                            <table style="width: 100%; margin-bottom: 12px;">
                                <tr style="font-size: 9px; letter-spacing: 1px; color: #555;">
                                    <td style="width: 42%; vertical-align: top;">VEHÍCULO — PLACA</td>
                                    <td style="width: 58%; vertical-align: top;">CONDUCTOR</td>
                                </tr>
                                <tr>
                                    <td style="vertical-align: top;">
                                        <div style="font-size: 36px; line-height: 1.1;"><strong t-field="o.placa_texto"/></div>
                                        <div style="font-size: 12px; color: #333; margin-top: 6px;">
                                            Cédula <strong t-field="o.cedula_conductor"/><br/>
                                            Transportadora <strong t-field="o.transportadora_id"/>
                                        </div>
                                    </td>
                                    <td style="vertical-align: top;">
                                        <div style="font-size: 36px; line-height: 1.1;"><strong t-field="o.conductor_id"/></div>
                                    </td>
                                </tr>
                            </table>

                            <!-- Tercero -->
                            <div style="margin-bottom: 12px;">
                                <div style="font-size: 9px; letter-spacing: 1px; color: #555;">TERCERO</div>
                                <div style="font-size: 22px; line-height: 1.15;"><strong t-field="o.tercero_id"/></div>
                                <div style="font-size: 12px; color: #333;">NIT / CC <strong t-field="o.nit_tercero"/></div>
                            </div>

                            <!-- Origen: una línea simple, sin cajas -->
                            <div style="font-size: 12px; margin-bottom: 12px;">
                                Origen: <strong t-field="o.origen_id"/>
                                <t t-if="o.lote_finca">&#160;&#160;&#160;Lote: <strong t-field="o.lote_finca"/></t>
                                &#160;&#160;&#160;Destino: <strong t-field="o.destino_id"/>
                            </div>

                            <!-- Pesos: la única caja del documento -->
                            <div style="border: 1px solid #111; padding: 12px 18px; margin-bottom: 14px;">
                                <table style="width: 100%;">
                                    <tr style="font-size: 22px;">
                                        <td style="padding: 2px 0;">Peso Lleno</td>
                                        <td style="text-align: right; padding: 2px 0;"><span t-field="o.peso_bruto"/> Kg</td>
                                    </tr>
                                    <tr style="font-size: 22px;">
                                        <td style="padding: 2px 0;">Peso Vacío</td>
                                        <td style="text-align: right; padding: 2px 0;"><span t-field="o.peso_tara"/> Kg</td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="border-top: 1px solid #111; padding: 0; height: 6px;"/>
                                    </tr>
                                    <tr>
                                        <td style="font-size: 15px; letter-spacing: 1px; vertical-align: middle;"><strong>PESO NETO</strong></td>
                                        <td style="text-align: right; font-size: 40px; line-height: 1.05;"><strong><span t-field="o.peso_neto"/> Kg</strong></td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Calidad: dos columnas -->
                            <table style="width: 100%; margin-bottom: 12px;">
                                <tr style="font-size: 9px; letter-spacing: 1px; color: #555;">
                                    <td style="width: 42%;">HUMEDAD</td>
                                    <td style="width: 58%;">IMPUREZAS</td>
                                </tr>
                                <tr style="font-size: 22px;">
                                    <td><strong><span t-field="o.humedad"/>%</strong></td>
                                    <td><strong><span t-field="o.impurezas"/>%</strong></td>
                                </tr>
                            </table>

                            <!-- Información técnica: una línea con separadores verticales -->
                            <div style="font-size: 12px; color: #333; margin-bottom: 10px;">
                                Producto <strong t-field="o.producto_id"/>
                                <span style="border-left: 1px solid #999; margin: 0 8px;"/>
                                Variedad <strong t-field="o.variedad_id"/>
                                <span style="border-left: 1px solid #999; margin: 0 8px;"/>
                                Grano Partido <strong><span t-field="o.grano_partido"/>%</strong>
                                <span style="border-left: 1px solid #999; margin: 0 8px;"/>
                                Bultos <strong t-field="o.bultos"/>
                            </div>

                            <!-- Observaciones -->
                            <t t-if="o.observaciones">
                                <div style="font-size: 12px; margin-bottom: 10px;">
                                    Observaciones: <span t-field="o.observaciones"/>
                                </div>
                            </t>

                            <!-- Firmas: dos líneas, sin cajas -->
                            <table style="width: 100%; margin-top: 40px;">
                                <tr>
                                    <td style="width: 50%; padding: 0 18px;">
                                        <div style="border-top: 1px solid #111; padding-top: 5px; font-size: 11px; text-align: center;">Firma Basculero</div>
                                    </td>
                                    <td style="width: 50%; padding: 0 18px;">
                                        <div style="border-top: 1px solid #111; padding-top: 5px; font-size: 11px; text-align: center;">Firma Conductor</div>
                                    </td>
                                </tr>
                            </table>

                        </div>

                        <!-- Pie de página real: se repite en cada hoja del PDF -->
                        <div class="footer" style="font-family: Arial, Helvetica, sans-serif;">
                            <div class="text-center" style="font-size: 9px; color: #999; padding-top: 4px;">
                                Este documento es una constancia del pesaje realizado
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
