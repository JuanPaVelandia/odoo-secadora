<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Formato de papel: Media Carta (5.5 x 8.5 pulgadas / 139.7 x 215.9 mm) -->
        <!-- IMPORTANTE: Debe ir ANTES del action_report para que la referencia funcione -->
        <record id="paperformat_tiquete_media_carta" model="report.paperformat">
            <field name="name">Tiquete Media Carta</field>
            <field name="default" eval="False"/>
            <field name="format">custom</field>
            <field name="page_height">216</field>
            <field name="page_width">140</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">8</field>
            <field name="margin_bottom">12</field>
            <field name="margin_left">9</field>
            <field name="margin_right">9</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <!-- Acción de impresión -->
        <record id="action_report_pesaje_tiquete" model="ir.actions.report">
            <field name="name">Tiquete de Pesaje</field>
            <field name="model">secadora.pesaje</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bascula.report_pesaje_tiquete_document</field>
            <field name="report_file">bascula.report_pesaje_tiquete_document</field>
            <field name="binding_model_id" ref="model_secadora_pesaje"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Tiquete - %s' % (object.name)</field>
            <field name="paperformat_id" ref="bascula.paperformat_tiquete_media_carta"/>
        </record>

        <!-- Cuerpo del tiquete, reutilizable: espera 'o' (un secadora.pesaje)
             en el contexto. Lo usan report_pesaje_tiquete_document (tiquete
             imprimible, que añade firmas y pie) y el reporte de viajes por
             pagar de secadora_transporte, que embebe un tiquete por flete.

             Diseño editorial (imagen guía):
             - 38px nº en rojo · 34px placa · 28px conductor · 26px tercero ·
               38px peso neto sobre banda gris · 24px humedad/impurezas ·
               etiquetas 10px negras en mayúscula espaciada · resto 12px.
             - Divisores como bordes de celda (lo único que wkhtmltopdf
               dibuja siempre) y table-layout fixed: ninguna celda puede
               empujar a las demás. -->
        <template id="report_pesaje_tiquete_body">
            <div style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 1.3; color: #111;">

                <!-- Encabezado -->
                <div class="text-center" style="margin-bottom: 12px;">
                    <div style="font-size: 16px; line-height: 1.1;"><strong t-field="o.company_id.name"/></div>
                    <div t-if="o.company_id.vat" style="font-size: 10px; color: #555; margin-top: 2px;">NIT: <span t-field="o.company_id.vat"/></div>
                    <div style="font-size: 10px; letter-spacing: 4px; color: #555; margin-top: 5px;">TIQUETE DE PESAJE</div>
                    <div style="font-size: 30px; line-height: 1.1; color: #cc1111; margin-top: 3px;">
                        <strong>No. <span t-field="o.name"/></strong>
                    </div>
                </div>

                <!-- Fila de datos generales: 5 columnas con divisores verticales -->
                <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed; border-top: 1px solid #333 !important; border-bottom: 1px solid #333 !important; margin-bottom: 12px;">
                    <tr>
                        <td style="border: none !important; width: 21%; padding: 8px 10px 8px 2px;">
                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>FECHA</strong></div>
                            <div style="font-size: 12px; margin-top: 3px;"><span t-field="o.fecha" t-options='{"format": "dd/MM/yyyy"}'/></div>
                        </td>
                        <td style="border: none !important; width: 19%; padding: 8px 10px; border-left: 1px solid #ccc !important;">
                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>ENTRADA</strong></div>
                            <div style="font-size: 12px; margin-top: 3px;"><span t-field="o.hora_entrada" t-options='{"format": "HH:mm:ss"}'/></div>
                        </td>
                        <td style="border: none !important; width: 19%; padding: 8px 10px; border-left: 1px solid #ccc !important;">
                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>SALIDA</strong></div>
                            <div style="font-size: 12px; margin-top: 3px;"><span t-field="o.hora_salida" t-options='{"format": "HH:mm:ss"}'/></div>
                        </td>
                        <td style="border: none !important; width: 18%; padding: 8px 10px; border-left: 1px solid #ccc !important;">
                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>TIPO</strong></div>
                            <div style="font-size: 12px; margin-top: 3px;"><span t-field="o.tipo_proceso"/></div>
                        </td>
                        <td style="border: none !important; width: 23%; padding: 8px 2px 8px 10px; border-left: 1px solid #ccc !important;">
                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>ESTADO</strong></div>
                            <div style="font-size: 12px; margin-top: 3px;"><span t-field="o.state"/></div>
                        </td>
                    </tr>
                </table>

                <!-- Vehículo y Conductor -->
                <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed; border-bottom: 1px solid #333 !important; margin-bottom: 12px;">
                    <tr>
                        <td style="border: none !important; width: 42%; vertical-align: top; padding: 0 14px 10px 2px; word-wrap: break-word;">
                            <div style="font-size: 11px; letter-spacing: 2px;"><strong>PLACA</strong></div>
                            <div style="font-size: 28px; line-height: 1.15; margin-top: 3px;"><strong t-field="o.placa_texto"/></div>
                            <div style="font-size: 11px; margin-top: 8px;">
                                <strong>CÉDULA:</strong> <span t-field="o.cedula_conductor"/><br/>
                                <strong>TRANSP.:</strong> <span t-field="o.transportadora_id"/>
                            </div>
                        </td>
                        <td style="border: none !important; width: 58%; vertical-align: top; padding: 0 2px 10px 14px; border-left: 1px solid #ccc !important; word-wrap: break-word;">
                            <div style="font-size: 11px; letter-spacing: 2px;"><strong>CONDUCTOR</strong></div>
                            <div style="font-size: 24px; line-height: 1.2; margin-top: 4px;"><strong t-field="o.conductor_id"/></div>
                        </td>
                    </tr>
                </table>

                <!-- Tercero -->
                <div style="border-bottom: 1px solid #333; padding: 0 2px 10px 2px; margin-bottom: 12px;">
                    <div style="font-size: 11px; letter-spacing: 2px;"><strong>TERCERO</strong></div>
                    <div style="font-size: 22px; line-height: 1.2; margin-top: 3px;"><strong t-field="o.tercero_id"/></div>
                    <div style="font-size: 11px; margin-top: 3px;">NIT/CC: <span t-field="o.nit_tercero"/></div>
                </div>

                <!-- Origen y Destino -->
                <div style="margin-bottom: 12px; padding: 0 2px;">
                    <div style="font-size: 11px; letter-spacing: 2px; margin-bottom: 5px;"><strong>ORIGEN Y DESTINO</strong></div>
                    <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed;">
                        <tr style="font-size: 11px;">
                            <td style="border: none !important; width: 36%; padding: 2px 10px 2px 0;"><strong>ORIGEN:</strong> <span t-field="o.origen_id"/></td>
                            <td style="border: none !important; width: 22%; padding: 2px 10px; border-left: 1px solid #ccc !important;"><strong>LOTE:</strong> <span t-field="o.lote_finca"/></td>
                            <td style="border: none !important; width: 42%; padding: 2px 0 2px 10px; border-left: 1px solid #ccc !important;"><strong>DESTINO:</strong> <span t-field="o.destino_id"/></td>
                        </tr>
                    </table>
                </div>

                <!-- Pesos: caja redondeada, neto sobre banda gris -->
                <div style="border: 1px solid #333; border-radius: 8px; padding: 5px 0 6px 0; margin-bottom: 12px;">
                    <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed;">
                        <tr style="font-size: 18px;">
                            <td style="border: none !important; padding: 8px 16px;">PESO LLENO</td>
                            <td style="border: none !important; padding: 8px 16px; text-align: right;"><strong><span t-field="o.peso_bruto" t-options='{"widget": "float", "precision": 0}'/> Kg</strong></td>
                        </tr>
                        <tr style="font-size: 18px;">
                            <td style="border: none !important; padding: 8px 16px; border-top: 1px solid #ccc !important;">PESO VACÍO</td>
                            <td style="border: none !important; padding: 8px 16px; text-align: right; border-top: 1px solid #ccc !important;"><strong><span t-field="o.peso_tara" t-options='{"widget": "float", "precision": 0}'/> Kg</strong></td>
                        </tr>
                    </table>
                    <div style="background-color: #ebebeb; border-radius: 5px; margin: 5px 8px 2px 8px; padding: 8px 16px;">
                        <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed;">
                            <tr>
                                <td style="border: none !important; font-size: 18px; vertical-align: middle;"><strong>PESO NETO</strong></td>
                                <td style="border: none !important; text-align: right; font-size: 32px; line-height: 1.1; white-space: nowrap;"><strong><span t-field="o.peso_neto" t-options='{"widget": "float", "precision": 0}'/> Kg</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Producto y Calidad -->
                <div style="border-top: 1px solid #333; padding: 8px 2px 0 2px; margin-bottom: 10px;">
                    <div style="font-size: 11px; letter-spacing: 2px; margin-bottom: 6px;"><strong>PRODUCTO Y CALIDAD</strong></div>
                    <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed; margin-bottom: 6px;">
                        <tr>
                            <td style="border: none !important; width: 42%; padding: 0 14px 5px 0;">
                                <div style="font-size: 9px; letter-spacing: 1px;"><strong>HUMEDAD</strong></div>
                                <div style="font-size: 20px; margin-top: 2px;"><strong><span t-field="o.humedad"/>%</strong></div>
                            </td>
                            <td style="border: none !important; width: 58%; padding: 0 0 5px 14px; border-left: 1px solid #ccc !important;">
                                <div style="font-size: 9px; letter-spacing: 1px;"><strong>IMPUREZAS</strong></div>
                                <div style="font-size: 20px; margin-top: 2px;"><strong><span t-field="o.impurezas"/>%</strong></div>
                            </td>
                        </tr>
                    </table>
                    <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed; border-top: 1px solid #ccc !important;">
                        <tr style="font-size: 10px;">
                            <td style="border: none !important; width: 32%; padding: 7px 10px 0 0; word-wrap: break-word;"><strong>PRODUCTO:</strong> <span t-field="o.producto_id"/></td>
                            <td style="border: none !important; width: 27%; padding: 7px 10px 0 10px; border-left: 1px solid #ccc !important; word-wrap: break-word;"><strong>VARIEDAD:</strong> <span t-field="o.variedad_id"/></td>
                            <td style="border: none !important; width: 26%; padding: 7px 10px 0 10px; border-left: 1px solid #ccc !important;"><strong>GRANO PART.:</strong> <span t-field="o.grano_partido"/>%</td>
                            <td style="border: none !important; width: 15%; padding: 7px 0 0 10px; border-left: 1px solid #ccc !important;"><strong>BULTOS:</strong> <span t-field="o.bultos"/></td>
                        </tr>
                    </table>
                </div>

                <!-- Observaciones -->
                <t t-if="o.observaciones">
                    <div style="font-size: 11px; margin-bottom: 8px; padding: 0 2px;">
                        <strong>OBSERVACIONES:</strong> <span t-field="o.observaciones"/>
                    </div>
                </t>

            </div>
        </template>

        <!-- Tiquete imprimible: cuerpo + firmas + pie de página -->
        <template id="report_pesaje_tiquete_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <t t-call="bascula.report_pesaje_tiquete_body"/>

                            <!-- Firmas -->
                            <table style="border-collapse: collapse; border: none !important; width: 100%; table-layout: fixed; margin-top: 18px; font-family: Arial, Helvetica, sans-serif;">
                                <tr>
                                    <td style="border: none !important; width: 50%; padding: 0 30px;">
                                        <div style="border-top: 1px solid #111; padding-top: 5px; font-size: 12px; text-align: center;">Firma del Basculero</div>
                                    </td>
                                    <td style="border: none !important; width: 50%; padding: 0 30px;">
                                        <div style="border-top: 1px solid #111; padding-top: 5px; font-size: 12px; text-align: center;">Firma del Conductor</div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Pie de página real: se repite en cada hoja del PDF -->
                        <div class="footer" style="font-family: Arial, Helvetica, sans-serif;">
                            <div class="text-center" style="font-size: 10px; color: #888; padding-top: 4px;">
                                Este documento es una constancia del pesaje realizado
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
