<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Formato de papel: Media Carta (5.5 x 8.5 pulgadas / 139.7 x 215.9 mm) -->
        <!-- IMPORTANTE: Debe ir ANTES del action_report para que la referencia funcione -->
        <record id="paperformat_tiquete_media_carta" model="report.paperformat">
            <field name="name">Tiquete Media Carta</field>
            <field name="default" eval="False"/>
            <field name="format">custom</field>
            <field name="page_height">216</field>
            <field name="page_width">140</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">6</field>
            <field name="margin_bottom">11</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <!-- Acción de impresión -->
        <record id="action_report_pesaje_tiquete" model="ir.actions.report">
            <field name="name">Tiquete de Pesaje</field>
            <field name="model">secadora.pesaje</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bascula.report_pesaje_tiquete_document</field>
            <field name="report_file">bascula.report_pesaje_tiquete_document</field>
            <field name="binding_model_id" ref="model_secadora_pesaje"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Tiquete - %s' % (object.name)</field>
            <field name="paperformat_id" ref="bascula.paperformat_tiquete_media_carta"/>
        </record>

        <!-- Plantilla del tiquete. Usa web.basic_layout: sin logo ni colores del
             tema estándar de Odoo; encabezado y pie propios del documento. -->
        <template id="report_pesaje_tiquete_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <!-- Jerarquía tipográfica del tiquete (no salirse de la escala):
                             10px etiquetas · 12px datos secundarios · 15px empresa ·
                             18px valores clave (placa, conductor, tercero, humedad,
                             impurezas, nº en rojo) · 22px peso neto (único héroe). -->
                        <div class="page" style="font-family: Arial, sans-serif; font-size: 12px; line-height: 1.4; color: #222;">
                            <!-- Encabezado -->
                            <div class="text-center" style="border-bottom: 1px solid #999; padding-bottom: 7px; margin-bottom: 9px;">
                                <div style="font-size: 15px;"><strong t-field="o.company_id.name"/></div>
                                <div t-if="o.company_id.vat" style="font-size: 10px; color: #777;">
                                    NIT: <span t-field="o.company_id.vat"/>
                                </div>
                                <div style="font-size: 10px; color: #777; letter-spacing: 2px; margin-top: 4px;">TIQUETE DE PESAJE</div>
                                <div style="font-size: 18px; color: #cc0000;">
                                    <strong>No. <span t-field="o.name"/></strong>
                                </div>
                            </div>

                            <!-- Información general -->
                            <div style="margin-bottom: 9px; font-size: 12px; color: #555;">
                                <strong>Fecha:</strong> <span t-field="o.fecha"/>
                                &#160;·&#160; <strong>Entrada:</strong> <span t-field="o.hora_entrada"/>
                                &#160;·&#160; <strong>Salida:</strong> <span t-field="o.hora_salida"/><br/>
                                <strong>Tipo:</strong> <span t-field="o.tipo_proceso"/>
                                &#160;·&#160; <strong>Estado:</strong> <span t-field="o.state"/>
                            </div>

                            <!-- Vehículo -->
                            <div style="margin-bottom: 9px;">
                                <div style="font-size: 10px; letter-spacing: 1.5px; color: #555; border-bottom: 1px solid #bbb; padding-bottom: 2px; margin-bottom: 5px;"><strong>VEHÍCULO</strong></div>
                                <div class="row">
                                    <div class="col-5">
                                        <div style="font-size: 10px; color: #888; letter-spacing: 0.5px;">PLACA</div>
                                        <strong style="font-size: 18px;"><span t-field="o.placa_texto"/></strong>
                                    </div>
                                    <div class="col-7">
                                        <div style="font-size: 10px; color: #888; letter-spacing: 0.5px;">CONDUCTOR</div>
                                        <strong style="font-size: 18px;"><span t-field="o.conductor_id"/></strong>
                                    </div>
                                </div>
                                <div style="font-size: 12px; color: #555; margin-top: 3px;">
                                    <strong>Cédula:</strong> <span t-field="o.cedula_conductor"/>
                                    &#160;·&#160; <strong>Transportadora:</strong> <span t-field="o.transportadora_id"/>
                                </div>
                            </div>

                            <!-- Tercero -->
                            <div style="margin-bottom: 9px;">
                                <div style="font-size: 10px; letter-spacing: 1.5px; color: #555; border-bottom: 1px solid #bbb; padding-bottom: 2px; margin-bottom: 5px;"><strong>TERCERO</strong></div>
                                <strong style="font-size: 18px;"><span t-field="o.tercero_id"/></strong>
                                <div style="font-size: 12px; color: #555;">
                                    <strong>NIT/CC:</strong> <span t-field="o.nit_tercero"/>
                                </div>
                            </div>

                            <!-- Origen y Destino -->
                            <div style="margin-bottom: 9px;">
                                <div style="font-size: 10px; letter-spacing: 1.5px; color: #555; border-bottom: 1px solid #bbb; padding-bottom: 2px; margin-bottom: 5px;"><strong>ORIGEN Y DESTINO</strong></div>
                                <div style="font-size: 12px;">
                                    <strong>Origen:</strong> <span t-field="o.origen_id"/>
                                    <t t-if="o.lote_finca">&#160;·&#160; <strong>Lote:</strong> <span t-field="o.lote_finca"/></t>
                                    &#160;·&#160; <strong>Destino:</strong> <span t-field="o.destino_id"/>
                                </div>
                            </div>

                            <!-- PESAJE (bloque destacado, único con marco) -->
                            <div style="margin-bottom: 9px; border: 1px solid #444; padding: 7px 12px; background-color: #f7f7f7;">
                                <table class="table table-borderless" style="font-size: 13px; margin-bottom: 0;">
                                    <tr>
                                        <td style="width: 50%;">Peso Lleno:</td>
                                        <td style="text-align: right;"><span t-field="o.peso_bruto"/> Kg</td>
                                    </tr>
                                    <tr>
                                        <td>Peso Vacío:</td>
                                        <td style="text-align: right;"><span t-field="o.peso_tara"/> Kg</td>
                                    </tr>
                                    <tr style="border-top: 1px solid #444;">
                                        <td style="padding-top: 5px;"><strong style="font-size: 15px;">Peso Neto:</strong></td>
                                        <td style="text-align: right; padding-top: 5px;"><strong style="font-size: 22px;"><span t-field="o.peso_neto"/> Kg</strong></td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Producto y Calidad -->
                            <div style="margin-bottom: 9px;">
                                <div style="font-size: 10px; letter-spacing: 1.5px; color: #555; border-bottom: 1px solid #bbb; padding-bottom: 2px; margin-bottom: 5px;"><strong>PRODUCTO Y CALIDAD</strong></div>
                                <div class="row" style="margin-bottom: 3px;">
                                    <div class="col-5">
                                        <div style="font-size: 10px; color: #888; letter-spacing: 0.5px;">HUMEDAD</div>
                                        <strong style="font-size: 18px;"><span t-field="o.humedad"/>%</strong>
                                    </div>
                                    <div class="col-7">
                                        <div style="font-size: 10px; color: #888; letter-spacing: 0.5px;">IMPUREZAS</div>
                                        <strong style="font-size: 18px;"><span t-field="o.impurezas"/>%</strong>
                                    </div>
                                </div>
                                <div style="font-size: 12px; color: #555;">
                                    <strong>Producto:</strong> <span t-field="o.producto_id"/>
                                    &#160;·&#160; <strong>Variedad:</strong> <span t-field="o.variedad_id"/>
                                    &#160;·&#160; <strong>Grano Partido:</strong> <span t-field="o.grano_partido"/>%
                                    &#160;·&#160; <strong>Bultos:</strong> <span t-field="o.bultos"/>
                                </div>
                            </div>

                            <!-- Observaciones -->
                            <t t-if="o.observaciones">
                                <div style="margin-bottom: 9px; font-size: 12px;">
                                    <strong>Observaciones:</strong><br/>
                                    <span t-field="o.observaciones"/>
                                </div>
                            </t>

                            <!-- Firmas -->
                            <div class="row" style="margin-top: 42px;">
                                <div class="col-6 text-center">
                                    <div style="border-top: 1px solid #444; padding-top: 4px; margin: 0 15px; font-size: 11px; color: #555;">
                                        Firma del Basculero
                                    </div>
                                </div>
                                <div class="col-6 text-center">
                                    <div style="border-top: 1px solid #444; padding-top: 4px; margin: 0 15px; font-size: 11px; color: #555;">
                                        Firma del Conductor
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Pie de página real: se repite en cada hoja del PDF -->
                        <div class="footer" style="font-family: Arial, sans-serif;">
                            <div class="text-center" style="border-top: 1px solid #999; padding-top: 4px; font-size: 10px; color: #777;">
                                Este documento es una constancia del pesaje realizado
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
