<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form -->
        <record id="view_secadora_precio_compra_form" model="ir.ui.view">
            <field name="name">secadora.precio.compra.form</field>
            <field name="model">secadora.precio.compra</field>
            <field name="arch" type="xml">
                <form string="Precio de Compra">
                    <sheet>
                        <group>
                            <group>
                                <field name="variedad_id"/>
                                <field name="precio"/>
                            </group>
                            <group>
                                <field name="fecha_desde"/>
                                <field name="fecha_hasta"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista List -->
        <record id="view_secadora_precio_compra_list" model="ir.ui.view">
            <field name="name">secadora.precio.compra.list</field>
            <field name="model">secadora.precio.compra</field>
            <field name="arch" type="xml">
                <list string="Precios de Compra" editable="bottom">
                    <field name="variedad_id"/>
                    <field name="precio"/>
                    <field name="fecha_desde"/>
                    <field name="fecha_hasta"/>
                    <field name="company_id" groups="base.group_multi_company" optional="show"/>
                    <field name="active" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Vista Search -->
        <record id="view_secadora_precio_compra_search" model="ir.ui.view">
            <field name="name">secadora.precio.compra.search</field>
            <field name="model">secadora.precio.compra</field>
            <field name="arch" type="xml">
                <search string="Buscar Precios">
                    <field name="variedad_id"/>
                    <separator/>
                    <filter name="filter_activos" string="Activos" domain="[('active', '=', True)]"/>
                    <filter name="filter_vigentes" string="Vigentes Hoy"
                            domain="[('fecha_desde', '&lt;=', context_today().strftime('%Y-%m-%d')),
                                     '|', ('fecha_hasta', '=', False),
                                     ('fecha_hasta', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_variedad" string="Variedad" context="{'group_by': 'variedad_id'}"/>
                        <filter name="group_company" string="Empresa" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción -->
        <record id="action_precio_compra" model="ir.actions.act_window">
            <field name="name">Precios de Compra</field>
            <field name="res_model">secadora.precio.compra</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_secadora_precio_compra_search"/>
            <field name="context">{'search_default_filter_activos': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configurar precios de compra
                </p>
                <p>
                    Defina los precios por variedad de arroz y rango de fechas.
                </p>
            </field>
        </record>

    </data>
</odoo>
