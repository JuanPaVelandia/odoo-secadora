<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_crear_liquidacion_wizard_form" model="ir.ui.view">
            <field name="name">secadora.crear.liquidacion.wizard.form</field>
            <field name="model">secadora.crear.liquidacion.wizard</field>
            <field name="arch" type="xml">
                <form string="Agregar Pesajes a Liquidación">
                    <group>
                        <group>
                            <field name="liquidacion_id" readonly="1" invisible="not liquidacion_id"/>
                            <field name="tercero_id"/>
                        </group>
                        <group>
                            <field name="fecha_desde"/>
                            <field name="fecha_hasta"/>
                        </group>
                    </group>
                    <separator string="Pesajes Encontrados"/>
                    <field name="pesaje_ids">
                        <list>
                            <field name="name"/>
                            <field name="fecha"/>
                            <field name="variedad_id"/>
                            <field name="peso_neto"/>
                            <field name="precio"/>
                        </list>
                    </field>
                    <footer>
                        <button name="action_crear" string="Agregar Pesajes" type="object"
                                class="oe_highlight"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para abrir el wizard desde lista de pesajes -->
        <record id="action_crear_liquidacion_wizard" model="ir.actions.act_window">
            <field name="name">Crear Liquidación</field>
            <field name="res_model">secadora.crear.liquidacion.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="bascula.model_secadora_pesaje"/>
            <field name="binding_view_types">list</field>
        </record>

    </data>
</odoo>
