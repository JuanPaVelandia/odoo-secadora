<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Plan analítico: Tipo de costo -->
        <record id="analytic_plan_tipo_costo" model="account.analytic.plan">
            <field name="name">Tipo de costo</field>
        </record>

        <!-- Cuentas analíticas del plan -->
        <record id="analytic_account_mantenimiento" model="account.analytic.account">
            <field name="name">Mantenimiento</field>
            <field name="plan_id" ref="analytic_plan_tipo_costo"/>
        </record>

        <record id="analytic_account_operacion" model="account.analytic.account">
            <field name="name">Operación</field>
            <field name="plan_id" ref="analytic_plan_tipo_costo"/>
        </record>

        <record id="analytic_account_administrativo" model="account.analytic.account">
            <field name="name">Administrativo</field>
            <field name="plan_id" ref="analytic_plan_tipo_costo"/>
        </record>

    </data>
</odoo>
