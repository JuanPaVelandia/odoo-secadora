<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Vistas de maintenance.equipment.cost.line (modelo intermedio) -->
    <!-- ============================================================ -->

    <!-- Vista lista -->
    <record id="view_equipment_cost_line_list" model="ir.ui.view">
        <field name="name">maintenance.equipment.cost.line.list</field>
        <field name="model">maintenance.equipment.cost.line</field>
        <field name="arch" type="xml">
            <list string="Costos de mantenimiento" editable="top">
                <field name="date" readonly="1"/>
                <field name="equipment_id"/>
                <field name="request_id"/>
                <field name="product_description" string="Recurso" readonly="1"/>
                <field name="quantity" readonly="1"/>
                <field name="product_id" readonly="1" optional="hide"/>
                <field name="partner_id" readonly="1" optional="show"/>
                <field name="move_id" readonly="1" optional="hide"/>
                <field name="percentage"/>
                <field name="amount" sum="Total"/>
                <field name="attachment_count" string="Adjuntos" readonly="1"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_equipment_cost_line_form" model="ir.ui.view">
        <field name="name">maintenance.equipment.cost.line.form</field>
        <field name="model">maintenance.equipment.cost.line</field>
        <field name="arch" type="xml">
            <form string="Línea de costo por equipo">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-paperclip">
                            <field name="attachment_count" string="Adjuntos" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group string="Datos de factura">
                            <field name="date" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                            <field name="move_line_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="product_description" readonly="1"/>
                            <field name="quantity" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Asignación">
                            <field name="equipment_id"/>
                            <field name="request_id"/>
                            <field name="percentage"/>
                            <field name="amount" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_equipment_cost_line_search" model="ir.ui.view">
        <field name="name">maintenance.equipment.cost.line.search</field>
        <field name="model">maintenance.equipment.cost.line</field>
        <field name="arch" type="xml">
            <search string="Buscar costos de equipo">
                <field name="equipment_id"/>
                <field name="product_id"/>
                <field name="request_id"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <separator/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_equipment" string="Equipo"
                            context="{'group_by': 'equipment_id'}"/>
                    <filter name="group_request" string="Orden de trabajo"
                            context="{'group_by': 'request_id'}"/>
                    <filter name="group_product" string="Recurso"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_partner" string="Proveedor"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_month" string="Mes"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista pivot -->
    <record id="view_equipment_cost_line_pivot" model="ir.ui.view">
        <field name="name">maintenance.equipment.cost.line.pivot</field>
        <field name="model">maintenance.equipment.cost.line</field>
        <field name="arch" type="xml">
            <pivot string="Costos de Mantenimiento">
                <field name="equipment_id" type="row"/>
                <field name="date" type="col" interval="month"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Acción para el nuevo modelo intermedio -->
    <record id="action_equipment_cost_lines" model="ir.actions.act_window">
        <field name="name">Costos por equipo</field>
        <field name="res_model">maintenance.equipment.cost.line</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="search_view_id" ref="view_equipment_cost_line_search"/>
    </record>

    <!-- ============================================================ -->
    <!--  Vistas legacy de account.move.line (facturas de mantenimiento) -->
    <!-- ============================================================ -->

    <!-- Vista lista: Facturas de Mantenimiento (líneas de factura) -->
    <record id="view_maintenance_cost_line_list" model="ir.ui.view">
        <field name="name">account.move.line.maintenance.cost.list</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="Facturas de Mantenimiento" multi_edit="1">
                <field name="date" string="Fecha" readonly="1"/>
                <field name="partner_id" string="Proveedor" readonly="1"/>
                <field name="move_name" string="Referencia factura" readonly="1"/>
                <field name="name" string="Descripción" readonly="1"/>
                <field
                    name="maintenance_equipment_ids"
                    widget="many2many_tags"
                    string="Equipo(s)"
                    readonly="1"
                    groups="maintenance.group_equipment_manager"
                />
                <field
                    name="maintenance_request_ids"
                    widget="many2many_tags"
                    string="Orden(es) de trabajo"
                    groups="maintenance.group_equipment_manager"
                />
                <field name="price_subtotal" string="Subtotal" readonly="1" sum="Total"/>
                <field name="move_id" column_invisible="1"/>
                <field name="move_type" column_invisible="1"/>
                <field name="parent_state" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Vista search para filtrar y agrupar -->
    <record id="view_maintenance_cost_line_search" model="ir.ui.view">
        <field name="name">account.move.line.maintenance.cost.search</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <search string="Buscar facturas de mantenimiento">
                <field name="partner_id" string="Proveedor"/>
                <field name="move_name" string="Factura"/>
                <field name="name" string="Descripción"/>
                <field name="maintenance_equipment_ids" string="Equipo"/>
                <field name="maintenance_request_ids" string="Orden de trabajo"/>
                <filter name="filter_posted" string="Publicadas"
                        domain="[('parent_state', '=', 'posted')]"/>
                <filter name="filter_has_analytic" string="Con analítica"
                        domain="[('analytic_distribution', '!=', False)]"/>
                <filter name="filter_unassigned" string="Sin equipo asignado"
                        domain="[('maintenance_equipment_ids', '=', False)]"/>
                <separator/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_equipment" string="Equipo"
                            context="{'group_by': 'maintenance_equipment_ids'}"/>
                    <filter name="group_request" string="Orden de trabajo"
                            context="{'group_by': 'maintenance_request_ids'}"/>
                    <filter name="group_partner" string="Proveedor"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_month" string="Mes"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista form para asignar equipos/OTs desde la vista de costos -->
    <record id="view_maintenance_cost_line_form" model="ir.ui.view">
        <field name="name">account.move.line.maintenance.cost.form</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <form string="Línea de factura - Mantenimiento" create="0" delete="0">
                <sheet>
                    <group>
                        <group string="Datos de factura">
                            <field name="date" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="move_name" readonly="1" string="Referencia"/>
                            <field name="name" readonly="1" string="Descripción"/>
                            <field name="price_subtotal" readonly="1"/>
                        </group>
                        <group string="Asignación de mantenimiento">
                            <field name="maintenance_request_ids"
                                   widget="many2many_tags"
                                   groups="maintenance.group_equipment_manager"/>
                        </group>
                    </group>
                    <group string="Equipos asignados">
                        <field name="equipment_cost_line_ids" nolabel="1"
                               groups="maintenance.group_equipment_manager">
                            <list editable="bottom">
                                <field name="equipment_id"/>
                                <field name="percentage"/>
                                <field name="amount" readonly="1"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para abrir las líneas de factura de mantenimiento -->
    <record id="action_maintenance_cost_lines" model="ir.actions.act_window">
        <field name="name">Facturas de Mantenimiento</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type', '=', 'in_invoice'),
            ('display_type', '=', 'product'),
        ]</field>
        <field name="context">{
            'search_default_filter_posted': 1,
            'search_default_filter_has_analytic': 1,
        }</field>
        <field name="search_view_id" ref="view_maintenance_cost_line_search"/>
    </record>

    <!-- Vincular vistas a la acción -->
    <record id="action_maintenance_cost_lines_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_maintenance_cost_line_list"/>
        <field name="act_window_id" ref="action_maintenance_cost_lines"/>
    </record>

    <record id="action_maintenance_cost_lines_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_maintenance_cost_line_form"/>
        <field name="act_window_id" ref="action_maintenance_cost_lines"/>
    </record>

</odoo>
