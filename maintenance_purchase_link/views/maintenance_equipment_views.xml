<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart buttons y campos adicionales en el formulario de equipo -->
    <record id="view_equipment_form_inherit_costs" model="ir.ui.view">
        <field name="name">maintenance.equipment.form.inherit.costs</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <!-- Smart button: Costos -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_maintenance_costs"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        groups="maintenance.group_equipment_manager">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="maintenance_cost_total" widget="monetary"/>
                        </span>
                        <span class="o_stat_text">Costos</span>
                    </div>
                </button>
                <!-- Smart button: Horómetro -->
                <button name="action_view_horometro_readings"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tachometer"
                        groups="maintenance.group_equipment_manager">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="horometro_current" digits="[42,1]"/>
                            <span> hrs</span>
                        </span>
                        <span class="o_stat_text">Horómetro</span>
                    </div>
                </button>
            </xpath>

            <!-- Botón diagnóstico temporal -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_debug_cost_lines"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bug"
                        string="Debug BD"/>
            </xpath>

            <!-- Campo de ubicación después de location -->
            <xpath expr="//field[@name='location']" position="after">
                <field name="lugar_id"/>
            </xpath>

            <!-- Grupo de horómetro en la pestaña de información -->
            <xpath expr="//field[@name='location']/.." position="after">
                <group string="Horómetro">
                    <field name="horometro_interval"/>
                    <field name="horometro_last_maintenance"/>
                    <field name="horometro_current" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
