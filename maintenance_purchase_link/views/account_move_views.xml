<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_inherit_maintenance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.maintenance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Equipos (tags readonly) en las líneas de factura de proveedor -->
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='analytic_distribution']" position="after">
                <field
                    name="maintenance_equipment_ids"
                    widget="many2many_tags"
                    string="Equipos mant."
                    optional="hide"
                    readonly="1"
                    column_invisible="parent.move_type != 'in_invoice'"
                    groups="maintenance.group_equipment_manager"
                />
                <field
                    name="maintenance_request_ids"
                    widget="many2many_tags"
                    string="OTs mant."
                    optional="hide"
                    column_invisible="parent.move_type != 'in_invoice'"
                    groups="maintenance.group_equipment_manager"
                />
            </xpath>

            <!-- Pestaña de mantenimiento -->
            <xpath expr="//notebook" position="inside">
                <page string="Mantenimiento"
                      name="maintenance_tab"
                      invisible="move_type != 'in_invoice'"
                      groups="maintenance.group_equipment_manager">
                    <group string="Equipos asignados (aplica a todas las líneas)">
                        <field name="maintenance_equipment_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="equipment_id"/>
                                <field name="percentage"/>
                            </list>
                        </field>
                    </group>
                    <div class="text-muted mb-3">
                        Al guardar, se propaga a todas las líneas de producto.
                        Para asociar OT y ver el detalle use el botón.
                    </div>
                    <button name="action_view_cost_lines"
                            type="object"
                            string="Ver / editar detalle de costos y OTs"
                            class="btn-primary"
                            icon="fa-list"
                            groups="maintenance.group_equipment_manager"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
