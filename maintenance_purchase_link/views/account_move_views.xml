<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Herencia del formulario de factura: agregar campos M2M en las líneas -->
    <record id="view_move_form_inherit_maintenance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.maintenance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Equipos (tags readonly) en las líneas de factura de proveedor -->
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='analytic_distribution']" position="after">
                <field
                    name="maintenance_equipment_ids"
                    widget="many2many_tags"
                    string="Equipos mant."
                    optional="hide"
                    readonly="1"
                    column_invisible="parent.move_type != 'in_invoice'"
                    groups="maintenance.group_equipment_manager"
                />
                <field
                    name="maintenance_request_ids"
                    widget="many2many_tags"
                    string="OTs mant."
                    optional="hide"
                    column_invisible="parent.move_type != 'in_invoice'"
                    groups="maintenance.group_equipment_manager"
                />
            </xpath>

            <!-- Pestaña de equipos a nivel de factura -->
            <xpath expr="//notebook" position="inside">
                <page string="Mantenimiento"
                      name="maintenance_tab"
                      invisible="move_type != 'in_invoice'"
                      groups="maintenance.group_equipment_manager">
                    <group string="Equipos asignados a la factura">
                        <field name="maintenance_equipment_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="equipment_id"/>
                                <field name="request_id"/>
                                <field name="percentage"/>
                            </list>
                        </field>
                    </group>
                    <button name="action_sync_from_cost_lines"
                            type="object"
                            string="↻ Sincronizar desde mantenimiento"
                            class="btn-link"
                            groups="maintenance.group_equipment_manager"/>
                    <div class="text-muted">
                        Al guardar, los equipos y porcentajes se propagan a las líneas.
                        Si asoció equipos/OTs desde mantenimiento, use el botón de sincronizar.
                    </div>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
