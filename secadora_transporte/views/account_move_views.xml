<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Smart button: fletes asociados a la factura de transportadora -->
        <record id="view_move_form_fletes" model="ir.ui.view">
            <field name="name">account.move.form.fletes</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_ver_fletes" type="object"
                            class="oe_stat_button" icon="fa-truck"
                            invisible="flete_count == 0">
                        <field name="flete_count" widget="statinfo" string="Fletes"/>
                    </button>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
