<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Heredar reporte de Orden de Servicio para agregar detalle de fletes -->
        <template id="report_orden_servicio_flete"
                  inherit_id="bascula.report_orden_servicio_document">

            <!-- Sección Fletes Pagados por Secadora: antes del bloque Total General -->
            <xpath expr="//div[contains(@style,'border: 3px solid #000')]" position="before">
                <div t-if="o.flete_secadora_ids" style="margin-bottom: 20px;">
                    <h4 style="background-color: #333; color: white; padding: 8px; margin: 0 0 10px 0; font-size: 14px;">Fletes Pagados por Secadora</h4>
                    <table style="width: 100%; border-collapse: collapse; border: 1px solid #ddd;">
                        <thead>
                            <tr style="background-color: #f0f0f0;">
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Número</th>
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Origen</th>
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Destino</th>
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: right;">Peso (Kg)</th>
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: right;">Costo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.flete_secadora_ids" t-as="flete">
                                <td style="border: 1px solid #ddd; padding: 8px;">
                                    <span t-field="flete.name"/>
                                </td>
                                <td style="border: 1px solid #ddd; padding: 8px;">
                                    <span t-field="flete.origen_id"/>
                                </td>
                                <td style="border: 1px solid #ddd; padding: 8px;">
                                    <span t-field="flete.destino_id"/>
                                </td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    <span t-field="flete.peso_kg" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    $<span t-field="flete.costo_total" t-options='{"widget": "float", "precision": 0}'/>
                                </td>
                            </tr>
                            <tr style="background-color: #f0f0f0; font-weight: bold;">
                                <td colspan="4" style="border: 1px solid #ddd; padding: 8px; text-align: right;">TOTAL FLETE SECADORA:</td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    $<span t-field="o.cobro_flete" t-options='{"widget": "float", "precision": 0}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </xpath>

            <!-- Agregar línea Flete Secadora en el bloque Total General (antes de TOTAL A FACTURAR) -->
            <xpath expr="//tr[.//span[@t-field='o.total_a_facturar']]" position="before">
                <tr t-if="o.cobro_flete > 0">
                    <td style="padding: 8px; font-size: 14px;">
                        <strong>Flete Secadora:</strong>
                    </td>
                    <td style="padding: 8px; text-align: right; font-size: 14px;">
                        <strong>+ $<span t-field="o.cobro_flete" t-options='{"widget": "float", "precision": 0}'/></strong>
                    </td>
                </tr>
            </xpath>

        </template>

    </data>
</odoo>
