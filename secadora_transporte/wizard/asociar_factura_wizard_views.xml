<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form del Wizard -->
        <record id="view_asociar_factura_wizard_form" model="ir.ui.view">
            <field name="name">secadora.asociar.factura.wizard.form</field>
            <field name="model">secadora.asociar.factura.wizard</field>
            <field name="arch" type="xml">
                <form string="Asociar Fletes a Factura">
                    <group>
                        <group>
                            <field name="transportadora_id"/>
                            <field name="costo_total_fletes"
                                   style="font-size: 16px; font-weight: bold; color: #00A09D;"/>
                        </group>
                        <group>
                            <field name="modo" widget="radio"/>
                            <field name="factura_id" invisible="modo != 'existente'"/>
                            <field name="partner_factura_id" invisible="modo != 'nueva'"/>
                        </group>
                    </group>
                    <group string="Fletes Seleccionados">
                        <field name="flete_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="fecha"/>
                                <field name="origen_id"/>
                                <field name="destino_id"/>
                                <field name="transportadora_id"/>
                                <field name="costo_total"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button name="action_asociar" string="Asociar a Factura"
                                type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción del Wizard (binding desde lista de fletes) -->
        <record id="action_asociar_factura_wizard" model="ir.actions.act_window">
            <field name="name">Asociar a Factura</field>
            <field name="res_model">secadora.asociar.factura.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="secadora_transporte.model_secadora_flete"/>
            <field name="binding_view_types">list</field>
        </record>

    </data>
</odoo>
