<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form del Wizard -->
        <record id="view_imprimir_viajes_pagar_wizard_form" model="ir.ui.view">
            <field name="name">secadora.imprimir.viajes.pagar.wizard.form</field>
            <field name="model">secadora.imprimir.viajes.pagar.wizard</field>
            <field name="arch" type="xml">
                <form string="Imprimir Viajes Facturados por Pagar">
                    <group>
                        <group string="Filtros">
                            <field name="transportadora_id"/>
                            <field name="company_id"/>
                            <field name="fecha_desde"/>
                            <field name="fecha_hasta"/>
                            <field name="pago_flete"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="factura_domain" invisible="1"/>
                            <field name="total_girar"
                                   style="font-size: 18px; font-weight: bold; color: #dc3545;"/>
                        </group>
                    </group>
                    <group string="Facturas a Pagar (quite las que no girará hoy)">
                        <field name="factura_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="ref" optional="show"/>
                                <field name="partner_id"/>
                                <field name="invoice_date"/>
                                <field name="amount_total" sum="Total"/>
                                <field name="amount_residual" sum="Saldo"/>
                                <field name="payment_state" widget="badge"
                                       decoration-danger="payment_state == 'not_paid'"
                                       decoration-warning="payment_state == 'partial'"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button name="action_imprimir" string="Imprimir Reporte"
                                type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción del Wizard (sin binding: se abre desde el menú o el tablero) -->
        <record id="action_imprimir_viajes_pagar_wizard" model="ir.actions.act_window">
            <field name="name">Imprimir Viajes Facturados por Pagar</field>
            <field name="res_model">secadora.imprimir.viajes.pagar.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
