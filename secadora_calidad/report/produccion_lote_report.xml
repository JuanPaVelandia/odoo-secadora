<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Formato de papel: Carta -->
        <!-- IMPORTANTE: Debe ir ANTES del action_report para que la referencia funcione -->
        <record id="paperformat_produccion_lote_carta" model="report.paperformat">
            <field name="name">Producción por Lote Carta</field>
            <field name="default" eval="False"/>
            <field name="format">Letter</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">12</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">5</field>
            <field name="dpi">90</field>
        </record>

        <!-- Acción de impresión. Sin binding: se lanza solo desde el wizard. -->
        <record id="action_report_produccion_lote" model="ir.actions.report">
            <field name="name">Producción por Finca y Lote</field>
            <field name="model">secadora.produccion.lote.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">secadora_calidad.report_produccion_lote_document</field>
            <field name="report_file">secadora_calidad.report_produccion_lote_document</field>
            <field name="print_report_name">'Produccion por Lote'</field>
            <field name="paperformat_id" ref="secadora_calidad.paperformat_produccion_lote_carta"/>
        </record>

        <!-- Plantilla. Patrón de la casa: web.basic_layout, SIN TABLAS
             (el CSS de assets pinta bordes en todo td/th y gana a <style>
             en el wkhtmltopdf de este servidor): divs flotados con anchos
             en porcentaje y estilos inline. -->
        <template id="report_produccion_lote_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <t t-set="grupos" t-value="o._get_grupos()"/>
                        <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; color: #111;">

                            <!-- Encabezado general del reporte -->
                            <div class="text-center" style="margin-bottom: 14px;">
                                <div style="font-size: 16px; line-height: 1.1;"><strong t-esc="(o.company_id or o.env.company).name"/></div>
                                <div style="font-size: 10px; letter-spacing: 4px; color: #555; margin-top: 5px;">REPORTE DE PRODUCCIÓN POR FINCA Y LOTE</div>
                                <div style="font-size: 10px; color: #555; margin-top: 3px;">
                                    <t t-if="o.fecha_desde or o.fecha_hasta">
                                        Período:
                                        <t t-if="o.fecha_desde"><span t-field="o.fecha_desde" t-options='{"format": "dd/MM/yyyy"}'/></t>
                                        <t t-else="">inicio</t>
                                        —
                                        <t t-if="o.fecha_hasta"><span t-field="o.fecha_hasta" t-options='{"format": "dd/MM/yyyy"}'/></t>
                                        <t t-else="">hoy</t>
                                    </t>
                                    <t t-else="">Todas las fechas</t>
                                </div>
                            </div>

                            <t t-foreach="grupos" t-as="g">
                                <!-- Una sección por finca+lote; evitar cortes dentro
                                     de la sección y salto de página entre secciones
                                     (hoja entregable al agricultor) -->
                                <div t-att-style="'page-break-inside: avoid;' + ('' if g_last else ' page-break-after: always;')">

                                    <!-- Encabezado del grupo -->
                                    <div style="border-top: 2px solid #111; border-bottom: 1px solid #333; padding: 8px 2px; margin-bottom: 10px; overflow: hidden;">
                                        <div style="float: left; width: 60%; box-sizing: border-box;">
                                            <div style="font-size: 9px; letter-spacing: 1px; color: #555;"><strong>FINCA / LOTE</strong></div>
                                            <div style="font-size: 20px; line-height: 1.2; margin-top: 2px;">
                                                <strong><t t-esc="g['finca'].name"/> — Lote <t t-esc="g['lote'].name or 'Sin lote'"/></strong>
                                            </div>
                                            <div style="font-size: 11px; margin-top: 4px;">
                                                <strong>AGRICULTOR(ES):</strong> <t t-esc="g['agricultores']"/>
                                                <t t-if="g['variedades']"> · <strong>VARIEDAD:</strong> <t t-esc="g['variedades']"/></t>
                                            </div>
                                        </div>
                                        <div style="float: left; width: 40%; box-sizing: border-box; text-align: right; padding-top: 4px;">
                                            <div style="font-size: 9px; letter-spacing: 1px; color: #555;"><strong>CORTA</strong></div>
                                            <div style="font-size: 13px; margin-top: 2px;">
                                                <strong>Del <span t-esc="g['fecha_inicio_corta'].strftime('%d/%m/%Y')"/>
                                                al <span t-esc="g['fecha_fin_corta'].strftime('%d/%m/%Y')"/></strong>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Caja de totales -->
                                    <div style="border: 1px solid #333; border-radius: 8px; overflow: hidden; margin-bottom: 10px; padding: 8px 0;">
                                        <div style="float: left; width: 34%; box-sizing: border-box; text-align: center; padding: 4px 10px;">
                                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>TOTAL KG</strong></div>
                                            <div style="font-size: 22px; margin-top: 2px;"><strong><t t-esc="'{:,.0f}'.format(g['total_kg'])"/></strong></div>
                                        </div>
                                        <div style="float: left; width: 33%; box-sizing: border-box; text-align: center; padding: 4px 10px; border-left: 1px solid #ccc;">
                                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>BULTOS</strong></div>
                                            <div style="font-size: 22px; margin-top: 2px;"><strong><t t-esc="'{:,.0f}'.format(g['total_bultos'])"/></strong></div>
                                        </div>
                                        <div style="float: left; width: 33%; box-sizing: border-box; text-align: center; padding: 4px 10px; border-left: 1px solid #ccc;">
                                            <div style="font-size: 9px; letter-spacing: 1px;"><strong>MULAS</strong></div>
                                            <div style="font-size: 22px; margin-top: 2px;"><strong><t t-esc="g['num_mulas']"/></strong></div>
                                        </div>
                                    </div>

                                    <!-- Ponderados por peso -->
                                    <div style="background-color: #ebebeb; border-radius: 5px; overflow: hidden; margin-bottom: 12px; padding: 6px 0;">
                                        <t t-set="ponderados" t-value="[('HUMEDAD', g['humedad'], '%'), ('IMPUREZAS', g['impurezas'], '%'), ('GRANO PART.', g['grano_partido'], '%'), ('TEMPERATURA', g['temperatura'], '°C')]"/>
                                        <t t-foreach="ponderados" t-as="pnd">
                                            <div t-att-style="'float: left; width: 25%; box-sizing: border-box; text-align: center; padding: 3px 8px;' + ('' if pnd_first else ' border-left: 1px solid #bbb;')">
                                                <div style="font-size: 9px; letter-spacing: 1px;"><strong><t t-esc="pnd[0]"/></strong></div>
                                                <div style="font-size: 15px; margin-top: 1px;">
                                                    <strong><t t-if="pnd[1]"><t t-esc="'%.2f' % pnd[1]"/><t t-esc="pnd[2]"/></t><t t-else="">N/D</t></strong>
                                                </div>
                                            </div>
                                        </t>
                                    </div>

                                    <!-- Detalle de mulas -->
                                    <t t-if="g['detalle']">
                                        <div style="font-size: 10px; letter-spacing: 2px; margin-bottom: 4px;"><strong>DETALLE DE MULAS</strong></div>
                                        <div style="overflow: hidden; font-size: 9px; letter-spacing: 1px; border-bottom: 1px solid #333; padding: 3px 0; color: #555;">
                                            <div style="float: left; width: 12%; box-sizing: border-box;"><strong>FECHA</strong></div>
                                            <div style="float: left; width: 14%; box-sizing: border-box;"><strong>TIQUETE</strong></div>
                                            <div style="float: left; width: 11%; box-sizing: border-box;"><strong>PLACA</strong></div>
                                            <div style="float: left; width: 25%; box-sizing: border-box;"><strong>TERCERO</strong></div>
                                            <div style="float: left; width: 10%; box-sizing: border-box; text-align: right;"><strong>BULTOS</strong></div>
                                            <div style="float: left; width: 12%; box-sizing: border-box; text-align: right;"><strong>KG</strong></div>
                                            <div style="float: left; width: 8%; box-sizing: border-box; text-align: right;"><strong>HUM.%</strong></div>
                                            <div style="float: left; width: 8%; box-sizing: border-box; text-align: right;"><strong>IMP.%</strong></div>
                                        </div>
                                        <t t-foreach="g['detalle']" t-as="r">
                                            <div style="overflow: hidden; font-size: 10px; padding: 3px 0; border-bottom: 1px solid #ddd;">
                                                <div style="float: left; width: 12%; box-sizing: border-box;"><span t-esc="r.fecha.strftime('%d/%m/%Y')"/></div>
                                                <div style="float: left; width: 14%; box-sizing: border-box;"><span t-esc="r.name"/></div>
                                                <div style="float: left; width: 11%; box-sizing: border-box;"><span t-esc="r.placa or ''"/></div>
                                                <div style="float: left; width: 25%; box-sizing: border-box; white-space: nowrap; overflow: hidden;"><span t-esc="r.tercero_id.name"/></div>
                                                <div style="float: left; width: 10%; box-sizing: border-box; text-align: right;"><span t-esc="r.bultos or ''"/></div>
                                                <div style="float: left; width: 12%; box-sizing: border-box; text-align: right;"><strong><t t-esc="'{:,.0f}'.format(r.peso_kg)"/></strong></div>
                                                <div style="float: left; width: 8%; box-sizing: border-box; text-align: right;"><t t-if="r.humedad"><t t-esc="'%.1f' % r.humedad"/></t><t t-else="">—</t></div>
                                                <div style="float: left; width: 8%; box-sizing: border-box; text-align: right;"><t t-if="r.impurezas"><t t-esc="'%.1f' % r.impurezas"/></t><t t-else="">—</t></div>
                                            </div>
                                        </t>
                                        <div style="font-size: 8px; color: #888; margin-top: 4px;">
                                            Bultos según remisión. En cargas mixtas el peso se prorratea por bultos entre los lotes de la mula.
                                        </div>
                                    </t>
                                </div>
                            </t>

                        </div>

                        <div class="footer" style="font-family: Arial, Helvetica, sans-serif;">
                            <div class="text-center" style="font-size: 10px; color: #888; padding-top: 4px;">
                                Reporte de producción — entradas de arroz paddy verde por finca y lote
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
