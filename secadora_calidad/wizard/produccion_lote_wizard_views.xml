<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_produccion_lote_wizard_form" model="ir.ui.view">
            <field name="name">secadora.produccion.lote.wizard.form</field>
            <field name="model">secadora.produccion.lote.wizard</field>
            <field name="arch" type="xml">
                <form string="Imprimir Producción por Lote">
                    <group>
                        <group>
                            <field name="finca_id" options="{'no_create': True}"/>
                            <field name="lote_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="company_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="fecha_desde"/>
                            <field name="fecha_hasta"/>
                            <field name="incluir_detalle"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_imprimir" string="Imprimir" type="object"
                                class="btn-primary" data-hotkey="q"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"
                                data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_produccion_lote_wizard" model="ir.actions.act_window">
            <field name="name">Imprimir Producción por Lote</field>
            <field name="res_model">secadora.produccion.lote.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- El menú vive en el módulo secadora_gerencia (menú Gerencia) -->

    </data>
</odoo>
