<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_paramo_cosecha_list" model="ir.ui.view">
        <field name="name">paramo.cosecha.list</field>
        <field name="model">paramo.cosecha</field>
        <field name="arch" type="xml">
            <list string="Cosechas" decoration-success="state == 'cerrada'" decoration-info="state == 'cosechada'">
                <field name="campaign"/>
                <field name="punto_operativo_id"/>
                <field name="acumulado_1425" widget="monetary"/>
                <field name="kg_secos"/>
                <field name="costo_kg" widget="monetary"/>
                <field name="merma_pct" widget="percentage"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_paramo_cosecha_form" model="ir.ui.view">
        <field name="name">paramo.cosecha.form</field>
        <field name="model">paramo.cosecha</field>
        <field name="arch" type="xml">
            <form string="Cosecha">
                <header>
                    <button name="action_open_close_wizard" type="object"
                            string="Cerrar cosecha (1425 → 1430)" class="btn-primary"
                            invisible="state == 'cerrada'"/>
                    <button name="action_view_move" type="object"
                            string="Ver asiento cosecha (secadora)"
                            invisible="not account_move_id"/>
                    <button name="action_view_finca_move" type="object"
                            string="Ver relieve 1425 (finca)"
                            invisible="not move_finca_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="en_cultivo,cosechada,cerrada"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="2026-Secano · Camelias"/></h1>
                    </div>
                    <group>
                        <group string="Dimensiones">
                            <field name="campaign"/>
                            <field name="punto_operativo_id"/>
                            <field name="analytic_cosecha_id"/>
                        </group>
                        <group string="Contabilidad e inventario">
                            <field name="account_biologico_id"/>
                            <field name="product_paddy_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Estructura (mono / intercompañía)" groups="base.group_multi_company">
                        <group>
                            <field name="company_id"/>
                            <field name="company_destino_id"
                                   help="Vacío = flujo interno; distinta = transferencia al costo"/>
                            <field name="is_intercompany"/>
                        </group>
                        <group invisible="not is_intercompany">
                            <field name="account_cxc_intercia_id" required="is_intercompany"/>
                            <field name="account_cxp_intercia_id" required="is_intercompany"/>
                        </group>
                    </group>
                    <group>
                        <group string="Kilos">
                            <field name="kg_a_secadora"/>
                            <field name="kg_secos"/>
                            <field name="merma_pct" widget="percentage"/>
                        </group>
                        <group string="Costo">
                            <field name="acumulado_1425" widget="monetary"/>
                            <field name="costo_kg" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Resultado de la cosecha" invisible="state != 'cerrada'">
                        <field name="lot_id"/>
                        <field name="picking_id"/>
                        <field name="acumulado_cierre" widget="monetary"/>
                        <field name="account_move_id"/>
                        <field name="move_finca_id" invisible="not is_intercompany"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_paramo_cosecha" model="ir.actions.act_window">
        <field name="name">Cosechas</field>
        <field name="res_model">paramo.cosecha</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
