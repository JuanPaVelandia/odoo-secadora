<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_co_exogenous_format_field_view_search" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.field.view.search</field>
        <field name="model">l10n_co.exogenous_format_field</field>
        <field name="arch" type="xml">
            <search string="Search Exogenous information format field">
                <field name="name"/>
                <field filter_domain="[('format_ids.name', 'ilike', self)]" name="format_ids" string="Format"/>
                <filter domain="[('active','=', False)]" name="inactive" string="Archived"/>
                <separator/>
                <filter context="{'group_by': 'company_id'}" groups="base.group_multi_company" name="company_id" string="Company"/>
                <filter context="{'group_by': 'format_ids'}" name="format_ids" string="Format"/>
                <filter context="{'group_by': 'source'}" name="source" string="Source"/>
            </search>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_field_view_form" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.field.view.form</field>
        <field name="model">l10n_co.exogenous_format_field</field>
        <field name="arch" type="xml">
            <form create="false" delete="false" string="Exogenous information format field">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget bg_color="bg-danger" invisible="active == True" name="web_ribbon" title="Archived"/>
                    <div class="oe_title" name="l10n_co_exogenous_format_field_title">
                        <label for="name" id="l10n_co_exogenous_format_field_title"/>
                        <h1>
                            <field class="d-block" name="name" placeholder="e.g. Website" required="1"/>
                            <field invisible="1" name="active"/>
                        </h1>
                    </div>
                    <group>
                        <group name="info_left">
                            <field name="max_length" required="1"/>
                            <field name="format_ids" required="1" widget="many2many_tags"/>
                        </group>
                        <group name="info_right">
                            <field name="attribute" required="1"/>
                            <field name="source" required="1"/>
                            <field invisible="source == 'journal_items'" name="is_unique_key"/>
                            <field invisible="source != 'contact'" name="applies_to_company"/>
                            <field invisible="source != 'contact'" name="applies_to_contact"/>
                            <field invisible="source != 'journal_items'" name="format_applies_concepts"/>
                            <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group name="info_left">
                            <field invisible="source != 'contact'" name="field_odoo_id" options="{'no_create': True}" required="source == 'contact'"/>
                            <field invisible="1" name="ttype"/>
                            <field invisible="1" name="relation"/>
                        </group>
                        <group name="info_right">
                            <field invisible="ttype != 'many2one'" name="field_odoo_internal_id" options="{'no_create': True}" required="ttype == 'many2one'"/>
                        </group>
                    </group>
                    <group colspan="4" invisible="format_applies_concepts == True" name="field_account_ids" string="Accounts">
                        <field colspan="2" name="field_account_ids" nolabel="1" required="format_applies_concepts == False">
                            <list editable="bottom">
                                <field name="account_ids" required="1" widget="many2many_tags"/>
                                <field name="name" required="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_field_view_tree" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.field.view.tree</field>
        <field name="model">l10n_co.exogenous_format_field</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" edit="false" string="Exogenous information format fields">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="source"/>
                <field name="is_unique_key"/>
                <field name="attribute"/>
                <field name="max_length"/>
                <field groups="base.group_multi_company" name="company_id"/>
            </list>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_field_action" model="ir.actions.act_window">
        <field name="name">Exogenous information format fields</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_co.exogenous_format_field</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
