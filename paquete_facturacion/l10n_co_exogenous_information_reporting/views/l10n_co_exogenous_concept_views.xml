<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_co_exogenous_concept_view_search" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.concept.view.search</field>
        <field name="model">l10n_co.exogenous_concept</field>
        <field name="arch" type="xml">
            <search string="Search Concepts">
                <field name="name"/>
                <field name="code"/>
                <filter domain="[('active','=', False)]" name="inactive" string="Archived"/>
                <separator/>
                <filter context="{'group_by': 'company_id'}" groups="base.group_multi_company" name="company_id" string="Company"/>
                <filter context="{'group_by': 'format_id'}" name="format_id" string="Format"/>
            </search>
        </field>
    </record>
    <record id="l10n_co_exogenous_concept_view_form" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.concept.view.form</field>
        <field name="model">l10n_co.exogenous_concept</field>
        <field name="arch" type="xml">
            <form delete="false" string="Concept">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget bg_color="bg-danger" invisible="active == True" name="web_ribbon" title="Archived"/>
                    <div class="oe_title" name="l10n_co_exogenous_concept_title">
                        <label for="code" id="l10n_co_exogenous_concept_title"/>
                        <h1>
                            <field class="d-block" name="code" placeholder="e.g. Website" required="1"/>
                            <field invisible="1" name="active"/>
                        </h1>
                    </div>
                    <group>
                        <group name="info_left">
                            <field name="format_id" options="{'no_create': True}" required="1"/>
                        </group>
                        <group name="info_right">
                            <field name="report_with_informan_nit"/>
                            <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group colspan="4" name="group_name">
                        <field colspan="2" name="name" required="1"/>
                    </group>
                    <group colspan="4" name="field_account_ids" string="Accounts">
                        <field colspan="2" name="field_account_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="account_ids" required="1" widget="many2many_tags"/>
                                <field name="name" required="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="l10n_co_exogenous_concept_view_tree" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.concept.view.tree</field>
        <field name="model">l10n_co.exogenous_concept</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" string="Concepts">
                <field name="code"/>
                <field name="name"/>
                <field name="format_id"/>
                <field name="report_with_informan_nit" optional="hide"/>
                <field groups="base.group_multi_company" name="company_id"/>
            </list>
        </field>
    </record>
    <record id="l10n_co_exogenous_concept_action" model="ir.actions.act_window">
        <field name="name">Concepts</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_co.exogenous_concept</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your concepts here.
            </p>
        </field>
    </record>
</odoo>
