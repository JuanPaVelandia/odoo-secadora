<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_co_exogenous_format_view_search" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.view.search</field>
        <field name="model">l10n_co.exogenous_format</field>
        <field name="arch" type="xml">
            <search string="Search Format">
                <field name="name"/>
                <field name="code"/>
                <filter domain="[('active','=', False)]" name="inactive" string="Archived"/>
                <filter domain="[('is_it_with_date_range','=', True)]" name="is_it_with_date_range" string="Is it with date range?"/>
                <filter domain="[('apply_concepts','=', True)]" name="apply_concepts" string="Apply Concepts?"/>
                <filter domain="[('applying_smaller_amounts','=', True)]" name="applying_smaller_amounts" string="Applying smaller amounts?"/>
                <separator/>
                <filter context="{'group_by': 'company_id'}" groups="base.group_multi_company" name="company_id" string="Company"/>
                <filter context="{'group_by': 'document_type_table_id'}" name="document_type_table_id" string="Document Type Table"/>
            </search>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_view_form" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.view.form</field>
        <field name="model">l10n_co.exogenous_format</field>
        <field name="arch" type="xml">
            <form create="false" delete="false" string="Format">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget bg_color="bg-danger" invisible="active == True" name="web_ribbon" title="Archived"/>
                    <div class="oe_title" name="l10n_co_exogenous_format_title">
                        <label for="code" id="l10n_co_exogenous_format_title"/>
                        <h1>
                            <field class="d-block" name="code" required="1"/>
                            <field invisible="1" name="active"/>
                        </h1>
                    </div>
                    <group>
                        <group name="info_left">
                            <field name="version"/>
                            <field name="appendix"/>
                        </group>
                        <group name="info_right">
                            <field name="document_type_table_id" options="{'no_create': True}"/>
                            <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group name="info_left">
                            <field name="applying_smaller_amounts"/>
                            <field name="is_it_with_date_range"/>
                            <field name="apply_concepts"/>
                        </group>
                        <group name="info_right">
                            <field invisible="1" name="company_currency_id"/>
                            <field invisible="applying_smaller_amounts == False" name="smaller_ammounts"/>
                        </group>
                    </group>
                    <group colspan="4" name="group_name">
                        <field colspan="2" name="name" required="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_view_tree" model="ir.ui.view">
        <field name="name">l10n.co.exogenous.format.view.tree</field>
        <field name="model">l10n_co.exogenous_format</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" string="Formats">
                <field name="code"/>
                <field name="name"/>
                <field name="version"/>
                <field name="appendix"/>
                <field name="document_type_table_id" optional="hide"/>
                <field name="is_it_with_date_range" optional="hide"/>
                <field name="apply_concepts" optional="hide"/>
                <field name="applying_smaller_amounts" optional="hide"/>
                <field name="smaller_ammounts" optional="hide"/>
                <field groups="base.group_multi_company" name="company_id" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="l10n_co_exogenous_format_action" model="ir.actions.act_window">
        <field name="name">Formats</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_co.exogenous_format</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your formats here.
            </p>
        </field>
    </record>
</odoo>
