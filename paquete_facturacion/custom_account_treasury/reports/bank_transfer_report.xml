<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         TRANSFERENCIA BANCARIA - Para transferencias entre cuentas
         ============================================================ -->

    <template id="report_bank_transfer_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang='es_CO')"/>
            <t t-set="is_internal" t-value="o.paired_internal_transfer_payment_id and True or False"/>
            <t t-set="dest_payment" t-value="o.paired_internal_transfer_payment_id"/>

            <div class="page">
                <!-- Encabezado -->
                <div class="row mb-4">
                    <div class="col-8">
                        <h2 style="color: #17a2b8;">
                            <strong>ORDEN DE TRANSFERENCIA</strong>
                        </h2>
                        <h5 class="text-muted">
                            <t t-if="is_internal">Transferencia Interna entre Cuentas</t>
                            <t t-else="">Transferencia Bancaria</t>
                        </h5>
                    </div>
                    <div class="col-4 text-end">
                        <div style="border: 2px solid #17a2b8; border-radius: 8px; padding: 10px; background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                            <div style="font-size: 16pt; font-weight: bold; color: #17a2b8;" t-field="o.name"/>
                            <div class="mt-2">
                                <strong>Fecha:</strong> <span t-field="o.date" t-options="{'format': 'dd/MM/yyyy'}"/>
                            </div>
                            <div class="small text-muted" t-if="o.bank_reference">
                                Ref: <span t-field="o.bank_reference"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Información de la Transferencia -->
                <div class="row mb-4">
                    <!-- Cuenta Origen -->
                    <div class="col-5">
                        <div style="border: 2px solid #dc3545; border-radius: 8px; padding: 15px; background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
                            <h6 style="color: #dc3545; font-weight: bold; text-transform: uppercase; border-bottom: 1px solid #dc3545; padding-bottom: 8px;">
                                <i class="fa fa-arrow-circle-up"/> CUENTA ORIGEN
                            </h6>
                            <div class="mb-2">
                                <strong>Banco/Caja:</strong>
                                <div style="font-size: 12pt; font-weight: bold;" t-field="o.journal_id.name"/>
                            </div>
                            <div class="mb-2" t-if="o.journal_id.bank_account_id">
                                <strong>Cuenta Bancaria:</strong>
                                <div t-field="o.journal_id.bank_account_id.acc_number"/>
                            </div>
                            <div t-if="o.journal_id.bank_id">
                                <strong>Entidad:</strong>
                                <span t-field="o.journal_id.bank_id.name"/>
                            </div>
                        </div>
                    </div>

                    <!-- Flecha -->
                    <div class="col-2 d-flex align-items-center justify-content-center">
                        <div style="font-size: 36pt; color: #17a2b8;">
                            <i class="fa fa-arrow-right"/>
                        </div>
                    </div>

                    <!-- Cuenta Destino -->
                    <div class="col-5">
                        <div style="border: 2px solid #28a745; border-radius: 8px; padding: 15px; background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                            <h6 style="color: #28a745; font-weight: bold; text-transform: uppercase; border-bottom: 1px solid #28a745; padding-bottom: 8px;">
                                <i class="fa fa-arrow-circle-down"/> CUENTA DESTINO
                            </h6>
                            <t t-if="dest_payment">
                                <div class="mb-2">
                                    <strong>Banco/Caja:</strong>
                                    <div style="font-size: 12pt; font-weight: bold;" t-field="dest_payment.journal_id.name"/>
                                </div>
                                <div class="mb-2" t-if="dest_payment.journal_id.bank_account_id">
                                    <strong>Cuenta Bancaria:</strong>
                                    <div t-field="dest_payment.journal_id.bank_account_id.acc_number"/>
                                </div>
                                <div t-if="dest_payment.journal_id.bank_id">
                                    <strong>Entidad:</strong>
                                    <span t-field="dest_payment.journal_id.bank_id.name"/>
                                </div>
                            </t>
                            <t t-elif="o.destination_account_id">
                                <div class="mb-2">
                                    <strong>Cuenta Contable:</strong>
                                    <div style="font-size: 11pt; font-weight: bold;">
                                        <span t-field="o.destination_account_id.code"/> - <span t-field="o.destination_account_id.name"/>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mb-2">
                                    <strong>Beneficiario:</strong>
                                    <div style="font-size: 11pt; font-weight: bold;" t-field="o.partner_id.name"/>
                                </div>
                                <div t-if="o.partner_id.bank_ids">
                                    <strong>Cuenta:</strong>
                                    <span t-out="o.partner_id.bank_ids[0].acc_number if o.partner_id.bank_ids else ''"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Monto de la Transferencia -->
                <div class="row mb-4">
                    <div class="col-6 offset-3">
                        <div style="border: 3px solid #17a2b8; border-radius: 10px; padding: 20px; text-align: center; background: linear-gradient(135deg, #e1f5fe 0%, #b3e5fc 100%);">
                            <div style="font-size: 11pt; color: #0277bd;">MONTO A TRANSFERIR</div>
                            <div style="font-size: 28pt; font-weight: bold; color: #01579b;">
                                <span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </div>
                            <div class="mt-2" t-if="o.currency_id.id != o.company_currency_id.id">
                                <span class="text-muted">
                                    Equivalente: <span t-out="'{:,.2f}'.format(o.amount * o.current_exchange_rate)"/>
                                    <span t-field="o.company_currency_id.symbol"/>
                                </span>
                                <br/>
                                <small class="text-muted">Tasa: <span t-field="o.current_exchange_rate"/></small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Monto en Letras -->
                <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 10px 15px; background-color: #f8f9fa; margin-bottom: 20px;">
                    <strong>SON:</strong>
                    <span t-out="o.currency_id.amount_to_text(o.amount)"/>
                </div>

                <!-- Concepto -->
                <div class="mb-4" t-if="o.memo">
                    <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 10px 15px;">
                        <strong>Concepto / Motivo:</strong>
                        <div t-field="o.memo"/>
                    </div>
                </div>

                <!-- Información Adicional -->
                <div class="row mb-4">
                    <div class="col-6">
                        <table class="table table-sm table-bordered">
                            <tr>
                                <td class="bg-light" style="width: 40%;"><strong>Método de Pago:</strong></td>
                                <td><span t-field="o.payment_method_line_id.name"/></td>
                            </tr>
                            <tr t-if="o.bank_reference">
                                <td class="bg-light"><strong>Ref. Bancaria:</strong></td>
                                <td><span t-field="o.bank_reference"/></td>
                            </tr>
                            <tr t-if="o.check_number">
                                <td class="bg-light"><strong>No. Cheque:</strong></td>
                                <td><span t-field="o.check_number"/></td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-6">
                        <table class="table table-sm table-bordered">
                            <tr>
                                <td class="bg-light" style="width: 40%;"><strong>Estado:</strong></td>
                                <td>
                                    <span t-if="o.state == 'posted'" class="badge bg-success">Confirmado</span>
                                    <span t-elif="o.state == 'draft'" class="badge bg-warning text-dark">Borrador</span>
                                    <span t-elif="o.state == 'cancel'" class="badge bg-danger">Cancelado</span>
                                </td>
                            </tr>
                            <tr t-if="o.move_id">
                                <td class="bg-light"><strong>Asiento:</strong></td>
                                <td><span t-field="o.move_id.name"/></td>
                            </tr>
                            <tr t-if="dest_payment">
                                <td class="bg-light"><strong>Doc. Destino:</strong></td>
                                <td><span t-field="dest_payment.name"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Detalle Contable -->
                <t t-if="o.move_id and o.move_id.line_ids">
                    <h6 style="color: #17a2b8; border-bottom: 2px solid #17a2b8; padding-bottom: 5px;">
                        <strong>DETALLE CONTABLE</strong>
                    </h6>
                    <table class="table table-sm table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Cuenta</th>
                                <th>Descripción</th>
                                <th class="text-end">Débito</th>
                                <th class="text-end">Crédito</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.move_id.line_ids.sorted(key=lambda l: (l.debit == 0, l.account_id.code))" t-as="line">
                                <tr>
                                    <td>
                                        <span t-field="line.account_id.code"/> - <span t-field="line.account_id.name"/>
                                    </td>
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-end">
                                        <span t-if="line.debit" t-field="line.debit" t-options="{'widget': 'monetary', 'display_currency': o.company_currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-if="line.credit" t-field="line.credit" t-options="{'widget': 'monetary', 'display_currency': o.company_currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <!-- Firmas -->
                <div class="row mt-5 pt-4">
                    <div class="col-3 text-center">
                        <div style="border-top: 1px solid #333; margin-top: 50px; padding-top: 8px; margin-left: 10px; margin-right: 10px;">
                            <strong>Solicitado por</strong>
                            <div class="small text-muted" t-if="o.create_uid">
                                <t t-out="o.create_uid.name"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-3 text-center">
                        <div style="border-top: 1px solid #333; margin-top: 50px; padding-top: 8px; margin-left: 10px; margin-right: 10px;">
                            <strong>Revisado por</strong>
                            <div class="small text-muted">Tesorería</div>
                        </div>
                    </div>
                    <div class="col-3 text-center">
                        <div style="border-top: 1px solid #333; margin-top: 50px; padding-top: 8px; margin-left: 10px; margin-right: 10px;">
                            <strong>Aprobado por</strong>
                            <div class="small text-muted">Gerencia</div>
                        </div>
                    </div>
                    <div class="col-3 text-center">
                        <div style="border-top: 1px solid #333; margin-top: 50px; padding-top: 8px; margin-left: 10px; margin-right: 10px;">
                            <strong>Ejecutado por</strong>
                            <div class="small text-muted">Banco</div>
                        </div>
                    </div>
                </div>

                <!-- Pie de página -->
                <div class="row mt-4 small text-muted" style="border-top: 1px solid #dee2e6; padding-top: 10px;">
                    <div class="col-4">
                        <span>Impreso: <t t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/></span>
                    </div>
                    <div class="col-4 text-center">
                        <span>Usuario: <t t-out="env.user.name"/></span>
                    </div>
                    <div class="col-4 text-end">
                        <span>Documento válido con firmas autorizadas</span>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_bank_transfer">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="custom_account_treasury.report_bank_transfer_document"/>
            </t>
        </t>
    </template>

    <!-- Acción del reporte -->
    <record id="action_report_bank_transfer" model="ir.actions.report">
        <field name="name">Orden de Transferencia</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_bank_transfer</field>
        <field name="report_file">custom_account_treasury.report_bank_transfer</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
