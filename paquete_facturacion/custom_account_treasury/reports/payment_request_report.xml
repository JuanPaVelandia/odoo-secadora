<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <template id="report_payment_request">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Encabezado -->
                        <div class="oe_structure"/>
                        <h2 class="text-center">
                            SOLICITUD DE PAGO
                            <span t-if="o.state == 'approved'" class="badge badge-success">APROBADO</span>
                            <span t-if="o.state == 'paid'" class="badge badge-info">PAGADO</span>
                            <span t-if="o.state == 'cancelled'" class="badge badge-danger">CANCELADO</span>
                        </h2>

                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Número:</strong> <span t-field="o.name"/><br/>
                                <strong>Fecha:</strong> <span t-field="o.date_request"/><br/>
                                <strong>Vencimiento:</strong> <span t-field="o.date_due"/><br/>
                                <strong>Tipo:</strong> <span t-field="o.request_type"/>
                            </div>
                            <div class="col-6 text-right">
                                <strong>Memo:</strong> <span t-field="o.memo"/><br/>
                                <strong>Estado:</strong> <span t-field="o.stage_id.name"/><br/>
                                <strong>Prioridad:</strong>
                                <span t-if="o.priority == '1'" class="text-danger">ALTA</span>
                                <span t-else="">Normal</span>
                            </div>
                        </div>

                        <!-- Beneficiario -->
                        <div class="row">
                            <div class="col-12">
                                <h4>Beneficiario</h4>
                                <table class="table table-sm">
                                    <tr>
                                        <td width="20%"><strong>Nombre:</strong></td>
                                        <td><span t-field="o.partner_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>NIT/CC:</strong></td>
                                        <td><span t-field="o.partner_id.vat"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Monto -->
                        <div class="row mt32">
                            <div class="col-12">
                                <table class="table table-sm">
                                    <tr class="bg-light">
                                        <td class="text-right" width="70%"><strong>MONTO SOLICITADO:</strong></td>
                                        <td class="text-right">
                                            <strong>
                                                <span t-field="o.currency_id.symbol"/>
                                                <span t-field="o.amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Descripción -->
                        <div class="row mt32" t-if="o.description">
                            <div class="col-12">
                                <h4>Descripción</h4>
                                <p><span t-field="o.description"/></p>
                            </div>
                        </div>

                        <!-- Facturas relacionadas -->
                        <div class="row mt32" t-if="o.invoice_ids">
                            <div class="col-12">
                                <h4>Facturas Relacionadas</h4>
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Número</th>
                                            <th>Fecha</th>
                                            <th class="text-right">Monto</th>
                                            <th class="text-right">Saldo</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.invoice_ids" t-as="inv">
                                            <tr>
                                                <td><span t-field="inv.name"/></td>
                                                <td><span t-field="inv.invoice_date"/></td>
                                                <td class="text-right"><span t-field="inv.amount_total"/></td>
                                                <td class="text-right"><span t-field="inv.amount_residual"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Firmas -->
                        <div class="row mt64">
                            <div class="col-4 text-center">
                                <br/><br/><br/>
                                <div style="border-top: 1px solid black; width: 80%; margin: auto;">
                                    <strong>Solicitante</strong><br/>
                                    <span t-field="o.create_uid.name"/>
                                </div>
                            </div>
                            <div class="col-4 text-center" t-if="o.state in ['approved', 'paid']">
                                <br/><br/><br/>
                                <div style="border-top: 1px solid black; width: 80%; margin: auto;">
                                    <strong>Aprobado por</strong><br/>
                                    <span t-field="o.write_uid.name"/>
                                </div>
                            </div>
                            <div class="col-4 text-center" t-if="o.payment_id">
                                <br/><br/><br/>
                                <div style="border-top: 1px solid black; width: 80%; margin: auto;">
                                    <strong>Pago</strong><br/>
                                    <span t-field="o.payment_id.name"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>