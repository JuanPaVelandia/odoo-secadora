<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================================
         COMPROBANTE DE EGRESO - CONCEPTOS (Estilo Factura)
         Sin cuentas contables, solo muestra conceptos y valores
         ======================================================================== -->

    <record id="paperformat_comprobante_egreso" model="report.paperformat">
        <field name="name">Comprobante de Egreso - Bohio</field>
        <field name="default" eval="True"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <template id="report_payment_voucher_conceptos_documento">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.company_id"/>
                <t t-set="is_outbound" t-value="doc.payment_type == 'outbound'"/>

                <div class="article" style="font-family: Arial, sans-serif; font-size: 8pt; line-height: 1.2; color: #333;">

                    <!-- ============================================
                         ENCABEZADO
                         ============================================ -->
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            <!-- Logo -->
                            <td style="width: 12%; padding: 5px; text-align: center; vertical-align: middle; border-bottom: 2px solid #4a4a4a;">
                                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-width: 80px; max-height: 50px;" alt="Logo"/>
                            </td>

                            <!-- Info Empresa -->
                            <td style="width: 38%; padding: 5px 10px; vertical-align: top; border-bottom: 1px solid #ccc;">
                                <div style="font-weight: bold; font-size: 9pt; color: #333; margin-bottom: 2px;" t-field="company.name"/>
                                <div><b>NIT:</b> <span t-field="company.vat"/></div>
                                <div t-if="company.company_registry"><b>Matricula:</b> <span t-field="company.company_registry"/></div>
                                <div><b>Dir:</b> <span t-field="company.street"/>, <span t-field="company.city"/></div>
                                <div><b>Tel:</b> <span t-field="company.phone"/></div>
                            </td>

                            <!-- Espacio QR (opcional) -->
                            <td style="width: 15%; padding: 5px; text-align: center; vertical-align: middle; border-bottom: 1px solid #ccc;">
                            </td>

                            <!-- Tipo y Numero -->
                            <td style="width: 35%; padding: 0; vertical-align: top; border-bottom: 1px solid #ccc;">
                                <div style="background: #4a4a4a; color: white; padding: 4px; text-align: center; font-size: 8pt; font-weight: bold;">
                                    <t t-if="is_outbound">COMPROBANTE DE EGRESO</t>
                                    <t t-else="">RECIBO DE CAJA</t>
                                </div>
                                <div style="text-align: center; padding: 5px; font-size: 14pt; font-weight: bold; color: #4a4a4a;">
                                    <span t-if="doc.payment_number" t-field="doc.payment_number"/>
                                    <span t-else="" t-field="doc.name"/>
                                </div>
                                <table style="width: 100%; font-size: 7pt;">
                                    <tr>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">DIA</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%d') if doc.date else '--'"/>
                                            </div>
                                        </td>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">MES</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%m') if doc.date else '--'"/>
                                            </div>
                                        </td>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">ANO</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%Y') if doc.date else '----'"/>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Beneficiario -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 5px;">
                        <tr>
                            <td style="width: 50%; padding: 3px 5px; border-bottom: 1px solid #eee;">
                                <b>Beneficiario:</b> <span t-field="doc.partner_id.name"/><br/>
                                <b>NIT/CC:</b> <span t-field="doc.partner_id.vat"/>
                                <t t-if="doc.partner_id.phone"> | <b>Tel:</b> <span t-field="doc.partner_id.phone"/></t>
                            </td>
                            <td style="width: 50%; padding: 3px 5px; border-bottom: 1px solid #eee;">
                                <b>Dir:</b> <span t-field="doc.partner_id.street"/><br/>
                                <b>Ciudad:</b> <span t-field="doc.partner_id.city"/>
                                <t t-if="doc.partner_id.email"> | <span t-field="doc.partner_id.email"/></t>
                            </td>
                        </tr>
                    </table>

                    <!-- ============================================
                         INFORMACION DE PAGO
                         ============================================ -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 3px; border: 1px solid #dee2e6;">
                        <tr>
                            <td style="width: 33%; padding: 5px 8px; border-right: 1px solid #dee2e6;">
                                <div style="font-size: 6pt; color: #6c757d; text-transform: uppercase;">Forma de Pago</div>
                                <div style="font-size: 8pt; font-weight: bold; color: #333;">
                                    <t t-if="doc.journal_id.type == 'bank'">Transferencia Bancaria</t>
                                    <t t-elif="doc.journal_id.type == 'cash'">Efectivo</t>
                                    <t t-else=""><span t-field="doc.journal_id.name"/></t>
                                </div>
                            </td>
                            <td style="width: 33%; padding: 5px 8px; border-right: 1px solid #dee2e6;">
                                <div style="font-size: 6pt; color: #6c757d; text-transform: uppercase;">Banco / Caja</div>
                                <div style="font-size: 8pt; font-weight: bold; color: #333;">
                                    <span t-field="doc.journal_id.name"/>
                                </div>
                            </td>
                            <td style="width: 34%; padding: 5px 8px;">
                                <div style="font-size: 6pt; color: #6c757d; text-transform: uppercase;">Referencia</div>
                                <div style="font-size: 8pt; font-weight: bold; color: #333;">
                                    <span t-if="doc.payment_reference" t-field="doc.payment_reference"/>
                                    <span t-elif="doc.move_id" t-field="doc.move_id.name"/>
                                    <span t-else="">-</span>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- ============================================
                         TABLA DE CONCEPTOS: CARGOS Y DESCUENTOS
                         ============================================ -->
                    <!-- Filtrar lineas: excluir asset_cash, rounding, line_section, line_note, is_main -->
                    <t t-set="all_lines" t-value="doc.payment_line_ids.filtered(lambda l: not l.is_main and l.display_type not in ['asset_cash', 'rounding', 'line_section', 'line_note'])"/>
                    <!-- CARGOS: Montos positivos que no son retenciones -->
                    <t t-set="cargo_lines" t-value="all_lines.filtered(lambda l: l.payment_amount and l.payment_amount > 0 and 'RET' not in (l.name or '').upper())"/>
                    <!-- DESCUENTOS: Montos negativos o retenciones -->
                    <t t-set="descuento_lines" t-value="all_lines.filtered(lambda l: (l.payment_amount and l.payment_amount &lt; 0) or ('RET' in (l.name or '').upper()))"/>

                    <table style="width: 100%; border-collapse: collapse; margin-top: 8px;">
                        <thead>
                            <tr style="background: #4a4a4a; color: white;">
                                <th style="width: 5%; padding: 4px; text-align: center; font-size: 7pt;">No.</th>
                                <th style="width: 35%; padding: 4px; text-align: left; font-size: 7pt;">CONCEPTO</th>
                                <th style="width: 25%; padding: 4px; text-align: left; font-size: 7pt;">TERCERO</th>
                                <th style="width: 17%; padding: 4px; text-align: right; font-size: 7pt;">BASE</th>
                                <th style="width: 18%; padding: 4px; text-align: right; font-size: 7pt;">VALOR</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- ========== SECCION: CARGOS (suman) ========== -->
                            <t t-if="cargo_lines">
                                <tr style="background: #d4edda;">
                                    <td colspan="5" style="padding: 4px 8px; font-size: 7pt; font-weight: bold; color: #155724; border-top: 2px solid #28a745;">
                                        (+) CARGOS
                                    </td>
                                </tr>
                                <t t-set="cargo_total" t-value="0"/>
                                <t t-set="cargo_num" t-value="0"/>
                                <t t-foreach="cargo_lines" t-as="line">
                                    <t t-set="cargo_num" t-value="cargo_num + 1"/>
                                    <t t-set="cargo_total" t-value="cargo_total + abs(line.payment_amount or 0)"/>
                                    <tr style="border-bottom: 1px solid #eee; background: #f8fff8;">
                                        <td style="padding: 3px 4px; text-align: center; font-size: 7pt;"><span t-out="cargo_num"/></td>
                                        <td style="padding: 3px 4px; font-size: 7pt;">
                                            <span t-out="line.name or ''"/>
                                            <t t-if="line.invoice_id">
                                                <span style="font-size: 6pt; color: #888;"> (<span t-field="line.invoice_id.name"/>)</span>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; font-size: 6pt;">
                                            <span t-if="line.partner_id" t-field="line.partner_id.name"/>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt;">
                                            <t t-if="line.invoice_id">
                                                <span t-out="'{:,.0f}'.format(line.invoice_id.amount_total or 0)"/>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt; font-weight: bold; color: #28a745;">
                                            <span t-out="'{:,.0f}'.format(abs(line.payment_amount or 0))"/>
                                        </td>
                                    </tr>
                                </t>
                                <!-- Subtotal Cargos -->
                                <tr style="background: #c3e6cb;">
                                    <td colspan="4" style="padding: 3px 8px; text-align: right; font-size: 7pt; font-weight: bold;">SUBTOTAL CARGOS:</td>
                                    <td style="padding: 3px 4px; text-align: right; font-size: 7pt; font-weight: bold; color: #155724;">
                                        <span t-out="'{:,.0f}'.format(cargo_total)"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- ========== SECCION: DESCUENTOS (restan) ========== -->
                            <t t-if="descuento_lines">
                                <tr style="background: #f8d7da;">
                                    <td colspan="5" style="padding: 4px 8px; font-size: 7pt; font-weight: bold; color: #721c24; border-top: 2px solid #dc3545;">
                                        (-) DESCUENTOS
                                    </td>
                                </tr>
                                <t t-set="descuento_total" t-value="0"/>
                                <t t-set="descuento_num" t-value="0"/>
                                <t t-foreach="descuento_lines" t-as="line">
                                    <t t-set="descuento_num" t-value="descuento_num + 1"/>
                                    <t t-set="descuento_total" t-value="descuento_total + abs(line.payment_amount or 0)"/>
                                    <tr style="border-bottom: 1px solid #eee; background: #fff8f8;">
                                        <td style="padding: 3px 4px; text-align: center; font-size: 7pt;"><span t-out="descuento_num"/></td>
                                        <td style="padding: 3px 4px; font-size: 7pt;">
                                            <span t-out="line.name or ''"/>
                                            <t t-if="line.invoice_id">
                                                <span style="font-size: 6pt; color: #888;"> (<span t-field="line.invoice_id.name"/>)</span>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; font-size: 6pt;">
                                            <span t-if="line.partner_id" t-field="line.partner_id.name"/>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt;">
                                            <t t-if="line.tax_base_amount">
                                                <span t-out="'{:,.0f}'.format(abs(line.tax_base_amount))"/>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt; font-weight: bold; color: #dc3545;">
                                            <span t-out="'({:,.0f})'.format(abs(line.payment_amount or 0))"/>
                                        </td>
                                    </tr>
                                </t>
                                <!-- Subtotal Descuentos -->
                                <tr style="background: #f5c6cb;">
                                    <td colspan="4" style="padding: 3px 8px; text-align: right; font-size: 7pt; font-weight: bold;">SUBTOTAL DESCUENTOS:</td>
                                    <td style="padding: 3px 4px; text-align: right; font-size: 7pt; font-weight: bold; color: #721c24;">
                                        <span t-out="'({:,.0f})'.format(descuento_total)"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- Si no hay ninguna linea de pago -->
                            <t t-if="not all_lines">
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td style="padding: 3px 4px; text-align: center; font-size: 7pt;">1</td>
                                    <td style="padding: 3px 4px; font-size: 7pt;">
                                        <t t-if="doc.memo"><span t-field="doc.memo"/></t>
                                        <t t-else="">Pago a <span t-field="doc.partner_id.name"/></t>
                                    </td>
                                    <td style="padding: 3px 4px; font-size: 6pt;">
                                        <span t-field="doc.partner_id.name"/>
                                    </td>
                                    <td style="padding: 3px 4px; text-align: right; font-size: 7pt;"></td>
                                    <td style="padding: 3px 4px; text-align: right; font-size: 7pt; font-weight: bold;">
                                        <span t-out="'{:,.0f}'.format(doc.amount or 0)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- ============================================
                         OBSERVACIONES Y TOTALES
                         ============================================ -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 5px;">
                        <tr>
                            <td style="width: 55%; padding: 5px; vertical-align: top; border-top: 1px solid #ccc;">
                                <div style="font-size: 7pt;"><b>Observaciones:</b></div>
                                <div style="font-size: 7pt; min-height: 25px;" t-if="doc.memo" t-field="doc.memo"/>

                                <div style="margin-top: 10px; font-size: 7pt;">
                                    <b t-if="doc.create_uid" t-field="doc.create_uid.name"/><br/>
                                    <span>Elaboro</span>
                                </div>
                            </td>

                            <td style="width: 45%; padding: 0; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <!-- Total -->
                                    <tr style="background: #4a4a4a; color: white;">
                                        <td style="padding: 5px 8px; font-size: 8pt;"><b>TOTAL A PAGAR</b></td>
                                        <td style="padding: 5px 8px; text-align: right; font-size: 9pt;">
                                            <b><span t-field="doc.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></b>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Monto en Letras -->
                    <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 6px 10px; background-color: #f8f9fa; margin-top: 8px;">
                        <strong style="font-size: 7pt;">SON:</strong>
                        <span style="font-size: 7pt; font-style: italic;" t-out="doc.currency_id.amount_to_text(doc.amount)"/>
                    </div>

                    <!-- Firmas -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
                        <tr>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Elaboro</div>
                            </td>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Aprobo</div>
                            </td>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Recibio Conforme</div>
                            </td>
                        </tr>
                    </table>

                    <!-- Pie de pagina -->
                    <div style="font-size: 6pt; color: #666; padding: 3px 5px; text-align: center; border-top: 1px solid #eee; margin-top: 10px;">
                        Impreso: <span t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/> |
                        Usuario: <span t-field="user.name"/>
                    </div>

                </div>
            </t>
        </t>
    </template>

    <!-- ACCION DE REPORTE - Conceptos -->
    <record id="action_report_payment_voucher_conceptos" model="ir.actions.report">
        <field name="name">Comprobante de Egreso (Conceptos)</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_payment_voucher_conceptos_documento</field>
        <field name="report_file">custom_account_treasury.report_payment_voucher_conceptos_documento</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_comprobante_egreso"/>
        <field name="print_report_name">'CE_Conceptos_%s' % (object.name or 'draft').replace('/', '_')</field>
    </record>


    <!-- ========================================================================
         COMPROBANTE DE EGRESO - CONTABLE (Con asiento contable)
         Muestra el detalle del asiento contable
         ======================================================================== -->

    <template id="report_payment_voucher_contable_documento">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.company_id"/>
                <t t-set="is_outbound" t-value="doc.payment_type == 'outbound'"/>

                <div class="article" style="font-family: Arial, sans-serif; font-size: 8pt; line-height: 1.2; color: #333;">

                    <!-- ============================================
                         ENCABEZADO
                         ============================================ -->
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            <!-- Logo -->
                            <td style="width: 12%; padding: 5px; text-align: center; vertical-align: middle; border-bottom: 2px solid #4a4a4a;">
                                <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-width: 80px; max-height: 50px;" alt="Logo"/>
                            </td>

                            <!-- Info Empresa -->
                            <td style="width: 38%; padding: 5px 10px; vertical-align: top; border-bottom: 1px solid #ccc;">
                                <div style="font-weight: bold; font-size: 9pt; color: #333; margin-bottom: 2px;" t-field="company.name"/>
                                <div><b>NIT:</b> <span t-field="company.vat"/></div>
                                <div><b>Dir:</b> <span t-field="company.street"/>, <span t-field="company.city"/></div>
                                <div><b>Tel:</b> <span t-field="company.phone"/></div>
                            </td>

                            <!-- Espacio -->
                            <td style="width: 15%; padding: 5px; text-align: center; vertical-align: middle; border-bottom: 1px solid #ccc;">
                            </td>

                            <!-- Tipo y Numero -->
                            <td style="width: 35%; padding: 0; vertical-align: top; border-bottom: 1px solid #ccc;">
                                <div style="background: #4a4a4a; color: white; padding: 4px; text-align: center; font-size: 8pt; font-weight: bold;">
                                    <t t-if="is_outbound">COMPROBANTE DE EGRESO - CONTABLE</t>
                                    <t t-else="">RECIBO DE CAJA</t>
                                </div>
                                <div style="text-align: center; padding: 5px; font-size: 14pt; font-weight: bold; color: #4a4a4a;">
                                    <span t-if="doc.payment_number" t-field="doc.payment_number"/>
                                    <span t-else="" t-field="doc.name"/>
                                </div>
                                <table style="width: 100%; font-size: 7pt;">
                                    <tr>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">DIA</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%d') if doc.date else '--'"/>
                                            </div>
                                        </td>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">MES</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%m') if doc.date else '--'"/>
                                            </div>
                                        </td>
                                        <td style="text-align: center; padding: 2px;">
                                            <div style="border: 1px solid #ddd; border-radius: 10px; padding: 2px 5px;">
                                                <div style="color: #999; font-size: 6pt;">ANO</div>
                                                <div style="font-weight: bold;" t-out="doc.date.strftime('%Y') if doc.date else '----'"/>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Beneficiario -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 5px;">
                        <tr>
                            <td style="width: 50%; padding: 3px 5px; border-bottom: 1px solid #eee;">
                                <b>Beneficiario:</b> <span t-field="doc.partner_id.name"/><br/>
                                <b>NIT/CC:</b> <span t-field="doc.partner_id.vat"/>
                            </td>
                            <td style="width: 50%; padding: 3px 5px; border-bottom: 1px solid #eee;">
                                <b>Asiento:</b> <span t-if="doc.move_id" t-field="doc.move_id.name"/><br/>
                                <b>Referencia:</b> <span t-if="doc.payment_reference" t-field="doc.payment_reference"/>
                            </td>
                        </tr>
                    </table>

                    <!-- ============================================
                         FORMA DE PAGO
                         ============================================ -->
                    <t t-set="has_multiple_methods" t-value="doc.payment_method_line_ids and len(doc.payment_method_line_ids) > 0"/>

                    <table style="width: 100%; border-collapse: collapse; margin-top: 5px; background: #f5f5f5; border: 1px solid #4a4a4a;">
                        <tr>
                            <td colspan="4" style="padding: 4px 8px; font-size: 7pt; font-weight: bold; color: #4a4a4a; border-bottom: 1px solid #4a4a4a;">
                                FORMA DE PAGO
                            </td>
                        </tr>
                        <t t-if="has_multiple_methods">
                            <!-- Pago Multiple -->
                            <t t-foreach="doc.payment_method_line_ids" t-as="method">
                                <tr style="border-bottom: 1px solid #ddd;">
                                    <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                        <b><span t-field="method.journal_id.name"/></b>
                                    </td>
                                    <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                        <t t-if="method.journal_id.type == 'bank'">Transferencia</t>
                                        <t t-elif="method.journal_id.type == 'cash'">Efectivo</t>
                                        <t t-else=""><span t-field="method.payment_method_id.name"/></t>
                                    </td>
                                    <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                        <t t-if="method.reference">Ref: <span t-field="method.reference"/></t>
                                    </td>
                                    <td style="width: 25%; padding: 3px 8px; font-size: 7pt; text-align: right; font-weight: bold;">
                                        <span t-out="'{:,.0f}'.format(method.amount)"/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                        <t t-else="">
                            <!-- Pago Simple -->
                            <tr>
                                <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                    <b><span t-field="doc.journal_id.name"/></b>
                                </td>
                                <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                    <t t-if="doc.journal_id.type == 'bank'">Transferencia Bancaria</t>
                                    <t t-elif="doc.journal_id.type == 'cash'">Efectivo</t>
                                    <t t-else=""><span t-field="doc.payment_method_line_id.name"/></t>
                                </td>
                                <td style="width: 25%; padding: 3px 8px; font-size: 7pt;">
                                    <t t-if="doc.payment_reference">Ref: <span t-field="doc.payment_reference"/></t>
                                </td>
                                <td style="width: 25%; padding: 3px 8px; font-size: 7pt; text-align: right; font-weight: bold;">
                                    <span t-out="'{:,.0f}'.format(doc.amount)"/>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <!-- ============================================
                         DETALLE CONTABLE (Asiento)
                         ============================================ -->
                    <t t-if="doc.move_id and doc.move_id.line_ids">
                        <t t-set="total_debit" t-value="0"/>
                        <t t-set="total_credit" t-value="0"/>

                        <!-- Titulo seccion -->
                        <div style="background: #4a4a4a; color: white; padding: 4px 8px; font-size: 7pt; font-weight: bold; margin-top: 8px;">
                            DETALLE CONTABLE
                        </div>

                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: #4a4a4a; color: white;">
                                    <th style="width: 10%; padding: 4px; text-align: left; font-size: 7pt;">CUENTA</th>
                                    <th style="width: 28%; padding: 4px; text-align: left; font-size: 7pt;">DESCRIPCION</th>
                                    <th style="width: 17%; padding: 4px; text-align: left; font-size: 7pt;">TERCERO</th>
                                    <th style="width: 15%; padding: 4px; text-align: left; font-size: 7pt;">C. ANALITICA</th>
                                    <th style="width: 15%; padding: 4px; text-align: right; font-size: 7pt;">DEBITO</th>
                                    <th style="width: 15%; padding: 4px; text-align: right; font-size: 7pt;">CREDITO</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.move_id.line_ids.sorted(key=lambda l: l.account_id.code)" t-as="line">
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td style="padding: 3px 4px; font-size: 7pt;">
                                            <span t-field="line.account_id.code"/>
                                        </td>
                                        <td style="padding: 3px 4px; font-size: 7pt;">
                                            <span t-field="line.account_id.name"/>
                                            <t t-if="line.name and line.name != '/'">
                                                <br/><span style="font-size: 6pt; color: #888;" t-field="line.name"/>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; font-size: 6pt;">
                                            <span t-if="line.partner_id" t-field="line.partner_id.name"/>
                                        </td>
                                        <td style="padding: 3px 4px; font-size: 6pt;">
                                            <span t-if="line.analytic_distribution" t-out="', '.join(line.analytic_distribution.keys()) if line.analytic_distribution else ''"/>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt;">
                                            <t t-if="line.debit">
                                                <span t-out="'{:,.0f}'.format(line.debit)"/>
                                            </t>
                                        </td>
                                        <td style="padding: 3px 4px; text-align: right; font-size: 7pt;">
                                            <t t-if="line.credit">
                                                <span t-out="'{:,.0f}'.format(line.credit)"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <t t-set="total_debit" t-value="total_debit + line.debit"/>
                                    <t t-set="total_credit" t-value="total_credit + line.credit"/>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background: #4a4a4a; color: white; font-weight: bold;">
                                    <td colspan="4" style="padding: 4px 8px; text-align: right; font-size: 7pt;">TOTALES</td>
                                    <td style="padding: 4px 8px; text-align: right; font-size: 7pt;">
                                        <span t-out="'{:,.0f}'.format(total_debit)"/>
                                    </td>
                                    <td style="padding: 4px 8px; text-align: right; font-size: 7pt;">
                                        <span t-out="'{:,.0f}'.format(total_credit)"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </t>

                    <!-- Total Neto -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 8px;">
                        <tr>
                            <td style="width: 60%; vertical-align: top;">
                                <!-- Monto en Letras -->
                                <div style="border: 1px solid #dee2e6; border-radius: 4px; padding: 6px 10px; background-color: #f8f9fa;">
                                    <strong style="font-size: 7pt;">SON:</strong>
                                    <span style="font-size: 7pt; font-style: italic;" t-out="doc.currency_id.amount_to_text(doc.amount)"/>
                                </div>
                            </td>
                            <td style="width: 40%; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="background: #4a4a4a; color: white;">
                                        <td style="padding: 5px 8px; font-size: 8pt;"><b>VALOR NETO</b></td>
                                        <td style="padding: 5px 8px; text-align: right; font-size: 9pt;">
                                            <b><span t-field="doc.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></b>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Firmas -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
                        <tr>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Elaboro</div>
                                <div style="font-size: 6pt; color: #888;" t-if="doc.create_uid" t-field="doc.create_uid.name"/>
                            </td>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Reviso</div>
                                <div style="font-size: 6pt; color: #888;">Contabilidad</div>
                            </td>
                            <td style="width: 33%; padding: 5px; text-align: center;">
                                <div style="border-top: 1px solid #333; margin-top: 30px; padding-top: 3px; font-size: 7pt;">Recibio</div>
                                <div style="font-size: 6pt; color: #888;" t-field="doc.partner_id.name"/>
                            </td>
                        </tr>
                    </table>

                    <!-- Pie de pagina -->
                    <div style="font-size: 6pt; color: #666; padding: 3px 5px; text-align: center; border-top: 1px solid #eee; margin-top: 10px;">
                        Impreso: <span t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/> |
                        Usuario: <span t-field="user.name"/>
                    </div>

                </div>
            </t>
        </t>
    </template>

    <!-- ACCION DE REPORTE - Contable -->
    <record id="action_report_payment_voucher_contable" model="ir.actions.report">
        <field name="name">Comprobante de Egreso (Contable)</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_payment_voucher_contable_documento</field>
        <field name="report_file">custom_account_treasury.report_payment_voucher_contable_documento</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_comprobante_egreso"/>
        <field name="print_report_name">'CE_Contable_%s' % (object.name or 'draft').replace('/', '_')</field>
    </record>

</odoo>
