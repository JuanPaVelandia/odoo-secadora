<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_payment_voucher_clean" model="ir.actions.report">
        <field name="name">Comprobante de Egreso</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_payment_voucher_clean</field>
        <field name="report_file">custom_account_treasury.report_payment_voucher_clean</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_us"/>
        <field name="print_report_name">'Comprobante_%s' % (object.name or 'draft').replace('/', '_')</field>
    </record>

    <template id="report_payment_voucher_clean">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <style>
                    /* Variables */
                    .ce-page { font-family: Arial, sans-serif; font-size: 9px; color: #333; }

                    /* Header */
                    .header { display: table; width: 100%; margin-bottom: 8px; border-bottom: 1px solid #333; padding-bottom: 6px; }
                    .ce-header-cell { display: table-cell; vertical-align: middle; }
                    .ce-header-logo { width: 15%; }
                    .ce-header-logo img { max-height: 40px; }
                    .ce-header-company { width: 55%; text-align: center; }
                    .ce-header-company-name { font-size: 11px; font-weight: bold; }
                    .ce-header-company-info { font-size: 7px; color: #555; line-height: 1.1; }
                    .ce-header-doc { width: 30%; text-align: right; }
                    .ce-header-doc-type { font-size: 9px; font-weight: bold; color: #c00; text-transform: uppercase; }
                    .ce-header-doc-num { font-size: 14px; font-weight: bold; }
                    .ce-header-doc-date { font-size: 8px; color: #555; }

                    /* Sections */
                    .ce-section { margin-bottom: 6px; }
                    .ce-section-title { background: #e0e0e0; padding: 2px 6px; font-weight: bold; font-size: 7px; text-transform: uppercase; margin-bottom: 3px; }

                    /* Info Grid */
                    .ce-info-grid { display: table; width: 100%; margin-bottom: 6px; }
                    .ce-info-col { display: table-cell; vertical-align: top; padding-right: 10px; }
                    .ce-label { font-size: 6px; color: #888; text-transform: uppercase; }
                    .ce-value { font-size: 9px; color: #222; margin-bottom: 3px; }
                    .ce-value-lg { font-size: 10px; font-weight: bold; }

                    /* Tables */
                    .ce-table { width: 100%; border-collapse: collapse; margin-bottom: 5px; }
                    .ce-table th { font-size: 6px; color: #666; text-transform: uppercase; padding: 2px 4px; text-align: left; background: #f0f0f0; border-bottom: 1px solid #ccc; }
                    .ce-table td { font-size: 8px; padding: 2px 4px; border-bottom: 1px solid #eee; }
                    .ce-table .text-right { text-align: right; }
                    .ce-table tfoot td { font-weight: bold; background: #f0f0f0; border-top: 1px solid #ccc; }
                    .ce-table .small-text { font-size: 6px; color: #888; }

                    /* Summary Grid */
                    .ce-summary { display: table; width: 100%; margin: 8px 0; }
                    .ce-summary-col { display: table-cell; width: 33.33%; vertical-align: top; padding: 0 5px; }
                    .ce-summary-box { border: 1px solid #ddd; padding: 5px; background: #fafafa; }
                    .ce-summary-title { font-size: 7px; color: #888; text-transform: uppercase; margin-bottom: 3px; }
                    .ce-summary-row { display: table; width: 100%; font-size: 8px; }
                    .ce-summary-label { display: table-cell; width: 60%; }
                    .ce-summary-value { display: table-cell; width: 40%; text-align: right; }

                    /* Total Box */
                    .ce-total-box { display: table; width: 100%; background: #f0f0f0; border: 1px solid #ccc; padding: 8px; margin: 8px 0; }
                    .ce-total-left { display: table-cell; vertical-align: middle; width: 35%; }
                    .ce-total-label { font-size: 7px; color: #888; text-transform: uppercase; }
                    .ce-total-amount { font-size: 16px; font-weight: bold; color: #c00; }
                    .ce-total-right { display: table-cell; vertical-align: middle; text-align: right; width: 65%; }
                    .ce-total-text { font-size: 8px; color: #555; font-style: italic; }

                    /* Signatures */
                    .ce-signatures { display: table; width: 100%; margin-top: 25px; }
                    .ce-sig { display: table-cell; width: 33.33%; text-align: center; padding: 0 10px; }
                    .ce-sig-line { border-top: 1px solid #333; margin-bottom: 2px; }
                    .ce-sig-label { font-size: 6px; color: #888; text-transform: uppercase; }
                    .ce-sig-name { font-size: 7px; }

                    /* Footer */
                    .footer { font-size: 7px; color: #666; border-top: 1px solid #ddd; padding-top: 5px; margin-top: 10px; }
                    .footer-table { display: table; width: 100%; }
                    .footer-left { display: table-cell; text-align: left; width: 50%; }
                    .footer-right { display: table-cell; text-align: right; width: 50%; }
                </style>

                <!-- HEADER -->
                <div class="header">
                    <div class="ce-header-cell ce-header-logo">
                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" alt="Logo"/>
                    </div>
                    <div class="ce-header-cell ce-header-company">
                        <div class="ce-header-company-name" t-field="doc.company_id.name"/>
                        <div class="ce-header-company-info">
                            NIT: <span t-field="doc.company_id.vat"/> |
                            <span t-field="doc.company_id.street"/> - <span t-field="doc.company_id.city"/>
                        </div>
                    </div>
                    <div class="ce-header-cell ce-header-doc">
                        <div class="ce-header-doc-type">
                            <t t-if="doc.payment_type == 'outbound'">Egreso</t>
                            <t t-else="">Ingreso</t>
                        </div>
                        <div class="ce-header-doc-num">
                            <t t-if="doc.payment_number"><span t-field="doc.payment_number"/></t>
                            <t t-else=""><span t-field="doc.name"/></t>
                        </div>
                        <div class="ce-header-doc-date">
                            <span t-field="doc.date" t-options="{'format': 'd/MM/yyyy'}"/>
                        </div>
                    </div>
                </div>

                <!-- ARTICLE (contenido principal) -->
                <div class="article ce-page" t-att-data-oe-model="doc and doc._name" t-att-data-oe-id="doc and doc.id">
                    <div class="page" style="padding: 5px 10px;">

                        <!-- INFORMACION PRINCIPAL -->
                        <div class="ce-info-grid">
                            <div class="ce-info-col" style="width: 40%;">
                                <div class="ce-section-title">Beneficiario</div>
                                <div class="ce-label">Nombre</div>
                                <div class="ce-value ce-value-lg" t-field="doc.partner_id.name"/>
                                <div class="ce-label">Identificacion</div>
                                <div class="ce-value">
                                    <span t-if="doc.partner_id.l10n_latam_identification_type_id" t-field="doc.partner_id.l10n_latam_identification_type_id.name"/>
                                    <span t-field="doc.partner_id.vat"/>
                                </div>
                            </div>
                            <div class="ce-info-col" style="width: 30%;">
                                <div class="ce-section-title">Forma de Pago</div>
                                <div class="ce-label">Metodo</div>
                                <div class="ce-value">
                                    <t t-if="doc.journal_id.type == 'bank'">Transferencia</t>
                                    <t t-elif="doc.journal_id.type == 'cash'">Efectivo</t>
                                    <t t-else=""><span t-field="doc.journal_id.name"/></t>
                                </div>
                                <div class="ce-label">Banco/Caja</div>
                                <div class="ce-value" t-field="doc.journal_id.name"/>
                            </div>
                            <div class="ce-info-col" style="width: 30%;">
                                <div class="ce-section-title">Referencia</div>
                                <div class="ce-label">Asiento</div>
                                <div class="ce-value" t-field="doc.move_id.name"/>
                                <t t-if="doc.payment_reference">
                                    <div class="ce-label">Ref. Bancaria</div>
                                    <div class="ce-value" t-field="doc.payment_reference"/>
                                </t>
                            </div>
                        </div>

                        <!-- CONCEPTO -->
                        <t t-if="doc.memo">
                            <div class="ce-section">
                                <div class="ce-section-title">Concepto</div>
                                <div class="ce-value" t-field="doc.memo"/>
                            </div>
                        </t>

                        <!-- DETALLE CONTABLE -->
                        <t t-if="doc.move_id and doc.move_id.line_ids">
                            <t t-set="subtotal" t-value="0"/>
                            <t t-set="total_taxes" t-value="0"/>
                            <t t-set="total_retentions" t-value="0"/>
                            <t t-set="total_debit" t-value="0"/>
                            <t t-set="total_credit" t-value="0"/>

                            <div class="ce-section">
                                <div class="ce-section-title">Detalle Contable</div>
                                <table class="ce-table">
                                    <thead>
                                        <tr>
                                            <th style="width: 10%;">Cuenta</th>
                                            <th style="width: 35%;">Descripcion</th>
                                            <th style="width: 20%;">Tercero</th>
                                            <th class="text-right" style="width: 15%;">Debito</th>
                                            <th class="text-right" style="width: 15%;">Credito</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.move_id.line_ids.sorted(key=lambda l: l.account_id.code)" t-as="line">
                                            <tr>
                                                <td><span t-field="line.account_id.code"/></td>
                                                <td>
                                                    <span t-field="line.account_id.name"/>
                                                    <t t-if="line.name and line.name != '/'">
                                                        <br/><span class="small-text" t-field="line.name"/>
                                                    </t>
                                                </td>
                                                <td><span t-if="line.partner_id" t-field="line.partner_id.name"/></td>
                                                <td class="text-right">
                                                    <span t-if="line.debit" t-field="line.debit" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-if="line.credit" t-field="line.credit" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                            <t t-set="total_debit" t-value="total_debit + line.debit"/>
                                            <t t-set="total_credit" t-value="total_credit + line.credit"/>
                                            <!-- Calcular impuestos y retenciones -->
                                            <t t-if="line.account_id.code and line.account_id.code[:2] in ['13', '23', '24']">
                                                <t t-if="line.credit > 0">
                                                    <t t-set="total_retentions" t-value="total_retentions + line.credit"/>
                                                </t>
                                                <t t-if="line.debit > 0">
                                                    <t t-set="total_taxes" t-value="total_taxes + line.debit"/>
                                                </t>
                                            </t>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="3" class="text-right">Total</td>
                                            <td class="text-right">
                                                <span t-out="total_debit" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                            </td>
                                            <td class="text-right">
                                                <span t-out="total_credit" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>

                            <!-- RESUMEN: SUBTOTAL, IMPUESTOS, RETENCIONES -->
                            <div class="ce-summary">
                                <div class="ce-summary-col">
                                    <div class="ce-summary-box">
                                        <div class="ce-summary-title">Subtotal</div>
                                        <div class="ce-summary-row">
                                            <div class="ce-summary-label">Base Gravable:</div>
                                            <div class="ce-summary-value">
                                                <t t-set="base_amount" t-value="doc.amount + total_retentions - total_taxes"/>
                                                <span t-out="base_amount" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="ce-summary-col">
                                    <div class="ce-summary-box">
                                        <div class="ce-summary-title">Impuestos (+)</div>
                                        <div class="ce-summary-row">
                                            <div class="ce-summary-label">IVA / Otros:</div>
                                            <div class="ce-summary-value">
                                                <span t-out="total_taxes" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="ce-summary-col">
                                    <div class="ce-summary-box">
                                        <div class="ce-summary-title">Retenciones (-)</div>
                                        <div class="ce-summary-row">
                                            <div class="ce-summary-label">Rete/ICA/IVA:</div>
                                            <div class="ce-summary-value">
                                                <span t-out="total_retentions" t-options='{"widget": "monetary", "display_currency": doc.company_id.currency_id}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- DOCUMENTOS APLICADOS -->
                        <t t-set="invoices" t-value="doc.reconciled_invoice_ids or doc.reconciled_bill_ids"/>
                        <t t-if="invoices">
                            <div class="ce-section">
                                <div class="ce-section-title">Documentos Aplicados</div>
                                <table class="ce-table">
                                    <thead>
                                        <tr>
                                            <th>Documento</th>
                                            <th>Fecha</th>
                                            <th class="text-right">Valor</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="invoices" t-as="inv">
                                            <tr>
                                                <td><span t-field="inv.name"/></td>
                                                <td><span t-field="inv.invoice_date" t-options="{'format': 'd/MM/yyyy'}"/></td>
                                                <td class="text-right">
                                                    <span t-field="inv.amount_total" t-options='{"widget": "monetary", "display_currency": inv.currency_id}'/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- TOTAL -->
                        <div class="ce-total-box">
                            <div class="ce-total-left">
                                <div class="ce-total-label">Valor Neto a Pagar</div>
                                <div class="ce-total-amount">
                                    <span t-field="doc.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </div>
                            </div>
                            <div class="ce-total-right">
                                <div class="ce-total-text">
                                    <t t-set="amount_text" t-value="doc.currency_id.amount_to_text(doc.amount)"/>
                                    <span t-out="amount_text"/>
                                </div>
                            </div>
                        </div>

                        <!-- FIRMAS -->
                        <div class="ce-signatures">
                            <div class="ce-sig">
                                <div class="ce-sig-line"></div>
                                <div class="ce-sig-label">Elaboro</div>
                                <div class="ce-sig-name" t-field="doc.create_uid.name"/>
                            </div>
                            <div class="ce-sig">
                                <div class="ce-sig-line"></div>
                                <div class="ce-sig-label">Reviso</div>
                                <div class="ce-sig-name">Contabilidad</div>
                            </div>
                            <div class="ce-sig">
                                <div class="ce-sig-line"></div>
                                <div class="ce-sig-label">Recibi</div>
                                <div class="ce-sig-name" t-field="doc.partner_id.name"/>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- FOOTER -->
                <div class="footer">
                    <div class="footer-table">
                        <div class="footer-left">
                            <span t-field="doc.company_id.name"/> | NIT: <span t-field="doc.company_id.vat"/>
                        </div>
                        <div class="footer-right">
                            Impreso: <span t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/> |
                            Usuario: <span t-field="user.name"/> |
                            Pagina <span class="page"/> de <span class="topage"/>
                        </div>
                    </div>
                </div>

            </t>
        </t>
    </template>
</odoo>
