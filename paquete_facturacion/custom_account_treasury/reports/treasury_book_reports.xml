<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIBRO DE PAGOS ==================== -->

    <!-- Acción del Reporte Libro de Pagos -->
    <record id="action_report_payment_book" model="ir.actions.report">
        <field name="name">Libro de Pagos</field>
        <field name="model">treasury.payment.book.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_payment_book_template</field>
        <field name="report_file">custom_account_treasury.report_payment_book_template</field>
        <field name="print_report_name">'Libro_Pagos_%s_%s' % (object.date_from, object.date_to)</field>
        <field name="binding_type">report</field>
    </record>

    <!-- Template del Reporte Libro de Pagos -->
    <template id="report_payment_book_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Encabezado -->
                        <div class="text-center mb-4">
                            <h2><strong>LIBRO DE PAGOS</strong></h2>
                            <h4>
                                <span t-field="wizard.env.company.name"/>
                            </h4>
                            <p>
                                <strong>Período:</strong>
                                <span t-field="wizard.date_from"/> al <span t-field="wizard.date_to"/>
                            </p>
                            <p t-if="wizard.journal_ids">
                                <strong>Diarios:</strong>
                                <t t-foreach="wizard.journal_ids" t-as="journal">
                                    <span t-field="journal.name"/><t t-if="not journal_last">, </t>
                                </t>
                            </p>
                            <p t-else="">
                                <strong>Diarios:</strong> Todos (Bancos y Cajas)
                            </p>
                        </div>

                        <!-- Tabla de Pagos -->
                        <t t-set="report_data" t-value="wizard._get_report_data()"/>

                        <t t-foreach="report_data['journals_data'].values()" t-as="journal_data">
                            <div class="mb-4">
                                <h5 class="bg-light p-2">
                                    <i class="fa fa-bank"/> <span t-out="journal_data['journal'].name"/>
                                </h5>
                                <table class="table table-sm table-bordered">
                                    <thead class="table-secondary">
                                        <tr>
                                            <th style="width: 10%;">Fecha</th>
                                            <th style="width: 15%;">Número</th>
                                            <th style="width: 25%;">Tercero</th>
                                            <th style="width: 20%;">Concepto</th>
                                            <th style="width: 10%;">Tipo</th>
                                            <th style="width: 10%;" class="text-end">Ingreso</th>
                                            <th style="width: 10%;" class="text-end">Egreso</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="journal_data['payments']" t-as="payment">
                                            <tr>
                                                <td><span t-field="payment.date"/></td>
                                                <td><span t-field="payment.name"/></td>
                                                <td><span t-field="payment.partner_id.name"/></td>
                                                <td><span t-field="payment.ref"/></td>
                                                <td>
                                                    <span t-if="payment.payment_type == 'inbound'" class="badge bg-success">Ingreso</span>
                                                    <span t-else="" class="badge bg-danger">Egreso</span>
                                                </td>
                                                <td class="text-end">
                                                    <t t-if="payment.payment_type == 'inbound'">
                                                        <span t-field="payment.amount" t-options="{'widget': 'monetary', 'display_currency': payment.currency_id}"/>
                                                    </t>
                                                </td>
                                                <td class="text-end">
                                                    <t t-if="payment.payment_type == 'outbound'">
                                                        <span t-field="payment.amount" t-options="{'widget': 'monetary', 'display_currency': payment.currency_id}"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <td colspan="5" class="text-end"><strong>Subtotal <span t-out="journal_data['journal'].name"/>:</strong></td>
                                            <td class="text-end text-success">
                                                <strong t-out="'{:,.0f}'.format(journal_data['total_inbound'])"/>
                                            </td>
                                            <td class="text-end text-danger">
                                                <strong t-out="'{:,.0f}'.format(journal_data['total_outbound'])"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </t>

                        <!-- Resumen General -->
                        <div class="mt-4 p-3 bg-light border">
                            <h5>RESUMEN GENERAL</h5>
                            <table class="table table-sm mb-0">
                                <tr>
                                    <td><strong>Total Ingresos (Cobros):</strong></td>
                                    <td class="text-end text-success">
                                        <strong>$ <t t-out="'{:,.0f}'.format(report_data['total_inbound'])"/></strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Total Egresos (Pagos):</strong></td>
                                    <td class="text-end text-danger">
                                        <strong>$ <t t-out="'{:,.0f}'.format(report_data['total_outbound'])"/></strong>
                                    </td>
                                </tr>
                                <tr class="border-top">
                                    <td><strong>Flujo Neto:</strong></td>
                                    <td class="text-end">
                                        <strong>$ <t t-out="'{:,.0f}'.format(report_data['total_inbound'] - report_data['total_outbound'])"/></strong>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Pie de página -->
                        <div class="mt-4 text-muted text-center" style="font-size: 10px;">
                            <p>Generado el <span t-out="report_data['print_date'].strftime('%d/%m/%Y %H:%M')"/> por <span t-out="wizard.env.user.name"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ==================== ARQUEO DE CAJA ==================== -->

    <!-- Acción del Reporte Arqueo de Caja -->
    <record id="action_report_cash_box" model="ir.actions.report">
        <field name="name">Arqueo de Caja</field>
        <field name="model">treasury.cash.box.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_cash_box_template</field>
        <field name="report_file">custom_account_treasury.report_cash_box_template</field>
        <field name="print_report_name">'Arqueo_Caja_%s_%s_%s' % (object.journal_id.name, object.date_from, object.date_to)</field>
        <field name="binding_type">report</field>
    </record>

    <!-- Template del Reporte Arqueo de Caja -->
    <template id="report_cash_box_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Encabezado -->
                        <div class="text-center mb-4">
                            <h2><strong>ARQUEO DE CAJA</strong></h2>
                            <h4>
                                <span t-field="wizard.env.company.name"/>
                            </h4>
                            <h5 class="text-primary">
                                <i class="fa fa-money"/> <span t-field="wizard.journal_id.name"/>
                            </h5>
                            <p>
                                <strong>Período:</strong>
                                <span t-field="wizard.date_from"/> al <span t-field="wizard.date_to"/>
                            </p>
                        </div>

                        <t t-set="report_data" t-value="wizard._get_report_data()"/>

                        <!-- Resumen de Saldos -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <table class="table table-bordered">
                                    <tbody>
                                        <tr class="table-light">
                                            <td style="width: 70%;"><strong>Saldo Inicial (al <span t-field="wizard.date_from"/>)</strong></td>
                                            <td style="width: 30%;" class="text-end">
                                                <strong>$ <t t-out="'{:,.0f}'.format(report_data['opening_balance'])"/></strong>
                                            </td>
                                        </tr>
                                        <tr class="text-success">
                                            <td>(+) Total Ingresos</td>
                                            <td class="text-end">$ <t t-out="'{:,.0f}'.format(report_data['total_inbound'])"/></td>
                                        </tr>
                                        <tr class="text-danger">
                                            <td>(-) Total Egresos</td>
                                            <td class="text-end">$ <t t-out="'{:,.0f}'.format(report_data['total_outbound'])"/></td>
                                        </tr>
                                        <tr class="table-primary">
                                            <td><strong>Saldo Final (al <span t-field="wizard.date_to"/>)</strong></td>
                                            <td class="text-end">
                                                <strong>$ <t t-out="'{:,.0f}'.format(report_data['closing_balance'])"/></strong>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Detalle de Movimientos -->
                        <t t-if="wizard.include_details and report_data['movements']">
                            <h5>DETALLE DE MOVIMIENTOS</h5>
                            <table class="table table-sm table-bordered">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width: 10%;">Fecha</th>
                                        <th style="width: 15%;">Documento</th>
                                        <th style="width: 25%;">Tercero</th>
                                        <th style="width: 20%;">Descripción</th>
                                        <th style="width: 10%;" class="text-end">Ingreso</th>
                                        <th style="width: 10%;" class="text-end">Egreso</th>
                                        <th style="width: 10%;" class="text-end">Saldo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-light">
                                        <td colspan="6"><em>Saldo Inicial</em></td>
                                        <td class="text-end"><strong><t t-out="'{:,.0f}'.format(report_data['opening_balance'])"/></strong></td>
                                    </tr>
                                    <t t-set="running_balance" t-value="report_data['opening_balance']"/>
                                    <t t-foreach="report_data['movements']" t-as="mov">
                                        <t t-set="running_balance" t-value="running_balance + mov['balance']"/>
                                        <tr>
                                            <td><t t-out="mov['date']"/></td>
                                            <td><t t-out="mov['move_name']"/></td>
                                            <td><t t-out="mov['partner_name'] or ''"/></td>
                                            <td><t t-out="mov['description'] or ''"/></td>
                                            <td class="text-end text-success">
                                                <t t-if="mov['inbound'] > 0">
                                                    <t t-out="'{:,.0f}'.format(mov['inbound'])"/>
                                                </t>
                                            </td>
                                            <td class="text-end text-danger">
                                                <t t-if="mov['outbound'] > 0">
                                                    <t t-out="'{:,.0f}'.format(mov['outbound'])"/>
                                                </t>
                                            </td>
                                            <td class="text-end"><t t-out="'{:,.0f}'.format(running_balance)"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot class="table-primary">
                                    <tr>
                                        <td colspan="4" class="text-end"><strong>TOTALES:</strong></td>
                                        <td class="text-end text-success"><strong><t t-out="'{:,.0f}'.format(report_data['total_inbound'])"/></strong></td>
                                        <td class="text-end text-danger"><strong><t t-out="'{:,.0f}'.format(report_data['total_outbound'])"/></strong></td>
                                        <td class="text-end"><strong><t t-out="'{:,.0f}'.format(report_data['closing_balance'])"/></strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- Firmas -->
                        <div class="mt-5 pt-4">
                            <div class="row">
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong>Elaborado por</strong>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong>Revisado por</strong>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong>Aprobado por</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pie de página -->
                        <div class="mt-4 text-muted text-center" style="font-size: 10px;">
                            <p>Generado el <span t-out="report_data['print_date'].strftime('%d/%m/%Y %H:%M')"/> por <span t-out="wizard.env.user.name"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
