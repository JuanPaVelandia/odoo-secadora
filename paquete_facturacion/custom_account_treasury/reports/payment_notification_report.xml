<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_payment_notification" model="ir.actions.report">
        <field name="name">Notificacion de Pago</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_payment_notification</field>
        <field name="report_file">custom_account_treasury.report_payment_notification</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_us"/>
        <field name="print_report_name">'Notificacion_%s' % (object.name or 'draft').replace('/', '_')</field>
    </record>

    <template id="report_payment_notification">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <style>
                    /* Variables */
                    .np-page { font-family: Arial, sans-serif; font-size: 10px; color: #333; }

                    /* Header */
                    .header { display: table; width: 100%; margin-bottom: 15px; border-bottom: 2px solid #333; padding-bottom: 12px; }
                    .np-header-cell { display: table-cell; vertical-align: middle; }
                    .np-header-logo { width: 20%; }
                    .np-header-logo img { max-height: 55px; }
                    .np-header-company { width: 55%; text-align: center; }
                    .np-header-company-name { font-size: 14px; font-weight: bold; margin-bottom: 2px; }
                    .np-header-company-info { font-size: 8px; color: #555; line-height: 1.3; }
                    .np-header-doc { width: 25%; text-align: right; }
                    .np-header-doc-type { font-size: 8px; color: #666; text-transform: uppercase; letter-spacing: 1px; }
                    .np-header-doc-num { font-size: 18px; font-weight: bold; color: #c00; }
                    .np-header-doc-date { font-size: 9px; color: #555; margin-top: 2px; }

                    /* Title */
                    .np-title { text-align: center; margin: 15px 0 20px; }
                    .np-title h2 { font-size: 14px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; margin: 0; }
                    .np-title-line { width: 50px; height: 2px; background: #c00; margin: 5px auto 0; }

                    /* Info */
                    .np-info { display: table; width: 100%; margin-bottom: 15px; }
                    .np-info-row { display: table-row; }
                    .np-info-cell { display: table-cell; width: 50%; padding: 5px 10px 5px 0; vertical-align: top; }
                    .np-label { font-size: 7px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1px; }
                    .np-value { font-size: 11px; color: #222; }
                    .np-value-lg { font-size: 12px; font-weight: bold; }

                    /* Amount Box */
                    .np-amount-box { background: #f8f8f8; border: 1px solid #ddd; padding: 15px; text-align: center; margin: 20px 0; }
                    .np-amount-label { font-size: 8px; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
                    .np-amount-value { font-size: 24px; font-weight: bold; color: #c00; }
                    .np-amount-text { font-size: 9px; color: #555; font-style: italic; margin-top: 8px; }

                    /* Documents Table */
                    .np-docs-title { font-size: 8px; color: #888; text-transform: uppercase; margin-bottom: 5px; }
                    .np-docs-table { width: 100%; border-collapse: collapse; }
                    .np-docs-table th { font-size: 7px; color: #888; text-transform: uppercase; padding: 5px; text-align: left; border-bottom: 1px solid #ddd; }
                    .np-docs-table td { font-size: 9px; padding: 5px; border-bottom: 1px solid #eee; }
                    .np-docs-table .text-right { text-align: right; }

                    /* Signatures */
                    .np-signatures { display: table; width: 100%; margin-top: 50px; }
                    .np-sig { display: table-cell; width: 50%; text-align: center; padding: 0 25px; }
                    .np-sig-line { border-top: 1px solid #333; margin-bottom: 5px; }
                    .np-sig-label { font-size: 8px; color: #555; }
                    .np-sig-name { font-size: 9px; color: #333; }

                    /* Footer */
                    .footer { font-size: 7px; color: #666; border-top: 1px solid #ddd; padding-top: 5px; margin-top: 15px; }
                    .footer-table { display: table; width: 100%; }
                    .footer-left { display: table-cell; text-align: left; width: 50%; }
                    .footer-right { display: table-cell; text-align: right; width: 50%; }
                </style>

                <!-- HEADER -->
                <div class="header">
                    <div class="np-header-cell np-header-logo">
                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" alt="Logo"/>
                    </div>
                    <div class="np-header-cell np-header-company">
                        <div class="np-header-company-name" t-field="doc.company_id.name"/>
                        <div class="np-header-company-info">
                            NIT: <span t-field="doc.company_id.vat"/><br/>
                            <span t-field="doc.company_id.street"/> - <span t-field="doc.company_id.city"/><br/>
                            Tel: <span t-field="doc.company_id.phone"/>
                        </div>
                    </div>
                    <div class="np-header-cell np-header-doc">
                        <div class="np-header-doc-type">
                            <t t-if="doc.payment_type == 'outbound'">Egreso No.</t>
                            <t t-else="">Ingreso No.</t>
                        </div>
                        <div class="np-header-doc-num">
                            <t t-if="doc.payment_number"><span t-field="doc.payment_number"/></t>
                            <t t-else=""><span t-field="doc.name"/></t>
                        </div>
                        <div class="np-header-doc-date">
                            <span t-field="doc.date" t-options="{'format': 'd/MM/yyyy'}"/>
                        </div>
                    </div>
                </div>

                <!-- ARTICLE (contenido principal) -->
                <div class="article np-page" t-att-data-oe-model="doc and doc._name" t-att-data-oe-id="doc and doc.id">
                    <div class="page" style="padding: 10px;">

                        <!-- TITULO -->
                        <div class="np-title">
                            <h2>
                                <t t-if="doc.payment_type == 'outbound'">Notificacion de Pago</t>
                                <t t-else="">Recibo de Caja</t>
                            </h2>
                            <div class="np-title-line"></div>
                        </div>

                        <!-- INFORMACION -->
                        <div class="np-info">
                            <div class="np-info-row">
                                <div class="np-info-cell">
                                    <div class="np-label">Beneficiario</div>
                                    <div class="np-value np-value-lg" t-field="doc.partner_id.name"/>
                                </div>
                                <div class="np-info-cell">
                                    <div class="np-label">Forma de Pago</div>
                                    <div class="np-value">
                                        <t t-if="doc.journal_id.type == 'bank'">Transferencia Bancaria</t>
                                        <t t-elif="doc.journal_id.type == 'cash'">Efectivo</t>
                                        <t t-else=""><span t-field="doc.journal_id.name"/></t>
                                    </div>
                                </div>
                            </div>
                            <div class="np-info-row">
                                <div class="np-info-cell">
                                    <div class="np-label">Identificacion</div>
                                    <div class="np-value">
                                        <span t-if="doc.partner_id.l10n_latam_identification_type_id" t-field="doc.partner_id.l10n_latam_identification_type_id.name"/>
                                        <span t-field="doc.partner_id.vat"/>
                                    </div>
                                </div>
                                <div class="np-info-cell" t-if="doc.payment_reference">
                                    <div class="np-label">Referencia</div>
                                    <div class="np-value" t-field="doc.payment_reference"/>
                                </div>
                            </div>
                        </div>

                        <!-- CONCEPTO -->
                        <t t-if="doc.memo">
                            <div style="margin-bottom: 15px;">
                                <div class="np-label">Concepto</div>
                                <div class="np-value" t-field="doc.memo"/>
                            </div>
                        </t>

                        <!-- MONTO -->
                        <div class="np-amount-box">
                            <div class="np-amount-label">Valor Total</div>
                            <div class="np-amount-value">
                                <span t-field="doc.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </div>
                            <div class="np-amount-text">
                                <t t-set="amount_text" t-value="doc.currency_id.amount_to_text(doc.amount)"/>
                                <span t-out="amount_text"/>
                            </div>
                        </div>

                        <!-- DOCUMENTOS APLICADOS -->
                        <t t-set="invoices" t-value="doc.reconciled_invoice_ids or doc.reconciled_bill_ids"/>
                        <t t-if="invoices">
                            <div class="np-docs-title">Documentos Aplicados</div>
                            <table class="np-docs-table">
                                <thead>
                                    <tr>
                                        <th>Documento</th>
                                        <th>Fecha</th>
                                        <th class="text-right">Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="invoices" t-as="inv">
                                        <tr>
                                            <td><span t-field="inv.name"/></td>
                                            <td><span t-field="inv.invoice_date" t-options="{'format': 'd/MM/yyyy'}"/></td>
                                            <td class="text-right">
                                                <span t-field="inv.amount_total" t-options='{"widget": "monetary", "display_currency": inv.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- FIRMAS -->
                        <div class="np-signatures">
                            <div class="np-sig">
                                <div class="np-sig-line"></div>
                                <div class="np-sig-label">Elaborado por</div>
                                <div class="np-sig-name" t-field="doc.create_uid.name"/>
                            </div>
                            <div class="np-sig">
                                <div class="np-sig-line"></div>
                                <div class="np-sig-label">Recibi conforme</div>
                                <div class="np-sig-name" t-field="doc.partner_id.name"/>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- FOOTER -->
                <div class="footer">
                    <div class="footer-table">
                        <div class="footer-left">
                            <span t-field="doc.company_id.name"/> | NIT: <span t-field="doc.company_id.vat"/>
                        </div>
                        <div class="footer-right">
                            Impreso: <span t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/> |
                            Usuario: <span t-field="user.name"/> |
                            Pagina <span class="page"/> de <span class="topage"/>
                        </div>
                    </div>
                </div>

            </t>
        </t>
    </template>
</odoo>
