<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         ASIENTO CONTABLE - Con cuentas analíticas, firma y moneda
         ============================================================ -->

    <template id="report_journal_entry_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang='es_CO')"/>
            <t t-set="has_foreign_currency" t-value="any(line.currency_id and line.currency_id != o.company_id.currency_id for line in o.line_ids)"/>
            <t t-set="has_analytic" t-value="any(line.analytic_distribution for line in o.line_ids)"/>

            <div class="page">
                <!-- Encabezado -->
                <div class="row mb-3">
                    <div class="col-8">
                        <h3>
                            <t t-if="o.move_type == 'entry'">
                                <strong>COMPROBANTE CONTABLE</strong>
                            </t>
                            <t t-elif="o.move_type in ('out_invoice', 'out_refund')">
                                <strong>FACTURA DE VENTA</strong>
                            </t>
                            <t t-elif="o.move_type in ('in_invoice', 'in_refund')">
                                <strong>FACTURA DE COMPRA</strong>
                            </t>
                            <t t-else="">
                                <strong>DOCUMENTO CONTABLE</strong>
                            </t>
                        </h3>
                        <div class="text-muted">
                            <span t-field="o.journal_id.name"/> -
                            <t t-set="related_payment" t-value="env['account.payment'].search([('move_id', '=', o.id)], limit=1)"/>
                            <span t-if="related_payment">Pago/Cobro</span>
                            <span t-else="">Asiento Manual</span>
                        </div>
                    </div>
                    <div class="col-4 text-end">
                        <div class="border rounded p-2 bg-light">
                            <div class="fw-bold fs-4" t-field="o.name"/>
                            <div class="mt-1">
                                <strong>Fecha:</strong> <span t-field="o.date" t-options="{'format': 'dd/MM/yyyy'}"/>
                            </div>
                            <div class="small text-muted" t-if="o.ref">
                                Ref: <span t-field="o.ref"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Información del Tercero (si aplica) -->
                <div class="row mb-3" t-if="o.partner_id">
                    <div class="col-12">
                        <div class="border rounded p-2 bg-light">
                            <div class="row">
                                <div class="col-6">
                                    <strong>Tercero:</strong> <span t-field="o.partner_id.name"/>
                                </div>
                                <div class="col-3" t-if="o.partner_id.vat">
                                    <strong>NIT/CC:</strong> <span t-field="o.partner_id.vat"/>
                                </div>
                                <div class="col-3" t-if="has_foreign_currency">
                                    <strong>Moneda:</strong>
                                    <t t-foreach="o.line_ids.mapped('currency_id')" t-as="curr">
                                        <t t-if="curr and curr != o.company_id.currency_id">
                                            <span t-out="curr.name"/>
                                        </t>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Detalle del Asiento Contable -->
                <table class="table table-sm table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px;">Cuenta</th>
                            <th>Descripción</th>
                            <th style="width: 120px;">Tercero</th>
                            <t t-if="has_analytic">
                                <th style="width: 120px;">Analítica</th>
                            </t>
                            <t t-if="has_foreign_currency">
                                <th class="text-end" style="width: 90px;">Moneda</th>
                                <th class="text-end" style="width: 100px;">Monto ME</th>
                            </t>
                            <th class="text-end" style="width: 110px;">Débito</th>
                            <th class="text-end" style="width: 110px;">Crédito</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.line_ids.sorted(key=lambda l: (l.debit == 0, l.account_id.code))" t-as="line">
                            <tr>
                                <td>
                                    <span t-field="line.account_id.code"/>
                                </td>
                                <td>
                                    <div><span t-field="line.account_id.name"/></div>
                                    <div class="small text-muted" t-if="line.name and line.name != '/'">
                                        <t t-out="line.name"/>
                                    </div>
                                </td>
                                <td class="small">
                                    <span t-if="line.partner_id" t-out="line.partner_id.name[:20] + '...' if len(line.partner_id.name or '') > 20 else line.partner_id.name"/>
                                </td>
                                <t t-if="has_analytic">
                                    <td class="small">
                                        <t t-if="line.analytic_distribution">
                                            <t t-foreach="line.analytic_distribution.items()" t-as="analytic">
                                                <t t-set="analytic_account" t-value="env['account.analytic.account'].browse(int(analytic[0]))"/>
                                                <div t-out="analytic_account.name[:15]"/>
                                            </t>
                                        </t>
                                    </td>
                                </t>
                                <t t-if="has_foreign_currency">
                                    <td class="text-end small">
                                        <span t-if="line.currency_id and line.currency_id != o.company_id.currency_id" t-out="line.currency_id.name"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-if="line.amount_currency and line.currency_id != o.company_id.currency_id"
                                              t-out="'{:,.2f}'.format(abs(line.amount_currency))"/>
                                    </td>
                                </t>
                                <td class="text-end">
                                    <span t-if="line.debit" t-field="line.debit" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <span t-if="line.credit" t-field="line.credit" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td t-att-colspan="3 + (1 if has_analytic else 0) + (2 if has_foreign_currency else 0)" class="text-end">
                                <strong>TOTALES:</strong>
                            </td>
                            <td class="text-end">
                                <span t-out="'{:,.2f}'.format(sum(o.line_ids.mapped('debit')))"/>
                            </td>
                            <td class="text-end">
                                <span t-out="'{:,.2f}'.format(sum(o.line_ids.mapped('credit')))"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Resumen de Moneda Extranjera -->
                <t t-if="has_foreign_currency">
                    <div class="row mb-3">
                        <div class="col-6 offset-6">
                            <div class="border rounded p-2 bg-warning-subtle">
                                <h6 class="mb-2"><strong>Resumen Moneda Extranjera</strong></h6>
                                <t t-set="foreign_lines" t-value="o.line_ids.filtered(lambda l: l.currency_id and l.currency_id != o.company_id.currency_id)"/>
                                <t t-foreach="foreign_lines.mapped('currency_id')" t-as="fcurr">
                                    <t t-set="curr_lines" t-value="foreign_lines.filtered(lambda l: l.currency_id == fcurr)"/>
                                    <div class="d-flex justify-content-between">
                                        <span><t t-out="fcurr.name"/>:</span>
                                        <span class="fw-bold">
                                            <t t-out="'{:,.2f}'.format(sum(curr_lines.mapped('amount_currency')))"/>
                                        </span>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Notas / Narración -->
                <div class="mb-4" t-if="o.narration">
                    <div class="border rounded p-2">
                        <strong>Observaciones:</strong>
                        <div t-field="o.narration"/>
                    </div>
                </div>

                <!-- Estado del Documento -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center p-2 border rounded">
                            <div>
                                <strong>Estado:</strong>
                                <span t-if="o.state == 'posted'" class="badge bg-success">Publicado</span>
                                <span t-elif="o.state == 'draft'" class="badge bg-warning">Borrador</span>
                                <span t-else="" class="badge bg-secondary" t-out="o.state"/>
                            </div>
                            <div t-if="related_payment">
                                <strong>Pago Relacionado:</strong>
                                <span t-out="related_payment.name"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Firmas -->
                <div class="row mt-5 pt-4">
                    <div class="col-4 text-center">
                        <div class="border-top border-dark pt-2 mx-2">
                            <strong>Elaborado por</strong>
                            <div class="small text-muted" t-if="o.create_uid">
                                <t t-out="o.create_uid.name"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="border-top border-dark pt-2 mx-2">
                            <strong>Revisado por</strong>
                            <div class="small text-muted">
                                Contador
                            </div>
                        </div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="border-top border-dark pt-2 mx-2">
                            <strong>Aprobado por</strong>
                            <div class="small text-muted">
                                Gerencia
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pie de página -->
                <div class="row mt-4 small text-muted border-top pt-2">
                    <div class="col-4">
                        <span>Impreso: <t t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/></span>
                    </div>
                    <div class="col-4 text-center">
                        <span>Usuario: <t t-out="env.user.name"/></span>
                    </div>
                    <div class="col-4 text-end">
                        <span>Página <span class="page"/> de <span class="topage"/></span>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_journal_entry">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="custom_account_treasury.report_journal_entry_document"/>
            </t>
        </t>
    </template>

    <!-- Acción del reporte para account.move -->
    <record id="action_report_journal_entry" model="ir.actions.report">
        <field name="name">Comprobante Contable</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_journal_entry</field>
        <field name="report_file">custom_account_treasury.report_journal_entry</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
