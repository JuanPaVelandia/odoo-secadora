<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         RECIBO DE COBRO - Para cobros de clientes
         ============================================================ -->

    <template id="report_collection_receipt_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang or 'es_CO')"/>
            <div class="page">
                <!-- Encabezado -->
                <div class="row mb-4">
                    <div class="col-8">
                        <h2 class="text-success">
                            <strong>RECIBO DE CAJA</strong>
                        </h2>
                        <h4 class="text-muted" t-if="o.payment_type == 'inbound'">Cobro de Cliente</h4>
                    </div>
                    <div class="col-4 text-end">
                        <div class="border rounded p-2 bg-light">
                            <div class="fw-bold text-success fs-4" t-field="o.name"/>
                            <div class="small text-muted">
                                <span t-if="o.cash_receipt_number">RC: <t t-out="o.cash_receipt_number"/></span>
                            </div>
                            <div class="mt-2">
                                <strong>Fecha:</strong> <span t-field="o.date" t-options="{'format': 'dd/MM/yyyy'}"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Información del Cliente y Pago -->
                <div class="row mb-4">
                    <div class="col-6">
                        <div class="border rounded p-3">
                            <h6 class="border-bottom pb-2 text-success"><strong>RECIBIDO DE</strong></h6>
                            <div class="mb-1">
                                <strong>Cliente:</strong> <span t-field="o.partner_id.name"/>
                            </div>
                            <div class="mb-1" t-if="o.partner_id.vat">
                                <strong>NIT/CC:</strong> <span t-field="o.partner_id.vat"/>
                            </div>
                            <div class="mb-1" t-if="o.partner_id.street">
                                <strong>Dirección:</strong> <span t-field="o.partner_id.street"/>
                            </div>
                            <div t-if="o.partner_id.email">
                                <strong>Email:</strong> <span t-field="o.partner_id.email"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded p-3">
                            <h6 class="border-bottom pb-2 text-success"><strong>FORMA DE PAGO</strong></h6>
                            <div class="mb-1">
                                <strong>Diario:</strong> <span t-field="o.journal_id.name"/>
                            </div>
                            <div class="mb-1" t-if="o.payment_method_line_id">
                                <strong>Método:</strong> <span t-field="o.payment_method_line_id.name"/>
                            </div>
                            <div class="mb-1" t-if="o.bank_reference">
                                <strong>Ref. Bancaria:</strong> <span t-field="o.bank_reference"/>
                            </div>
                            <div t-if="o.currency_id.id != o.company_currency_id.id">
                                <strong>Moneda:</strong> <span t-field="o.currency_id.name"/>
                                <br/>
                                <strong>Tasa:</strong> <span t-field="o.current_exchange_rate"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Monto Grande -->
                <div class="text-center mb-4 p-3 border rounded bg-success text-white">
                    <div class="fs-6">VALOR RECIBIDO</div>
                    <div class="fs-1 fw-bold">
                        <span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                    </div>
                </div>

                <!-- Concepto -->
                <div class="mb-3" t-if="o.memo">
                    <div class="border rounded p-2 bg-light">
                        <strong>Concepto:</strong> <span t-field="o.memo"/>
                    </div>
                </div>

                <!-- Detalle de Facturas Cobradas -->
                <t t-set="payment_lines" t-value="o.payment_line_ids.filtered(lambda l: not l.is_main and l.to_pay and not l.display_type)"/>
                <t t-if="payment_lines">
                    <h6 class="text-success border-bottom pb-2"><strong>APLICADO A</strong></h6>
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Factura</th>
                                <th>Descripción</th>
                                <th>Vencimiento</th>
                                <th class="text-end">Saldo Anterior</th>
                                <th class="text-end">Valor Aplicado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="payment_lines" t-as="line">
                                <tr>
                                    <td>
                                        <span t-if="line.move_line_id" t-out="line.move_line_id.move_id.name"/>
                                        <span t-else="" t-out="line.account_id.code"/>
                                    </td>
                                    <td><span t-field="line.name"/></td>
                                    <td><span t-field="line.date_maturity" t-options="{'format': 'dd/MM/yyyy'}"/></td>
                                    <td class="text-end">
                                        <span t-field="line.amount_residual" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.payment_amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="4" class="text-end">TOTAL:</td>
                                <td class="text-end">
                                    <span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </t>

                <!-- Monto en Letras -->
                <div class="border rounded p-2 mb-4 bg-light">
                    <strong>SON:</strong>
                    <span t-out="o.currency_id.amount_to_text(o.amount)"/>
                </div>

                <!-- Nota de agradecimiento -->
                <div class="text-center mb-4 p-2 border rounded bg-light">
                    <em>Gracias por su pago. Este recibo es válido como comprobante de pago.</em>
                </div>

                <!-- Firmas -->
                <div class="row mt-5 pt-4">
                    <div class="col-6 text-center">
                        <div class="border-top border-dark pt-2 mx-5">
                            <strong>Cajero / Recibido por</strong>
                            <div class="small text-muted" t-if="o.create_uid">
                                <t t-out="o.create_uid.name"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 text-center">
                        <div class="border-top border-dark pt-2 mx-5">
                            <strong>Cliente</strong>
                            <div class="small text-muted">
                                Firma de conformidad
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pie de página -->
                <div class="row mt-4 small text-muted">
                    <div class="col-6">
                        <span>Impreso: <t t-out="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/></span>
                    </div>
                    <div class="col-6 text-end">
                        <span t-if="o.move_id">Asiento: <t t-out="o.move_id.name"/></span>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_collection_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="custom_account_treasury.report_collection_receipt_document"/>
            </t>
        </t>
    </template>

    <!-- Acción del reporte -->
    <record id="action_report_collection_receipt" model="ir.actions.report">
        <field name="name">Recibo de Caja</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_account_treasury.report_collection_receipt</field>
        <field name="report_file">custom_account_treasury.report_collection_receipt</field>
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
