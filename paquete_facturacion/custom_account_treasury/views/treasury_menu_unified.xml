<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================ -->
        <!-- DEFINICIÓN DE ACCIONES (PRIMERO) -->
        <!-- ============================================ -->

        <!-- Acciones Rápidas -->
        <record id="action_quick_payment_customer" model="ir.actions.act_window">
            <field name="name">Registrar Cobro</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">form</field>
            <field name="context">{
                'default_payment_type': 'inbound',
                'default_partner_type': 'customer'
            }</field>
            <field name="target">new</field>
        </record>

        <record id="action_quick_payment_supplier" model="ir.actions.act_window">
            <field name="name">Registrar Pago</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">form</field>
            <field name="context">{
                'default_payment_type': 'outbound',
                'default_partner_type': 'supplier'
            }</field>
            <field name="target">new</field>
        </record>

        <record id="action_quick_advance_request" model="ir.actions.act_window">
            <field name="name">Nuevo Anticipo</field>
            <field name="res_model">advance.request</field>
            <field name="view_mode">form</field>
            <field name="context">{
                'default_stage_id': 1
            }</field>
            <field name="target">new</field>
        </record>

        <!-- Acciones para Anticipos -->
        <record id="action_advance_request_approved" model="ir.actions.act_window">
            <field name="name">Anticipos Aprobados</field>
            <field name="res_model">advance.request</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('state', '=', 'approved')]</field>
            <field name="context">{'search_default_not_paid': 1}</field>
        </record>

        <record id="action_advance_to_apply" model="ir.actions.act_window">
            <field name="name">Anticipos por Aplicar</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_advance', '=', True), ('advance_balance', '>', 0)]</field>
            <field name="context">{'search_default_group_by_partner': 1}</field>
        </record>

        <!-- Acción para Transferencias -->
        <record id="action_new_internal_transfer" model="ir.actions.act_window">
            <field name="name">Nueva Transferencia Interna</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">form</field>
            <field name="context">{
                'default_payment_type': 'outbound',
                'default_partner_type': 'supplier',
                'is_internal_transfer': True
            }</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================ -->
        <!-- MENÚ PRINCIPAL DE TESORERÍA -->
        <!-- Definido en treasury_menu_root.xml -->
        <!-- ============================================ -->

        <!-- ============================================ -->
        <!-- 2. PAGOS -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_payments"
            name="Pagos"
            parent="menu_treasury_root"
            sequence="20"/>

        <!-- 2.1 Pagos a Proveedores (Vista Mejorada) -->
        <menuitem id="menu_action_treasury_payments_payable"
            action="custom_account_treasury.action_payment_supplier_enhanced"
            name="Pagos a Proveedores"
            parent="menu_treasury_payments"
            sequence="10"/>

        <!-- 2.2 Solicitudes de Pago -->
        <menuitem id="menu_payment_requests"
            action="custom_account_treasury.action_payment_request"
            name="Solicitudes de Pago"
            parent="menu_treasury_payments"
            sequence="20"/>

        <!-- 2.3 Órdenes de Compra -->
        <menuitem id="menu_purchase_orders_treasury"
            action="action_purchase_orders_treasury"
            name="Órdenes de Compra"
            parent="menu_treasury_payments"
            sequence="30"/>

        <!-- 2.4 Anticipo de Compras -->
        <menuitem id="menu_purchase_advance_wizard"
            action="action_purchase_advance_wizard"
            name="Anticipo de Compras"
            parent="menu_treasury_payments"
            sequence="40"/>

        <!-- 2.5 Pago Rápido -->
        <menuitem id="menu_quick_payment_supplier"
            name="Nuevo Pago"
            parent="menu_treasury_payments"
            action="action_quick_payment_supplier"
            sequence="100"/>

        <!-- ============================================ -->
        <!-- 3. COBROS -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_receivables"
            name="Cobros"
            parent="menu_treasury_root"
            sequence="30"/>

        <!-- 3.1 Cobros de Clientes (Vista Mejorada) -->
        <menuitem id="menu_action_treasury_payments_receivable"
            action="custom_account_treasury.action_payment_customer_enhanced"
            name="Cobros de Clientes"
            parent="menu_treasury_receivables"
            sequence="10"/>

        <!-- 3.2 Anticipo de Ventas -->
        <menuitem id="menu_sale_advance_wizard"
            action="action_sale_advance_wizard"
            name="Anticipo de Ventas"
            parent="menu_treasury_receivables"
            sequence="40"/>

        <!-- 3.3 Cobro Rápido -->
        <menuitem id="menu_quick_payment_customer"
            name="Nuevo Cobro"
            parent="menu_treasury_receivables"
            action="action_quick_payment_customer"
            sequence="100"/>

        <!-- ============================================ -->
        <!-- 4. ANTICIPOS -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_advances"
            name="Anticipos"
            parent="menu_treasury_root"
            sequence="40"/>

        <!-- 4.1 Solicitudes de Anticipo -->
        <menuitem id="menu_advance_requests"
            action="custom_account_treasury.action_advance_request"
            name="Solicitudes de Anticipo"
            parent="menu_treasury_advances"
            sequence="10"/>

        <!-- 4.2 Anticipos Aprobados -->
        <menuitem id="menu_advance_approved"
            action="action_advance_request_approved"
            name="Anticipos Aprobados"
            parent="menu_treasury_advances"
            sequence="20"/>

        <!-- 4.3 Anticipos por Aplicar -->
        <menuitem id="menu_advance_to_apply"
            action="action_advance_to_apply"
            name="Por Aplicar"
            parent="menu_treasury_advances"
            sequence="30"/>

        <!-- 4.4 Anticipo Rápido -->
        <menuitem id="menu_quick_advance"
            name="Nuevo Anticipo"
            parent="menu_treasury_advances"
            action="action_quick_advance_request"
            sequence="100"/>

        <!-- ============================================ -->
        <!-- 5. TRANSFERENCIAS INTERNAS -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_transfers"
            name="Transferencias Internas"
            parent="menu_treasury_root"
            sequence="50"/>

        <!-- 5.1 Todas las Transferencias -->
        <menuitem id="menu_action_treasury_payments_transfer"
            action="account.action_account_payments_transfer"
            name="Todas las Transferencias"
            parent="menu_treasury_transfers"
            sequence="10"/>

        <!-- 5.2 Nueva Transferencia -->
        <menuitem id="menu_new_internal_transfer"
            action="action_new_internal_transfer"
            name="Nueva Transferencia"
            parent="menu_treasury_transfers"
            sequence="20"/>

        <!-- ============================================ -->
        <!-- 6. REPORTES -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_reports"
            name="Reportes"
            groups="custom_account_treasury.group_treasury_user"
            parent="menu_treasury_root"
            sequence="80"/>

        <!-- 6.1 Libro de Pagos -->
        <menuitem id="menu_report_payment_book"
            action="action_treasury_payment_book_wizard"
            name="Libro de Pagos"
            parent="menu_treasury_reports"
            sequence="10"/>

        <!-- 6.2 Arqueo de Caja -->
        <menuitem id="menu_report_cash_box"
            action="action_treasury_cash_box_wizard"
            name="Arqueo de Caja"
            parent="menu_treasury_reports"
            sequence="20"/>

        <!-- ============================================ -->
        <!-- 7. CONFIGURACIÓN -->
        <!-- ============================================ -->
        <menuitem id="menu_treasury_config"
            name="Configuración"
            groups="custom_account_treasury.group_treasury_manager"
            parent="menu_treasury_root"
            sequence="100"/>

        <!-- 7.1 Administración -->
        <menuitem id="menu_treasury_administration"
            parent="menu_treasury_config"
            name="Administración"
            sequence="10"/>

        <menuitem id="menu_treasury_payment_method"
            action="custom_account_treasury.account_payment_method_action"
            parent="menu_treasury_administration"
            name="Métodos de Pago"
            sequence="10"/>

        <menuitem id="menu_treasury_action_advance_type"
            action="custom_account_treasury.action_advance_type"
            parent="menu_treasury_administration"
            name="Tipos de Anticipo"
            sequence="20"/>

        <menuitem id="menu_treasury_action_stages"
            action="custom_account_treasury.action_payment_request_stage"
            parent="menu_treasury_administration"
            name="Etapas de Solicitud"
            sequence="30"/>

        <menuitem id="menu_treasury_action_approval_limits"
            action="custom_account_treasury.action_advance_approval_limit"
            parent="menu_treasury_administration"
            name="Límites de Aprobación"
            sequence="40"/>

        <menuitem id="menu_treasury_sequence_config"
            action="custom_account_treasury.action_treasury_sequence_config"
            parent="menu_treasury_administration"
            name="Secuencias de Tesorería"
            sequence="50"/>

        <menuitem id="menu_treasury_bank_commission"
            action="action_treasury_bank_commission"
            parent="menu_treasury_administration"
            name="Comisiones Bancarias"
            sequence="60"/>

        <menuitem id="menu_treasury_bank_charge_type"
            action="treasury_bank_charge_type_action"
            parent="menu_treasury_administration"
            name="Tipos de Cargo Bancario"
            sequence="65"/>

        <menuitem id="menu_treasury_payment_schedule"
            action="action_treasury_payment_schedule"
            parent="menu_treasury_administration"
            name="Calendario de Pagos"
            sequence="70"/>

        <menuitem id="menu_treasury_holiday"
            action="action_treasury_holiday"
            parent="menu_treasury_administration"
            name="Festivos"
            sequence="80"/>

        <!-- 7.2 Configuración de Cuentas -->
        <menuitem id="menu_treasury_configuration"
            parent="menu_treasury_config"
            name="Cuentas Contables"
            sequence="20"/>

        <!-- Acción: Cuentas Contables de Tesorería -->
        <record id="action_treasury_accounts" model="ir.actions.act_window">
            <field name="name">Plan de Cuentas</field>
            <field name="res_model">account.account</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_by_account_type': 1}</field>
        </record>

        <menuitem id="menu_treasury_accounts"
            action="action_treasury_accounts"
            name="Plan de Cuentas"
            parent="menu_treasury_configuration"
            sequence="10"/>

        <!-- Acción: Diarios de Pago -->
        <record id="action_treasury_payment_journals" model="ir.actions.act_window">
            <field name="name">Diarios de Pago</field>
            <field name="res_model">account.journal</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('type', 'in', ['bank', 'cash'])]</field>
        </record>

        <menuitem id="menu_treasury_payment_journals"
            action="action_treasury_payment_journals"
            name="Diarios de Pago"
            parent="menu_treasury_configuration"
            sequence="20"/>

        <!-- Acción: Impuestos -->
        <record id="action_treasury_taxes" model="ir.actions.act_window">
            <field name="name">Impuestos</field>
            <field name="res_model">account.tax</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_treasury_taxes_config"
            action="action_treasury_taxes"
            name="Impuestos"
            parent="menu_treasury_configuration"
            sequence="30"/>

    </data>
</odoo>
