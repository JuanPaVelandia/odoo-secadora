<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vistas treasury.bank.commission -->
    <record id="view_treasury_bank_commission_list" model="ir.ui.view">
        <field name="name">treasury.bank.commission.list</field>
        <field name="model">treasury.bank.commission</field>
        <field name="arch" type="xml">
            <list string="Comisiones Bancarias" default_order="bank_id, service_category">
                <field name="bank_id"/>
                <field name="journal_id" optional="show"/>
                <field name="service_category"/>
                <field name="charge_frequency"/>
                <field name="payment_type"/>
                <field name="is_exempt" widget="boolean_toggle"/>
                <field name="commission_type" column_invisible="is_exempt"/>
                <field name="commission_fixed" optional="show"/>
                <field name="commission_percent" optional="show"/>
                <field name="min_commission" optional="hide"/>
                <field name="max_commission" optional="hide"/>
                <field name="tax_ids" widget="many2many_tags" optional="show"/>
                <field name="expense_account_id" optional="hide"/>
                <field name="payment_method_id" optional="hide"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_bank_commission_form" model="ir.ui.view">
        <field name="name">treasury.bank.commission.form</field>
        <field name="model">treasury.bank.commission</field>
        <field name="arch" type="xml">
            <form string="Comision Bancaria">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_toggle"/>
                    </div>
                    <widget name="web_ribbon" title="EXENTO" bg_color="text-bg-success" invisible="not is_exempt"/>
                    <group>
                        <group string="Banco">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="bank_id" options="{'no_create': True}" placeholder="Seleccione el banco..."/>
                            <field name="journal_id" options="{'no_create': True}" domain="[('type', 'in', ['bank', 'cash']), ('bank_id', '=', bank_id)]"/>
                        </group>
                        <group string="Servicio">
                            <field name="service_category"/>
                            <field name="charge_frequency"/>
                            <field name="payment_method_id" options="{'no_create': True}"/>
                            <field name="payment_type"/>
                        </group>
                    </group>
                    <group>
                        <group string="Comision">
                            <field name="is_exempt" widget="boolean_toggle"/>
                            <field name="commission_type" invisible="is_exempt"/>
                            <field name="commission_fixed" invisible="is_exempt or commission_type == 'percent'"/>
                            <field name="commission_percent" invisible="is_exempt or commission_type == 'fixed'"/>
                            <field name="min_commission" invisible="is_exempt or commission_type == 'fixed'"/>
                            <field name="max_commission" invisible="is_exempt or commission_type == 'fixed'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Impuestos y Contabilidad">
                            <field name="tax_ids" widget="many2many_tags" options="{'no_create': True}" invisible="is_exempt"/>
                            <field name="expense_account_id" options="{'no_create': True}" invisible="is_exempt"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notas adicionales sobre el tarifario..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_treasury_bank_commission_search" model="ir.ui.view">
        <field name="name">treasury.bank.commission.search</field>
        <field name="model">treasury.bank.commission</field>
        <field name="arch" type="xml">
            <search>
                <field name="bank_id"/>
                <field name="journal_id"/>
                <field name="service_category"/>
                <field name="payment_method_id"/>
                <filter string="Pagos" name="outbound" domain="[('payment_type', '=', 'outbound')]"/>
                <filter string="Recaudos" name="inbound" domain="[('payment_type', '=', 'inbound')]"/>
                <filter string="Por Transaccion" name="transaction" domain="[('charge_frequency', '=', 'transaction')]"/>
                <filter string="Mensuales" name="monthly" domain="[('charge_frequency', '=', 'monthly')]"/>
                <filter string="ACH" name="ach" domain="[('service_category', '=', 'ach')]"/>
                <filter string="Mismo Banco" name="same_bank" domain="[('service_category', '=', 'ach_same_bank')]"/>
                <filter string="PSE" name="pse" domain="[('service_category', '=', 'pse')]"/>
                <filter string="Cheques" name="cheques" domain="[('service_category', 'in', ['cheque', 'cheque_gerencia'])]"/>
                <filter string="Cuota Manejo" name="cuota" domain="[('service_category', '=', 'cuota_manejo')]"/>
                <filter string="Exentos" name="exempt" domain="[('is_exempt', '=', True)]"/>
                <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Banco" name="group_bank" context="{'group_by': 'bank_id'}"/>
                    <filter string="Diario" name="group_journal" context="{'group_by': 'journal_id'}"/>
                    <filter string="Categoria" name="group_category" context="{'group_by': 'service_category'}"/>
                    <filter string="Frecuencia" name="group_frequency" context="{'group_by': 'charge_frequency'}"/>
                    <filter string="Tipo" name="group_type" context="{'group_by': 'payment_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_treasury_bank_commission" model="ir.actions.act_window">
        <field name="name">Comisiones Bancarias</field>
        <field name="res_model">treasury.bank.commission</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear comision bancaria
            </p>
            <p>
                Configure las comisiones que cobra cada banco por metodo de pago.
            </p>
        </field>
    </record>

    <!-- Vistas treasury.payment.schedule -->
    <record id="view_treasury_payment_schedule_list" model="ir.ui.view">
        <field name="name">treasury.payment.schedule.list</field>
        <field name="model">treasury.payment.schedule</field>
        <field name="arch" type="xml">
            <list string="Calendario de Pagos">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="payment_type"/>
                <field name="schedule_type"/>
                <field name="weekday_ids" widget="many2many_tags" optional="show"/>
                <field name="holiday_behavior" optional="show"/>
                <field name="only_business_days" optional="hide"/>
                <field name="journal_id" optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_payment_schedule_form" model="ir.ui.view">
        <field name="name">treasury.payment.schedule.form</field>
        <field name="model">treasury.payment.schedule</field>
        <field name="arch" type="xml">
            <form string="Calendario de Pagos">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_toggle"/>
                    </div>
                    <group>
                        <group string="Informacion General">
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="payment_type"/>
                            <field name="schedule_type"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Banco Predeterminado">
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="payment_method_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Dias de la Semana" invisible="schedule_type != 'weekday'">
                        <field name="weekday_ids" widget="many2many_tags" colspan="2"/>
                    </group>
                    <group string="Dias del Mes" invisible="schedule_type != 'monthday'">
                        <field name="day_of_month_ids" widget="many2many_tags" colspan="2"/>
                    </group>
                    <group string="Manejo de Festivos">
                        <group>
                            <field name="holiday_behavior"/>
                        </group>
                        <group>
                            <field name="only_business_days"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notas adicionales..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_treasury_payment_schedule_search" model="ir.ui.view">
        <field name="name">treasury.payment.schedule.search</field>
        <field name="model">treasury.payment.schedule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="payment_type"/>
                <filter string="Proveedores" name="supplier" domain="[('payment_type', '=', 'supplier')]"/>
                <filter string="Nomina" name="payroll" domain="[('payment_type', '=', 'payroll')]"/>
                <filter string="Impuestos" name="taxes" domain="[('payment_type', '=', 'taxes')]"/>
                <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Tipo de Pago" name="group_type" context="{'group_by': 'payment_type'}"/>
                    <filter string="Tipo Programacion" name="group_schedule" context="{'group_by': 'schedule_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_treasury_payment_schedule" model="ir.actions.act_window">
        <field name="name">Calendario de Pagos</field>
        <field name="res_model">treasury.payment.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear calendario de pagos
            </p>
            <p>
                Configure los dias en que se realizan pagos (por semana o por dia del mes).
            </p>
        </field>
    </record>

    <!-- Vistas treasury.payment.schedule.day -->
    <record id="view_treasury_payment_schedule_day_list" model="ir.ui.view">
        <field name="name">treasury.payment.schedule.day.list</field>
        <field name="model">treasury.payment.schedule.day</field>
        <field name="arch" type="xml">
            <list string="Dias del Mes" editable="bottom">
                <field name="day"/>
                <field name="name" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="action_treasury_payment_schedule_day" model="ir.actions.act_window">
        <field name="name">Dias del Mes</field>
        <field name="res_model">treasury.payment.schedule.day</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Vistas treasury.holiday (Festivos) -->
    <record id="view_treasury_holiday_list" model="ir.ui.view">
        <field name="name">treasury.holiday.list</field>
        <field name="model">treasury.holiday</field>
        <field name="arch" type="xml">
            <list string="Festivos" editable="bottom">
                <field name="date"/>
                <field name="name"/>
                <field name="recurring"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_holiday_form" model="ir.ui.view">
        <field name="name">treasury.holiday.form</field>
        <field name="model">treasury.holiday</field>
        <field name="arch" type="xml">
            <form string="Festivo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="recurring"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_treasury_holiday_search" model="ir.ui.view">
        <field name="name">treasury.holiday.search</field>
        <field name="model">treasury.holiday</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="date"/>
                <filter string="Recurrentes" name="recurring" domain="[('recurring', '=', True)]"/>
                <filter string="Este Año" name="this_year" domain="[('date', '&gt;=', (context_today()).strftime('%Y-01-01')), ('date', '&lt;=', (context_today()).strftime('%Y-12-31'))]"/>
                <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Mes" name="group_month" context="{'group_by': 'date:month'}"/>
                    <filter string="Año" name="group_year" context="{'group_by': 'date:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_treasury_holiday_calendar" model="ir.ui.view">
        <field name="name">treasury.holiday.calendar</field>
        <field name="model">treasury.holiday</field>
        <field name="arch" type="xml">
            <calendar string="Festivos" date_start="date" color="recurring" mode="year">
                <field name="name"/>
            </calendar>
        </field>
    </record>

    <record id="action_treasury_holiday" model="ir.actions.act_window">
        <field name="name">Festivos</field>
        <field name="res_model">treasury.holiday</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_this_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Agregar festivo
            </p>
            <p>
                Configure los dias festivos para el calendario de pagos.
            </p>
        </field>
    </record>

</odoo>
