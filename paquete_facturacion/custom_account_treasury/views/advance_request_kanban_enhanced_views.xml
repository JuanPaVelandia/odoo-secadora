<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================================
         VISTA KANBAN MEJORADA PARA SOLICITUDES DE ANTICIPO (ESTILO KANBAN)
         ======================================================================== -->
    <record id="view_advance_request_kanban_enhanced" model="ir.ui.view">
        <field name="name">advance.request.kanban.enhanced</field>
        <field name="model">advance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column"
                    quick_create="false" sample="1">
                <field name="stage_id"/>
                <field name="color"/>
                <field name="request_type"/>
                <field name="currency_id"/>
                <progressbar field="kanban_state" colors='{"normal": "secondary", "done": "success", "blocked": "danger"}'/>
                <templates>
                    <t t-name="menu">
                        <a t-if="widget.editable" role="menuitem" type="edit" class="dropdown-item">Editar</a>
                        <a t-if="widget.deletable" role="menuitem" type="delete" class="dropdown-item">Eliminar</a>
                        <field name="color" widget="kanban_color_picker"/>
                    </t>
                    <t t-name="card">
                        <!-- Badge tipo de solicitud -->
                        <widget name="web_ribbon" title="Cliente" bg_color="text-bg-success"
                                t-if="record.request_type.raw_value == 'customer'"/>
                        <widget name="web_ribbon" title="Proveedor" bg_color="text-bg-primary"
                                t-if="record.request_type.raw_value == 'supplier'"/>
                        <widget name="web_ribbon" title="Empleado" bg_color="text-bg-info"
                                t-if="record.request_type.raw_value == 'employee'"/>
                        <widget name="web_ribbon" title="Otro" bg_color="text-bg-secondary"
                                t-if="record.request_type.raw_value == 'other'"/>

                        <!-- Encabezado -->
                        <field name="partner_id" class="fw-bold fs-5"/>
                        <field name="advance_type_id" class="text-muted small"/>

                        <!-- Monto -->
                        <div class="text-center my-2">
                            <field name="amount_requested" widget="monetary" class="fw-bold fs-4 text-primary"/>
                        </div>

                        <!-- Fecha -->
                        <div class="d-flex align-items-center text-muted small">
                            <i class="fa fa-calendar me-1"/>
                            <field name="date_request"/>
                        </div>

                        <!-- Footer -->
                        <footer class="pt-2">
                            <field name="priority" widget="priority"/>
                            <field name="activity_ids" widget="kanban_activity"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================================================
         ACCIÓN PARA SOLICITUDES DE CLIENTES
         ======================================================================== -->
    <record id="action_advance_request_customer" model="ir.actions.act_window">
        <field name="name">Solicitudes de Anticipos - Clientes</field>
        <field name="res_model">advance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('request_type', '=', 'customer')]</field>
        <field name="context">{'default_request_type': 'customer', 'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de anticipos de clientes
            </p>
            <p>
                Las solicitudes de anticipo de clientes permiten gestionar
                los pagos anticipados que realizan sus clientes.
            </p>
        </field>
    </record>

    <!-- ========================================================================
         ACCIÓN PARA GENERACIÓN PARA PROVEEDORES
         ======================================================================== -->
    <record id="action_advance_request_supplier" model="ir.actions.act_window">
        <field name="name">Generación de Anticipos - Proveedores</field>
        <field name="res_model">advance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('request_type', '=', 'supplier')]</field>
        <field name="context">{'default_request_type': 'supplier', 'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay generación de anticipos para proveedores
            </p>
            <p>
                La generación de anticipos para proveedores permite gestionar
                los pagos anticipados que realiza a sus proveedores.
            </p>
        </field>
    </record>

    <!-- ========================================================================
         ACCIÓN PARA ANTICIPOS DE EMPLEADOS
         ======================================================================== -->
    <record id="action_advance_request_employee" model="ir.actions.act_window">
        <field name="name">Anticipos - Empleados</field>
        <field name="res_model">advance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('request_type', '=', 'employee')]</field>
        <field name="context">{'default_request_type': 'employee', 'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay anticipos para empleados
            </p>
            <p>
                Los anticipos de empleados permiten gestionar préstamos
                y anticipos de nómina para su personal.
            </p>
        </field>
    </record>

    <!-- ========================================================================
         ACCIÓN PARA OTROS ANTICIPOS
         ======================================================================== -->
    <record id="action_advance_request_other" model="ir.actions.act_window">
        <field name="name">Otros Anticipos</field>
        <field name="res_model">advance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('request_type', '=', 'other')]</field>
        <field name="context">{'default_request_type': 'other', 'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay otros tipos de anticipos
            </p>
            <p>
                Esta categoría permite gestionar anticipos que no entran
                en las categorías de clientes, proveedores o empleados.
            </p>
        </field>
    </record>

    <!-- ========================================================================
         MENÚS PARA ANTICIPOS POR TIPO - DESACTIVADOS (usa menú unificado)
         ======================================================================== -->
    <menuitem id="menu_advance_requests_by_type"
              name="Anticipos por Tipo"
              parent="custom_account_treasury.menu_treasury_root"
              sequence="45"
              active="False"/>

    <menuitem id="menu_advance_request_customer"
              name="Solicitudes (Clientes)"
              parent="menu_advance_requests_by_type"
              action="action_advance_request_customer"
              sequence="1"/>

    <menuitem id="menu_advance_request_supplier"
              name="Generación (Proveedores)"
              parent="menu_advance_requests_by_type"
              action="action_advance_request_supplier"
              sequence="2"/>

    <menuitem id="menu_advance_request_employee"
              name="Empleados"
              parent="menu_advance_requests_by_type"
              action="action_advance_request_employee"
              sequence="3"/>

    <menuitem id="menu_advance_request_other"
              name="Otros"
              parent="menu_advance_requests_by_type"
              action="action_advance_request_other"
              sequence="4"/>

    <!-- ========================================================================
         VISTA KANBAN PARA PAGOS (ANTICIPOS APLICADOS)
         ======================================================================== -->
    <record id="view_account_payment_advance_kanban" model="ir.ui.view">
        <field name="name">account.payment.advance.kanban</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" quick_create="false" sample="1">
                <field name="partner_type"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <!-- Badge según tipo de tercero -->
                        <widget name="web_ribbon" title="Cliente" bg_color="text-bg-success"
                                t-if="record.partner_type.raw_value == 'customer'"/>
                        <widget name="web_ribbon" title="Proveedor" bg_color="text-bg-primary"
                                t-if="record.partner_type.raw_value == 'supplier'"/>

                        <!-- Encabezado -->
                        <field name="partner_id" class="fw-bold fs-5"/>
                        <field name="name" class="text-muted small"/>

                        <!-- Tipo de anticipo -->
                        <field name="advance_type_id" class="text-muted small"/>

                        <!-- Monto -->
                        <div class="text-center my-2">
                            <field name="amount" widget="monetary" class="fw-bold fs-4 text-primary"/>
                        </div>

                        <!-- Footer con fecha y estado -->
                        <footer class="pt-2">
                            <div class="d-flex align-items-center text-muted small">
                                <i class="fa fa-calendar me-1"/>
                                <field name="date"/>
                            </div>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'posted'"
                                   decoration-info="state == 'draft'"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================================================
         ACCIÓN PARA VER ANTICIPOS APLICADOS POR TIPO
         ======================================================================== -->
    <record id="action_account_payment_advance_customer" model="ir.actions.act_window">
        <field name="name">Anticipos Aplicados - Clientes</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="view_account_payment_advance_kanban"/>
        <field name="domain">[('advance', '=', True), ('partner_type', '=', 'customer')]</field>
        <field name="context">{'default_advance': True, 'default_partner_type': 'customer'}</field>
    </record>

    <record id="action_account_payment_advance_supplier" model="ir.actions.act_window">
        <field name="name">Anticipos Aplicados - Proveedores</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="view_account_payment_advance_kanban"/>
        <field name="domain">[('advance', '=', True), ('partner_type', '=', 'supplier')]</field>
        <field name="context">{'default_advance': True, 'default_partner_type': 'supplier'}</field>
    </record>

    <record id="action_account_payment_advance_employee" model="ir.actions.act_window">
        <field name="name">Anticipos Aplicados - Empleados</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="view_account_payment_advance_kanban"/>
        <field name="domain">[('advance', '=', True), ('partner_type', '=', 'employee')]</field>
        <field name="context">{'default_advance': True, 'default_partner_type': 'employee'}</field>
    </record>

    <!-- ========================================================================
         SUBMENÚS PARA ANTICIPOS APLICADOS - DESACTIVADOS (usa menú unificado)
         ======================================================================== -->
    <menuitem id="menu_advance_applied_by_type"
              name="Anticipos Aplicados"
              parent="custom_account_treasury.menu_treasury_root"
              sequence="46"
              active="False"/>

    <menuitem id="menu_advance_applied_customer"
              name="Clientes"
              parent="menu_advance_applied_by_type"
              action="action_account_payment_advance_customer"
              sequence="1"/>

    <menuitem id="menu_advance_applied_supplier"
              name="Proveedores"
              parent="menu_advance_applied_by_type"
              action="action_account_payment_advance_supplier"
              sequence="2"/>

    <menuitem id="menu_advance_applied_employee"
              name="Empleados"
              parent="menu_advance_applied_by_type"
              action="action_account_payment_advance_employee"
              sequence="3"/>

</odoo>
