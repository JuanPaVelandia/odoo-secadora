<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Modal para Detalle de Línea de Pago - Diseño Expandible -->
        <record id="view_payment_detail_from" model="ir.ui.view">
            <field name="name">account.payment.detail.form</field>
            <field name="model">account.payment.detail</field>
            <field name="arch" type="xml">
                <form string="Detalle de Línea" class="o_payment_detail_modal">
                    <sheet>
                        <!-- Campos ocultos -->
                        <field name="state" invisible="1"/>
                        <field name="company_id" invisible="1"/>
                        <field name="company_currency_id" invisible="1"/>
                        <field name="payment_currency_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>

                        <!-- Encabezado con información del documento -->
                        <div class="o_payment_detail_header d-flex justify-content-between align-items-center mb-3 p-3 bg-light rounded">
                            <div>
                                <h4 class="mb-0">
                                    <field name="invoice_id" readonly="1" class="fw-bold"/>
                                </h4>
                                <small class="text-muted">
                                    <field name="partner_id" readonly="1"/>
                                </small>
                            </div>
                            <div class="text-end">
                                <div class="fs-3 fw-bold text-primary">
                                    <field name="payment_amount"/>
                                </div>
                                <small class="text-muted">
                                    Deuda: <field name="amount_residual" readonly="1" class="text-danger"/>
                                </small>
                            </div>
                        </div>

                        <!-- Sección 1: Montos -->
                        <div class="o_collapsible_section mb-3" data-section="amounts">
                            <div class="o_section_header d-flex justify-content-between align-items-center p-2 bg-secondary bg-opacity-10 rounded cursor-pointer" onclick="this.closest('.o_collapsible_section').classList.toggle('collapsed')">
                                <span class="fw-bold"><i class="fa fa-money me-2"/>Montos y Pagos</span>
                                <i class="fa fa-chevron-down o_collapse_icon"/>
                            </div>
                            <div class="o_section_content p-3 border border-top-0 rounded-bottom">
                                <group col="4">
                                    <field name="payment_amount" string="Monto a Pagar"/>
                                    <field name="amount_residual" string="Deuda Pendiente" readonly="1"/>
                                    <field name="debit" string="Débito" readonly="1"/>
                                    <field name="credit" string="Crédito" readonly="1"/>
                                </group>
                                <group col="4">
                                    <field name="payment_difference" string="Diferencia" readonly="1"/>
                                    <field name="exchange_diff_amount" string="Dif. Cambio" readonly="1"/>
                                    <field name="is_final_payment" string="Pago Final" widget="boolean_toggle" readonly="1"/>
                                    <field name="to_pay" string="A Pagar" widget="boolean_toggle"/>
                                </group>
                            </div>
                        </div>

                        <!-- Sección 2: Tasa de Cambio (solo si hay moneda extranjera) -->
                        <div class="o_collapsible_section mb-3" data-section="exchange" invisible="currency_id == company_currency_id">
                            <div class="o_section_header d-flex justify-content-between align-items-center p-2 bg-info bg-opacity-10 rounded cursor-pointer" onclick="this.closest('.o_collapsible_section').classList.toggle('collapsed')">
                                <span class="fw-bold"><i class="fa fa-exchange me-2"/>Tasa de Cambio</span>
                                <i class="fa fa-chevron-down o_collapse_icon"/>
                            </div>
                            <div class="o_section_content p-3 border border-top-0 rounded-bottom">
                                <group col="2">
                                    <group string="Tasa del Sistema">
                                        <field name="currency_rate" string="Tasa Sistema" readonly="1"/>
                                        <field name="amount_residual_currency" string="Deuda ME" readonly="1"/>
                                    </group>
                                    <group string="Tasa Manual por Línea">
                                        <field name="use_manual_rate" string="Usar Tasa Manual" widget="boolean_toggle"/>
                                        <field name="manual_currency_rate"
                                               string="Tasa Manual"
                                               invisible="not use_manual_rate"
                                               required="use_manual_rate"/>
                                        <field name="rate_negotiation_date"
                                               string="Fecha Negociación"
                                               invisible="not use_manual_rate"
                                               placeholder="Fecha en que se negoció..."/>
                                    </group>
                                </group>
                                <div class="alert alert-info p-2 mt-2" role="alert" invisible="not use_manual_rate">
                                    <i class="fa fa-info-circle me-2"/>
                                    La tasa manual se usará para esta línea. Ingrese la fecha de negociación para métricas.
                                </div>
                            </div>
                        </div>

                        <!-- Sección 3: Impuestos -->
                        <div class="o_collapsible_section mb-3" data-section="taxes" invisible="not has_taxes_to_revert">
                            <div class="o_section_header d-flex justify-content-between align-items-center p-2 bg-warning bg-opacity-10 rounded cursor-pointer" onclick="this.closest('.o_collapsible_section').classList.toggle('collapsed')">
                                <span class="fw-bold"><i class="fa fa-percent me-2"/>Impuestos a Revertir</span>
                                <i class="fa fa-chevron-down o_collapse_icon"/>
                            </div>
                            <div class="o_section_content p-3 border border-top-0 rounded-bottom">
                                <field name="has_taxes_to_revert" invisible="1"/>
                                <group>
                                    <field name="invoice_tax_ids" string="Impuestos de Factura"
                                           widget="many2many_tags" readonly="1"
                                           options="{'no_create': True, 'color_field': ''}"/>
                                    <field name="taxes_to_revert_ids" string="Impuestos a Revertir"
                                           widget="many2many_tags"
                                           domain="[('id', 'in', invoice_tax_ids)]"
                                           options="{'no_create': True, 'color_field': ''}"
                                           placeholder="Seleccione impuestos..."/>
                                    <field name="tax_revert_amount" string="Monto a Revertir" readonly="1"
                                           invisible="not taxes_to_revert_ids"/>
                                </group>
                            </div>
                        </div>

                        <!-- Sección 4: Diferencia de Pago -->
                        <div class="o_collapsible_section mb-3 collapsed" data-section="writeoff" invisible="payment_difference == 0">
                            <div class="o_section_header d-flex justify-content-between align-items-center p-2 bg-danger bg-opacity-10 rounded cursor-pointer" onclick="this.closest('.o_collapsible_section').classList.toggle('collapsed')">
                                <span class="fw-bold"><i class="fa fa-balance-scale me-2"/>Manejo de Diferencia</span>
                                <i class="fa fa-chevron-down o_collapse_icon"/>
                            </div>
                            <div class="o_section_content p-3 border border-top-0 rounded-bottom">
                                <group>
                                    <field name="payment_difference_handling" string="Acción" widget="radio"/>
                                    <field name="writeoff_account_id" string="Cuenta Diferencia"
                                           invisible="payment_difference_handling != 'reconcile'"/>
                                </group>
                            </div>
                        </div>

                        <!-- Sección 5: Información Adicional (colapsada por defecto) -->
                        <div class="o_collapsible_section mb-3 collapsed" data-section="info">
                            <div class="o_section_header d-flex justify-content-between align-items-center p-2 bg-light rounded cursor-pointer" onclick="this.closest('.o_collapsible_section').classList.toggle('collapsed')">
                                <span class="fw-bold"><i class="fa fa-info-circle me-2"/>Información Adicional</span>
                                <i class="fa fa-chevron-down o_collapse_icon"/>
                            </div>
                            <div class="o_section_content p-3 border border-top-0 rounded-bottom">
                                <group col="4">
                                    <field name="account_id" string="Cuenta"/>
                                    <field name="name" string="Descripción"/>
                                    <field name="date_maturity" string="Vencimiento" readonly="1"/>
                                    <field name="display_type" string="Tipo" readonly="1"/>
                                </group>
                                <group col="4">
                                    <field name="move_line_id" string="Apunte" readonly="1"/>
                                    <field name="number" string="Número" readonly="1"/>
                                    <field name="ref" string="Referencia" readonly="1"/>
                                    <field name="journal_id" string="Diario" readonly="1"/>
                                </group>
                            </div>
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_save_changes" string="Guardar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_payment_detail_tree" model="ir.ui.view">
            <field name="name">account.payment.detail.list</field>
            <field name="model">account.payment.detail</field>
            <field name="arch" type="xml">
                <list>
                    <field name="type" />
                    <field name="company_id" invisible="1" />
                    <field name="account_id" domain="[('company_ids', 'in', company_id)]" />
                    <field name="partner_id" />
                    <field name="name" />
                    <field name="ref" invisible="1" />
                    <field name="number" />
                    <field name="currency_id" />
                    <field name="amount_currency" />
                    <field name="debit" />
                    <field name="credit" />
                    <field name="date" invisible="1" />
                    <field name="payment_id" invisible="1" />
                    <field name="journal_id" invisible="1" />
                    <field name="company_currency_id" invisible="1" />
                    <field name="invoice_id" invisible="1" />
                    <field name="move_id" invisible="1" />
                    <field name="is_account_line" invisible="1" />
                    <field name="is_transfer" invisible="1" />
                    <field name="is_manual_currency" invisible="1" />
                    <field name="is_diff" invisible="1" />
                    <field name="is_counterpart" invisible="1" />
                    <field name="exclude_from_payment_detail" invisible="1" />
                    <field name="balance" readonly="1" force_save="1" />
                    <field name="payment_currency_id" invisible="1" />
                    <field name="to_pay" />
                </list>
            </field>
        </record>

        <!-- Vista formulario para selección de impuestos a revertir -->
        <record id="view_payment_detail_tax_revert_form" model="ir.ui.view">
            <field name="name">account.payment.detail.tax.revert.form</field>
            <field name="model">account.payment.detail</field>
            <field name="arch" type="xml">
                <form string="Revertir Impuestos">
                    <sheet>
                        <div class="oe_title mb-3">
                            <h2>Revertir Impuestos de Línea</h2>
                        </div>

                        <!-- Información de la línea de pago -->
                        <group col="4" string="Información del Pago">
                            <field name="invoice_id" string="Factura" readonly="1"/>
                            <field name="partner_id" string="Tercero" readonly="1"/>
                            <field name="payment_amount" string="Monto a Pagar" readonly="1"/>
                            <field name="payment_currency_id" string="Moneda" readonly="1"/>
                        </group>

                        <!-- Información de la factura original -->
                        <group col="4" string="Información de la Factura Original" invisible="not invoice_id">
                            <field name="invoice_untaxed_amount" string="Subtotal (sin IVA)" readonly="1"/>
                            <field name="invoice_tax_total" string="Total Impuestos" readonly="1"/>
                            <field name="invoice_total_amount" string="Total Factura" readonly="1"/>
                            <field name="payment_percentage" string="% del Pago" readonly="1" widget="percentage"/>
                        </group>

                        <!-- Impuestos de la factura -->
                        <group string="Impuestos Disponibles en la Factura">
                            <field name="invoice_tax_ids"
                                   widget="many2many_tags"
                                   readonly="1"
                                   options="{'no_create': True}"
                                   nolabel="1"
                                   colspan="2"/>
                        </group>

                        <separator string="Configuración de Reversión"/>

                        <!-- Selector de tipo de base y impuestos a revertir -->
                        <group col="2">
                            <group string="Tipo de Cálculo">
                                <field name="tax_revert_base_type" widget="radio"/>
                            </group>
                            <group string="Impuestos a Revertir">
                                <field name="taxes_to_revert_ids"
                                       widget="many2many_tags"
                                       domain="[('id', 'in', invoice_tax_ids)]"
                                       options="{'no_create': True}"
                                       nolabel="1"
                                       placeholder="Seleccione los impuestos..."/>
                            </group>
                        </group>

                        <!-- Resumen del cálculo -->
                        <group col="4" string="Resultado del Cálculo" invisible="not taxes_to_revert_ids">
                            <field name="tax_revert_base" string="Base Imponible" readonly="1"/>
                            <field name="tax_revert_amount" string="Impuesto a Revertir" readonly="1"/>
                            <div colspan="2">
                                <div class="alert alert-info mb-0" role="status">
                                    <i class="fa fa-info-circle me-2"/>
                                    <strong>Resultado:</strong> Se descontará
                                    <field name="tax_revert_amount" readonly="1" class="d-inline fw-bold"/>
                                    del monto a pagar.
                                </div>
                            </div>
                        </group>

                        <!-- Líneas de impuesto generadas -->
                        <group string="Líneas de Impuesto Generadas" invisible="not revert_tax_line_ids">
                            <field name="revert_tax_line_ids" nolabel="1" colspan="2">
                                <list readonly="1" decoration-danger="payment_amount &lt; 0" decoration-success="payment_amount &gt; 0">
                                    <field name="name"/>
                                    <field name="tax_line_id2" string="Impuesto"/>
                                    <field name="account_id" string="Cuenta"/>
                                    <field name="tax_base_amount" string="Base"/>
                                    <field name="payment_amount" string="Monto" sum="Total"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_apply_tax_revert"
                                string="Aplicar Reversión"
                                type="object"
                                class="btn-primary"
                                invisible="not taxes_to_revert_ids"/>
                        <button name="action_clear_tax_revert"
                                string="Limpiar"
                                type="object"
                                class="btn-warning"
                                invisible="not taxes_to_revert_ids"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- pagos, cobros y tesoreria  -->
        <record id="view_account_move_reversal_payment" model="ir.ui.view">
            <field name="name">account.payment.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form" />
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="open_reconcile_view" class="oe_stat_button" icon="fa-anchor" type="object" string="Conciliada">
                    </button>
                </div>
                <xpath expr="//button[@name='action_draft']" position="after">
                    <button name="action_propose_payment_distribution" class="btn btn-success" invisible="state != 'draft'" string="Proponer distribución" type="object" icon="fa-gears"/>
                    <button name="action_delete_counterpart_lines" class="btn btn-danger" invisible="state != 'draft'" string="Eliminar Líneas" type="object" icon="fa-minus"/>
                    <button name="action_revert_taxes" class="btn btn-warning" invisible="state != 'draft'" string="Revertir Impuestos" type="object" icon="fa-undo" title="Elimina los impuestos calculados de las líneas"/>
                    <button name="action_apply_taxes" class="btn btn-info" invisible="state != 'draft'" string="Aplicar Impuestos" type="object" icon="fa-calculator" title="Recalcula los impuestos de las líneas"/>
                </xpath>

                <!-- Campos de numeración después del título -->
                <xpath expr="//div[@class='oe_title']" position="after">
                    <group>
                        <field name="is_cash_receipt" invisible="1"/>
                        <field name="cash_receipt_number" invisible="not is_cash_receipt" readonly="1" class="text-success fw-bold" string="Número RC"/>
                        <field name="payment_number" invisible="is_cash_receipt or not payment_number" readonly="1" class="text-primary fw-bold" string="Número Pago/Cobro"/>
                    </group>
                </xpath>

                <group name="main_group" position="inside">
                    <group name="advance_section" invisible="paired_internal_transfer_payment_id">
                    <label for="advance"/>
                    <div class="d-flex flex-column">
                        <div class="d-flex align-items-center">
                            <field name="advance" readonly="state != 'draft'" class="me-2"/>
                            <span class="text-muted">¿Es un anticipo?</span>
                        </div>

                        <div invisible="not advance" class="mt-2">
                            <label for="advance_type_id" class="me-2"/>
                            <div class="d-flex align-items-center">
                                <field name="advance_type_id" options="{'no_create': 1, 'no_edit': 1}" readonly="state != 'draft'" required="advance" class="w-100"/>
                                <i class="fa fa-cog ms-2" title="Tipo de anticipo"/>
                            </div>

                            <label for="code_advance" class="mt-2"/>
                            <div class="d-flex align-items-center">
                                <field name="code_advance" readonly="state != 'draft'" class="w-100" placeholder="Código de anticipo"/>
                                <i class="fa fa-barcode ms-2" title="Código de anticipo"/>
                            </div>

                            <div class="alert alert-info mt-2 mb-0 p-2" role="alert" invisible="not advance_type_id">
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-info-circle me-2"/>
                                    <small>
                                        <span invisible="payment_type != 'outbound'">
                                            Anticipo a proveedor
                                        </span>
                                        <span invisible="payment_type != 'inbound'">
                                            Anticipo de cliente
                                        </span>
                                        <strong class="ms-1">
                                            <field name="advance_type_id" readonly="1" nolabel="1"/>
                                        </strong>
                                    </small>
                                </div>
                            </div>

                            <div class="alert alert-warning mt-2 mb-0 p-2" role="alert" invisible="advance_type_id">
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-exclamation-triangle me-2"/>
                                    <small>Seleccione un tipo de anticipo</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </group>
                <group name="payment_difference_section" invisible="paired_internal_transfer_payment_id">
                    <label for="payment_difference_line"/>
                    <div class="d-flex flex-column w-100">
                        <field name="payment_difference_line" invisible="1" force_save="1"/>
                        
                        <div class="d-flex align-items-center">
                            <field name="amount_signed" readonly="1" force_save="1" class="fw-bold"/>
                            <span class="mx-2">→</span>
                            <field name="amount" readonly="1" force_save="1" class="fw-bold"/>
                        </div>

                        <div class="alert alert-success mt-2 mb-0 p-2" role="alert" invisible="payment_difference_line &lt;= 0">
                            <div class="d-flex align-items-center">
                                <i class="fa fa-plus-circle me-2"/>
                                <div>
                                    <strong>Diferencia a favor: </strong>
                                    <field name="payment_difference_line" readonly="1" force_save="1" class="oe_inline text-success"/>
                                    <field name="currency_id" readonly="1" force_save="1" class="oe_inline"/>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning mt-2 mb-0 p-2" role="alert" invisible="payment_difference_line &gt;= 0">
                            <div class="d-flex align-items-center">
                                <i class="fa fa-minus-circle me-2"/>
                                <div>
                                    <strong>Diferencia a pagar: </strong>
                                    <field name="payment_difference_line" readonly="1" force_save="1" class="oe_inline text-warning"/>
                                    <field name="currency_id" readonly="1" force_save="1" class="oe_inline"/>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-2 mb-0 p-2" role="alert" invisible="payment_difference_line != 0">
                            <div class="d-flex align-items-center">
                                <i class="fa fa-check-circle me-2"/>
                                <span>Los montos coinciden exactamente</span>
                            </div>
                        </div>
                    </div>
                </group>
                <group name="currency_config" invisible="currency_id == company_currency_id">
                    <label for="currency_id"/>
                    <div>
                        <field name="currency_id" options="{'no_create': True}" class="oe_inline"/>
                        <span class="fst-italic ms-2">Moneda diferente a la compañía</span>
                    </div>
                
                    <label for="manual_currency_rate_active"/>
                    <div>
                        <field name="manual_currency_rate_active" class="oe_inline"/>
                        <span class="ms-2">¿Usar tipo de cambio manual?</span>
                    </div>
                
                    <label for="current_exchange_rate"/>
                    <div>
                        <field name="current_exchange_rate" class="oe_inline" required="manual_currency_rate_active" force_save="1" readonly="not manual_currency_rate_active"/>
                        <span class="ms-2 text-muted">
                            1 <field name="currency_id" readonly="1" class="oe_inline"/> = 
                            <field name="current_exchange_rate" readonly="1" class="oe_inline"/> 
                            <field name="company_currency_id" readonly="1" class="oe_inline"/>
                        </span>
                        <div class="text-muted mt-1" invisible="manual_currency_rate_active">
                            <small><i class="fa fa-info-circle"/> Usando tipo de cambio del sistema</small>
                        </div>
                        <div class="text-warning mt-1" invisible="not manual_currency_rate_active">
                            <small><i class="fa fa-exclamation-triangle"/> Usando tipo de cambio manual</small>
                        </div>
                    </div>
                </group>
                <group name="payment_controls" invisible="paired_internal_transfer_payment_id">
                    <!-- Campos ocultos que siempre están activos -->
                    <field name="enable_multi_partner" invisible="1"/>
                    <field name="enable_multi_payment_method" invisible="1"/>

                    <label for="is_document_cross"/>
                    <div>
                        <field name="is_document_cross" widget="boolean_toggle" class="oe_inline"/>
                        <span class="ms-2">¿Es cruce de documentos?</span>
                    </div>

                    <label for="adjustment_peso"/>
                    <div>
                        <field name="adjustment_peso" widget="boolean_toggle" class="oe_inline"/>
                        <span class="ms-2">¿Aplicar ajuste por peso?</span>
                    </div>

                    <field name="adjustment_amount" invisible="not adjustment_peso"/>
                    <field name="adjustment_account_id" invisible="not adjustment_peso or not adjustment_amount" required="adjustment_peso and adjustment_amount != 0"/>
                    <field name="check_number" invisible="1"/>
                </group>
                 </group>
                <field name="payment_type" position="after">
                    <field name="change_destination_account" invisible="1"/>
                    <field name="outstanding_account_id" readonly="state != 'draft'"/>
                    <field name="destination_account_id" readonly="state != 'draft'"/>
                </field>

                <!-- Formas de pago (siempre visible) -->
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="payment_method_line_ids" context="{'default_payment_id': id}" readonly="state != 'draft'" nolabel="1" colspan="2">
                        <list editable="bottom">
                            <field name="payment_method_id" required="1"/>
                            <field name="journal_id" required="1"/>
                            <field name="account_id" required="1"/>
                            <field name="amount" sum="Total" required="1"/>
                            <field name="check_number" invisible="not is_check" required="is_check"/>
                            <field name="is_check" column_invisible="1"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </xpath>
            </field>
        </record>

        <record id="view_account_payment_tree" model="ir.ui.view">
            <field name="name">account.payment.list</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_tree" />
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="code_advance" />
                </field>
            </field>
        </record>

        <record id="view_account_supplier_payment_tree" model="ir.ui.view">
            <field name="name">account.supplier.payment.list</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_supplier_payment_tree" />
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="code_advance" />
                </field>
            </field>
        </record>
        

    </data>
</odoo>
