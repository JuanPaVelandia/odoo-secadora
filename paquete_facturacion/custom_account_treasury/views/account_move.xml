<odoo>
    <data>
        <!-- ========== HERENCIA VISTA FORMULARIO FACTURA ========== -->
        <record id="view_move_form_inherit_force_fields" model="ir.ui.view">
            <field name="name">account.move.form.inherit.force.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']//field[@name='account_id']" position="after">
                    <field name="force_account_id"
                           optional="hide"
                           string="Cuenta Forzada"
                           domain="[('active', '=', True), ('company_ids', 'in', [False, parent.company_id]), ('account_type', 'in', ['asset_receivable', 'liability_payable'])]"/>
                </xpath>
            </field>
        </record>

        
        <!-- ========== VISTA LISTA JOURNAL ITEMS ========== -->
        <record id="view_move_line_tree_payment" model="ir.ui.view">
            <field name="name">account.move.line.payment.list</field>
            <field name="model">account.move.line</field>
            <field eval="100" name="priority"/>
            <field name="arch" type="xml">
                <list string="Journal Items" create="false" edit="false" sample="1" expand="context.get('expand', True)">
                    <field name="date" optional="hide"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="journal_id" invisible="1" options="{&quot;no_open&quot;:True}"/>
                    <field name="move_id" optional="show"/>
                    <field name="account_id" options="{'no_open': True}" groups="account.group_account_readonly"/>
                    <field name="partner_id" optional="hide"/>
                    <field name="force_account_id" optional="hide" string="Cuenta Forzada"/>
                    <field name="statement_id" invisible="1"/>
                    <field name="ref" optional="hide"/>
                    <field name="name" invisible="1" optional="show"/>
                    <field name="debit" invisible="1" sum="Total Debit"/>
                    <field name="credit" invisible="1" sum="Total Credit"/>
                    <field name="balance" sum="Total Balance"/>
                    <field name="amount_residual" sum="Total Residual"/>
                    <field name="amount_currency" groups="base.group_multi_currency" optional="hide"/>
                    <field name="currency_id" readonly="1" groups="base.group_multi_currency" optional="hide" string="Original Currency"/>
                    <field name="date_maturity"/>
                    <field name="company_currency_id" invisible="1"/>
                    <field name="parent_state" invisible="1"/>
                </list>
            </field>
        </record>
    </data>
</odoo>
