<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================ -->
        <!-- ACCIONES - PAGOS POR ESTADO -->
        <!-- ============================================ -->

        <!-- Pagos en Borrador -->
        <record id="action_payment_state_draft" model="ir.actions.act_window">
            <field name="name">Pagos en Borrador</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'draft')]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos en borrador
                </p>
                <p>
                    Los pagos en borrador son aquellos que aún no han sido confirmados.
                </p>
            </field>
        </record>

        <!-- Pagos Publicados -->
        <record id="action_payment_state_posted" model="ir.actions.act_window">
            <field name="name">Pagos Publicados</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'posted')]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos publicados
                </p>
                <p>
                    Los pagos publicados son aquellos que ya han sido confirmados y registrados en la contabilidad.
                </p>
            </field>
        </record>

        <!-- Pagos Cancelados -->
        <record id="action_payment_state_cancelled" model="ir.actions.act_window">
            <field name="name">Pagos Cancelados</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'cancel')]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos cancelados
                </p>
                <p>
                    Los pagos cancelados son aquellos que fueron anulados.
                </p>
            </field>
        </record>

        <!-- Pagos Conciliados -->
        <record id="action_payment_state_reconciled" model="ir.actions.act_window">
            <field name="name">Pagos Conciliados</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'posted'), ('is_reconciled', '=', True)]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos conciliados
                </p>
                <p>
                    Los pagos conciliados son aquellos que han sido aplicados a facturas o anticipos.
                </p>
            </field>
        </record>

        <!-- Pagos Sin Conciliar -->
        <record id="action_payment_state_not_reconciled" model="ir.actions.act_window">
            <field name="name">Pagos Sin Conciliar</field>
            <field name="res_model">account.payment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'posted'), ('is_reconciled', '=', False)]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos sin conciliar
                </p>
                <p>
                    Los pagos sin conciliar son aquellos que aún no han sido aplicados a ninguna factura o anticipo.
                </p>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- MENÚS - PAGOS POR ESTADO -->
        <!-- ============================================ -->

        <!-- Menú principal: entre Dashboard (1) y Pagos (20) -->
        <menuitem id="menu_payment_by_state"
            name="Pagos por Estado"
            parent="custom_account_treasury.menu_treasury_root"
            sequence="10"/>

        <menuitem id="menu_payment_state_draft"
            name="Borradores"
            parent="menu_payment_by_state"
            action="action_payment_state_draft"
            sequence="10"/>

        <menuitem id="menu_payment_state_posted"
            name="Publicados"
            parent="menu_payment_by_state"
            action="action_payment_state_posted"
            sequence="20"/>

        <menuitem id="menu_payment_state_reconciled"
            name="Conciliados"
            parent="menu_payment_by_state"
            action="action_payment_state_reconciled"
            sequence="30"/>

        <menuitem id="menu_payment_state_not_reconciled"
            name="Sin Conciliar"
            parent="menu_payment_by_state"
            action="action_payment_state_not_reconciled"
            sequence="40"/>

        <menuitem id="menu_payment_state_cancelled"
            name="Cancelados"
            parent="menu_payment_by_state"
            action="action_payment_state_cancelled"
            sequence="50"/>

    </data>
</odoo>
