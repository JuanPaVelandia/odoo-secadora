<odoo>
    <data>
        <!-- Vista formulario para account.account -->
        <record id="view_account_form_advance" model="ir.ui.view">
            <field name="name">account.account.form.advance</field>
            <field name="model">account.account</field>
            <field name="inherit_id" ref="account.view_account_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tax_ids']" position="after">
                    <field name="is_advance_account"/>
                    <field name="advance_account_type"
                           invisible="not is_advance_account"
                           required="is_advance_account"/>
                </xpath>
            </field>
        </record>

        <!-- Vista lista para account.account -->
        <record id="view_account_list_advance" model="ir.ui.view">
            <field name="name">account.account.list.advance</field>
            <field name="model">account.account</field>
            <field name="inherit_id" ref="account.view_account_list"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='account_type']" position="after">
                    <field name="is_advance_account" widget="boolean_toggle"/>
                    <field name="advance_account_type" optional="hide"/>
                </xpath>
            </field>
        </record>

  
    </data>
</odoo>