<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Vista heredada mínima - solo agrega campos necesarios al formulario base de Odoo
            La vista principal está en account_payment_enhanced_view.xml
        -->
        <record id="view_account_payment_form_inherit_treasury" model="ir.ui.view">
            <field name="name">account.payment.form.inherit.treasury</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <!-- Solo agregar campos invisibles necesarios para que funcione el modelo -->
                <xpath expr="//sheet" position="inside">
                    <field name="is_cash_receipt" invisible="1"/>
                    <field name="payment_number" invisible="1"/>
                    <field name="cash_receipt_number" invisible="1"/>
                    <field name="advance" invisible="1"/>
                    <field name="code_advance" invisible="1"/>
                </xpath>
            </field>
        </record>

        <!-- Vista de lista para líneas de detalle de pago -->
        <record id="view_account_payment_detail_list" model="ir.ui.view">
            <field name="name">account.payment.detail.list</field>
            <field name="model">account.payment.detail</field>
            <field name="arch" type="xml">
                <list string="Líneas de Detalle de Pago" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="payment_id" invisible="context.get('default_payment_id')"/>
                    <field name="move_line_id"/>
                    <field name="invoice_id"/>
                    <field name="partner_id"/>
                    <field name="account_id"/>
                    <field name="name"/>
                    <field name="payment_amount" sum="Total"/>
                    <field name="tax_ids" widget="many2many_tags" options="{'color_field': ''}"/>
                    <field name="debit" sum="Total Débito"/>
                    <field name="credit" sum="Total Crédito"/>
                    <field name="currency_id" groups="base.group_multi_currency"/>
                </list>
            </field>
        </record>

        <!-- Vista Form para detalle de línea de pago -->
        <record id="view_payment_detail_from" model="ir.ui.view">
            <field name="name">account.payment.detail.form</field>
            <field name="model">account.payment.detail</field>
            <field name="arch" type="xml">
                <form string="Detalle de Línea">
                    <sheet>
                        <group>
                            <group string="Documento">
                                <field name="move_line_id" readonly="1"/>
                                <field name="invoice_id" readonly="1"/>
                                <field name="partner_id"/>
                                <field name="account_id"/>
                            </group>
                            <group string="Montos">
                                <field name="currency_id"/>
                                <field name="amount_residual" readonly="1"/>
                                <field name="amount_residual_currency" readonly="1"/>
                                <field name="payment_amount"/>
                            </group>
                        </group>
                        <group>
                            <group string="Tasa de Cambio">
                                <field name="currency_rate" readonly="1"/>
                                <field name="use_manual_rate"/>
                                <field name="manual_currency_rate" invisible="not use_manual_rate"/>
                            </group>
                            <group string="Contabilidad">
                                <field name="debit" readonly="1"/>
                                <field name="credit" readonly="1"/>
                                <field name="balance" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_save_changes" string="Guardar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
