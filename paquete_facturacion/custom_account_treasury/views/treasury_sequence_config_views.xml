<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================ -->
        <!-- VISTAS DE CONFIGURACIÓN DE SECUENCIAS -->
        <!-- ============================================ -->

        <!-- Vista Form -->
        <record id="view_treasury_sequence_config_form" model="ir.ui.view">
            <field name="name">treasury.sequence.config.form</field>
            <field name="model">treasury.sequence.config</field>
            <field name="arch" type="xml">
                <form string="Configuración de Secuencia">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(account.action_account_payments)d"
                                    type="action"
                                    class="oe_stat_button"
                                    icon="fa-money">
                                <field name="usage_count" widget="statinfo" string="Usos"/>
                            </button>
                        </div>

                        <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Nombre de la configuración"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Configuración General">
                                <field name="config_type"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                            <group string="Secuencia">
                                <field name="sequence_id"
                                       options="{'no_quick_create': True}"
                                       context="{'default_company_id': company_id}"/>
                                <field name="prefix" placeholder="Ej: EGR-, RC-"/>
                                <field name="suffix" placeholder="Ej: -2025"/>
                            </group>
                        </group>

                        <group string="Filtros de Aplicación">
                            <group>
                                <field name="payment_type"
                                       invisible="config_type == 'advance'"/>
                                <field name="advance_type_id"
                                       invisible="config_type != 'advance'"
                                       options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="journal_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"
                                       invisible="config_type == 'advance'"/>
                            </group>
                        </group>

                        <div class="alert alert-info" role="status">
                            <h4 class="alert-heading">
                                <i class="fa fa-info-circle me-2" title="Información"/>
                                Guía de Configuración
                            </h4>
                            <p>
                                <strong>Tipo de Configuración:</strong>
                            </p>
                            <ul>
                                <li><strong>Pago/Egreso:</strong> Para pagos a proveedores y transferencias salientes.</li>
                                <li><strong>Recibo de Caja:</strong> Para cobros de clientes.</li>
                                <li><strong>Anticipo:</strong> Para anticipos (puede filtrar por tipo específico).</li>
                            </ul>
                            <p>
                                <strong>Prioridad de Aplicación:</strong>
                            </p>
                            <ol>
                                <li>Configuración con diarios específicos</li>
                                <li>Configuración general por tipo</li>
                            </ol>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista List -->
        <record id="view_treasury_sequence_config_tree" model="ir.ui.view">
            <field name="name">treasury.sequence.config.list</field>
            <field name="model">treasury.sequence.config</field>
            <field name="arch" type="xml">
                <list string="Configuraciones de Secuencia">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="config_type"/>
                    <field name="payment_type" optional="show"/>
                    <field name="advance_type_id" optional="show"/>
                    <field name="journal_ids" widget="many2many_tags" optional="show"/>
                    <field name="sequence_id"/>
                    <field name="prefix" optional="show"/>
                    <field name="usage_count"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Vista Search -->
        <record id="view_treasury_sequence_config_search" model="ir.ui.view">
            <field name="name">treasury.sequence.config.search</field>
            <field name="model">treasury.sequence.config</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="config_type"/>
                    <field name="sequence_id"/>
                    <filter name="payment" string="Pagos/Egresos" domain="[('config_type', '=', 'payment')]"/>
                    <filter name="receipt" string="Recibos" domain="[('config_type', '=', 'receipt')]"/>
                    <filter name="advance" string="Anticipos" domain="[('config_type', '=', 'advance')]"/>
                    <filter name="inactive" string="Archivados" domain="[('active', '=', False)]"/>
                    <group>
                        <filter name="group_by_type" string="Tipo" context="{'group_by': 'config_type'}"/>
                        <filter name="group_by_company" string="Compañía" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción -->
        <record id="action_treasury_sequence_config" model="ir.actions.act_window">
            <field name="name">Secuencias de Tesorería</field>
            <field name="res_model">treasury.sequence.config</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configurar secuencias de tesorería
                </p>
                <p>
                    Configure las secuencias para generar números de egresos,
                    recibos de caja y anticipos.
                </p>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- EXTENSIÓN DE VISTA DE DIARIO -->
        <!-- ============================================ -->
        <record id="view_account_journal_form_treasury_sequence" model="ir.ui.view">
            <field name="name">account.journal.form.treasury.sequence</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='advanced_settings']" position="after">
                    <page string="Secuencias Tesorería" name="treasury_sequences"
                          invisible="type not in ('bank', 'cash')">
                        <group>
                            <group>
                                <field name="use_treasury_numbering"/>
                            </group>
                        </group>
                        <group invisible="not use_treasury_numbering">
                            <group string="Secuencias">
                                <field name="supplier_payment_sequence_id"
                                       string="Secuencia Egresos"
                                       options="{'no_quick_create': True}"/>
                                <field name="customer_payment_sequence_id"
                                       string="Secuencia Recibos"
                                       options="{'no_quick_create': True}"/>
                            </group>
                            <group string="Secuencia General">
                                <field name="treasury_sequence_id"
                                       string="Secuencia General"
                                       options="{'no_quick_create': True}"/>
                            </group>
                        </group>
                        <div class="alert alert-info" role="status" invisible="not use_treasury_numbering">
                            <i class="fa fa-info-circle me-2" title="Información"/>
                            Las secuencias configuradas aquí tienen prioridad sobre las configuraciones globales.
                        </div>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- EXTENSIÓN DE TIPO DE ANTICIPO -->
        <!-- ============================================ -->
        <record id="view_advance_type_form_sequence" model="ir.ui.view">
            <field name="name">advance.type.form.sequence</field>
            <field name="model">advance.type</field>
            <field name="inherit_id" ref="custom_account_treasury.view_advance_type_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='company']" position="after">
                    <group string="Secuencia de Numeración" name="sequence_group">
                        <field name="sequence_id"
                               string="Secuencia"
                               options="{'no_quick_create': True}"/>
                        <field name="sequence_prefix"
                               placeholder="Ej: ANT-CLI, ANT-PROV"/>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
