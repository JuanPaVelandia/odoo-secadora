<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_treasury" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.treasury</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Tesorería" string="Tesorería" name="custom_account_treasury" groups="custom_account_treasury.group_treasury_manager">
                    <block title="Configuración de Anticipos" name="treasury_advances_setting">
                        <setting string="Gestión de Anticipos" help="Configura la gestión de anticipos de clientes y proveedores">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="treasury_default_customer_advance_account_id" string="Cuenta de Anticipos de Clientes" class="col-lg-3"/>
                                    <field name="treasury_default_customer_advance_account_id"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_default_supplier_advance_account_id" string="Cuenta de Anticipos a Proveedores" class="col-lg-3"/>
                                    <field name="treasury_default_supplier_advance_account_id"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_auto_apply_advances" class="col-lg-3"/>
                                    <field name="treasury_auto_apply_advances"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Configuración de Préstamos" name="treasury_loans_setting">
                        <setting string="Gestión de Préstamos" help="Configura la gestión de préstamos a clientes, proveedores y empleados">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="treasury_default_customer_loan_account_id" string="Cuenta de Préstamos a Clientes" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_default_customer_loan_account_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_default_supplier_loan_account_id" string="Cuenta de Préstamos de Proveedores" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_default_supplier_loan_account_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_default_employee_loan_account_id" string="Cuenta de Préstamos a Empleados" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_default_employee_loan_account_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_loan_payment_journal_id" string="Diario de Préstamos" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_loan_payment_journal_id" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="treasury_auto_apply_loans" class="col-lg-4"/>
                                    <field name="treasury_auto_apply_loans"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Diarios de Tesorería" name="treasury_journals_setting">
                        <setting string="Configuración de Diarios" help="Define los diarios utilizados para operaciones de tesorería">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="treasury_advance_payment_journal_id" string="Diario de Anticipos" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_advance_payment_journal_id" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Multi-Tercero" name="treasury_multi_partner_setting">
                        <setting string="Funcionalidad Multi-Tercero" help="Permite asignar diferentes terceros por línea en facturas">
                            <field name="treasury_enable_multi_partner"/>
                            <div class="content-group" invisible="not treasury_enable_multi_partner">
                                <div class="row mt16">
                                    <label for="treasury_multi_partner_default" class="col-lg-4"/>
                                    <field name="treasury_multi_partner_default"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Diferencia en Cambio" name="treasury_exchange_diff_setting">
                        <setting string="Configuración de Diferencia en Cambio" help="Define cómo se registran las diferencias de cambio en pagos con moneda extranjera">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="treasury_exchange_diff_mode" string="Modo de Registro" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_exchange_diff_mode" class="oe_inline"/>
                                </div>
                                <div class="text-muted ms-3 mb-2" style="font-size: 12px;">
                                    <i class="fa fa-info-circle"/> En el mismo asiento: La diferencia se registra como líneas adicionales en el pago.
                                    En asiento separado: Se crea un asiento contable independiente para la diferencia.
                                </div>
                                <div class="row">
                                    <label for="treasury_exchange_diff_group_mode" string="Agrupación de Líneas" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_exchange_diff_group_mode" class="oe_inline"/>
                                </div>
                                <div class="text-muted ms-3 mb-2" style="font-size: 12px;">
                                    <i class="fa fa-info-circle"/> Por línea: Una línea por cada deuda. Agrupado: Por documento. General: Una sola línea consolidada.
                                </div>
                                <div class="row">
                                    <label for="treasury_exchange_diff_separate_journal_id" string="Diario para Diferencias" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_exchange_diff_separate_journal_id" class="oe_inline"
                                           invisible="treasury_exchange_diff_mode != 'separate_entry'"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="Opciones Adicionales" help="Configuraciones adicionales para el manejo de diferencias de cambio">
                            <div class="content-group">
                                <div class="row mt16">
                                    <field name="treasury_exchange_diff_link_document" class="oe_inline"/>
                                    <label for="treasury_exchange_diff_link_document" string="Asociar a Documento Original"/>
                                </div>
                                <div class="row">
                                    <field name="treasury_exchange_diff_auto_reconcile" class="oe_inline"/>
                                    <label for="treasury_exchange_diff_auto_reconcile" string="Conciliar Automáticamente"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="Manejo de IVA Manual" help="Configuración especial cuando hay retenciones de IVA manuales">
                            <div class="content-group">
                                <div class="row mt16">
                                    <field name="treasury_exchange_diff_handle_manual_iva" class="oe_inline"/>
                                    <label for="treasury_exchange_diff_handle_manual_iva" string="Manejar IVA Manual en Diferencia"/>
                                </div>
                                <div class="row" invisible="not treasury_exchange_diff_handle_manual_iva">
                                    <label for="treasury_exchange_diff_iva_account_id" string="Cuenta de Ajuste IVA" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_exchange_diff_iva_account_id" class="oe_inline"/>
                                </div>
                                <div class="text-muted ms-3" style="font-size: 12px;" invisible="not treasury_exchange_diff_handle_manual_iva">
                                    <i class="fa fa-info-circle"/> Cuando se retiene IVA manualmente, la diferencia en cambio se calcula sobre la base sin IVA y se genera un ajuste adicional para el IVA.
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Gastos Bancarios" name="treasury_bank_expense_setting">
                        <setting string="Cuentas de Gastos Bancarios" help="Configura las cuentas para gastos bancarios y comisiones">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="treasury_bank_expense_account_id" string="Cuenta de Gastos Bancarios" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_bank_expense_account_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_bank_expense_iva_account_id" string="Cuenta de IVA Gastos Bancarios" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_bank_expense_iva_account_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="treasury_bank_expense_partner_id" string="Tercero por Defecto" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_bank_expense_partner_id" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="IVA en Gastos Bancarios" help="Configuracion de IVA para gastos bancarios">
                            <div class="content-group">
                                <div class="row mt16">
                                    <field name="treasury_bank_expense_apply_iva" class="oe_inline"/>
                                    <label for="treasury_bank_expense_apply_iva" string="Aplicar IVA a Gastos Bancarios"/>
                                </div>
                                <div class="row" invisible="not treasury_bank_expense_apply_iva">
                                    <label for="treasury_bank_expense_iva_rate" string="Tasa IVA (%)" class="col-lg-4 o_light_label"/>
                                    <field name="treasury_bank_expense_iva_rate" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Action para abrir configuración -->
    <record id="action_treasury_config_settings" model="ir.actions.act_window">
        <field name="name">Configuración de Tesorería</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'custom_account_treasury'}</field>
    </record>

</odoo>
