<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Comisiones Bancolombia - Pagos ACH -->
        <record id="commission_bancolombia_ach_outbound" model="treasury.bank.commission">
            <field name="service_category">ach</field>
            <field name="payment_type">outbound</field>
            <field name="commission_type">fixed</field>
            <field name="commission_fixed">1900</field>
            <field name="notes">Comision ACH a otros bancos - Tarifario Bancolombia 2024</field>
        </record>

