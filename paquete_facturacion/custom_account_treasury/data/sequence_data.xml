<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    	
		<record id="sequence_payment_employee" model="ir.sequence">
            <field name="name">Payments employee sequence</field>
            <field name="code">account.payment.employee</field>
            <field name="prefix">EMPL.OUT-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">4</field>
        </record>

		<record id="sequence_payment_advance_supplier" model="ir.sequence">
            <field name="name">Payments advance supplier sequence</field>
            <field name="code">account.payment.advance.supplier</field>
            <field name="prefix">ANT.SUPP-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">4</field>
        </record>

        <record id="sequence_payment_advance_customer" model="ir.sequence">
            <field name="name">Payments advance customer sequence</field>
            <field name="code">account.payment.advance.customer</field>
            <field name="prefix">ANT.CUST-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">4</field>
        </record>

        <record id="sequence_payment_advance_employee" model="ir.sequence">
            <field name="name">Payments advance employee sequence</field>
            <field name="code">account.payment.advance.employee</field>
            <field name="prefix">ANT.EMPL-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">4</field>
        </record>

        <!-- ===== SECUENCIAS PARA RECIBOS DE CAJA (CRUCES SIN MOVIMIENTO DE EFECTIVO) ===== -->
        <record id="sequence_cash_receipt_customer" model="ir.sequence">
            <field name="name">Recibo de Caja Cliente</field>
            <field name="code">account.cash.receipt.customer</field>
            <field name="prefix">RC-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

        <record id="sequence_cash_receipt_supplier" model="ir.sequence">
            <field name="name">Recibo de Caja Proveedor</field>
            <field name="code">account.cash.receipt.supplier</field>
            <field name="prefix">RC-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

        <record id="sequence_cash_receipt_employee" model="ir.sequence">
            <field name="name">Recibo de Caja Empleado</field>
            <field name="code">account.cash.receipt.employee</field>
            <field name="prefix">RC-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

        <!-- ===== SECUENCIAS PARA RECIBOS DE COBRO (RC) Y COMPROBANTES DE EGRESO (CE) ===== -->

        <!-- RC - Recibo de Cobro (Ingresos/Cobros de Clientes) -->
        <record id="sequence_payment_inbound_customer" model="ir.sequence">
            <field name="name">Recibo de Cobro - Cliente</field>
            <field name="code">account.payment.inbound.customer</field>
            <field name="prefix">RC-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

        <!-- CE - Comprobante de Egreso (Pagos a Proveedores) -->
        <record id="sequence_payment_outbound_supplier" model="ir.sequence">
            <field name="name">Comprobante de Egreso - Proveedor</field>
            <field name="code">account.payment.outbound.supplier</field>
            <field name="prefix">CE-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

        <!-- CE - Comprobante de Egreso (Pagos a Empleados) -->
        <record id="sequence_payment_outbound_employee" model="ir.sequence">
            <field name="name">Comprobante de Egreso - Empleado</field>
            <field name="code">account.payment.outbound.employee</field>
            <field name="prefix">CE-%(range_year)s-</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="True" name="use_date_range"/>
            <field eval="False" name="company_id"/>
            <field name="padding">5</field>
        </record>

    </data>
</odoo>