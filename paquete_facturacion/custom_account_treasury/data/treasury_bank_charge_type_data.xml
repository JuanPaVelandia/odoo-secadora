<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- GMF - Gravamen a los Movimientos Financieros (4x1000) -->
        <record id="charge_type_gmf" model="treasury.bank.charge.type">
            <field name="name">GMF (4x1000)</field>
            <field name="code">GMF</field>
            <field name="sequence">1</field>
            <field name="charge_type">tax</field>
            <field name="apply_iva">False</field>
            <field name="calculation_type">percentage</field>
            <field name="percentage">0.4</field>
            <field name="percentage_base">transaction</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Gravamen a los Movimientos Financieros - 4 por mil sobre retiros y transferencias</field>
        </record>

        <!-- Comision Bancaria -->
        <record id="charge_type_comision" model="treasury.bank.charge.type">
            <field name="name">Comision Bancaria</field>
            <field name="code">COMISION</field>
            <field name="sequence">2</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">True</field>
            <field name="iva_rate">19.0</field>
            <field name="calculation_type">manual</field>
            <field name="apply_to_inbound">True</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Comision por servicios bancarios (ACH, transferencias, etc.)</field>
        </record>

        <!-- IVA sobre Comision -->
        <record id="charge_type_iva_comision" model="treasury.bank.charge.type">
            <field name="name">IVA sobre Comision</field>
            <field name="code">IVA_COM</field>
            <field name="sequence">3</field>
            <field name="charge_type">tax</field>
            <field name="apply_iva">False</field>
            <field name="calculation_type">percentage</field>
            <field name="percentage">19.0</field>
            <field name="percentage_base">transaction</field>
            <field name="apply_to_inbound">True</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">IVA 19% sobre comisiones bancarias</field>
        </record>

        <!-- Cuota de Manejo -->
        <record id="charge_type_cuota_manejo" model="treasury.bank.charge.type">
            <field name="name">Cuota de Manejo</field>
            <field name="code">CUOTA_MANEJO</field>
            <field name="sequence">4</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">True</field>
            <field name="iva_rate">19.0</field>
            <field name="calculation_type">fixed</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">False</field>
            <field name="description">Cuota mensual de manejo de cuenta bancaria</field>
        </record>

        <!-- Chequera -->
        <record id="charge_type_chequera" model="treasury.bank.charge.type">
            <field name="name">Chequera</field>
            <field name="code">CHEQUERA</field>
            <field name="sequence">5</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">True</field>
            <field name="iva_rate">19.0</field>
            <field name="calculation_type">fixed</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Costo de chequera o cheques individuales</field>
        </record>

        <!-- Certificaciones -->
        <record id="charge_type_certificacion" model="treasury.bank.charge.type">
            <field name="name">Certificacion Bancaria</field>
            <field name="code">CERTIF</field>
            <field name="sequence">6</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">True</field>
            <field name="iva_rate">19.0</field>
            <field name="calculation_type">fixed</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">False</field>
            <field name="description">Expedicion de certificaciones bancarias</field>
        </record>

        <!-- Retefuente -->
        <record id="charge_type_retefuente" model="treasury.bank.charge.type">
            <field name="name">Retencion en la Fuente</field>
            <field name="code">RETEFUENTE</field>
            <field name="sequence">10</field>
            <field name="charge_type">withholding</field>
            <field name="apply_iva">False</field>
            <field name="calculation_type">percentage</field>
            <field name="apply_to_inbound">True</field>
            <field name="apply_to_outbound">False</field>
            <field name="description">Retencion en la fuente sobre rendimientos financieros</field>
        </record>

        <!-- Intereses por Sobregiro -->
        <record id="charge_type_interes_sobregiro" model="treasury.bank.charge.type">
            <field name="name">Intereses Sobregiro</field>
            <field name="code">INT_SOBREGIRO</field>
            <field name="sequence">7</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">True</field>
            <field name="iva_rate">19.0</field>
            <field name="calculation_type">manual</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Intereses por uso de sobregiro o cupo de credito</field>
        </record>

        <!-- Seguro de Transaccion -->
        <record id="charge_type_seguro" model="treasury.bank.charge.type">
            <field name="name">Seguro de Transaccion</field>
            <field name="code">SEGURO</field>
            <field name="sequence">8</field>
            <field name="charge_type">expense</field>
            <field name="apply_iva">False</field>
            <field name="calculation_type">fixed</field>
            <field name="apply_to_inbound">False</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Seguro o proteccion de transacciones electronicas</field>
        </record>

        <!-- Otros cargos bancarios -->
        <record id="charge_type_otros" model="treasury.bank.charge.type">
            <field name="name">Otros Cargos Bancarios</field>
            <field name="code">OTROS</field>
            <field name="sequence">99</field>
            <field name="charge_type">other</field>
            <field name="apply_iva">False</field>
            <field name="calculation_type">manual</field>
            <field name="apply_to_inbound">True</field>
            <field name="apply_to_outbound">True</field>
            <field name="description">Otros cargos bancarios no clasificados</field>
        </record>

    </data>
</odoo>
