<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Etapas por defecto -->
        <record id="stage_draft" model="payment.request.stage">
            <field name="name">Borrador</field>
            <field name="sequence">1</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_requested" model="payment.request.stage">
            <field name="name">Solicitado</field>
            <field name="sequence">10</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_approved" model="payment.request.stage">
            <field name="name">Aprobado</field>
            <field name="sequence">20</field>
            <field name="is_approved">True</field>
            <field name="approval_amount">50000</field>
            <field name="fold">False</field>
        </record>

        <record id="stage_paid" model="payment.request.stage">
            <field name="name">Pagado</field>
            <field name="sequence">30</field>
            <field name="is_paid">True</field>
            <field name="fold">True</field>
        </record>

        <record id="stage_cancelled" model="payment.request.stage">
            <field name="name">Cancelado</field>
            <field name="sequence">100</field>
            <field name="is_cancelled">True</field>
            <field name="fold">True</field>
        </record>
    </data>
</odoo>