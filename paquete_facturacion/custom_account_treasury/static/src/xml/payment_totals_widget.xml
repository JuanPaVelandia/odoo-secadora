<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="custom_account_treasury.PaymentTotalsWidget">
        <div class="o_payment_totals">
            <div class="row">
                <!-- Columna izquierda: Por Tipo de Cuenta -->
                <div class="col-md-6">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-light py-2">
                            <h6 class="mb-0"><i class="fa fa-list-alt me-2"/>Por Tipo de Cuenta</h6>
                        </div>
                        <div class="card-body p-0">
                            <t t-foreach="accountGroups" t-as="group" t-key="group.name">
                                <!-- Cabecera del grupo -->
                                <div t-attf-class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-#{group.color}-subtle">
                                    <span>
                                        <i t-attf-class="fa #{group.icon} me-2 text-#{group.color}"/>
                                        <strong t-out="group.name"/>
                                    </span>
                                    <span t-attf-class="badge bg-#{group.color}" t-out="group.formatted_amount"/>
                                </div>
                                <!-- Detalles -->
                                <t t-if="group.details">
                                    <t t-foreach="group.details" t-as="detail" t-key="detail.name">
                                        <div class="d-flex justify-content-between px-3 py-1 small border-bottom" style="padding-left: 2rem !important;">
                                            <span class="text-muted text-truncate" style="max-width: 200px;" t-out="detail.name"/>
                                            <span class="text-nowrap" t-out="detail.formatted_amount"/>
                                        </div>
                                    </t>
                                </t>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Columna derecha: Por Concepto + Total -->
                <div class="col-md-6">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-light py-2">
                            <h6 class="mb-0"><i class="fa fa-tags me-2"/>Por Concepto</h6>
                        </div>
                        <div class="card-body p-0">
                            <t t-foreach="conceptGroups" t-as="group" t-key="group.name">
                                <!-- Cabecera del grupo -->
                                <div t-attf-class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <span>
                                        <i t-attf-class="fa #{group.icon} me-2 text-#{group.color}"/>
                                        <span t-out="group.name"/>
                                    </span>
                                    <span class="fw-semibold" t-out="group.formatted_amount"/>
                                </div>
                                <!-- Detalles (para impuestos) -->
                                <t t-if="group.details">
                                    <t t-foreach="group.details" t-as="detail" t-key="detail.name">
                                        <div class="d-flex justify-content-between px-3 py-1 small border-bottom bg-light" style="padding-left: 2rem !important;">
                                            <span class="text-muted fst-italic text-truncate" style="max-width: 180px;" t-out="detail.name"/>
                                            <span class="text-nowrap" t-out="detail.formatted_amount"/>
                                        </div>
                                    </t>
                                </t>
                            </t>
                        </div>

                        <!-- Total -->
                        <div class="card-footer bg-primary text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold">TOTAL A PAGAR:</span>
                                <span class="fs-4 fw-bold" t-out="formattedTotal"/>
                            </div>
                        </div>
                    </div>

                    <!-- Diferencia -->
                    <t t-if="hasDifference">
                        <div class="alert alert-warning py-2 d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-exclamation-triangle me-2"/>Diferencia:</span>
                            <span class="fw-bold text-danger" t-out="formattedDifference"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
