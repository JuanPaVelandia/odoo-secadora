<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="custom_account_treasury.InvoiceSelectorWidget">
        <div class="o_invoice_selector border rounded p-2 bg-light">
            <!-- Header con controles -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="d-flex align-items-center gap-2">
                    <strong class="text-primary">
                        <i class="fa fa-file-text-o me-1"/>
                        Documentos Pendientes
                    </strong>
                    <span class="badge bg-secondary" t-if="state.invoices.length">
                        <t t-esc="state.invoices.length"/> docs
                    </span>
                </div>
                <div class="d-flex gap-1">
                    <button type="button" class="btn btn-sm btn-outline-primary"
                            t-on-click="refresh" title="Actualizar">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>
            </div>

            <!-- Barra de búsqueda y filtros -->
            <div class="d-flex gap-2 mb-2" t-if="state.invoices.length > 0">
                <div class="flex-grow-1">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Buscar por número o referencia..."
                           t-on-input="onSearchChange"
                           t-att-value="state.searchTerm"/>
                </div>
                <div class="btn-group btn-group-sm">
                    <button type="button"
                            t-attf-class="btn {{ state.showOverdue ? 'btn-danger' : 'btn-outline-danger' }}"
                            t-on-click="toggleOverdue" title="Vencidas">
                        <i class="fa fa-exclamation-circle"/> Vencidas
                    </button>
                    <button type="button"
                            t-attf-class="btn {{ state.showCurrent ? 'btn-success' : 'btn-outline-success' }}"
                            t-on-click="toggleCurrent" title="Por vencer">
                        <i class="fa fa-clock-o"/> Por vencer
                    </button>
                </div>
            </div>

            <!-- Botones de selección masiva -->
            <div class="d-flex gap-1 mb-2" t-if="state.invoices.length > 0">
                <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="selectAll">
                    <i class="fa fa-check-square-o"/> Todas
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="deselectAll">
                    <i class="fa fa-square-o"/> Ninguna
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger" t-on-click="selectOverdue">
                    <i class="fa fa-exclamation-triangle"/> Solo vencidas
                </button>
            </div>

            <!-- Loading -->
            <div class="text-center py-3" t-if="state.loading">
                <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                <p class="text-muted mt-2">Cargando documentos...</p>
            </div>

            <!-- Sin partner -->
            <div class="text-center py-3 text-muted" t-if="!partnerId and !state.loading">
                <i class="fa fa-user-o fa-2x mb-2"/>
                <p>Seleccione un tercero para ver documentos pendientes</p>
            </div>

            <!-- Sin documentos -->
            <div class="text-center py-3 text-muted" t-if="partnerId and !state.loading and state.invoices.length === 0">
                <i class="fa fa-check-circle fa-2x text-success mb-2"/>
                <p>No hay documentos pendientes</p>
            </div>

            <!-- Lista de facturas -->
            <div class="o_invoice_list" style="max-height: 300px; overflow-y: auto;"
                 t-if="!state.loading and filteredInvoices.length > 0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width: 30px;"></th>
                            <th>Documento</th>
                            <th class="text-center">Vence</th>
                            <th class="text-center">Días</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Pendiente</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="filteredInvoices" t-as="invoice" t-key="invoice.id">
                            <tr t-attf-class="{{ invoice.isOverdue ? 'table-danger' : '' }} {{ state.selectedIds.has(invoice.id) ? 'table-primary' : '' }}"
                                style="cursor: pointer;">
                                <td class="text-center" t-on-click="() => this.toggleInvoice(invoice.id)">
                                    <input type="checkbox" class="form-check-input"
                                           t-att-checked="state.selectedIds.has(invoice.id)"
                                           t-on-change="() => this.toggleInvoice(invoice.id)"/>
                                </td>
                                <td t-on-click="() => this.openInvoice(invoice.id)">
                                    <div class="d-flex align-items-center">
                                        <i t-attf-class="fa {{ invoice.isRefund ? 'fa-minus-circle text-warning' : 'fa-file-text-o text-primary' }} me-1"/>
                                        <div>
                                            <strong t-esc="invoice.name"/>
                                            <small class="d-block text-muted" t-if="invoice.ref" t-esc="invoice.ref"/>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center" t-esc="invoice.dueDateFormatted"/>
                                <td class="text-center">
                                    <span t-if="invoice.isOverdue"
                                          class="badge bg-danger"
                                          t-esc="'+' + invoice.daysDue"/>
                                    <span t-else=""
                                          class="badge bg-success"
                                          t-esc="invoice.daysDue"/>
                                </td>
                                <td class="text-end text-muted">
                                    <small t-esc="invoice.totalFormatted"/>
                                </td>
                                <td class="text-end fw-bold">
                                    <span t-attf-class="{{ invoice.isRefund ? 'text-warning' : 'text-dark' }}">
                                        <t t-if="invoice.isRefund">-</t>
                                        <t t-esc="invoice.amountFormatted"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Footer con total y botón agregar -->
            <div class="border-top pt-2 mt-2" t-if="state.invoices.length > 0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted">Seleccionados:</span>
                        <strong class="ms-1 text-primary" t-esc="selectedCount"/>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="text-end">
                            <small class="text-muted d-block">Total a pagar</small>
                            <strong class="text-success fs-5">
                                $ <t t-esc="formatCurrency(state.totalSelected)"/>
                            </strong>
                        </div>
                        <button type="button"
                                class="btn btn-primary"
                                t-att-disabled="!hasSelection"
                                t-on-click="addSelectedToPayment">
                            <i class="fa fa-plus me-1"/>
                            Agregar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
