<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIBRO DE PAGOS ==================== -->

    <!-- Vista Form del Wizard Libro de Pagos -->
    <record id="view_treasury_payment_book_wizard_form" model="ir.ui.view">
        <field name="name">treasury.payment.book.wizard.form</field>
        <field name="model">treasury.payment.book.wizard</field>
        <field name="arch" type="xml">
            <form string="Libro de Pagos">
                <group>
                    <group string="Rango de Fechas">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Filtros">
                        <field name="journal_ids" widget="many2many_tags"/>
                        <field name="payment_type"/>
                        <field name="partner_id"/>
                        <field name="state_filter"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button name="action_view_payments" string="Ver Pagos" type="object" class="btn-secondary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del Wizard Libro de Pagos -->
    <record id="action_treasury_payment_book_wizard" model="ir.actions.act_window">
        <field name="name">Libro de Pagos</field>
        <field name="res_model">treasury.payment.book.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ==================== ARQUEO DE CAJA ==================== -->

    <!-- Vista Form del Wizard Arqueo de Caja -->
    <record id="view_treasury_cash_box_wizard_form" model="ir.ui.view">
        <field name="name">treasury.cash.box.wizard.form</field>
        <field name="model">treasury.cash.box.wizard</field>
        <field name="arch" type="xml">
            <form string="Arqueo de Caja">
                <group>
                    <group string="Rango de Fechas">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Caja">
                        <field name="journal_id"/>
                        <field name="include_details"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button name="action_view_movements" string="Ver Movimientos" type="object" class="btn-secondary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del Wizard Arqueo de Caja -->
    <record id="action_treasury_cash_box_wizard" model="ir.actions.act_window">
        <field name="name">Arqueo de Caja</field>
        <field name="res_model">treasury.cash.box.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
