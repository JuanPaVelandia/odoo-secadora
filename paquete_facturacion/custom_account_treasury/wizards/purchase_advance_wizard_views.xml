<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================ -->
    <!-- WIZARD: ANTICIPO RÁPIDO DE COMPRAS -->
    <!-- ============================================ -->

    <record id="purchase_advance_wizard_form" model="ir.ui.view">
        <field name="name">purchase.advance.wizard.form</field>
        <field name="model">purchase.advance.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Anticipo de Compra">
                <group>
                    <group string="Proveedor y Órdenes">
                        <field name="partner_id"
                               options="{'no_create': True}"
                               placeholder="Seleccione proveedor..."/>
                        <field name="purchase_order_ids"
                               widget="many2many_tags"
                               placeholder="Seleccione órdenes..."
                               options="{'no_create': True}"
                               invisible="not partner_id"/>
                        <field name="company_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group string="Configuración del Anticipo">
                        <field name="advance_type_id"
                               options="{'no_create': True}"
                               placeholder="Tipo de anticipo..."/>
                        <field name="percentage" widget="percentage"/>
                        <field name="create_mode" widget="radio"/>
                    </group>
                </group>

                <!-- Resumen de Montos -->
                <group string="Resumen" invisible="not purchase_order_ids">
                    <group>
                        <field name="orders_total" widget="monetary" readonly="1"/>
                        <field name="orders_paid" widget="monetary" readonly="1"/>
                        <field name="orders_pending" widget="monetary" readonly="1"/>
                    </group>
                    <group>
                        <field name="amount" widget="monetary" class="oe_inline"/>
                        <field name="journal_id"
                               invisible="create_mode != 'direct'"
                               required="create_mode == 'direct'"
                               options="{'no_create': True}"/>
                        <field name="payment_date"
                               invisible="create_mode != 'direct'"/>
                    </group>
                </group>

                <field name="memo" placeholder="Referencia o concepto del anticipo..."/>

                <!-- Detalle de Órdenes -->
                <notebook invisible="not purchase_order_ids">
                    <page string="Detalle de Órdenes" name="order_detail">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" create="0" delete="0">
                                <field name="include" widget="boolean_toggle"/>
                                <field name="order_name"/>
                                <field name="order_date"/>
                                <field name="order_amount" sum="Total Órdenes"/>
                                <field name="advance_amount" sum="Total Anticipo"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button name="action_create_advance"
                            string="Crear Anticipo"
                            type="object"
                            class="btn-primary"
                            invisible="not purchase_order_ids"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir desde Tesorería -->
    <record id="action_purchase_advance_wizard" model="ir.actions.act_window">
        <field name="name">Anticipo de Compras</field>
        <field name="res_model">purchase.advance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_create_mode': 'direct'}</field>
    </record>

    <!-- ============================================ -->
    <!-- VISTA DE ÓRDENES DE COMPRA PARA TESORERÍA -->
    <!-- ============================================ -->

    <record id="purchase_order_treasury_list" model="ir.ui.view">
        <field name="name">purchase.order.treasury.list</field>
        <field name="model">purchase.order</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Órdenes de Compra"
                  decoration-info="state in ('draft', 'sent')"
                  decoration-warning="state == 'to approve'"
                  decoration-success="state == 'purchase'"
                  multi_edit="1">
                <header>
                    <button name="%(action_purchase_advance_wizard)d"
                            string="Crear Anticipo"
                            type="action"
                            class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_order"/>
                <field name="amount_total" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('draft', 'sent')"
                       decoration-warning="state == 'to approve'"
                       decoration-success="state == 'purchase'"/>
                <field name="invoice_status" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="purchase_order_treasury_search" model="ir.ui.view">
        <field name="name">purchase.order.treasury.search</field>
        <field name="model">purchase.order</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
                <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="pending" string="Pendientes de Pago"
                        domain="[('invoice_status', '!=', 'invoiced')]"/>
                <filter name="confirmed" string="Confirmadas"
                        domain="[('state', '=', 'purchase')]"/>
                <filter name="to_approve" string="Por Aprobar"
                        domain="[('state', '=', 'to approve')]"/>
                <filter name="this_month" string="Este Mes"
                        domain="[('date_order', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="group_partner" string="Agrupar por Proveedor" context="{'group_by': 'partner_id'}"/>
                <filter name="group_state" string="Agrupar por Estado" context="{'group_by': 'state'}"/>
                <filter name="group_date" string="Agrupar por Fecha" context="{'group_by': 'date_order:month'}"/>
            </search>
        </field>
    </record>

    <!-- Acción para ver órdenes desde Tesorería -->
    <record id="action_purchase_orders_treasury" model="ir.actions.act_window">
        <field name="name">Órdenes de Compra</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('purchase_order_treasury_list')})]"/>
        <field name="search_view_id" ref="purchase_order_treasury_search"/>
        <field name="domain">[('state', 'in', ['draft', 'sent', 'to approve', 'purchase'])]</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay órdenes de compra pendientes
            </p>
            <p>
                Seleccione órdenes de compra para crear anticipos directamente.
            </p>
        </field>
    </record>

</odoo>
