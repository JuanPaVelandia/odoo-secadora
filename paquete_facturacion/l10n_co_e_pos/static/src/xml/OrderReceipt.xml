<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_co_e_pos.OrderReceiptCO">
        <div class="pos-receipt">
            <t t-set="client" t-value="order.partner_id"/>
            <t t-set="is_refund" t-value="order.totalDue &lt; 0"/>
            <t t-set="sign" t-value="is_refund ? -1 : 1"/>
            <t t-set="company" t-value="order.company"/>

            <!-- Logo -->
            <div class="pos-receipt-center-align">
                <img t-if="company.id" t-attf-src="/web/image?model=res.company&amp;id={{company.id}}&amp;field=logo"
                     alt="Logo" class="pos-receipt-logo"/>
            </div>

            <!-- Company Info -->
            <div class="pos-receipt-center-align" style="font-size: 11px; line-height: 1.3;">
                <t t-if="company.name">
                    <b style="font-size: 12px;"><t t-esc="company.name"/></b><br/>
                </t>
                <t t-if="company.vat">
                    <t t-esc="company.vat"/><br/>
                </t>
                <t t-if="company.street">
                    <t t-esc="company.street"/><br/>
                </t>
                <t t-if="company.phone">
                    TEL: <t t-esc="company.phone"/><br/>
                </t>
            </div>

            <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>

            <!-- Factura Header -->
            <t t-if="order.to_invoice">
                <div class="pos-receipt-center-align" style="margin: 8px 0;">
                    <b style="font-size: 12px;">
                        <t t-if="is_refund and order.dian_number and order.dian_number !== 'false'">NOTA CRÉDITO ELECTRÓNICA</t>
                        <t t-elif="is_refund">NOTA CRÉDITO</t>
                        <t t-elif="order.dian_number and order.dian_number !== 'false'">Factura Electrónica de Venta</t>
                        <t t-else="">FACTURA DE VENTA</t>
                    </b>
                </div>

                <div style="display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 8px;">
                    <div>
                        <t t-if="order.dian_number and order.dian_number !== 'false'">
                            <b><t t-esc="order.dian_number"/></b>
                        </t>
                        <t t-else="">
                            <b><t t-esc="order.name"/></b>
                        </t>
                    </div>
                </div>

                <div style="font-size: 10px; margin-bottom: 4px;">
                    Fecha: <t t-if="order.dian_invoice_date"><t t-esc="order.dian_invoice_date"/></t>
                    <t t-else=""><t t-esc="order.formatDateOrTime('date_order', 'date')"/></t>
                </div>
            </t>

            <!-- Customer Info -->
            <div style="font-size: 10px; text-align: left; margin: 8px 0; line-height: 1.4;">
                <div><b>Cliente:</b> <t t-esc="client ? client.name : 'Cliente General'"/></div>
                <t t-if="client and client.vat">
                    <div><b>C.C. / Nit:</b> <t t-esc="client.vat"/></div>
                </t>
                <t t-if="client and (client.phone or client.mobile)">
                    <div><b>Teléfono:</b> <t t-esc="client.mobile || client.phone"/></div>
                </t>
                <t t-if="client and client.street">
                    <div><b>Dirección:</b> <t t-esc="client.street"/></div>
                </t>
            </div>

            <div style="font-size: 10px; margin-bottom: 8px;">
                <b>Vendedor:</b> <t t-esc="order.getCashierName()"/>
            </div>

            <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>

            <!-- Products Table -->
            <div style="font-size: 10px;">
                <div style="display: flex; justify-content: space-between; font-weight: bold; border-bottom: 1px solid #000; padding-bottom: 3px; margin-bottom: 5px;">
                    <div style="flex: 1;">PRODUCTO Y/O SERVICIO</div>
                    <div style="text-align: right; min-width: 80px;">TOTAL</div>
                </div>

                <t t-foreach="order.lines" t-as="line" t-key="line.id">
                    <div style="margin-bottom: 6px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 2px;">
                            <div style="flex: 1;">
                                <t t-esc="(line.qty * sign).toFixed(0)"/> x
                                <t t-if="line.product_id.default_code">[<t t-esc="line.product_id.default_code"/>] </t>
                                <t t-esc="line.getFullProductName()"/>
                            </div>
                            <div style="text-align: right; min-width: 80px;">
                                <t t-esc="formatCurrency(line.priceExcl * sign)"/>
                            </div>
                        </div>
                        <t t-if="line.discount">
                            <div style="font-size: 9px; color: #666; margin-left: 15px;">
                                Desc. <t t-esc="line.discount"/>%
                            </div>
                        </t>
                    </div>
                </t>
            </div>

            <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>

            <!-- Totals -->
            <div style="font-size: 11px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <div><b>SUB TOTAL:</b></div>
                    <div style="text-align: right;"><t t-esc="formatCurrency(order.priceExcl * sign)"/></div>
                </div>

                <t t-if="order.getTotalDiscount()">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                        <div><b>DESCUENTOS:</b></div>
                        <div style="text-align: right;"><t t-esc="formatCurrency(order.getTotalDiscount() * sign)"/></div>
                    </div>
                </t>

                <t t-if="order.amountTaxes > 0">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                        <div><b>IMPUESTOS:</b></div>
                        <div style="text-align: right;"><t t-esc="formatCurrency(order.amountTaxes * sign)"/></div>
                    </div>
                </t>

                <div style="display: flex; justify-content: space-between; margin-bottom: 3px; padding-top: 3px; border-top: 1px solid #000;">
                    <div><b>TOTAL A PAGAR:</b></div>
                    <div style="text-align: right;"><b><t t-esc="formatCurrency(order.totalDue * sign)"/></b></div>
                </div>

                <t t-foreach="paymentLines" t-as="pay" t-key="pay.id">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                        <div><b><t t-esc="pay.payment_method_id.name"/>:</b></div>
                        <div style="text-align: right;"><t t-esc="formatCurrency(pay.getAmount() * sign)"/></div>
                    </div>
                </t>

                <t t-if="!is_refund and order.change">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                        <div><b>CAMBIO:</b></div>
                        <div style="text-align: right;"><t t-esc="formatCurrency(order.change)"/></div>
                    </div>
                </t>
            </div>

            <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>

            <!-- Tax Details Table -->
            <t t-set="taxDetails" t-value="order.prices.taxDetails"/>
            <t t-if="taxDetails and taxDetails.has_tax_groups">
                <div style="font-size: 9px; margin: 8px 0;">
                    <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; font-weight: bold; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 4px;">
                        <div>IMPUESTOS</div>
                        <div style="text-align: right;">VR BASE</div>
                        <div style="text-align: right;">VR IVA</div>
                        <div style="text-align: right;">VR TOTAL</div>
                    </div>
                    <t t-foreach="taxDetails.subtotals" t-as="subtotal" t-key="subtotal.name">
                        <t t-foreach="subtotal.tax_groups" t-as="tg" t-key="tg.id">
                            <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; margin-bottom: 2px;">
                                <div><t t-esc="tg.group_name"/></div>
                                <div style="text-align: right;"><t t-esc="formatCurrency(tg.base_amount_currency * sign)"/></div>
                                <div style="text-align: right;"><t t-esc="formatCurrency(tg.tax_amount_currency * sign)"/></div>
                                <div style="text-align: right;"><t t-esc="formatCurrency((tg.base_amount_currency + tg.tax_amount_currency) * sign)"/></div>
                            </div>
                        </t>
                    </t>
                </div>
                <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>
            </t>

            <!-- CUFE DIAN -->
            <t t-if="order.to_invoice and order.dian_cufe and order.dian_cufe !== false and order.dian_cufe !== 'false'">
                <div class="pos-receipt-center-align" style="margin: 8px 0;">
                    <b style="font-size: 10px;">CUFE DIAN</b>
                </div>
                <div class="pos-receipt-center-align" style="word-wrap: break-word; word-break: break-all; font-size: 7px; line-height: 1.2; margin-bottom: 8px;">
                    <t t-esc="order.dian_cufe"/>
                </div>
            </t>

            <!-- QR Code -->
            <t t-if="order.to_invoice and order.dian_co_qr_data and order.dian_co_qr_data !== false and order.dian_co_qr_data !== 'false'">
                <div class="pos-receipt-center-align" style="margin: 10px 0;">
                    <img id="qrcodeCO" t-att-src="order.dian_co_qr_data" style="width: 180px; height: 180px;"/>
                </div>
            </t>

            <!-- Resolución DIAN -->
            <t t-if="order.to_invoice and order.dian_resolution_number and order.dian_resolution_number !== 'false'">
                <div class="pos-receipt-center-align" style="font-size: 8px; line-height: 1.3; margin: 8px 0;">
                    <b>RESOLUCIÓN DE FACTURACIÓN ELECTRÓNICA</b><br/>
                    <t t-esc="order.dian_resolution_number"/>
                    <t t-if="order.dian_resolution_date and order.dian_resolution_date_to">
                        <t t-esc="order.dian_resolution_date"/> - <t t-esc="order.dian_resolution_date_to"/>
                    </t><br/>
                    <t t-if="order.dian_resolution_number_from and order.dian_resolution_number_to">
                        PREFIJO <t t-if="order.dian_ref"><t t-esc="order.dian_ref"/> </t>
                        DEL <t t-esc="order.dian_resolution_number_from"/> AL <t t-esc="order.dian_resolution_number_to"/>
                    </t>
                </div>
                <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>
            </t>

            <!-- Fecha de vencimiento -->
            <t t-if="order.dian_invoice_date_due and order.dian_invoice_date_due !== false and order.dian_invoice_date_due !== 'false'">
                <div class="pos-receipt-center-align" style="font-size: 11px; margin: 8px 0;">
                    <b>Fecha Vencimiento:</b> <t t-esc="order.dian_invoice_date_due"/><br/>
                    <b>FACTURA A CRÉDITO</b>
                </div>
                <div style="border-top: 1px dashed #000; margin: 8px 0;"></div>
            </t>

            <!-- Footer -->
            <t t-if="order.config.receipt_footer">
                <div class="pos-receipt-center-align" style="font-size: 8px; white-space: pre-line; line-height: 1.2; margin-top: 8px;">
                    <t t-esc="order.config.receipt_footer"/>
                </div>
            </t>

            <div class="pos-receipt-center-align" style="font-size: 9px; margin-top: 10px;">
                <t t-esc="order.name"/> - <t t-esc="order.formatDateOrTime('date_order')"/>
            </div>
        </div>
    </t>
</templates>
