<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de formulario de Account Move con campo de modo de cálculo de impuestos -->
    <record id="view_move_form_tax_mode" model="ir.ui.view">
        <field name="name">account.move.form.tax.mode</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Agregar el campo después del journal -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="tax_calculation_mode"
                       widget="radio"
                       options="{'horizontal': true}"
                       readonly="state == 'posted'"/>
            </xpath>

        </field>
    </record>

</odoo>
