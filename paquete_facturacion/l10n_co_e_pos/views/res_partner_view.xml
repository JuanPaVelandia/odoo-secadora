<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista formulario SIMPLE para POS Colombia - Creada desde cero -->
        <record id="view_partner_form_pos_co_simple" model="ir.ui.view">
            <field name="name">res.partner.form.pos.co.simple</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <form string="Cliente" class="o_pos_partner_form">
                    <sheet>
                        <div class="container-fluid">
                            <!-- 1. ES UNA EMPRESA (Header con Icono Grande) -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="card border-lacasa-verde shadow-sm">
                                        <div class="card-body p-4">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center">
                                                    <!-- Icono grande dinámico -->
                                                    <div class="me-4">
                                                        <div class="partner-type-icon" invisible="is_company">
                                                            <i class="fa fa-user-circle fa-4x text-primary" title="Persona Natural"/>
                                                        </div>
                                                        <div class="partner-type-icon" invisible="not is_company">
                                                            <i class="fa fa-building fa-4x text-warning" title="Empresa"/>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <h5 class="mb-1" style="color: #7a814a !important;" invisible="is_company">
                                                            <strong>Persona Natural</strong>
                                                        </h5>
                                                        <h5 class="mb-1" style="color: #e91e8c !important;" invisible="not is_company">
                                                            <strong>Empresa / Persona Jurídica</strong>
                                                        </h5>
                                                        <p class="text-muted mb-0 small">Seleccione el tipo de cliente</p>
                                                    </div>
                                                </div>
                                                <div class="text-end">
                                                    <label for="is_company" class="form-label mb-2 small text-muted">Es una empresa</label>
                                                    <field name="is_company" widget="boolean_toggle" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 2. IDENTIFICACIÓN (Card Bootstrap) -->
                            <div class="row mb-3">
                                <div class="col-12">
                                    <div class="card border-lacasa-turquesa">
                                        <div class="card-header bg-lacasa-turquesa text-white">
                                            <h6 class="mb-0"><i class="fa fa-id-card me-2" title="Identificacion"/>Identificación</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-6 mb-2">
                                                    <field name="l10n_latam_identification_type_id"
                                                           string="Tipo de Identificación"
                                                           placeholder="Seleccione tipo de documento"
                                                           required="1"
                                                           domain="[('l10n_co_document_code', '!=', False)]"
                                                           options="{'no_create': True, 'no_open': True}"
                                                           class="form-control"/>
                                                </div>
                                                <div class="col-md-6 mb-2">
                                                    <field name="vat"
                                                           string="NIT/CC"
                                                           placeholder="Número de Documento"
                                                           required="1"
                                                           class="form-control"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 3. NOMBRES (Card Bootstrap - Persona Natural) -->
                            <div class="row mb-3" invisible="is_company">
                                <div class="col-12">
                                    <div class="card border-lacasa-verde">
                                        <div class="card-header bg-lacasa-verde text-white">
                                            <h6 class="mb-0"><i class="fa fa-user me-2" title="Personal"/>Información Personal</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-6 mb-2">
                                                    <field name="first_name"
                                                           string="Primer Nombre"
                                                           placeholder="Primer Nombre"
                                                           required="not is_company"
                                                           class="form-control"/>
                                                </div>
                                                <div class="col-md-6 mb-2">
                                                    <field name="second_name"
                                                           string="Segundo Nombre"
                                                           placeholder="Segundo Nombre (Opcional)"
                                                           class="form-control"/>
                                                </div>
                                                <div class="col-md-6 mb-2">
                                                    <field name="first_lastname"
                                                           string="Primer Apellido"
                                                           placeholder="Primer Apellido"
                                                           required="not is_company"
                                                           class="form-control"/>
                                                </div>
                                                <div class="col-md-6 mb-2">
                                                    <field name="second_lastname"
                                                           string="Segundo Apellido"
                                                           placeholder="Segundo Apellido (Opcional)"
                                                           class="form-control"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 3. RAZÓN SOCIAL (Card Bootstrap - Empresa) -->
                            <div class="row mb-3" invisible="not is_company">
                                <div class="col-12">
                                    <div class="card border-lacasa-rosa">
                                        <div class="card-header bg-lacasa-rosa text-white">
                                            <h6 class="mb-0"><i class="fa fa-building me-2" title="Empresa"/>Información de la Empresa</h6>
                                        </div>
                                        <div class="card-body">
                                            <field name="name"
                                                   string="Razón Social"
                                                   placeholder="Nombre de la Empresa"
                                                   required="is_company"
                                                   class="form-control"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 4. CONTACTO Y DIRECCIÓN (Lado a Lado) -->
                            <div class="row mb-3">
                                <!-- CONTACTO (Izquierda) -->
                                <div class="col-md-6">
                                    <div class="card border-lacasa-turquesa h-100">
                                        <div class="card-header bg-lacasa-turquesa text-white">
                                            <h6 class="mb-0"><i class="fa fa-phone me-2" title="Contacto"/>Contacto</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-2">
                                                <field name="phone" string="Teléfono" placeholder="Teléfono" class="form-control"/>
                                            </div>
                                            <div class="mb-2">
                                                <field name="mobile" string="Celular" placeholder="Celular" class="form-control"/>
                                            </div>
                                            <div class="mb-2">
                                                <field name="email" string="Correo Electrónico" placeholder="correo@ejemplo.com" class="form-control"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- DIRECCIÓN (Derecha) -->
                                <div class="col-md-6">
                                    <div class="card border-lacasa-verde h-100">
                                        <div class="card-header bg-lacasa-verde text-white">
                                            <h6 class="mb-0"><i class="fa fa-map-marker me-2" title="Direccion"/>Dirección</h6>
                                        </div>
                                        <div class="card-body">
                                            <!-- Campos ocultos -->
                                            <field name="state_id" invisible="1"
                                                   domain="[('country_id', '=', country_id)]"
                                                   options="{'no_create': True, 'no_open': True}"/>
                                            <field name="zip" invisible="1"/>

                                            <div class="mb-2">
                                                <field name="street" string="Calle" placeholder="Dirección completa" class="form-control"/>
                                            </div>
                                            <div class="mb-2">
                                                <field name="country_id" string="País" options="{'no_create': True, 'no_open': True}" class="form-control"/>
                                            </div>
                                            <div class="mb-2">
                                                <field name="city_id"
                                                       string="Ciudad"
                                                       placeholder="Seleccione ciudad"
                                                       domain="[('country_id', '=', country_id)]"
                                                       options="{'no_create': True, 'no_open': True}"
                                                       class="form-control"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 6. INFORMACIÓN FISCAL (Card Bootstrap con Badge) -->
                            <div class="row mb-3">
                                <div class="col-12">
                                    <div class="card border-lacasa-rosa">
                                        <div class="card-header bg-lacasa-rosa text-white">
                                            <h6 class="mb-0"><i class="fa fa-file-text me-2" title="Fiscal"/>Información Fiscal DIAN</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-4 mb-2">
                                                    <field name="category_id"
                                                           string="Categorías"
                                                           widget="many2many_tags"
                                                           options="{'color_field': 'color', 'no_create_edit': True}"/>
                                                </div>
                                                <div class="col-md-4 mb-2">
                                                    <field name="tribute_id"
                                                           string="Tributo"
                                                           options="{'no_create': True, 'no_open': True}"
                                                           class="form-control"/>
                                                </div>
                                                <div class="col-md-4 mb-2">
                                                    <field name="fiscal_responsability_ids"
                                                           string="Responsabilidades"
                                                           widget="many2many_tags"
                                                           options="{'no_create_edit': True}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 7. INFORMACIÓN DE CRÉDITO (Card Bootstrap con Iconos) -->
                            <div class="row mb-3">
                                <div class="col-12">
                                    <div class="card border-lacasa-amarillo">
                                        <div class="card-header bg-lacasa-amarillo text-dark">
                                            <h6 class="mb-0"><i class="fa fa-dollar me-2" title="Credito"/>Información de Crédito</h6>
                                        </div>
                                        <div class="card-body">
                                            <field name="currency_id" invisible="1"/>
                                            <div class="row">
                                                <div class="col-md-4 mb-2">
                                                    <label for="credit_limit" class="text-muted small">Límite de Crédito</label>
                                                    <field name="credit_limit" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </div>
                                                <div class="col-md-4 mb-2">
                                                    <label for="credit" class="text-success small">A Cobrar</label>
                                                    <field name="credit" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </div>
                                                <div class="col-md-4 mb-2">
                                                    <label for="debit" class="text-danger small">A Pagar</label>
                                                    <field name="debit" widget="monetary" options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 8. FIRMA ELECTRÓNICA (Card Bootstrap) -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="card border-lacasa-verde">
                                    <div class="card-header bg-lacasa-verde text-white">
                                        <h6 class="mb-0"><i class="fa fa-pencil-square-o me-2" title="Firma"/>Firma Electrónica y Autorización de Datos</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <!-- Checkbox de Términos -->
                                            <div class="col-md-6 mb-3">
                                                <div class="form-check">
                                                    <field name="terms_accepted" widget="boolean" nolabel="1" class="form-check-input"/>
                                                    <label class="form-check-label" for="terms_accepted">
                                                        <strong>Acepto los Términos y Condiciones</strong>
                                                    </label>
                                                </div>
                                            </div>

                                            <!-- Checkbox de Política de Datos (HABEAS DATA) -->
                                            <div class="col-md-6 mb-3">
                                                <div class="form-check">
                                                    <field name="privacy_policy_accepted" widget="boolean" nolabel="1" class="form-check-input"/>
                                                    <label class="form-check-label" for="privacy_policy_accepted">
                                                        <strong>Autorizo Tratamiento de Datos Personales (HABEAS DATA)</strong>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mt-3">
                                            <!-- Área de Firma -->
                                            <div class="col-md-8">
                                                <div class="o_form_label"><i class="fa fa-pencil me-1" title="Firma"/>Firma del Cliente</div>
                                                <field name="signature_image" widget="signature" options="{'size': [400, 200]}"/>
                                                <small class="text-muted">Firme en el recuadro usando su dedo o lápiz táctil</small>
                                            </div>

                                            <!-- Información de Firma -->
                                            <div class="col-md-4">
                                                <div class="card bg-light">
                                                    <div class="card-body">
                                                        <h6 class="card-title">Información de Firma</h6>

                                                        <!-- Cuando SÍ hay firma -->
                                                        <div invisible="not signature_date">
                                                            <p class="mb-1">
                                                                <i class="fa fa-calendar text-success me-1" title="Fecha"/>
                                                                <strong>Firmado:</strong>
                                                            </p>
                                                            <field name="signature_date" readonly="1" nolabel="1"/>
                                                            <hr/>
                                                            <div class="badge bg-success">
                                                                <i class="fa fa-check-circle me-1" title="Confirmado"/>Firmado
                                                            </div>
                                                        </div>

                                                        <!-- Cuando NO hay firma -->
                                                        <div invisible="signature_date">
                                                            <p class="text-muted mb-0">
                                                                <i class="fa fa-info-circle me-1" title="Información"/>
                                                                Sin firma registrada
                                                            </p>
                                                            <div class="badge bg-warning mt-2">
                                                                Pendiente
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Notebook con Facturas -->
                        <notebook>
                            <page string="Facturas Pendientes" name="invoices">
                                <field name="invoice_ids"
                                       domain="[('move_type', '=', 'out_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ['not_paid', 'partial'])]"
                                       context="{'default_partner_id': id, 'default_move_type': 'out_invoice'}">
                                    <list string="Facturas" create="0" delete="0">
                                        <field name="name" string="Número"/>
                                        <field name="invoice_date" string="Fecha"/>
                                        <field name="invoice_date_due" string="Vencimiento"/>
                                        <field name="amount_total_in_currency_signed" string="Total"/>
                                        <field name="amount_residual_signed" string="Saldo Pendiente"/>
                                        <field name="status_in_payment" string="Estado Pago" widget="badge" decoration-warning="payment_state == 'partial'" decoration-danger="payment_state == 'not_paid'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Heredar la acción estándar de POS para usar nuestra vista simple -->
        <record id="point_of_sale.res_partner_action_edit_pos" model="ir.actions.act_window">
            <field name="view_id" ref="view_partner_form_pos_co_simple"/>
            <field name="context" eval="{
                'default_country_id': ref('base.co'),
                'default_is_company': False,
                'default_tribute_id': ref('l10n_co_e_invoice.tribute_ZZ'),
                'default_fiscal_responsability_ids': [(6, 0, [ref('l10n_co_e_invoice.fiscal_responsability_R-99-PN')])],
            }"/>
        </record>

    </data>
</odoo>
