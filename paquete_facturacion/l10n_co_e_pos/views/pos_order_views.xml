<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de lista (tree) para pos.order - Campos DIAN Colombia -->
    <record id="view_pos_order_tree_co" model="ir.ui.view">
        <field name="name">pos.order.tree.co</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <!-- Agregar columnas DIAN después de la columna 'name' -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="dian_number" optional="show" string="N° DIAN"/>
                <field name="dian_invoice_date" optional="show" string="Fecha DIAN"/>
                <field name="dian_state_dian_document" optional="hide" string="Estado DIAN"/>
                <field name="l10n_co_edi_nc_type" optional="hide" string="Tipo NC"/>
            </xpath>

            <!-- Decoración: marcar en verde las facturadas con DIAN -->
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-success">dian_number and dian_state_dian_document == 'Aceptado'</attribute>
                <attribute name="decoration-warning">dian_number and dian_state_dian_document != 'Aceptado' and dian_state_dian_document</attribute>
                <attribute name="decoration-muted">not dian_number</attribute>
            </xpath>
        </field>
    </record>

    <!-- Vista de formulario para pos.order - Campos Colombia -->
    <record id="view_pos_pos_form_co" model="ir.ui.view">
        <field name="name">pos.order.form.co</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">

            <!-- Agregar campo Tipo de NC después de refunded_order_id -->
            <xpath expr="//field[@name='refunded_order_id']" position="after">
                <field name="l10n_co_edi_nc_type"
                       readonly="1"
                       invisible="not refunded_order_id"
                       widget="selection"
                       string="Tipo NC"/>
            </xpath>

            <!-- Agregar campos DIAN en grupo "Facturación DIAN" -->
            <xpath expr="//group[@name='order_total']" position="after">
                <group string="Facturación Electrónica DIAN" name="dian_info"
                       invisible="not account_move">
                    <group string="Datos de Factura">
                        <field name="dian_number" readonly="1" string="Número DIAN"/>
                        <field name="dian_cufe" readonly="1" string="CUFE"
                               widget="CopyClipboardChar"/>
                        <field name="dian_state_dian_document" readonly="1" string="Estado DIAN"
                               widget="badge" decoration-success="dian_state_dian_document == 'Aceptado'"
                               decoration-warning="dian_state_dian_document != 'Aceptado'"/>
                    </group>
                    <group string="Fechas">
                        <field name="dian_invoice_date" readonly="1" string="Fecha Emisión"/>
                        <field name="dian_invoice_date_due" readonly="1" string="Fecha Vencimiento"/>
                    </group>
                    <group string="Resolución DIAN" invisible="not dian_resolution_number">
                        <field name="dian_resolution_number" readonly="1" string="Número Resolución"/>
                        <field name="dian_resolution_date" readonly="1" string="Fecha Resolución"/>
                    </group>
                </group>
            </xpath>

            <!-- Agregar Smart Buttons para ver factura DIAN -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_view_dian_invoice"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="not dian_number"
                        help="Ver factura DIAN">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Factura</span>
                        <span class="o_stat_value"><field name="dian_number"/></span>
                    </div>
                </button>

                <button type="object"
                        name="action_view_refund_origin"
                        class="oe_stat_button"
                        icon="fa-undo"
                        invisible="not refunded_order_id"
                        help="Ver orden original de este refund">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Factura</span>
                        <span class="o_stat_text">Original</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>



</odoo>
