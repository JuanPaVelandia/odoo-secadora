<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Secuencias para documentos DIAN -->
        <record id="seq_dian_document" model="ir.sequence">
            <field name="name">DIAN Document Sequence</field>
            <field name="code">dian.document</field>
            <field name="prefix">DIAN/%(year)s/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Tipos de documento DIAN -->
        <record id="dian_doc_type_01" model="dian.document.type">
            <field name="code">01</field>
            <field name="name">Factura de Venta</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_02" model="dian.document.type">
            <field name="code">02</field>
            <field name="name">Factura de Exportación</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_03" model="dian.document.type">
            <field name="code">03</field>
            <field name="name">Factura de Contingencia</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_04" model="dian.document.type">
            <field name="code">04</field>
            <field name="name">Factura Electrónica Tipo 04</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_05" model="dian.document.type">
            <field name="code">05</field>
            <field name="name">Documento Soporte</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_91" model="dian.document.type">
            <field name="code">91</field>
            <field name="name">Nota Crédito</field>
            <field name="active">True</field>
        </record>

        <record id="dian_doc_type_92" model="dian.document.type">
            <field name="code">92</field>
            <field name="name">Nota Débito</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>