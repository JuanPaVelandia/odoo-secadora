<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dian_unify_lines_wizard_form" model="ir.ui.view">
        <field name="name">dian.unify.lines.wizard.form</field>
        <field name="model">dian.unify.lines.wizard</field>
        <field name="arch" type="xml">
            <form string="Unificar Líneas en un Producto">
                <group>
                    <group>
                        <field name="processor_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="line_count" readonly="1"/>
                        <field name="total_amount" readonly="1"/>
                    </group>
                </group>

                <separator string="Seleccione el Producto"/>
                <group>
                    <group colspan="2">
                        <field name="product_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="quantity"/>
                        <field name="uom_id"/>
                        <field name="description" colspan="2" placeholder="Descripción personalizada (opcional)"/>
                    </group>
                </group>

                <div class="alert alert-info" role="status">
                    <p><strong>Información:</strong></p>
                    <ul>
                        <li>Se eliminarán todas las <strong><field name="line_count"/> líneas actuales</strong></li>
                        <li>Se creará <strong>1 línea</strong> con el producto seleccionado</li>
                        <li>El precio unitario se calculará automáticamente para mantener el total de <strong><field name="total_amount" widget="monetary"/></strong></li>
                    </ul>
                </div>

                <footer>
                    <button string="Unificar" type="object" name="action_unify" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
