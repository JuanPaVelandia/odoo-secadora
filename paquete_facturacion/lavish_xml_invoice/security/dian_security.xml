<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="privilege_dian" model="res.groups.privilege">
            <field name="name">DIAN</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
        </record>

        <!-- Grupo de Usuario DIAN -->
        <record model="res.groups" id="group_dian_user">
            <field name="name">DIAN User</field>
            <field name="privilege_id" ref="privilege_dian"/>
        </record>

        <!-- Grupo de Administrador DIAN -->
        <record model="res.groups" id="group_dian_manager">
            <field name="name">DIAN Manager</field>
            <field name="privilege_id" ref="privilege_dian"/>
            <field name="implied_ids" eval="[(4, ref('group_dian_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
