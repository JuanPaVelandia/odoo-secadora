    <!-- =================================================================== -->
    <!-- VISTA MEJORADA DEL PROCESADOR CON INFORMACIÓN VISUAL -->
    <!-- =================================================================== -->

    <record id="view_dian_document_processor_form_visual_improved" model="ir.ui.view">
        <field name="name">dian.document.processor.form.visual.improved</field>
        <field name="model">dian.document.processor</field>
        <field name="inherit_id" ref="view_dian_document_processor_form_po_creation"/>
        <field name="arch" type="xml">

            <!-- Agregar widget statusbar mejorado -->
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="widget">statusbar</attribute>
                <attribute name="clickable">1</attribute>
            </xpath>

            <!-- Ocultar campos de referencias vacías -->
            <xpath expr="//field[@name='billing_reference_id']" position="attributes">
                <attribute name="invisible">not billing_reference_id</attribute>
            </xpath>

            <xpath expr="//field[@name='billing_reference_cufe']" position="attributes">
                <attribute name="invisible">not billing_reference_cufe</attribute>
            </xpath>

            <xpath expr="//field[@name='billing_reference_date']" position="attributes">
                <attribute name="invisible">not billing_reference_date</attribute>
            </xpath>

            <!-- Ocultar motivos de NC/ND si no aplican -->
            <xpath expr="//field[@name='credit_note_reason']" position="attributes">
                <attribute name="invisible">document_type != '91'</attribute>
            </xpath>

            <xpath expr="//field[@name='debit_note_reason']" position="attributes">
                <attribute name="invisible">document_type != '92'</attribute>
            </xpath>

            <!-- Ocultar anticipos si no hay -->
            <xpath expr="//field[@name='amount_prepaid']" position="attributes">
                <attribute name="invisible">amount_prepaid == 0</attribute>
            </xpath>

            <!-- Ocultar cargos si están en 0 -->
            <xpath expr="//field[@name='amount_charges']" position="attributes">
                <attribute name="invisible">amount_charges == 0</attribute>
            </xpath>

        </field>
    </record>

</odoo>
