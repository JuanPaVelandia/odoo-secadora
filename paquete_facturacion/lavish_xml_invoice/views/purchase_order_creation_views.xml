<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =================================================================== -->
    <!-- CREACIÓN DE ÓRDENES DE COMPRA DESDE DIAN -->
    <!-- =================================================================== -->

    <!-- Extensión de la vista form del procesador para agregar creación de OC -->
    <record id="view_dian_document_processor_form_po_creation" model="ir.ui.view">
        <field name="name">dian.document.processor.form.po.creation</field>
        <field name="model">dian.document.processor</field>
        <field name="inherit_id" ref="view_dian_document_processor_form_po_matching"/>
        <field name="arch" type="xml">

            <!-- Agregar botones de creación de OC -->
            <xpath expr="//header/button[@name='action_view_purchase_orders']" position="after">
                <button name="action_create_purchase_order"
                        string="Crear Orden de Compra"
                        type="object"
                        class="btn-success"
                        icon="fa-plus-circle"
                        invisible="state not in ['processed', 'validated'] or not supplier_id"
                        groups="purchase.group_purchase_manager"/>

                <button name="action_view_suggested_po_by_amount"
                        string="Buscar por Monto"
                        type="object"
                        class="btn-info"
                        icon="fa-search-dollar"
                        invisible="not has_suggested_po_by_amount"
                        groups="purchase.group_purchase_user"/>
            </xpath>

            <!-- Agregar estadísticas de sugerencias -->
            <xpath expr="//group[@name='po_matching_info']" position="inside">
                <field name="has_suggested_po_by_amount" invisible="1"/>
                <field name="suggested_po_by_amount_ids" invisible="1"/>
                <label for="has_suggested_po_by_amount" string="OC Sugeridas por Monto"
                       invisible="not has_suggested_po_by_amount"/>
                <div invisible="not has_suggested_po_by_amount">
                    <span class="badge badge-info">
                        <field name="suggested_po_by_amount_ids" widget="many2many_tags" readonly="1"/>
                    </span>
                </div>
            </xpath>

            <!-- Mejorar visualización de campos con colspan -->
            <xpath expr="//group[@name='document_info']" position="attributes">
                <attribute name="colspan">2</attribute>
            </xpath>

            <xpath expr="//group[@name='parties']" position="attributes">
                <attribute name="colspan">2</attribute>
            </xpath>

            <xpath expr="//group[@name='currency_info']" position="attributes">
                <attribute name="colspan">2</attribute>
            </xpath>

            <!-- Ocultar campos vacíos -->
            <xpath expr="//field[@name='order_reference']" position="attributes">
                <attribute name="invisible">not order_reference</attribute>
            </xpath>

            <xpath expr="//field[@name='despatch_reference']" position="attributes">
                <attribute name="invisible">not despatch_reference</attribute>
            </xpath>

            <xpath expr="//field[@name='receipt_reference']" position="attributes">
                <attribute name="invisible">not receipt_reference</attribute>
            </xpath>

            <xpath expr="//field[@name='contract_reference']" position="attributes">
                <attribute name="invisible">not contract_reference</attribute>
            </xpath>

            <!-- Agregar colspan a campos Many2many y One2many -->
            <xpath expr="//field[@name='line_ids']" position="attributes">
                <attribute name="colspan">2</attribute>
            </xpath>

            <!-- Mejorar vista inline de líneas con subtotales y descuentos -->
            <xpath expr="//field[@name='line_ids']/list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>

            <xpath expr="//field[@name='line_ids']/list/field[@name='price_unit']" position="after">
                <field name="discount_amount" optional="show" sum="Total Descuentos"/>
                <field name="charge_amount" optional="hide"/>
                <field name="price_subtotal" sum="Subtotal" readonly="1"/>
                <field name="tax_amount" optional="show" sum="Total Impuestos" readonly="1"/>
                <field name="price_total" sum="Total General" readonly="1"/>
            </xpath>

        </field>
    </record>

    <!-- =================================================================== -->
    <!-- WIZARD: SUGERENCIAS DE OC POR MONTO -->
    <!-- =================================================================== -->

    <record id="view_dian_po_suggestion_wizard_form" model="ir.ui.view">
        <field name="name">dian.po.suggestion.wizard.form</field>
        <field name="model">dian.po.suggestion.wizard</field>
        <field name="arch" type="xml">
            <form string="Órdenes de Compra Sugeridas por Monto">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <i class="fa fa-search-dollar" title="Busqueda"/> Búsqueda de OC por Monto
                        </h1>
                    </div>

                    <group colspan="2">
                        <group string="Documento DIAN">
                            <field name="processor_id" readonly="1"/>
                            <field name="supplier_id" readonly="1"/>
                            <field name="document_amount" widget="monetary" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>

                        <group string="Criterios de Búsqueda">
                            <label for="tolerance_percentage"/>
                            <div class="o_row">
                                <field name="tolerance_percentage" widget="percentage" class="oe_inline"/>
                                <button name="action_refresh_suggestions"
                                        string="Actualizar"
                                        type="object"
                                        class="btn-sm btn-secondary"
                                        icon="fa-refresh"/>
                            </div>
                            <field name="has_suggestions" invisible="1"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="status" invisible="not has_suggestions">
                        <strong><i class="fa fa-info-circle" title="Informacion"/> Información:</strong>
                        Se encontraron órdenes de compra con montos similares (±<field name="tolerance_percentage" class="oe_inline"/>%).
                        Click en "Asociar" para hacer match automático de líneas.
                    </div>

                    <div class="alert alert-warning" role="status" invisible="has_suggestions">
                        <strong><i class="fa fa-exclamation-triangle" title="Advertencia"/> No se encontraron resultados</strong><br/>
                        No hay órdenes de compra con montos similares.
                        Intente aumentar la tolerancia o cree una nueva orden de compra.
                    </div>

                    <separator string="Órdenes Sugeridas" invisible="not has_suggestions"/>

                    <field name="suggestion_ids" invisible="not has_suggestions" nolabel="1" colspan="2">
                        <list string="Sugerencias" decoration-success="similarity_score &gt;= 0.95"
                              decoration-info="similarity_score &gt;= 0.90 and similarity_score &lt; 0.95"
                              decoration-warning="similarity_score &gt;= 0.80 and similarity_score &lt; 0.90"
                              create="false" delete="false">

                            <!-- Columna de similitud visual -->
                            <field name="similarity_score" string="Similitud %" widget="percentage"/>

                            <!-- Información de la OC -->
                            <field name="po_name" string="Número OC"/>
                            <field name="po_date" string="Fecha"/>
                            <field name="po_date_planned" string="Entrega" optional="show"/>
                            <field name="po_line_count" string="# Líneas"/>
                            <field name="po_partner_ref" string="Ref. Proveedor" optional="hide"/>

                            <!-- Cantidades pendientes -->
                            <field name="po_qty_to_receive" string="Pend. Recibir"
                                   optional="show"
                                   decoration-warning="po_qty_to_receive &gt; 0"/>
                            <field name="po_qty_to_invoice" string="Pend. Facturar"
                                   optional="show"
                                   decoration-warning="po_qty_to_invoice &gt; 0"/>

                            <!-- Montos -->
                            <field name="po_amount" string="Monto OC" widget="monetary" sum="Total"/>
                            <field name="amount_difference" string="Diferencia" widget="monetary"
                                   decoration-danger="amount_difference &lt; 0"
                                   decoration-success="amount_difference == 0"
                                   decoration-warning="amount_difference &gt; 0"/>
                            <field name="difference_percentage" string="Dif. %" widget="percentage"
                                   optional="hide"/>

                            <!-- Estado facturación -->
                            <field name="po_invoice_status" string="Facturación" widget="badge"
                                   optional="show"
                                   decoration-success="po_invoice_status == 'invoiced'"
                                   decoration-warning="po_invoice_status == 'to invoice'"
                                   decoration-info="po_invoice_status == 'no'"/>

                            <!-- Estado -->
                            <field name="po_state" string="Estado" widget="badge"
                                   decoration-success="po_state == 'purchase'"
                                   decoration-info="po_state == 'done'"/>

                            <!-- Botón de acción -->
                            <button name="action_match_with_order"
                                    string="Asociar"
                                    type="object"
                                    class="btn-primary btn-sm"
                                    icon="fa-link"/>

                            <!-- Campos ocultos -->
                            <field name="purchase_order_id" column_invisible="1"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="similarity_class" column_invisible="1"/>
                        </list>
                    </field>

                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- =================================================================== -->
    <!-- VISTA MEJORADA DE LÍNEAS CON CAMPOS OCULTOS -->
    <!-- =================================================================== -->
