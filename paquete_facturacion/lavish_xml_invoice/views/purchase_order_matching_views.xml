<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =================================================================== -->
    <!-- EXTENSIÓN DE VISTAS PARA MATCHING CON ÓRDENES DE COMPRA -->
    <!-- =================================================================== -->

    <!-- Extensión de la vista form del procesador principal para agregar matching -->
    <record id="view_dian_document_processor_form_po_matching" model="ir.ui.view">
        <field name="name">dian.document.processor.form.po.matching</field>
        <field name="model">dian.document.processor</field>
        <field name="inherit_id" ref="lavish_xml_invoice.view_dian_document_processor_form"/>
        <field name="arch" type="xml">

            <!-- Agregar botones en el header -->
            <xpath expr="//header/button[@name='process_xml']" position="after">
                <button name="action_open_po_matching_wizard"
                        string="Asociar con OC"
                        type="object"
                        class="btn-primary"
                        icon="fa-shopping-cart"
                        invisible="state not in ['processed', 'validated'] or not supplier_id"
                        groups="purchase.group_purchase_user"/>

                <button name="action_auto_match_all_po_lines"
                        string="Match Automático OC"
                        type="object"
                        class="btn-success"
                        icon="fa-bolt"
                        invisible="state not in ['processed', 'validated'] or not supplier_id"
                        groups="purchase.group_purchase_user"/>

                <button name="action_view_purchase_orders"
                        string="Ver Órdenes de Compra"
                        type="object"
                        icon="fa-external-link"
                        invisible="not has_po_matches"
                        groups="purchase.group_purchase_user"/>
            </xpath>

            <!-- Agregar campos de matching en el grupo de información -->
            <xpath expr="//group[@name='parties']" position="after">
                <group string="Matching con Órdenes de Compra" name="po_matching_info"
                       invisible="not supplier_id">
                    <field name="purchase_order_count" readonly="1"/>
                    <field name="has_po_matches" invisible="1"/>
                    <field name="po_match_progress" widget="progressbar"/>
                    <field name="purchase_order_ids" invisible="1"/>
                </group>
            </xpath>

            <!-- Extender el list inline de líneas para agregar campos de matching -->
            <xpath expr="//field[@name='line_ids']/list/field[@name='product_id']" position="after">
                <field name="purchase_line_id" optional="hide"/>
                <field name="po_match_percentage"
                       string="Match %"
                       widget="percentage"
                       optional="hide"/>
                <field name="is_po_auto_matchable"
                       string="Auto"
                       widget="boolean"
                       optional="hide"/>
            </xpath>

            <!-- Agregar decoraciones al list de líneas -->
            <xpath expr="//field[@name='line_ids']/list" position="attributes">
                <attribute name="decoration-bf">purchase_line_id != False</attribute>
            </xpath>

        </field>
    </record>

    <!-- =================================================================== -->
    <!-- WIZARD: SELECCIÓN DE LÍNEA DE OC -->
    <!-- =================================================================== -->

    <record id="view_dian_po_line_selection_wizard_form" model="ir.ui.view">
        <field name="name">dian.po.line.selection.wizard.form</field>
        <field name="model">dian.po.line.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Seleccionar Línea de Orden de Compra">
                <sheet>
                    <group>
                        <group string="Línea DIAN">
                            <field name="dian_line_id" readonly="1"/>
                            <field name="supplier_id" readonly="1"/>
                            <field name="product_name" readonly="1"/>
                            <field name="quantity" readonly="1"/>
                            <field name="price_unit" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Seleccionar Orden de Compra"/>
                    <group>
                        <field name="purchase_order_id"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>

                    <separator string="Líneas Disponibles" invisible="not purchase_order_id"/>
                    <group invisible="not purchase_order_id">
                        <field name="po_line_ids" invisible="1"/>
                        <field name="selected_po_line_id"
                               widget="selection"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>

                    <group string="Información de Línea Seleccionada"
                           invisible="not selected_po_line_id">
                        <group>
                            <field name="selected_line_qty" readonly="1"/>
                            <field name="selected_line_price" readonly="1"/>
                        </group>
                        <group>
                            <field name="match_score"
                                   widget="percentpie"
                                   string="Similitud"
                                   readonly="1"/>
                        </group>
                    </group>

                    <div class="alert alert-success" role="alert"
                         invisible="not selected_po_line_id or match_score &lt; 0.8">
                        <strong>Excelente coincidencia:</strong>
                        Esta línea tiene alta similitud con la línea DIAN
                    </div>

                    <div class="alert alert-warning" role="alert"
                         invisible="not selected_po_line_id or match_score &gt;= 0.8 or match_score &lt; 0.5">
                        <strong>Coincidencia media:</strong>
                        Verifique que la línea sea correcta
                    </div>

                    <div class="alert alert-danger" role="alert"
                         invisible="not selected_po_line_id or match_score &gt;= 0.5">
                        <strong>Baja coincidencia:</strong>
                        Esta línea tiene poca similitud con la línea DIAN
                    </div>

                </sheet>
                <footer>
                    <button string="Confirmar Asociación"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- =================================================================== -->
    <!-- WIZARD: MATCHING MASIVO CON OC -->
    <!-- =================================================================== -->

    <record id="view_dian_po_matching_wizard_form" model="ir.ui.view">
        <field name="name">dian.po.matching.wizard.form</field>
        <field name="model">dian.po.matching.wizard</field>
        <field name="arch" type="xml">
            <form string="Asociar con Órdenes de Compra">
                <sheet>
                    <group>
                        <group string="Documento">
                            <field name="processor_id" readonly="1"/>
                            <field name="supplier_id" readonly="1"/>
                        </group>

                        <group string="Estadísticas">
                            <field name="total_lines" readonly="1"/>
                            <field name="already_matched" readonly="1"/>
                            <field name="matchable_lines" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Configuración de Matching"/>
                    <group>
                        <group>
                            <field name="auto_match_threshold"
                                   widget="percentage"
                                   help="Umbral mínimo (0.75 = 75%)"/>
                            <field name="only_exact_matches"/>
                        </group>
                        <group>
                            <field name="purchase_order_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <p><strong>Información:</strong></p>
                        <ul>
                            <li>El sistema buscará automáticamente líneas de OC pendientes de facturar</li>
                            <li>Se compararán productos, descripciones, cantidades y precios</li>
                            <li>Solo se asociarán líneas que superen el umbral de similitud</li>
                            <li>Las UdM incompatibles serán marcadas como advertencias</li>
                        </ul>
                    </div>

                    <div class="alert alert-warning" role="alert"
                         invisible="matchable_lines == 0">
                        <strong>Advertencia:</strong>
                        Se encontraron <field name="matchable_lines" readonly="1" class="oe_inline"/>
                        líneas que pueden ser asociadas automáticamente
                    </div>

                </sheet>
                <footer>
                    <button string="Vista Previa"
                            name="action_preview_matches"
                            type="object"
                            class="btn-secondary"
                            icon="fa-eye"/>
                    <button string="Ejecutar Matching"
                            name="action_execute_matching"
                            type="object"
                            class="btn-primary"
                            icon="fa-bolt"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
