<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============== VISTAS PARA EL PROCESADOR DIAN (SIN ATTRS/STATES) ============== -->
    
    <!-- Vista Form -->
    <record id="view_dian_document_processor_form" model="ir.ui.view">
        <field name="name">dian.document.processor.form</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <form string="Documento Electrónico DIAN">
                <header>
                    <button name="process_xml" type="object" string="Procesar XML" class="btn-primary"/>
                    <button name="action_retrieve_xml_from_dian" type="object" string="Recuperar desde DIAN" class="btn-info" icon="fa-cloud-download"/>
                    <button name="validate_xml_signature" type="object" string="Validar Firma" class="btn-secondary" icon="fa-shield"/>
                    <button name="create_invoice" type="object" string="Crear Factura" class="btn-success" confirm="¿Está seguro de crear la factura en Odoo?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,xml_loaded,processed,validated,invoiced"/>
                </header>
                <sheet>
                    <!-- Campo invisible para control -->
                    <field name="has_validation_warning" invisible="1"/>

                    <!-- Area de carga de archivos (visible solo en estado borrador) -->
                    <div class="o_invoice_upload alert alert-info text-center p-4 mb-4" invisible="state != 'draft'" role="status">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="text-center">
                                    <i class="fa fa-file-code-o fa-2x d-block mb-2" title="XML"/>
                                    <div class="fw-bold mb-2">Cargar XML</div>
                                    <field name="xml_content" filename="xml_filename" widget="binary" nolabel="1"/>
                                    <field name="xml_filename" invisible="1"/>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center">
                                    <i class="fa fa-file-archive-o fa-2x d-block mb-2" title="ZIP"/>
                                    <div class="fw-bold mb-2">Cargar ZIP</div>
                                    <field name="zip_file" filename="zip_filename" widget="binary" nolabel="1"/>
                                    <field name="zip_filename" invisible="1"/>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex flex-column align-items-center">
                                    <i class="fa fa-cloud-download fa-2x mb-2 text-info" title="Recuperar desde DIAN"/>
                                    <span class="text-muted">o ingresa CUFE para recuperar desde DIAN</span>
                                    <field name="cufe" placeholder="CUFE/CUDE" class="mt-2" style="max-width: 300px;"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Indicador de archivo cargado -->
                    <div class="alert alert-success text-center mb-3" invisible="state == 'draft' or not xml_filename" role="status">
                        <i class="fa fa-check-circle" title="Archivo cargado"/> Archivo cargado: <strong><field name="xml_filename" readonly="1" class="oe_inline"/></strong>
                    </div>

                    <!-- Título con tipo de documento -->
                    <div class="oe_title">
                        <label for="document_type"/>
                        <h1>
                            <field name="document_type" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                            <field name="document_number" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>
                    
                    <!-- Mensaje de Validación -->
                    <group>
                        <field name="validation_message" readonly="1" placeholder="Sin advertencias" string="Estado de Validación"/>
                    </group>
                    
                    <!-- Grupos principales -->
                    <group>
                        <group name="document_info" string="Información del Documento">
                            <field name="cufe" readonly="1"/>
                            <field name="issue_date" readonly="1"/>
                            <field name="due_date" readonly="1"/>
                            <field name="payment_means_code" readonly="1"/>
                            <field name="invoice_period_start" readonly="1"/>
                            <field name="invoice_period_end" readonly="1"/>
                        </group>
                        <group name="parties" string="Terceros">
                            <field name="supplier_id" readonly="1" context="{'show_vat': True}"/>
                            <field name="customer_id" readonly="1" context="{'show_vat': True}"/>
                            <field name="delivery_partner_id" readonly="1" context="{'show_vat': True}"/>
                        </group>
                    </group>
                    
                    <group>
                        <group name="currency_info" string="Moneda y Tasa de Cambio">
                            <field name="document_currency_id" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="exchange_rate" digits="[16, 6]"/>
                            <field name="exchange_rate_date"/>
                        </group>
                        <group name="references" string="Referencias">
                            <field name="billing_reference_id" readonly="1"/>
                            <field name="billing_reference_cufe" readonly="1"/>
                            <field name="billing_reference_date" readonly="1"/>
                            <field name="order_reference" readonly="1"/>
                            <field name="despatch_reference" readonly="1"/>
                            <field name="receipt_reference" readonly="1"/>
                            <field name="contract_reference" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Notebook con pestañas -->
                    <notebook>
                        <!-- Pestaña única: Líneas y Resumen -->
                        <page string="Documento" colspan="2">
                            <!-- Botones de acciones masivas -->
                            <div class="oe_button_box mb-3">
                                <button name="action_unify_lines_to_product" type="object"
                                        string="Unificar en un Producto"
                                        class="btn-primary"
                                        icon="fa-compress"
                                        invisible="not line_ids"
                                        help="Unifica todas las líneas en una sola con un producto específico"/>
                            </div>

                            <!-- 1. Líneas de productos/servicios -->
                            <field name="line_ids" nolabel="1" colspan="2">
                                <list string="Líneas"
                                      decoration-warning="has_product_match == False"
                                      decoration-success="has_product_match == True"
                                      decoration-info="is_unified == True"
                                      editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="is_unified" column_invisible="1"/>
                                    <field name="product_code" optional="show"/>
                                    <field name="product_name"/>
                                    <field name="product_id" domain="[('purchase_ok', '=', True)]"/>
                                    <field name="has_product_match" column_invisible="1"/>
                                    <field name="match_confidence" widget="percentage" optional="hide"/>
                                    <field name="unified_line_count" string="Líneas Unificadas" optional="show" readonly="1"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" groups="uom.group_uom"/>
                                    <field name="price_unit"/>
                                    <field name="discount_percentage" optional="show"/>
                                    <field name="discount_amount" optional="show" sum="Total Descuentos"/>
                                    <field name="charge_amount" optional="hide"/>
                                    <field name="price_subtotal" sum="Subtotal" readonly="1"/>
                                    <field name="tax_amount" optional="show" sum="Total Impuestos" readonly="1"/>
                                    <field name="tax_ids" widget="many2many_tags" optional="show" readonly="1"/>
                                    <field name="price_total" sum="Total General" readonly="1"/>
                                    <field name="price_calculation_method" optional="hide"/>
                                    <button name="find_product" type="object" string="Buscar" icon="fa-search"/>
                                    <button name="create_product" type="object" string="Crear" icon="fa-plus" confirm="¿Crear nuevo producto?"/>
                                </list>
                                <form>
                                    <group>
                                        <group string="Producto">
                                            <field name="product_code"/>
                                            <field name="product_ean"/>
                                            <field name="product_name"/>
                                            <field name="product_brand"/>
                                            <field name="product_model"/>
                                            <field name="product_id"/>
                                            <field name="match_confidence" widget="percentage"/>
                                        </group>
                                        <group string="Cantidades y Precios">
                                            <field name="quantity"/>
                                            <field name="uom_code"/>
                                            <field name="uom_id"/>
                                            <field name="price_unit"/>
                                            <field name="price_calculation_method"/>
                                        </group>
                                        <group string="Descuentos y Totales">
                                            <field name="discount_percentage"/>
                                            <field name="discount_amount"/>
                                            <field name="charge_amount"/>
                                            <field name="price_subtotal"/>
                                            <field name="tax_amount"/>
                                            <field name="price_total"/>
                                        </group>
                                        <group string="Información Adicional">
                                            <field name="mandatary_partner_id"/>
                                            <field name="delivery_date"/>
                                            <field name="notes"/>
                                        </group>
                                    </group>
                                    <group string="Impuestos del XML" colspan="2">
                                        <field name="tax_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                                        <field name="tax_details" readonly="1" nolabel="1"/>
                                    </group>
                                    <group string="Líneas Unificadas" invisible="not is_unified" colspan="2">
                                        <field name="is_unified" invisible="1"/>
                                        <field name="unified_line_count" readonly="1"/>
                                        <field name="unified_from_line_ids" nolabel="1" colspan="2">
                                            <list string="Líneas Originales" create="false" delete="false">
                                                <field name="sequence"/>
                                                <field name="product_name"/>
                                                <field name="quantity"/>
                                                <field name="uom_id"/>
                                                <field name="price_unit"/>
                                                <field name="price_subtotal"/>
                                            </list>
                                        </field>
                                    </group>
                                </form>
                            </field>

                            <!-- 2. Descuentos y Cargos Globales -->
                            <group string="Descuentos y Cargos Globales" invisible="not allowance_charge_ids" colspan="2">
                                <field name="allowance_charge_ids" readonly="1" nolabel="1" colspan="2">
                                    <list string="Descuentos/Cargos" create="false" delete="false">
                                        <field name="type"/>
                                        <field name="reason"/>
                                        <field name="percentage"/>
                                        <field name="base_amount" sum="Base Total"/>
                                        <field name="amount" sum="Monto Total"/>
                                    </list>
                                </field>
                            </group>

                            <!-- 3. Pagos Anticipados -->
                            <group string="Pagos Anticipados" invisible="not prepaid_ids" colspan="2">
                                <field name="prepaid_ids" readonly="1" nolabel="1" colspan="2">
                                    <list string="Anticipos" create="false" delete="false">
                                        <field name="payment_id"/>
                                        <field name="paid_date"/>
                                        <field name="paid_amount" sum="Total Anticipos"/>
                                    </list>
                                </field>
                            </group>

                            <!-- 4. Resumen de Impuestos -->
                            <separator string="Resumen de Impuestos" colspan="2"/>
                            <field name="tax_summary_ids" readonly="1" nolabel="1" colspan="2">
                                <list string="Impuestos" decoration-danger="is_withholding" create="false" delete="false">
                                    <field name="tax_code"/>
                                    <field name="tax_name"/>
                                    <field name="tax_base" sum="Base Imponible"/>
                                    <field name="tax_percentage"/>
                                    <field name="tax_amount" sum="Total Impuestos"/>
                                    <field name="is_withholding"/>
                                    <field name="tax_id"/>
                                    <button name="find_odoo_tax" type="object" string="Asociar Impuesto" icon="fa-link"/>
                                </list>
                            </field>

                            <!-- 5. Totales finales -->
                            <group colspan="2">
                                <group string="Totales" class="oe_subtotal_footer oe_right">
                                    <field name="amount_untaxed" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Subtotal"/>
                                    <field name="amount_discount" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Descuentos" invisible="amount_discount == 0"/>
                                    <field name="amount_charges" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Cargos" invisible="amount_charges == 0"/>
                                    <field name="amount_prepaid" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Anticipos" invisible="amount_prepaid == 0"/>
                                    <field name="amount_tax" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Impuestos"/>
                                    <field name="amount_withholding" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Retenciones" invisible="amount_withholding == 0"/>
                                    <div class="oe_subtotal_footer_separator oe_inline">
                                        <label for="amount_total" string="Total"/>
                                        <field name="amount_total" nolabel="1" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" class="oe_subtotal_footer_separator"/>
                                    </div>
                                    <field name="payable_amount" readonly="1" widget="monetary" options="{'currency_field': 'document_currency_id'}" string="Monto a Pagar" class="oe_subtotal_footer_separator" invisible="payable_amount == amount_total"/>
                                </group>
                                <group string="En Moneda Local" invisible="document_currency_id == currency_id">
                                    <field name="amount_untaxed_local" readonly="1" widget="monetary" string="Subtotal Local"/>
                                    <field name="amount_total_local" readonly="1" widget="monetary" string="Total Local"/>
                                </group>
                            </group>
                        </page>
                        
                        <!-- Pestaña de Documentos Relacionados -->
                        <page string="Documentos Relacionados">
                            <group>
                                <field name="invoice_id" readonly="1"/>
                            </group>
                            <group string="Notas Crédito Relacionadas">
                                <field name="related_credit_note_ids" readonly="1" nolabel="1">
                                    <list>
                                        <field name="document_number"/>
                                        <field name="issue_date"/>
                                        <field name="amount_total"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Notas Débito Relacionadas">
                                <field name="related_debit_note_ids" readonly="1" nolabel="1">
                                    <list>
                                        <field name="document_number"/>
                                        <field name="issue_date"/>
                                        <field name="amount_total"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        
                        <!-- Pestaña de XML -->
                        <page string="XML y Archivos">
                            <div class="alert alert-info mb-3" role="status">
                                <i class="fa fa-info-circle" title="Informacion"/> <strong>Cómo procesar un ZIP:</strong>
                                <ol class="mb-0">
                                    <li>Adjunta un archivo ZIP en el chatter (parte inferior)</li>
                                    <li>Haz clic en el botón "Extraer y Procesar ZIP"</li>
                                    <li>El sistema extraerá automáticamente el XML y PDF</li>
                                    <li>El documento se procesará automáticamente</li>
                                </ol>
                            </div>
                            <group>
                                <button name="action_extract_from_zip"
                                        type="object"
                                        string="Extraer y Procesar ZIP desde Chatter"
                                        class="btn-primary btn-lg"
                                        icon="fa-file-archive-o"
                                        help="Extrae XML y PDF del archivo ZIP adjuntado en el chatter y procesa el documento"/>
                            </group>
                            <group>
                                <group string="Archivos Extraídos">
                                    <field name="xml_filename" readonly="1"/>
                                    <field name="xml_content" filename="xml_filename" widget="binary" readonly="1"/>
                                    <field name="pdf_filename" readonly="1"/>
                                    <field name="pdf_file" filename="pdf_filename" widget="binary" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Contenido XML"/>
                            <field name="xml_content" widget="ace" options="{'mode': 'xml'}" readonly="1"/>
                            <separator string="XML Factura (Extraído de AttachedDocument)"/>
                            <field name="xml_invoice" widget="ace" options="{'mode': 'xml'}" readonly="1"/>
                        </page>
                        
                        <!-- Pestaña de Configuración -->
                        <page string="Configuración">
                            <group>
                                <group string="Opciones de Procesamiento">
                                    <field name="auto_predict_products"/>
                                    <field name="update_product_codes"/>
                                </group>
                                <group string="Motivos (NC/ND)">
                                    <field name="credit_note_reason" readonly="1"/>
                                    <field name="debit_note_reason" readonly="1"/>
                                    <field name="discrepancy_response_code" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Notas"/>
                            <field name="notes" readonly="1"/>
                            <separator string="Log de Errores"/>
                            <field name="error_log" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Vista Kanban con Upload -->
    <record id="view_dian_document_processor_kanban" model="ir.ui.view">
        <field name="name">dian.document.processor.kanban</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" quick_create="false">
                <field name="document_type"/>
                <field name="document_number"/>
                <field name="issue_date"/>
                <field name="supplier_id"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="xml_filename"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <field name="document_type" widget="badge"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'processed'"
                                   decoration-success="state in ('validated', 'invoiced')"
                                   decoration-danger="state == 'error'"/>
                        </div>
                        <div class="fw-bold fs-5 mt-2">
                            <field name="document_number"/>
                        </div>
                        <div class="text-muted">
                            <field name="supplier_id"/>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <span><field name="issue_date"/></span>
                            <span class="fw-bold"><field name="amount_total" widget="monetary"/></span>
                        </div>
                        <div t-if="record.xml_filename.raw_value" class="text-success mt-1">
                            <i class="fa fa-file-code-o" title="Archivo XML"/> <t t-out="record.xml_filename.value"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Form simplificada para carga rapida (debe estar antes de list view que la referencia) -->
    <record id="view_dian_document_processor_form_upload" model="ir.ui.view">
        <field name="name">dian.document.processor.form.upload</field>
        <field name="model">dian.document.processor</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="Cargar Documento DIAN">
                <sheet>
                    <div class="text-center p-4">
                        <h2 class="mb-4">Cargar Documento Electronico DIAN</h2>
                        <p class="text-muted mb-4">Seleccione un archivo ZIP o XML para procesar</p>

                        <div class="row justify-content-center">
                            <div class="col-md-5 mb-3">
                                <div class="card h-100 border-success">
                                    <div class="card-body text-center">
                                        <i class="fa fa-file-archive-o fa-4x text-success mb-3" title="Archivo ZIP"/>
                                        <h5 class="card-title">Archivo ZIP</h5>
                                        <p class="card-text text-muted small">Contiene XML y PDF del documento</p>
                                        <field name="zip_file" filename="zip_filename" class="mt-2"/>
                                        <field name="zip_filename" invisible="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5 mb-3">
                                <div class="card h-100 border-primary">
                                    <div class="card-body text-center">
                                        <i class="fa fa-file-code-o fa-4x text-primary mb-3" title="Archivo XML"/>
                                        <h5 class="card-title">Archivo XML</h5>
                                        <p class="card-text text-muted small">Solo el XML del documento</p>
                                        <field name="xml_content" filename="xml_filename" class="mt-2"/>
                                        <field name="xml_filename" invisible="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <p class="text-muted mb-2">O ingrese el CUFE para recuperar desde DIAN:</p>
                            <div class="row justify-content-center">
                                <div class="col-md-8">
                                    <field name="cufe" placeholder="CUFE/CUDE del documento" class="text-center"/>
                                </div>
                            </div>
                        </div>

                        <!-- Campos ocultos necesarios -->
                        <field name="pdf_file" invisible="1"/>
                        <field name="pdf_filename" invisible="1"/>
                        <field name="document_number" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="action_upload_and_process" type="object" string="Procesar" class="btn-primary" icon="fa-cogs"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Accion de carga rapida (debe estar antes de list view que la referencia) -->
    <record id="action_dian_quick_upload" model="ir.actions.act_window">
        <field name="name">Cargar Documento DIAN</field>
        <field name="res_model">dian.document.processor</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_dian_document_processor_form_upload"/>
        <field name="target">new</field>
    </record>

    <!-- Vista List -->
    <record id="view_dian_document_processor_list" model="ir.ui.view">
        <field name="name">dian.document.processor.list</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <list string="Documentos DIAN" decoration-info="state == 'draft'" decoration-warning="has_validation_warning" decoration-success="state == 'invoiced'" decoration-danger="state == 'error'">
                <header>
                    <button name="%(action_dian_quick_upload)d" type="action" string="Cargar XML/ZIP" class="btn-primary" icon="fa-upload"/>
                </header>
                <field name="document_type"/>
                <field name="document_number"/>
                <field name="issue_date"/>
                <field name="supplier_id"/>
                <field name="customer_id"/>
                <field name="document_currency_id"/>
                <field name="exchange_rate"/>
                <field name="amount_total"/>
                <field name="has_validation_warning" invisible="1"/>
                <field name="invoice_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    
    <!-- Vista Search -->
    <record id="view_dian_document_processor_search" model="ir.ui.view">
        <field name="name">dian.document.processor.search</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <search string="Buscar Documentos DIAN">
                <field name="document_number"/>
                <field name="cufe"/>
                <field name="supplier_id"/>
                <field name="customer_id"/>
                <field name="billing_reference_id"/>
                <field name="billing_reference_cufe"/>
                <separator/>
                <filter string="Facturas" name="invoices" domain="[('document_type', 'in', ['01','02','03','04','05'])]"/>
                <filter string="Notas Crédito" name="credit_notes" domain="[('document_type', '=', '91')]"/>
                <filter string="Notas Débito" name="debit_notes" domain="[('document_type', '=', '92')]"/>
                <separator/>
                <filter string="Con Advertencias" name="with_warnings" domain="[('has_validation_warning', '=', True)]"/>
                <filter string="Sin Factura Odoo" name="no_invoice" domain="[('invoice_id', '=', False)]"/>
                <filter string="Con Factura Odoo" name="with_invoice" domain="[('invoice_id', '!=', False)]"/>
                <separator/>
                <filter string="Estado Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Procesado" name="processed" domain="[('state', '=', 'processed')]"/>
                <filter string="Validado" name="validated" domain="[('state', '=', 'validated')]"/>
                <filter string="Facturado" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
                <filter string="Error" name="error" domain="[('state', '=', 'error')]"/>
                <separator/>
                <filter string="Hoy" name="today" domain="[('issue_date', '=', context_today())]"/>
                <filter string="Última Semana" name="last_week" domain="[('issue_date', '&gt;=', (context_today() - datetime.timedelta(days=7)))]"/>
                <filter string="Último Mes" name="last_month" domain="[('issue_date', '&gt;=', (context_today() - datetime.timedelta(days=30)))]"/>
                <separator/>
                <group>
                    <filter string="Tipo Documento" name="group_type" context="{'group_by': 'document_type'}"/>
                    <filter string="Proveedor" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                    <filter string="Cliente" name="group_customer" context="{'group_by': 'customer_id'}"/>
                    <filter string="Fecha Emisión" name="group_date" context="{'group_by': 'issue_date:month'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Moneda" name="group_currency" context="{'group_by': 'document_currency_id'}"/>
                    <filter string="Medio de Pago" name="group_payment" context="{'group_by': 'payment_means_code'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Vista Pivot -->
    <record id="view_dian_document_processor_pivot" model="ir.ui.view">
        <field name="name">dian.document.processor.pivot</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Documentos DIAN">
                <field name="supplier_id" type="row"/>
                <field name="document_type" type="col"/>
                <field name="amount_total" type="measure"/>
                <field name="amount_tax" type="measure"/>
                <field name="amount_withholding" type="measure"/>
            </pivot>
        </field>
    </record>
    
    <!-- Vista Graph -->
    <record id="view_dian_document_processor_graph" model="ir.ui.view">
        <field name="name">dian.document.processor.graph</field>
        <field name="model">dian.document.processor</field>
        <field name="arch" type="xml">
            <graph string="Documentos DIAN" type="bar">
                <field name="issue_date" interval="month"/>
                <field name="amount_total" type="measure"/>
            </graph>
        </field>
    </record>
    
    <!-- ============== WIZARD DE PROCESAMIENTO ============== -->
    
    <record id="view_dian_document_process_wizard" model="ir.ui.view">
        <field name="name">dian.document.process.wizard.form</field>
        <field name="model">dian.document.process.wizard</field>
        <field name="arch" type="xml">
            <form string="Procesar Documento DIAN">
                <group>
                    <field name="input_type" widget="radio"/>
                </group>
                <group>
                    <field name="cufe" placeholder="Ingrese el CUFE o CUDE del documento"/>
                </group>
                <group>
                    <field name="xml_filename" invisible="1"/>
                    <field name="xml_file" filename="xml_filename"/>
                </group>
                <group>
                    <field name="folder_path" placeholder="/ruta/a/la/carpeta/con/xmls"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="supplier_id"/>
                </group>
                <separator string="Opciones de Procesamiento"/>
                <group col="4">
                    <field name="auto_predict_products"/>
                    <field name="create_product"/>
                    <field name="update_product_codes"/>
                    <field name="update_exchange_rate"/>
                </group>
                <footer>
                    <button name="process_document" type="object" string="Procesar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- ============== WIZARD BÚSQUEDA DE PRODUCTOS ============== -->
    
    <record id="view_dian_document_product_search_wizard" model="ir.ui.view">
        <field name="name">dian.document.product.search.wizard.form</field>
        <field name="model">dian.document.product.search.wizard</field>
        <field name="arch" type="xml">
            <form string="Buscar y Asociar Producto">
                <group>
                    <field name="line_id" invisible="1"/>
                    <field name="search_term" placeholder="Buscar por nombre, código o barcode"/>
                </group>
                <group string="Productos Encontrados">
                    <field name="product_ids" nolabel="1">
                        <list>
                            <field name="default_code"/>
                            <field name="name"/>
                            <field name="barcode"/>
                            <field name="list_price"/>
                        </list>
                    </field>
                </group>
                <group>
                    <field name="selected_product_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Asociar Producto" class="btn-primary"/>
                    <button string="Cancelar" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- ============== ACCIONES Y MENÚS ============== -->

    <record id="action_dian_document_processor" model="ir.actions.act_window">
        <field name="name">Documentos Electrónicos DIAN</field>
        <field name="res_model">dian.document.processor</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_dian_document_processor_search"/>
        <field name="context">{'search_default_last_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cargar documento electronico DIAN
            </p>
            <p>
                Haga clic para cargar un archivo ZIP o XML desde DIAN.
            </p>
            <p>
                <a type="action" name="%(action_dian_quick_upload)d" class="btn btn-primary">
                    <i class="fa fa-upload" title="Cargar"/> Cargar Documento
                </a>
            </p>
        </field>
    </record>
    
    <record id="action_dian_document_process_wizard" model="ir.actions.act_window">
        <field name="name">Procesar Documento DIAN</field>
        <field name="res_model">dian.document.process.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    
    <!-- Menú Principal -->
    <menuitem id="menu_dian_root" name="DIAN" web_icon="lavish_xml_invoice,static/description/icon.png" sequence="50"/>
    
    <menuitem id="menu_dian_documents" name="Documentos" parent="menu_dian_root" sequence="10"/>
    
    <menuitem id="menu_dian_document_processor" name="Documentos Electrónicos" parent="menu_dian_documents" action="action_dian_document_processor" sequence="10"/>
    
    <menuitem id="menu_dian_process_document" name="Procesar Documento" parent="menu_dian_documents" action="action_dian_document_process_wizard" sequence="20"/>
    
    <!-- Configuración -->
    <menuitem id="menu_dian_configuration" name="Configuración" parent="menu_dian_root" sequence="90" groups="account.group_account_manager"/>
    
</odoo>
