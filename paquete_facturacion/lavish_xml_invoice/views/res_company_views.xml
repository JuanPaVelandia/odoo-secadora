<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_dian_form" model="ir.ui.view">
        <field name="name">res.company.dian.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="DIAN Configuration">
                    <group>
                        <group string="DIAN Settings">
                            <field name="dian_test_mode" widget="boolean_toggle"/>
                            <field name="dian_certificate_file" filename="dian_certificate_filename" invisible="not dian_test_mode"/>
                            <field name="dian_certificate_filename" invisible="1"/>
                            <field name="dian_certificate_password" password="True" invisible="not dian_test_mode"/>
                        </group>
                        <group string="DIAN Credentials">
                            <field name="dian_software_id"/>
                            <field name="dian_software_pin" password="True"/>
                            <field name="dian_test_set_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>