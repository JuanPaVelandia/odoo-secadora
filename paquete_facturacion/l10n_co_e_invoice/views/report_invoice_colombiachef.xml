<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paperformat used by the ColombiaChef invoice report -->
        <record id="paperformat_custom_invoice" model="report.paperformat">
            <field name="name">ColombiaChef - Invoice</field>
            <field name="default" eval="False"/>
            <field name="format">Letter</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">5</field>
            <field name="dpi">90</field>
            <field name="css_margins" eval="True"/>
        </record>

        <!-- New invoice report template (standalone) -->
        <template id="report_invoice_colombiachef">
            <t t-call="web.html_container">
                <t t-set="print_with_payments" t-value="True"/>
                <t t-foreach="docs" t-as="o">
                    <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
                        <style>
                        body { font-family: Arial, sans-serif; }
                        .header-section { background-color: #e0e0e0; padding: 4px 8px; font-weight: bold; font-size: 11px; margin: 5px 0; }
                        .main-table { width: 100%; border-collapse: collapse; }
                        .main-table td, .main-table th { border-right: 0.5px solid #000;border-left: 0.5px solid #000; padding: 4px; font-size: 10px; }
                        .main-table th { background-color: #e0e0e0; font-weight: bold; text-align: center; }
                        .info-row td { padding: 2px 5px; font-size: 10px; }
                        .total-section { background-color: #f0f0f0; font-weight: bold; }
                        .footer-info { font-size: 8px; margin-top: 10px; }
                        .qr-section { text-align: center; padding: 10px; }
                    </style>
                        <!-- Header -->
                        <div class="header row" style="margin-bottom: 10px;">
                            <div class="col-2">
                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 80px;" alt="Logo"/>
                            </div>
                            <div class="col-6 text-center">
                                <h6 style="margin: 0; font-weight: bold; font-size: 14px;">
                                    <t t-out="o.company_id.name"/>
                                    <br/>
                                NIT:
                                    <t t-out="o.company_id.vat"/>
                                </h6>
                                <p style="font-size: 9px; margin: 3px 0;">
                                Dirección:
                                    <t t-out="o.company_id.street"/>,
                                    <t t-out="o.company_id.city"/>, Colombia
                                    <br/>
                                Tel:
                                    <t t-out="o.company_id.phone"/>
                                    <br/>
                                Correo Electrónico:
                                    <t t-out="o.company_id.email"/>
                                    <br/>
                                    <t t-out="o.company_id.website"/>
                                </p>
                            </div>
                            <div class="col-4 text-end">
                                <div class="text-center">
                                    <t t-if="o.cufe and o.move_type in ['out_invoice', 'out_refund']">
                                      <img t-if="o.QR_code" t-att-src="image_data_uri(o.QR_code)" style="max-height: 80px;" alt="Logo"/>
                                    </t>
                                    <h6 style="margin: 5px 0; font-weight: bold;">
                                        <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">
                                            <t t-if="o.env.company.production">Factura Electrónica de Venta</t>
                                            <t t-else="">Factura de Venta</t>
                                        </span>
                                        <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">
                                        Borrador de Factura
                                    </span>
                                        <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">
                                        Factura Cancelada
                                    </span>
                                        <span t-if="o.move_type == 'out_refund'">
                                        Nota Crédito
                                    </span>
                                        <span t-if="o.move_type == 'in_invoice'">
                                        Factura de Compra
                                    </span>
                                        <span t-if="o.move_type == 'in_refund'">
                                        Nota Crédito de Proveedor
                                    </span>
                                    </h6>
                                    <p style="font-size: 12px; margin: 0; font-weight: bold;">
                                        <t t-out="o.name"/>
                                    </p>
                                </div>
                            </div>
                        </div>
                        <!-- INFORMACIÓN DEL CLIENTE -->
                        <div class="header-section">INFORMACIÓN DEL CLIENTE</div>
                        <table class="table table-borderless" style="width: 100%; margin-bottom: 10px;">
                            <tr class="info-row">
                                <td width="15%">
                                    <strong>Nombre:</strong>
                                </td>
                                <td width="35%">
                                    <t t-out="o.partner_id.name"/>
                                </td>
                                <td>
                                    <strong>CC/NIT:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_id.vat"/>
                                </td>
                                <td>
                                    <strong>Teléfono:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_id.phone or 'N/A'"/>
                                </td>
                            </tr>
                            <tr class="info-row">
                                <td>
                                    <strong>Dirección:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_id.street or 'N/A'"/>
                                </td>
                                <td>
                                    <strong>Ciudad:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_id.city_id.display_name if o.partner_id.city_id else o.partner_id.city"/>
                                </td>
                                <td>
                                    <strong>Email:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_id.email or 'N/A'"/>
                                </td>
                            </tr>

                        </table>
                        <div class="header-section">Direccion de envio</div>
                        <table class="table table-borderless" style="width: 100%; margin-bottom: 10px;">
                            <tr class="info-row">
                                <td width="15%">
                                    <strong>Nombre:</strong>
                                </td>
                                <td width="35%">
                                    <t t-out="o.partner_shipping_id.name"/>
                                </td>
                                <td>
                                    <strong>CC/NIT:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_shipping_id.vat"/>
                                </td>
                                <td>
                                    <strong>Teléfono:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_shipping_id.phone or 'N/A'"/>
                                </td>
                            </tr>
                            <tr class="info-row">
                                <td>
                                    <strong>Dirección:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_shipping_id.street or 'N/A'"/>
                                </td>
                                <td>
                                    <strong>Ciudad:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_shipping_id.city_id.display_name if o.partner_shipping_id.city_id else o.partner_shipping_id.city"/>
                                </td>
                                <td>
                                    <strong>Email:</strong>
                                </td>
                                <td>
                                    <t t-out="o.partner_shipping_id.email or 'N/A'"/>
                                </td>
                            </tr>

                        </table>

                        <!-- DATOS DE LA FACTURA -->
                        <div class="header-section">DATOS DE LA FACTURA</div>
                        <table class="table table-borderless" style="width: 100%; margin-bottom: 10px">
                            <tr class="info-row">
                                <td>
                                    <strong>Fecha Factura:</strong>
                                </td>
                                <td>
                                    <t t-out="o.invoice_date"/>
                                </td>
                                <td>
                                    <strong>Fecha Vencimiento:</strong>
                                </td>
                                <td>
                                    <t t-out="o.invoice_date_due"/>
                                </td>
                                <td>
                                    <strong>Fecha Validación DIAN:</strong>
                                </td>
                                <td>
                                    <t t-out="o.fecha_xml"/>
                                </td>
                            </tr>
                            <tr class="info-row">
                                <td width="15%">
                                    <strong>Vendedor:</strong>
                                </td>
                                <td>
                                    <t t-out="o.invoice_user_id.name or o.invoice_user_id.name"/>
                                </td>
                                <td width="15%">
                                    <strong>Orden de compra:</strong>
                                </td>
                                <td>
                                    <t t-out="o.ref"/>
                                </td>
                                <td>
                                    <strong>Forma De Pago:</strong>
                                </td>
                                <td>
                                    <t t-out="o.payment_format or 'Contado'"/>
                                </td>
                            </tr>
                            <tr class="info-row">
                                <td width="15%">
                                    <strong>Términos de Pago:</strong>
                                </td>
                                <td>
                                    <t t-out="o.invoice_payment_term_id.name"/>
                                </td>
                                <td width="15%">
                                    <strong>Orden de origen:</strong>
                                </td>
                                <td>
                                    <t t-out="o.invoice_origin"/>
                                </td>
                                <td>
                                    <strong>Medio De Pago:</strong>
                                </td>
                                <td>
                                    <t t-out="o.method_payment_id.name or 'Pago a depositado y/o acordado (PPD)'"/>
                                </td>
                            </tr>
                        </table>
                        <!-- DETALLE DE LA FACTURA -->
                        <div class="header-section">DETALLE DE LA FACTURA</div>
                        <table class="main-table" style="border-top:1px solid black;border-bottom:1px solid black">
                            <thead>
                                <tr>
                                    <th width="3%">#</th>
                                    <th width="7%">CÓDIGO</th>
                                    <th width="25%">DESCRIPCIÓN</th>
                                    <th width="8%">CANTIDAD</th>
                                    <th width="5%">U/M</th>
                                    <th width="10%">UNITARIO</th>
                                    <th width="6%">DISC %</th>
                                    <th width="8%">-DISC V.</th>
                                    <th width="6%">IMP %</th>
                                    <th width="8%">IMP V.</th>
                                    <th width="10%">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="num_item" t-value="0"/>
                                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.display_type == 'product')"/>
                                <!-- Productos existentes -->
                                <t t-foreach="product_lines" t-as="line">
                                    <t t-set="num_item" t-value="num_item + 1"/>
                                    <tr>
                                        <td class="text-center">
                                            <t t-out="num_item"/>
                                        </td>
                                        <td class="text-center">
                                            <t t-out="line.product_id.default_code or ''"/>
                                        </td>
                                        <td>
                                            <t t-out="line.name"/>
                                        </td>
                                        <td class="text-center">
                                            <t t-out="'{:.2f}'.format(line.quantity)"/>
                                        </td>

                                        <td class="text-center">UND</td>
                                        <td class="text-end">
                                            <t t-out="'{:,.2f}'.format(line.price_unit)"/>
                                        </td>
                                        <td class="text-center">
                                            <t t-if="line.discount">
                                                <t t-out="'{:.1f}'.format(line.discount)"/>
                                            </t>
                                            <t t-else="">0.0</t>
                                        </td>
                                        <td class="text-end">
                                            <t t-if="line.discount">
                                                <t t-out="'{:,.2f}'.format(line.price_unit * line.quantity * line.discount / 100)"/>
                                            </t>
                                            <t t-else="">0.00</t>
                                        </td>
                                        <td class="text-center">
                                            <t t-set="taxes" t-value="line.tax_ids.filtered(lambda l: l.tributes == '01')"/>
                                            <t t-if="taxes">
                                                <t t-out="'{:.0f}'.format(taxes[0].amount)"/>
                                            </t>
                                            <t t-else="">0</t>
                                        </td>
                                        <td class="text-end">
                                            <t t-set="taxes" t-value="line.tax_ids.filtered(lambda l: l.tributes == '01')"/>
                                            <t t-if="taxes">
                                                <t t-out="'{:,.2f}'.format(line.price_subtotal * taxes[0].amount / 100)"/>
                                            </t>
                                            <t t-else="">0.00</t>
                                        </td>
                                        <td class="text-end">
                                            <strong>
                                                <t t-out="'{:,.2f}'.format(line.price_total)"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="11" style="padding: 3px; font-size: 10px;">
                                        <strong>Total Ítems:</strong>
                                        <t t-out="num_item"/> |

                                        <strong>Cantidad Total:</strong>
                                        <t t-out="'{:.2f}'.format(sum(product_lines.mapped('quantity')))"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                        <!-- OBSERVACIONES DE LA FACTURA -->
                        <t t-if="o.narration">
                            <div class="header-section">OBSERVACIONES DE LA FACTURA</div>
                            <div style="border: 1px solid #000; padding: 5px; font-size: 10px;">
                                <t t-out="o.narration"/>
                            </div>
                        </t>
                        <t>
                            <!-- <div style="border: 1px solid #000; padding: 5px; font-size: 10px;">
                        Cuenta bancaria autorizada: BANCOLOMBIA AHORROS 484-840847-96
                        TITULAR DE LA CUENTA: JHON ALEXANDER GOMEZ MORENO
                        </div> -->
                        </t>
                        <!-- Sección de Totales y Pagos -->
                        <table style="width: 100%; margin-top: 5px;">
                            <tr>
                                <td width="50%" style="vertical-align: top; padding-right: 10px;">
                                    <!-- Información adicional y cuenta bancaria -->
                           <div style="line-height:90%;font-size:12px">
                                        <span>Autorizacion DIAN numero:</span>
                                        <span t-out="o.resolution_number"/>
                                        <br/>
                                        <span>Fecha de Autorizacion:</span>
                                        <span t-out="o.resolution_date"/>
                                        <t t-if="o.resolution_date_to">
                                            <span> Vigencia de Autorizacion:</span>
                                            <span t-out="o.resolution_date_to"/>
                                        </t>
                                        <br/>
                                        <span>Prefijo:</span>
                                        <span t-out="o.journal_id.code"/>
                                        <span> Rango de Facturacion:</span>
                                        <span t-out="o.resolution_number_from"/>
                                        <span> - </span>
                                        <span t-out="o.resolution_number_to"/>
                                    </div>

                                </td>
                                <td width="50%" style="vertical-align: top;">
                         <table class="main-table">
                                    <!-- Cálculo de subtotales manual -->
                                    <t t-set="excluded_codes" t-value="['91', '90', '13', '83', '100','TIPS']"/>
                                    <t t-set="regular_lines" t-value="o.invoice_line_ids.filtered(lambda l: not l.product_id or l.product_id.default_code not in excluded_codes)"/>
                                    <t t-set="special_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.default_code in excluded_codes)"/>
                                    <t t-set="subtotal" t-value="sum(regular_lines.mapped('price_subtotal'))"/>

                                    <!-- 1. Subtotal de productos regulares -->
                                    <tr>
                                        <td class="text-start" width="60%"><strong>SUB TOTAL</strong></td>
                                        <td class="text-end">
                                            <span t-out="subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                        </td>
                                    </tr>

                                    <!-- 2. Impuestos (sólo positivos agrupados por categoría) - Excluyendo AutoRftaRenta -->
                                    <t t-set="positive_taxes" t-value="{}"/>
                                    <t t-set="excluded_tax_names" t-value="['AutoRftaRenta -1.1%', 'AutoRftaRenta 1.1%']"/>
                                    <t t-foreach="regular_lines" t-as="line">
                                        <t t-foreach="line.tax_ids" t-as="tax">
                                            <t t-if="tax.amount &gt; 0 and tax.name not in excluded_tax_names">
                                                <t t-set="tax_name" t-value="tax.name"/>
                                                <t t-set="tax_amount" t-value="line.price_subtotal * (tax.amount / 100.0)"/>
                                                <t t-if="tax_name in positive_taxes">
                                                    <t t-set="positive_taxes" t-value="dict(positive_taxes, **{tax_name: positive_taxes[tax_name] + tax_amount})"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-set="positive_taxes" t-value="dict(positive_taxes, **{tax_name: tax_amount})"/>
                                                </t>
                                            </t>
                                        </t>
                                    </t>

                                    <t t-set="total_taxes" t-value="0"/>
                                    <t t-foreach="positive_taxes.items()" t-as="tax_item">
                                        <tr>
                                            <td class="text-start"><strong><t t-out="tax_item[0]"/></strong></td>
                                            <td class="text-end">
                                                <span t-out="tax_item[1]" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                            </td>
                                        </tr>
                                        <t t-set="total_taxes" t-value="total_taxes + tax_item[1]"/>
                                    </t>

                                    <!-- 3. Total General (Subtotal + Impuestos) -->
                                    <t t-set="total_general" t-value="subtotal + total_taxes"/>
                                    <tr class="total-section">
                                        <td class="text-start"><strong>TOTAL OPERACIÓN COP</strong></td>
                                        <td class="text-end">
                                            <strong><span t-out="total_general" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/></strong>
                                        </td>
                                    </tr>

                                    <!-- 4. Retenciones (impuestos negativos) -->
                                    <t t-set="negative_taxes" t-value="{}"/>
                                    <t t-foreach="regular_lines" t-as="line">
                                        <t t-foreach="line.tax_ids" t-as="tax">
                                            <t t-if="tax.amount &lt; 0">
                                                <t t-set="tax_name" t-value="tax.name"/>
                                                <t t-set="tax_amount" t-value="line.price_subtotal * (tax.amount / 100.0)"/>
                                                <t t-if="tax_name in negative_taxes">
                                                    <t t-set="negative_taxes" t-value="dict(negative_taxes, **{tax_name: negative_taxes[tax_name] + tax_amount})"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-set="negative_taxes" t-value="dict(negative_taxes, **{tax_name: tax_amount})"/>
                                                </t>
                                            </t>
                                        </t>
                                    </t>

                                    <t t-if="negative_taxes">
                                        <t t-foreach="negative_taxes.items()" t-as="tax_item">
                                            <tr>
                                                <td class="text-start"><t t-out="tax_item[0]"/></td>
                                                <td class="text-end">
                                                    <span t-out="tax_item[1]" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>

                                    <!-- 5. Cargos especiales y retenciones especiales -->
                                    <t t-if="len(special_lines) &gt; 0">
                                        <t t-foreach="special_lines" t-as="line">
                                            <tr>
                                                <td class="text-start"><span t-field="line.name"/></td>
                                                <td class="text-end">
                                                    <span t-field="line.price_subtotal"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>

                                    <!-- 6. Redondeo -->
                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-if="tax_totals and tax_totals.get('display_rounding', False) and tax_totals.get('rounding_amount', 0) != 0">
                                        <tr>
                                            <td class="text-start"><strong>REDONDEO</strong></td>
                                            <td class="text-end"><t t-out="'{:,.2f}'.format(tax_totals['rounding_amount'])"/></td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr>
                                            <td class="text-start"><strong>REDONDEO</strong></td>
                                            <td class="text-end">0.00</td>
                                        </tr>
                                    </t>

                                    <!-- 7. Total Final -->
                                    <tr class="total-section">
                                        <td class="text-start"><strong>TOTAL A PAGAR</strong></td>
                                        <td class="text-end">
                                            <strong><span t-field="o.amount_total"/></strong>
                                        </td>
                                    </tr>

                                    <!-- Información de pagos si está disponible -->
                                    <t t-if="print_with_payments">
                                        <t t-if="o.payment_state != 'invoicing_legacy'">
                                            <t t-set="payments_vals" t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                                            <t t-if="len(payments_vals) &gt; 0">
                                                <tr>
                                                    <td colspan="2" class="text-center" style="background-color: #e0e0e0;"><strong>Pagos Recibidos</strong></td>
                                                </tr>
                                                <t t-foreach="payments_vals" t-as="payment_vals">
                                                    <tr>
                                                        <td class="text-start">
                                                            <i class="oe_form_field text-right oe_payment_label">Pago
                                                                <t t-out="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                                                            </i>
                                                        </td>
                                                        <td class="text-end">
                                                            <span t-out="payment_vals['amount']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <tr class="total-section">
                                                    <td class="text-start"><strong>SALDO PENDIENTE</strong></td>
                                                    <td class="text-end"><strong><span t-field="o.amount_residual"/></strong></td>
                                                </tr>
                                            </t>
                                        </t>
                                    </t>
                                </table>


                                </td>
                            </tr>
                        </table>
                        <!-- CUFE y firma -->
                        <div style="border: 1px solid black; padding: 10px; margin-top: 5px;">
                            <div class="row">
                                <div class="col-8">
                                    <div style="font-size: 9px;">
                                        <t t-if="o.move_type == 'out_invoice'">
                                            <strong>CUFE:</strong>
                                        </t>
                                        <t t-if="o.move_type == 'out_refund'">
                                            <strong>CUDE:</strong>
                                        </t>
                                        <t t-if="o.move_type in ['in_invoice', 'in_refund']">
                                            <strong>CUDS:</strong>
                                        </t>
                                        <span style="word-break: break-all;">
                                            <t t-out="o.cufe if o.cufe else o.name"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <div style="font-size: 9px; margin-top: 5px;">
                        <div class="col-12">
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <td style="width: 40%; vertical-align: top;">

                                        <strong>Fecha de Impresión:</strong> <span t-out="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                                    </td>
                                    <td style="width: 40%; vertical-align: top;">
