<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Dispatch al template colombiano desde el report_invoice principal -->
        <template id="report_invoice_co_dispatch" inherit_id="account.report_invoice">
            <xpath expr="//t[@t-if]" position="after">
                <t t-elif="o._get_name_invoice_report() == 'l10n_co_e_invoice.report_electronic_invoice_document_inherit'"
                   t-call="l10n_co_e_invoice.report_electronic_invoice_document_inherit"
                   t-lang="lang"/>
            </xpath>
        </template>

        <!-- Template principal de factura electrónica colombiana (primary=True para evitar conflictos con otras herencias) -->
        <template id="report_electronic_invoice_document_inherit" inherit_id="account.report_invoice_document" primary="True">
            <xpath expr="//t[@t-call='web.external_layout']" position="replace">
                <t t-call="web.html_container">
                    <div class="article cc-invoice" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
                        <style>
                            .cc-invoice { color: #000000; font-family: Arial, sans-serif; }
                            .cc-invoice h6 { margin: 0; font-weight: 600; letter-spacing: 0.2px; }
                            .cc-invoice .cc-muted { color: #000000; }
                            .cc-invoice .cc-panel { border: 1px solid #c9ced3; border-radius: 10px; overflow: hidden; }
                            .cc-invoice .cc-panel table { border-collapse: separate; border-spacing: 0; }
                            .cc-invoice .cc-header { background-color: #e6e8eb }
                            .cc-invoice .cc-border { border-bottom: 1px solid #c9ced3; }
                            .cc-invoice .cc-border-right { border-right: 1px solid #c9ced3; }
                            .cc-invoice .cc-small { font-size: 11px; }
                            .cc-invoice .cc-legal { font-size: 11px; line-height: 1.25; }
                            .cc-invoice .cc-note { font-size: 9px; line-height: 1.25; }
                            .cc-invoice .cc-totals-table { width: 100%; border: 0.5px solid #c9ced3; border-collapse: collapse; }
                            .cc-invoice .cc-totals-table td,
                            .cc-invoice .cc-totals-table th { border-bottom: 0.5px solid #c9ced3; padding: 4px; font-size: 10px; }
                            .cc-invoice .cc-totals-table .o_total td { background-color: #e6e8eb; font-size: 12px; color: #000000; font-weight: 700; }
                            .cc-invoice thead th { font-weight: 700; }
                            .cc-invoice .invoice_tbody td { border-bottom: 0.5px solid #c9ced3; }
                            .cc-invoice .cc-doc-title { font-weight: 900; font-size: 15px; }
                        </style>
                        <div class="header">
                            <div class="row" style="font-size:12px">
                                <div class="col-4">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="float: left;height: 80px; display: block;" alt="Logo"/>
                                </div>
                                <div class="col-4 text-center">
                                    <p>
                                        <b style="font-size:15px" t-out="o.company_id.name"/>
                                        <br/>
                                                NIT:
                                                
                                        <t t-out="o.company_id.vat"/>
                                        <br/>
                                        <t t-out="o.company_id.street"/>
                                        <br/>
 Telefono :
                                                
                                        <t t-out="o.company_id.phone"/>
                                        <t t-if="o.company_id.partner_id.mobile"> - <t t-out="o.company_id.partner_id.mobile"/></t>
                                        <br/>
                                        <t t-out="o.company_id.city"/>
,
                                                
                                        <t t-out="o.company_id.state_id.name"/>
                                        <br/>
                                        <t t-out="o.company_id.email"/>
                                        <br/>
                                                Actividad Economica |
                                        <t t-if="o.company_id.partner_id._fields.get('ciiu_activity') and o.company_id.partner_id.ciiu_activity"
                                           t-out="o.company_id.partner_id.ciiu_activity.code"/>
                                        <t t-else="">N/A</t>
                                        <br/>
                                                Tarifa de ICA
                                        <t t-if="o.company_id.partner_id._fields.get('ciiu_activity') and o.company_id.partner_id.ciiu_activity"
                                           t-out="o.company_id.partner_id.ciiu_activity.porcent_ica"/>
                                        <t t-else="">N/A</t>
 X 1.000
                                                  
                                        <br/>
                                                Tributo | 
                                        <t t-out="o.company_id.partner_id.tribute_id.display_name"/>
                                        <br/>
                                                Responsabilidad fiscal | 
                                        <t t-out="o.company_id.partner_id.fiscal_responsability_ids.code"/>
                                    </p>
                                </div>
                                <div class="col-4" style="font-size:11px">
                                    <div>
                                        <table class="table table-sm table-borderless cc-panel" style="line-height: 1.2;border: 1px solid #c9ced3;margin-top: 1rem;margin-bottom: 1rem;width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 10px; overflow: hidden; font-size:12px">
                                            <tr>
                                                <th colspan="2" class="text-center" style=" background-color: #e6e8eb;">
                                                    <h6 class="cc-doc-title">
                                                        <span t-if="o.env.company.production and  o.move_type == 'out_invoice' and o.state == 'posted'">
                                                                    Factura Electrónica de Venta
                                                        </span>
                                                        <span t-if="o.env.company.production == False and o.move_type == 'out_invoice' and o.state == 'posted'">
                                                                    Factura de venta
                                                        </span>
                                                        <span t-if="not o.env.company.production and o.move_type == 'out_invoice' and o.state == 'posted'">
                                                                    Factura
                                                        </span>
                                                        <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">
                                                                    Borrador</span>
                                                        <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">
                                                                    Cancelada</span>
                                                        <span t-if="o.move_type == 'out_refund'">Notas Creditos</span>
                                                        <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                                                        <span t-if="o.move_type == 'in_invoice'">Factura de Compra</span>
                                                    </h6>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th class="text-start">
                                                    <span>Numero: </span>
                                                </th>
                                                <td>
                                                    <span t-if="o.name != '/'" t-field="o.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th class="text-start">
                                                    <span>Fecha Factura: </span>
                                                </th>
                                                <td>
                                                    <span t-field="o.invoice_date"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th class="text-start">
                                                    <span>Fecha Generación: </span>
                                                </th>
                                                <td>
                                                    <span t-field="o.fecha_xml"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th class="text-start">
                                                    <span>Fecha Vencimiento: </span>
                                                </th>
                                                <td>
                                                    <span t-field="o.invoice_date_due"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div style="margin-top:-10px;text-align: left;padding:5px;border: 1px solid #c9ced3;margin-bottom: 0rem;width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 10px; overflow: hidden; font-size:12px">
                                        <b> Vendedor: </b>
                                        <span t-field="o.invoice_user_id"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <br/>
                        <br/>
                        <t t-set="o" t-value="o.with_context(lang=lang)"/>
                        <t t-set="forced_vat" t-value="o.fiscal_position_id.foreign_vat"/>
                        <div class="page">
                            <div class="row">
                                <table class="table table-borderless cc-panel" style="line-height: 1.2;border: 1px solid #c9ced3;width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 10px; overflow: hidden; font-size:12px">
                                    <tbody>
                                        <tr>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Señores: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span t-field="o.partner_id.name"/>
                                            </td>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span/>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3"/>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Nit / C.C.: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span t-field="o.partner_id.vat"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Dirección: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span t-field="o.partner_id.street"/>
                                            </td>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span>Ciudad: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span t-field="o.partner_id.city"/>
                                            </td>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Forma de Pago: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span class="m-0" t-field="o.payment_format"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Teléfono: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <span t-field="o.partner_id.phone"/>
                                            </td>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span/>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3"/>
                                            <th class="text-start" style="border-bottom:1px solid #c9ced3">
                                                <span> Medio de Pago: </span>
                                            </th>
                                            <td style="border-bottom:1px solid #c9ced3">
                                                <t t-set="payment_method_display"
                                                   t-value="o.method_payment_id and o.method_payment_id.name or ''"/>
                                                <span class="m-0" t-out="payment_method_display"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-start">
                                                <span> Email: </span>
                                            </th>
                                            <td>
                                                <span t-field="o.partner_id.email"/>
                                            </td>
                                            <th class="text-start">
                                                <span/>
                                            </th>
                                            <td/>
                                            <th class="text-start">
                                                <span> Orden de compra: </span>
                                            </th>
                                            <td>
                                                <span t-field="o.ref"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
                            <table class="table table-sm table-borderless cc-panel" style="max-height: 500px;margin-top:-10px;line-height: 1.2;border: 1px solid #c9ced3;width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 10px; overflow: hidden; font-size:12px">
                                <thead>
                                    <tr>
                                        <th class="text-center" style=" background-color: #e6e8eb;margin-bottom:-10px;border-bottom: 1px solid #c9ced3;border-right: 1px solid #c9ced3;">
                                            <span>Items</span>
                                        </th>
                                        <t t-set="num_item" t-value="0"/>
                                        <th name="th_description" class="text-left" style=" background-color: #e6e8eb;margin-bottom:-10px;border-bottom: 1px solid #c9ced3;border-right: 1px solid #c9ced3;">
                                            <span>COD</span>
                                        </th>
                                        <th name="th_description" class="text-left" style=" background-color: #e6e8eb;margin-bottom:-10px;border-bottom: 1px solid #c9ced3;border-right: 1px solid #c9ced3;">
                                            <span>Descripcion</span>
                                        </th>
                                        <th name="th_quantity" class="text-right" style=" background-color: #e6e8eb;margin-bottom:-10px;border-bottom: 1px solid #c9ced3;border-right: 1px solid #c9ced3;">
                                            <span>Cantidad</span>
                                        </th>
                                        <th name="th_priceunit" style=" background-color: #e6e8eb;margin-bottom:-10px;border-bottom: 1px solid #c9ced3;border-right: 1px solid #c9ced3;">
                                            <span>Precio Unitario</span>
                                        </th>
                                        <th name="th_price_unit" style=" background-color: #e6e8eb;" t-if="display_discount" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <span>Disc.%</span>
                                        </th>
                                        <th name="th_subtotal" class="text-right" style=" background-color: #e6e8eb;">
                                            <span> Total </span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-set="current_subtotal" t-value="0"/>
                                    <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_id.name, -l.id), reverse=True)"/>
                                    <t t-foreach="lines" t-as="line">
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                            <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">
                                                <t t-set="num_item" t-value="num_item + 1"/>
                                                <td style="border-right: 1px solid #c9ced3;" class="text-center">
                                                    <span t-out="num_item"/>
                                                </td>
                                                <td style="border-right: 1px solid #c9ced3;" class="text-center">
                                                    <span t-field="line.product_id.default_code"/>
                                                </td>
                                                <td style="border-right: 1px solid #c9ced3;" name="account_invoice_line_name">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                                <td style="border-right: 1px solid #c9ced3;" class="text-end">
                                                    <span t-field="line.quantity"/>
                                                </td>
                                                <td style="border-right: 1px solid #c9ced3;" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.price_unit"/>
                                                </td>
                                                <td t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.discount"/>
                                                </td>
                                                <td class="text-end o_price_total">
                                                    <span class="text-nowrap" t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                    <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                                    <span class="text-nowrap" t-if="not (o.env.user.has_group('account.group_show_line_subtotals_tax_excluded') or o.env.user.has_group('account.group_show_line_subtotals_tax_included'))"
                                                          t-out="line.price_total" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </t>
                                            <t t-if="line.display_type == 'line_section'">
                                                <td colspan="99">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                                <t t-set="current_section" t-value="line"/>
                                                <t t-set="current_subtotal" t-value="0"/>
                                            </t>
                                            <t t-if="line.display_type == 'line_note'">
                                                <td colspan="99">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                            </t>
                                        </tr>
                                        <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                                            <tr class="is-subtotal text-right" style="background-color: #e6e8eb">
                                                <td colspan="99">
                                                    <strong class="mr16">Subtotal</strong>
                                                    <span t-out="current_subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                                <t>
                                    <td colspan="99" style="border-top:1px solid #c9ced3;">
                                        <div style="text-align: left;">
                                            <strong style="font-size:11px"> Total de ítems: </strong>
                                            <span t-out="len(o.invoice_line_ids)"/>
 | 
                                            <strong style="font-size:11px">Total en letras:</strong>
                                            <span t-out="o.currency_id.amount_to_text(o.amount_total)"/>
                                        </div>
                                    </td>
                                </t>
                            </table>
                            <div name="comment" class="cc-panel" style="margin-top:-10px;border: 1px solid #c9ced3;width: 100%; border-collapse: separate; border-spacing: 0; border-radius: 10px; overflow: hidden; font-size:12px">
                                <div id="total" class="row">
                                    <div class="col-7">
                                        <div style="font-size:11px;border-bottom: 1px solid #c9ced3;text-align: left;padding:1px">
                                            <strong>Esta factura de venta es un título valor,
                                                        conforme al Art.772, Modificado en la ley 1231 de
                                                        2008</strong>
                                        </div>
                                        <div class="cc-legal" style="border-bottom: 1px solid #c9ced3;text-align: justify;padding:2px">
                                                    El cliente,  autoriza a 
                                            <span t-field="o.company_id.name"/>
        y/o quien represente sus derechos o intereses a reportar, consultar, procesar, solicitar o divulgar ante
        cualquier entidad que gestione bases de datos, como DATACREDITO, CIFIN, FENALCO, entre otras, toda la
        información sobre mi comportamiento y realidad comercial. La presente factura/nota de venta se asimila a un
        titulo valor según la ley 1231 de 2008; con su aceptación se exime expresamente a 
                                            <span t-field="o.company_id.name"/>
 de cualquier 
        requerimiento privado o judicial para su constitucion en mora. En caso de no
        cancelar a su vencimiento se causarán intereses de mora a la tasa máxima legal permitida. Sin perjuicio de las
        acciones de cobro pertinentes por el incumplimiento.  
        
                                                
                                        </div>
                                        <div class="cc-note" style="text-align: justify;border-bottom: 1px solid #c9ced3;height:30px">
                                                       Observaciones: 
                                            <span t-field="o.narration"/>
                                        </div>
                                    </div>
                                    <div class="col-5" style="font-size:10px;line-height: 100%;border-left: 1px solid #c9ced3;">
                                        <div style="border-bottom:1px solid #c9ced3">
                                            <table class="cc-totals-table" style="page-break-inside: avoid;">
                                                <tr class="">
                                                    <td>
                                                        <strong>Moneda</strong>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-field="o.currency_id"/>
                                                    </td>
                                                </tr>
                                                <t t-set="tax_totals" t-value="o.tax_totals"/>
                                                <t t-set="currency" t-value="o.currency_id"/>
                                                <t t-call="account.document_tax_totals"/>
                                                <!--Payments-->
                                                <tr class="border-black o_total"/>
                                                <t t-if="print_with_payments">
                                                    <t t-if="o.payment_state != 'invoicing_legacy'">
                                                        <t t-set="payments_vals" t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                                            <tr>
                                                                <td>
                                                                    <i class="oe_form_field text-right oe_payment_label">
                                                                                Pagos
                                                                                
                                                                        <t t-out="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                                                                    </i>
                                                                </td>
                                                                <td class="text-right">
                                                                    <span t-out="payment_vals['amount']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                        <t t-if="len(payments_vals) &gt; 0">
                                                            <tr class="border-black">
                                                                <td>
                                                                    <strong>Importe Adeudado</strong>
                                                                </td>
                                                                <td class="text-right">
                                                                    <span t-field="o.amount_residual"/>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </t>
                                                </t>
                                            </table>
                                            <div name="QR_code" t-if="o.cufe and (o.diancode_id.qr_data or o.qr_data)" align="left" style="font-size:10px;line-height: 100%;border-top: 1px solid #c9ced3;">
                                                <img t-att-src="o._get_qr_image_data_uri()" style="max-height: 120px;"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row" style="padding:1px;padding-bottom:10px;border-bottom:1px solid #c9ced3;border-top:1px solid #c9ced3">
                                    <div class="col-4" style="border-right: 1px solid #c9ced3;">
                                                Firma Recibe
                                    </div>
                                    <div class="col-4" style="border-right: 1px solid #c9ced3;">
                                                Firma Elaboró:
                                    </div>
                                    <div class="col-4"> Software Propio 
                                        <br/>
                                        <small t-field="o.company_id.name"/>
 - 
                                        <small t-field="o.company_id.vat"/>
                                    </div>
                                </div>
                                <div t-if="o.cufe" style="border-bottom:1px solid #c9ced3">
                                    <b t-if="o.move_type == 'out_invoice'">CUFE:</b>
                                    <b t-if="o.move_type == 'out_refund'">CUDE:</b>
                                    <span style="font-size:10px;line-height: 100%;" t-field="o.cufe"/>
                                </div>
                                <div t-if="o.cufe" style="border-bottom:1px solid #c9ced3">
                                    <b> Sello de Firma: </b>
                                    <p style="font-size:10px;line-height: 100%;" t-out="o.extract_signature_value()"/>
                                </div>
                                <div style="border-bottom:1px solid #c9ced3">
                                    <b> Software de Facturación: </b>
                                    <small t-field="o.company_id.name"/>
 - 
                                    <small t-field="o.company_id.vat"/>
                                </div>
                                <div style="border: 1px solid #c9ced3;font-size:10px;line-height: 100%; padding:3px">
                                    <span>Autorizacion DIAN numero:</span>
                                    <span t-field="o.resolution_number"/>
 |
                
                
                                            
                                    <span>Fecha de Autorizacion:</span>
                                    <span t-field="o.resolution_date"/>
