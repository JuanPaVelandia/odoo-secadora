<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_company_form_dian_extended" model="ir.ui.view">
        <field name="name">Datos de la compañía requeridos por la DIAN</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="before">
                <field name="sales_discount_account" />
                <field name="purchase_discount_account" />
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="dian" string="Configuracion DIAN">
                    <group string="Datos Básicos DIAN" col="2">
                        <field name="trade_name" />
                        <field name="operation_type" />
                        <field name="software_identification_code" />
                        <field name="identificador_set_pruebas" />
                        <field name="software_pin" />
                        <field name="password_environment" />
                        <field name="seed_code" />
                        <field name="document_repository" />
                        <field name="in_use_dian_sequence" />
                        <field name="production" />
                    </group>
                    
                    <separator string="Certificado Digital"/>
                    <group string="Certificado Digital" col="2">
                        <field name="certificate_file" />
                        <field name="certificate_key" password="True" />
                        <field name="certificate_is_valid" readonly="1" />
                        <field name="certificate_subject_name" readonly="1" />
                        <field name="certificate_date_start" readonly="1" />
                        <field name="certificate_date_end" readonly="1" />
                        <field name="digital_certificate" readonly="1" invisible="1" />
                        <field name="issuer_name" readonly="1" />
                        <field name="serial_number" readonly="1" />
                        <field name="pem_file" readonly="1" invisible="1" />
                        <field name="certificate_loading_error" readonly="1" invisible="certificate_loading_error == ''" />
                    </group>
                    
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="button_extract_certificate"
                            string="Extraer Datos del Certificado"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-certificate"
                            invisible="certificate_file == False"
                        />
                    </div>
                    
                    <separator string="Consulta de Rangos DIAN"/>
                    <group string="Rangos de Numeración" col="1">
                        <div class="oe_button_box">
                            <button
                                name="query_numbering_range"
                                string="Consultar Rangos DIAN"
                                type="object"
                                class="btn-primary"
                                icon="fa-search"
                            />
                            <button
                                name="show_resolutions_html"
                                string="Ver Resoluciones"
                                type="object"
                                class="btn-secondary"
                                icon="fa-table"
                            />
                        </div>
                        <field name="numbering_ranges_html" widget="html" nolabel="1" />
                        <field name="xml_response_numbering_range" readonly="1" invisible="1" />
                    </group>
                    
                    <separator string="Contingencia"/>
                    <group string="Contingencia Tipo 4" col="2">
                        <field name="in_contingency_4" />
                        <field name="exists_invoice_contingency_4" />
                        <field name="date_init_contingency_4" invisible="in_contingency_4 == False" />
                        <field name="date_end_contingency_4" invisible="in_contingency_4 == False" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
