<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="recepcion_factura_dian_view_tree" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.view.tree</field>
        <field name="model">recepcion.factura.dian</field>
        <field name="arch" type="xml">
            <list string="recepcion_factura_dian">
                <field name="name" />
                <field name="zip_file" />
                <field name="application_response_ids" string="Eventos Dian" widget="many2many_tags"/>
                <field name="tiene_eventos" />
            </list>
        </field>
    </record>

    <record id="recepcion_factura_dian_view_form" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.view.form</field>
        <field name="model">recepcion.factura.dian</field>
        <field name="arch" type="xml">
            <form string="">
                <header>
                    <field name="state" widget="statusbar"/>
                    <button type="object" name="read_zip" string="Extraer ZIP"  invisible="state in ['read','send','procces']"/>
                    <button type="object" name="process_xml" string="Procesar XML"  invisible="state in  ['draft','send','procces']"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="supplier_id" />
                            <field name="cufe" />
                            <field name="zip_file"  readonly="state in ['read','send']"/>
                        </group>
                        <group>
                            <field name="n_invoice" />
                            <field name="date_invoice" />
                        </group>
                    </group>
                    <notebook>
                        <page name="line_invoice" string="Lineas de factura">
                            <field name="order_line_ids" />
                            <group>
                                <group>
                                </group>
                                <group>
                                    <field name="total_tax" readonly="1"/>
                                    <field name="total_untax" readonly="1"/>
                                    <field name="total" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page name="pdf_view" string="Factura">
                            <field name="pdf_file" widget="pdf_viewer"/>
                        </page>
                        <page name="invoice_xml" string="XML Factura">
                            <field name="invoice_xml" readonly="1"/>
                        </page>
                        <page name="xml_text" string="XML Completo">
                            <field name="xml_text" readonly="1"/>
                        </page>
                        <page name="dian_events" string="Eventos DIAN">
                            <group col="1">
                                <button name="add_application_response" type="object" string="Enviar Acuse de recibo" context="{'response_code': '030'}"/>
                                <button name="add_application_response" type="object" string="Enviar Recibo del bien y/o servicio" context="{'response_code': '032'}"/>
                                <button name="add_application_response" type="object" string="Enviar Aceptación expresa" context="{'response_code': '033'}"/>
                            </group>
                            <field name="application_response_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="recepcion_factura_dian_action" model="ir.actions.act_window">
        <field name="name">Recepcion Factura Dian</field>
        <field name="res_model">recepcion.factura.dian</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="recepcion_factura_dian_menu"
        name="Recepcion Facturas Dian"
        action="recepcion_factura_dian_action"
        parent="account.menu_finance_payables"
        sequence="10"/>

    <!-- Vistas para líneas de factura DIAN -->
    <record id="recepcion_factura_dian_line_view_tree" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.line.view.tree</field>
        <field name="model">recepcion.factura.dian.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" />
                <field name="qty" />
                <field name="uom" />
                <field name="price" />
                <field name="total" />
            </list>
        </field>
    </record>

    <record id="recepcion_factura_dian_line_view_form" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.line.view.form</field>
        <field name="model">recepcion.factura.dian.line</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name" />
                    <field name="recepcion_id" />
                    <field name="qty" />
                    <field name="uom" />
                    <field name="price" />
                    <field name="total" />
                </group>
                <separator string="Impuestos"/>
                <field name="tax_ids">
                    <list editable="bottom">
                        <field name="name" />
                        <field name="tax_id" />
                        <field name="tax_type" />
                        <field name="percentage" />
                        <field name="taxable_amount" />
                        <field name="tax_amount" />
                    </list>
                </field>
            </form>
        </field>
    </record>

    <!-- Vistas para impuestos de factura -->
    <record id="recepcion_factura_dian_tax_view_tree" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.tax.view.tree</field>
        <field name="model">recepcion.factura.dian.tax</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" />
                <field name="recepcion_id" />
                <field name="tax_id" />
                <field name="tax_type" />
                <field name="percentage" />
                <field name="taxable_amount" />
                <field name="tax_amount" />
            </list>
        </field>
    </record>

    <record id="recepcion_factura_dian_tax_view_form" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.tax.view.form</field>
        <field name="model">recepcion.factura.dian.tax</field>
        <field name="arch" type="xml">
            <form string="Impuesto">
                <group>
                    <field name="name" />
                    <field name="recepcion_id" />
                    <field name="tax_id" />
                    <field name="tax_type" />
                    <field name="percentage" />
                    <field name="taxable_amount" />
                    <field name="tax_amount" />
                </group>
            </form>
        </field>
    </record>

    <!-- Vistas para impuestos de línea de factura -->
    <record id="recepcion_factura_dian_line_tax_view_tree" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.line.tax.view.tree</field>
        <field name="model">recepcion.factura.dian.line.tax</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name" />
                <field name="line_id" />
                <field name="tax_id" />
                <field name="tax_type" />
                <field name="percentage" />
                <field name="taxable_amount" />
                <field name="tax_amount" />
            </list>
        </field>
    </record>

    <record id="recepcion_factura_dian_line_tax_view_form" model="ir.ui.view">
        <field name="name">recepcion.factura.dian.line.tax.view.form</field>
        <field name="model">recepcion.factura.dian.line.tax</field>
        <field name="arch" type="xml">
            <form string="Impuesto de Línea">
                <group>
                    <field name="name" />
                    <field name="line_id" />
                    <field name="tax_id" />
                    <field name="tax_type" />
                    <field name="percentage" />
                    <field name="taxable_amount" />
                    <field name="tax_amount" />
                </group>
            </form>
        </field>
    </record>

</odoo>
