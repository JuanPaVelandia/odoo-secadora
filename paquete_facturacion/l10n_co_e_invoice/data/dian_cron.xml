<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1"> 

        <record id="dian_validate_accept_email_invoice_cron" model="ir.cron">
            <field name="name">Aceptacion email del cliente luego de pasados 3 dias</field>
            <field eval="True" name="active"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="state">code</field>
            <field name="model_id" ref="model_dian_document"/>
            <field name="code">model._cron_validate_accept_email_invoice_dian()</field>
        </record>
        
    </data>
	    <data noupdate="1">
	        <record id="ir_cron_process_dian_pending_emails" model="ir.cron">
	            <field name="name">DIAN: Procesar emails pendientes</field>
	            <field name="model_id" ref="model_dian_document"/>
	            <field name="state">code</field>
	            <field name="code">model.process_pending_emails()</field>
	            <field name="interval_number">1</field>
	            <field name="interval_type">hours</field>
	            <!-- Disabled: do not post/send DIAN pending emails automatically. -->
	            <field name="active" eval="False"/>
	        </record>
	    </data>
	</odoo>
