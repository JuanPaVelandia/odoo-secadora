<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="application_response_wizard_view" model="ir.ui.view">
            <field name="name">application.response.wizard,form</field>
            <field name="model">application.response.wizard</field>
            <field name="arch" type="xml">
                <form string="Registrar Eventos Dian">
                    <group>
                        <field name="event_type" invisible="1"/>
                        <field name="response_code_invoice_received" invisible="event_type != 'invoice_received'"/>
                        <field name="response_code_invoice_sent" invisible="event_type != 'invoice_sent'"/>

                        <field name="ValorFEVavala" readonly="0" invisible="not ValorFEVavala"/>
                        <field name="ValorFEV_TV" readonly="0" invisible="not ValorFEV_TV"/>
                        <field name="ValorPagado" readonly="0" invisible="not ValorPagado"/>
                        <field name="NuevoValorTV" readonly="0" invisible="not NuevoValorTV"/>
                        <field name="ValorTotalEndoso" readonly="0" invisible="not ValorTotalEndoso"/>
                        <field name="PrecioPagarseFEV" readonly="0" invisible="not PrecioPagarseFEV"/>
                        <field name="TasaDescuento" readonly="0" invisible="not TasaDescuento"/>
                        <field name="MedioPago" readonly="0" invisible="not MedioPago"/>
                        <field name="ValorTV" readonly="0" invisible="not ValorTV"/>
                        <field name="MontoMedidaCautelar" readonly="0" invisible="not MontoMedidaCautelar"/>
                        <field name="ValorDeuda" readonly="0" invisible="not ValorDeuda"/>
                        <field name="ValorLimitación" readonly="0" invisible="not ValorLimitación"/>
                        <field name="ValorActualTituloValor" readonly="0" invisible="not ValorActualTituloValor"/>
                        <field name="ValorPendienteTituloValor" readonly="0" invisible="not ValorPendienteTituloValor"/>
                        <field name="ValorAceptado" readonly="0" invisible="not ValorAceptado"/>
                        <field name="ValorPendiente" readonly="0" invisible="not ValorPendiente"/>
                        <field name="ValorTransferenciaDerechos" readonly="0" invisible="not ValorTransferenciaDerechos"/>
                        <field name="FactordeDescuento" readonly="0" invisible="not FactordeDescuento"/>


                        <field name="note_1" readonly="0" invisible="not note_1"/>

                        <div class="alert alert-warning" role="alert" style="margin-bottom:0px;" invisible="not note_2_info">
                                <span class="o_stat_text"><field name="note_2_info"/></span>
                        </div>

                        <field name="note_2" readonly="0" invisible="not note_2"/>

                        <div class="alert alert-warning" role="alert" style="margin-bottom:0px;" invisible="not note_3_info">
                            <span class="o_stat_text"><field name="note_3_info"/></span>
                        </div>

                        <field name="note_3" readonly="0" invisible="not note_3"/>

                        <div class="alert alert-warning" role="alert" style="margin-bottom:0px;" invisible="not note_4_info">
                            <span class="o_stat_text"><field name="note_4_info"/></span>
                        </div>

                        <field name="note_4" readonly="0" invisible="not note_4"/>
                        <field name="note_5" readonly="0" invisible="not note_5"/>                        
                    </group>
                    
                    <footer>
                        <button
                            string="Confirmar"
                            name="validate_event"
                            type="object"
                            default_focus="1"
                            class="btn-primary"
                        />
                        <button
                            string="Cancelar"
                            class="btn-default"
                            special="cancel"
                        />
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_register_event_dian" model="ir.actions.act_window">
            <field name="name">Registrar Eventos Dian</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">application.response.wizard</field>
            <field name="binding_model_id" ref="model_recepcion_factura_dian" />
            <field name="binding_view_types">list,form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <record id="action_account_move_register_event_dian" model="ir.actions.act_window">
            <field name="name">Registrar Eventos Dian</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">application.response.wizard</field>
            <field name="binding_model_id" ref="model_account_move" />
            <field name="binding_view_types">list,form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
