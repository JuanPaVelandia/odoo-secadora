<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <!--
    Template de filtros para Balance de Prueba por Tercero.

    Sigue el patrón nativo de Odoo 18:
    - t-name define el nombre del template (referenciado en JS y Python)
    - t-inherit hereda del template base (SIN t-inherit-mode="extension")
    - xpath para insertar/modificar elementos

    Referencia: account_reports/static/src/components/aged_partner_balance/filters.xml
    -->

    <t t-name="libros_contables_colombia.TrialBalancePartnerFilters"
       t-inherit="account_reports.AccountReportFiltersCustomizable">

        <!-- Insertar filtros personalizados antes del filtro extra_options -->
        <xpath expr="//div[@id='filter_extra_options']" position="before">

            <!-- ================================================================= -->
            <!-- FILTRO POR RANGO DE CUENTAS CONTABLES                             -->
            <!-- ================================================================= -->
            <t t-if="hasAccountRangeFilter">
                <div id="filter_account_range" class="filter_account_range">
                    <Dropdown>
                        <button class="btn btn-secondary">
                            <i class="fa fa-calculator me-1"/>
                            <span class="o_dropdown_title">Cuentas</span>
                            <t t-if="hasActiveAccountFilter">
                                <span class="badge bg-primary ms-1">
                                    <i class="fa fa-filter"/>
                                </span>
                            </t>
                        </button>

                        <t t-set-slot="content">
                            <!-- Encabezado del filtro -->
                            <div class="dropdown-header border-bottom pb-2 mb-2">
                                <strong><i class="fa fa-calculator me-1"/>Filtro por Rango de Cuentas</strong>
                                <t t-if="hasActiveAccountFilter">
                                    <button
                                        class="btn btn-sm btn-link text-danger float-end p-0"
                                        t-on-click="clearAccountRangeFilter"
                                        title="Limpiar filtros"
                                    >
                                        <i class="fa fa-times"/> Limpiar
                                    </button>
                                </t>
                            </div>

                            <!-- Cuenta Desde -->
                            <div class="dropdown-item-text px-3 py-2">
                                <label class="form-label small mb-1">
                                    <i class="fa fa-arrow-right me-1 text-success"/>Desde cuenta:
                                </label>
                                <div class="input-group input-group-sm">
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="Ej: 1105"
                                        t-att-value="accountRangeState.accountFrom"
                                        t-on-input="onAccountFromInput"
                                        t-on-keydown="(ev) => this.onAccountInputKeydown(ev, 'from')"
                                    />
                                    <button
                                        class="btn btn-outline-primary"
                                        type="button"
                                        t-on-click="applyAccountFrom"
                                        title="Aplicar"
                                    >
                                        <i class="fa fa-check"/>
                                    </button>
                                </div>
                                <t t-if="accountFrom">
                                    <small class="text-muted">
                                        Actual: <span class="fw-bold" t-esc="accountFrom"/>
                                    </small>
                                </t>
                            </div>

                            <!-- Cuenta Hasta -->
                            <div class="dropdown-item-text px-3 py-2">
                                <label class="form-label small mb-1">
                                    <i class="fa fa-arrow-left me-1 text-danger"/>Hasta cuenta:
                                </label>
                                <div class="input-group input-group-sm">
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="Ej: 1199"
                                        t-att-value="accountRangeState.accountTo"
                                        t-on-input="onAccountToInput"
                                        t-on-keydown="(ev) => this.onAccountInputKeydown(ev, 'to')"
                                    />
                                    <button
                                        class="btn btn-outline-primary"
                                        type="button"
                                        t-on-click="applyAccountTo"
                                        title="Aplicar"
                                    >
                                        <i class="fa fa-check"/>
                                    </button>
                                </div>
                                <t t-if="accountTo">
                                    <small class="text-muted">
                                        Actual: <span class="fw-bold" t-esc="accountTo"/>
                                    </small>
                                </t>
                            </div>

                            <div class="dropdown-divider"/>

                            <!-- Excluir Cuentas -->
                            <div class="dropdown-item-text px-3 py-2">
                                <label class="form-label small mb-1">
                                    <i class="fa fa-ban me-1 text-warning"/>Excluir cuentas:
                                </label>
                                <div class="input-group input-group-sm">
                                    <input
                                        type="text"
                                        class="form-control"
                                        placeholder="Codigo a excluir"
                                        t-att-value="accountRangeState.accountExcludeInput"
                                        t-on-input="onAccountExcludeInput"
                                        t-on-keydown="(ev) => this.onAccountInputKeydown(ev, 'exclude')"
                                    />
                                    <button
                                        class="btn btn-outline-warning"
                                        type="button"
                                        t-on-click="addAccountExclude"
                                        title="Agregar a exclusion"
                                    >
                                        <i class="fa fa-plus"/>
                                    </button>
                                </div>

                                <!-- Lista de cuentas excluidas -->
                                <t t-if="accountExclude.length > 0">
                                    <div class="mt-2">
                                        <small class="text-muted">Cuentas excluidas:</small>
                                        <div class="d-flex flex-wrap gap-1 mt-1">
                                            <t t-foreach="accountExclude" t-as="code" t-key="code">
                                                <span class="badge bg-warning text-dark">
                                                    <t t-esc="code"/>
                                                    <button
                                                        class="btn-close btn-close-sm ms-1"
                                                        style="font-size: 0.6rem;"
                                                        t-on-click="() => this.removeAccountExclude(code)"
                                                        title="Quitar de exclusion"
                                                    />
                                                </span>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <!-- Resumen del filtro activo -->
                            <t t-if="hasActiveAccountFilter">
                                <div class="dropdown-divider"/>
                                <div class="dropdown-item-text px-3 py-2 bg-light">
                                    <small class="text-muted">
                                        <i class="fa fa-info-circle me-1"/>
                                        <t t-esc="accountFilterSummary"/>
                                    </small>
                                </div>
                            </t>
                        </t>
                    </Dropdown>
                </div>
            </t>

            <!-- ================================================================= -->
            <!-- FILTROS DE RETENCION COLOMBIANOS                                  -->
            <!-- ================================================================= -->
            <t t-if="hasWithholdingFilters">
                <div id="filter_withholding" class="filter_withholding d-flex gap-1">

                    <!-- Dropdown de Tipo de Operacion (Compra/Venta) -->
                    <t t-if="operationTypes.length > 0">
                        <Dropdown>
                            <button class="btn btn-secondary">
                                <span class="o_dropdown_title">Operacion</span>
                                <t t-if="selectedOperationType !== 'all'">
                                    <span class="badge bg-info ms-1">
                                        <t t-foreach="operationTypes" t-as="ot" t-key="ot.id">
                                            <t t-if="ot.id === selectedOperationType" t-esc="ot.name"/>
                                        </t>
                                    </span>
                                </t>
                            </button>

                            <t t-set-slot="content">
                                <t t-foreach="operationTypes" t-as="opType" t-key="opType.id">
                                    <DropdownItem
                                        class="{ 'selected': opType.selected }"
                                        onSelected="() => this.onOperationTypeChange(opType.id)"
                                    >
                                        <i t-if="opType.selected" class="fa fa-check me-2"/>
                                        <i t-elif="opType.id === 'purchase'" class="fa fa-shopping-cart me-2 text-warning"/>
                                        <i t-elif="opType.id === 'sale'" class="fa fa-money me-2 text-success"/>
                                        <i t-elif="opType.id === 'purchase_refund'" class="fa fa-undo me-2 text-warning"/>
                                        <i t-elif="opType.id === 'sale_refund'" class="fa fa-undo me-2 text-success"/>
                                        <i t-else="" class="fa fa-list me-2"/>
                                        <t t-esc="opType.name"/>
                                    </DropdownItem>
                                </t>
                            </t>
                        </Dropdown>
                    </t>

                    <!-- Dropdown de Tipo de Concepto -->
                    <t t-if="conceptTypes.length > 0">
                        <Dropdown>
                            <button class="btn btn-secondary">
                                <span class="o_dropdown_title">Tipo Retencion</span>
                                <t t-if="selectedConceptType !== 'all'">
                                    <span class="badge bg-primary ms-1">
                                        <t t-foreach="conceptTypes" t-as="ct" t-key="ct.id">
                                            <t t-if="ct.id === selectedConceptType" t-esc="ct.name"/>
                                        </t>
                                    </span>
                                </t>
                            </button>

                            <t t-set-slot="content">
                                <t t-foreach="conceptTypes" t-as="conceptType" t-key="conceptType.id">
                                    <DropdownItem
                                        class="{ 'selected': conceptType.selected }"
                                        onSelected="() => this.onConceptTypeChange(conceptType.id)"
                                    >
                                        <i t-if="conceptType.selected" class="fa fa-check me-2"/>
                                        <t t-esc="conceptType.name"/>
                                    </DropdownItem>
                                </t>
                            </t>
                        </Dropdown>
                    </t>

                    <!-- Dropdown de Conceptos Especificos -->
                    <t t-if="withholdingConcepts.length > 0">
                        <Dropdown>
                            <button class="btn btn-secondary">
                                <span class="o_dropdown_title">Conceptos</span>
                                <t t-if="controller.options.withholding_concept_ids and controller.options.withholding_concept_ids.length > 0">
                                    <span class="badge bg-primary ms-1" t-esc="controller.options.withholding_concept_ids.length"/>
                                </t>
                            </button>

                            <t t-set-slot="content">
                                <!-- Opcion para limpiar filtros -->
                                <DropdownItem
                                    class="'text-danger'"
                                    onSelected="() => this.clearWithholdingFilters()"
                                >
                                    <i class="fa fa-times me-2"/>
                                    Limpiar todos los filtros
                                </DropdownItem>
                                <div class="dropdown-divider"/>
                                <!-- Lista de conceptos -->
                                <t t-foreach="withholdingConcepts" t-as="concept" t-key="concept.id">
                                    <DropdownItem
                                        class="{ 'selected': concept.selected }"
                                        onSelected="() => this.toggleWithholdingConcept(concept.id)"
                                        closingMode="'none'"
                                    >
                                        <i t-if="concept.selected" class="fa fa-check-square-o me-2"/>
                                        <i t-else="" class="fa fa-square-o me-2"/>
                                        <span class="text-muted me-1" t-esc="'[' + concept.code + ']'"/>
                                        <t t-esc="concept.name"/>
                                    </DropdownItem>
                                </t>
                            </t>
                        </Dropdown>
                    </t>

                    <!-- Dropdown de Ciudades -->
                    <t t-if="hasCityFilter">
                        <Dropdown>
                            <button class="btn btn-secondary">
                                <i class="fa fa-map-marker me-1"/>
                                <span class="o_dropdown_title">Ciudad</span>
                                <t t-if="hasActiveCityFilter">
                                    <span class="badge bg-success ms-1" t-esc="selectedCitiesCount"/>
                                </t>
                            </button>

                            <t t-set-slot="content">
                                <!-- Opcion para limpiar filtro de ciudades -->
                                <t t-if="hasActiveCityFilter">
                                    <DropdownItem
                                        class="'text-danger'"
                                        onSelected="() => this.clearCityFilter()"
                                    >
                                        <i class="fa fa-times me-2"/>
                                        Limpiar filtro de ciudades
                                    </DropdownItem>
                                    <div class="dropdown-divider"/>
                                </t>
                                <!-- Lista de ciudades -->
                                <t t-foreach="cities" t-as="city" t-key="city.id">
                                    <DropdownItem
                                        class="{ 'selected': city.selected }"
                                        onSelected="() => this.toggleCity(city.id)"
                                        closingMode="'none'"
                                    >
                                        <i t-if="city.selected" class="fa fa-check-square-o me-2 text-success"/>
                                        <i t-else="" class="fa fa-square-o me-2"/>
                                        <i class="fa fa-map-marker me-1 text-muted"/>
                                        <t t-esc="city.name"/>
                                    </DropdownItem>
                                </t>
                            </t>
                        </Dropdown>
                    </t>

                </div>
            </t>

        </xpath>

        <!-- Reemplazar el filtro extra_options para agregar opciones personalizadas -->
        <xpath expr="//div[@id='filter_extra_options']" position="replace">
            <div id="filter_extra_options">
                <t t-call="libros_contables_colombia.TrialBalancePartnerFilterExtraOptions"/>
            </div>
        </xpath>

    </t>

    <!--
    Template para las opciones extra del Balance por Tercero.
    Inserta opciones personalizadas al final del dropdown de opciones.
    Usamos t-set-slot="content" como ancla porque siempre existe.
    -->
    <t t-name="libros_contables_colombia.TrialBalancePartnerFilterExtraOptions"
       t-inherit="account_reports.AccountReportFilterExtraOptions">

        <!-- Ocultar la opción de jerarquía nativa de Odoo (usamos Jerarquía PUC en su lugar) -->
        <xpath expr="//t[@t-if='controller.filters.show_hierarchy']" position="replace">
            <!-- Jerarquía nativa de Odoo reemplazada por Jerarquía PUC colombiana -->
        </xpath>

        <!-- Insertar al final del contenido del dropdown usando t-set-slot como ancla -->
        <xpath expr="//t[@t-set-slot='content']" position="inside">

            <!-- Separador para filtros colombianos -->
            <div class="dropdown-divider"/>
            <div class="dropdown-header small text-muted">
                <i class="fa fa-flag me-1"/>Opciones Colombia
            </div>

            <!-- Filtro para ocultar terceros sin movimiento (Balance por Tercero) -->
            <t t-if="hasHidePartnersNoMovementFilter">
                <DropdownItem
                    class="{ 'selected': controller.options.hide_partners_no_movement }"
                    onSelected="() => this.toggleHidePartnersNoMovement()"
                    closingMode="'none'"
                >
                    <i t-if="controller.options.hide_partners_no_movement" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    Ocultar terceros sin movimiento
                </DropdownItem>
            </t>

            <!-- Filtro para ocultar cuentas sin movimiento (Libro Auxiliar) -->
            <t t-if="hasHideAccountsNoMovementFilter">
                <DropdownItem
                    class="{ 'selected': controller.options.hide_accounts_no_movement }"
                    onSelected="() => this.toggleHideAccountsNoMovement()"
                    closingMode="'none'"
                >
                    <i t-if="controller.options.hide_accounts_no_movement" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    Ocultar cuentas sin movimiento
                </DropdownItem>
            </t>

            <!-- Filtro para mostrar jerarquía PUC colombiano -->
            <t t-if="hasPucHierarchyFilter">
                <DropdownItem
                    class="{ 'selected': controller.options.puc_hierarchy }"
                    onSelected="() => this.togglePucHierarchy()"
                    closingMode="'none'"
                >
                    <i t-if="controller.options.puc_hierarchy" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    <i class="fa fa-sitemap me-1"/>
                    Jerarquía PUC (Clase/Grupo/Cuenta)
                </DropdownItem>

                <!-- Selector de nivel de jerarquía (solo cuando jerarquía está activa) -->
                <t t-if="controller.options.puc_hierarchy and pucHierarchyLevels.length > 0">
                    <div class="dropdown-divider my-1"/>
                    <div class="dropdown-item-text px-3 py-1">
                        <small class="text-muted fw-bold">
                            <i class="fa fa-level-down me-1"/>Mostrar hasta nivel:
                        </small>
                    </div>
                    <t t-foreach="pucHierarchyLevels" t-as="level" t-key="level.id">
                        <DropdownItem
                            class="{ 'selected': level.selected, 'ps-4': true }"
                            onSelected="() => this.onPucHierarchyLevelChange(level.id)"
                            closingMode="'none'"
                        >
                            <i t-if="level.selected" class="fa fa-check me-2"/>
                            <i t-else="" class="fa fa-circle-o me-2 text-muted"/>
                            <t t-esc="level.name"/>
                        </DropdownItem>
                    </t>

                    <!-- Opciones de visualización -->
                    <div class="dropdown-divider my-1"/>
                    <div class="dropdown-item-text px-3 py-1">
                        <small class="text-muted fw-bold">
                            <i class="fa fa-eye me-1"/>Opciones de detalle:
                        </small>
                    </div>

                    <!-- Mostrar Terceros -->
                    <DropdownItem
                        class="{ 'selected': pucShowPartners, 'ps-4': true }"
                        onSelected="() => this.togglePucShowPartners()"
                        closingMode="'none'"
                    >
                        <i t-if="pucShowPartners" class="fa fa-check-square-o me-2"/>
                        <i t-else="" class="fa fa-square-o me-2"/>
                        <i class="fa fa-users me-1"/>
                        Mostrar Terceros
                    </DropdownItem>

                    <!-- Mostrar Movimientos -->
                    <DropdownItem
                        class="{ 'selected': pucShowMovements, 'ps-4': true }"
                        onSelected="() => this.togglePucShowMovements()"
                        closingMode="'none'"
                    >
                        <i t-if="pucShowMovements" class="fa fa-check-square-o me-2"/>
                        <i t-else="" class="fa fa-square-o me-2"/>
                        <i class="fa fa-list-alt me-1"/>
                        Mostrar Movimientos
                    </DropdownItem>

                    <!-- Modo de visualización -->
                    <t t-if="pucDisplayModes.length > 0">
                        <div class="dropdown-divider my-1"/>
                        <div class="dropdown-item-text px-3 py-1">
                            <small class="text-muted fw-bold">
                                <i class="fa fa-th-list me-1"/>Modo de vista:
                            </small>
                        </div>
                        <t t-foreach="pucDisplayModes" t-as="mode" t-key="mode.id">
                            <DropdownItem
                                class="{ 'selected': mode.selected, 'ps-4': true }"
                                onSelected="() => this.onPucDisplayModeChange(mode.id)"
                                closingMode="'none'"
                            >
                                <i t-if="mode.selected" class="fa fa-check me-2"/>
                                <i t-else="" class="fa fa-circle-o me-2 text-muted"/>
                                <t t-esc="mode.name"/>
                            </DropdownItem>
                        </t>
                    </t>
                </t>
            </t>

            <!-- ============================================================= -->
            <!-- FILTROS DE FORMATO DE COLORES                                  -->
            <!-- ============================================================= -->
            <t t-if="hasColorFormattingFilter">
                <div class="dropdown-divider"/>
                <div class="dropdown-item-text px-3 py-1">
                    <small class="text-muted fw-bold">
                        <i class="fa fa-paint-brush me-1"/>Formato de Colores:
                    </small>
                </div>

                <!-- Toggle de colores -->
                <DropdownItem
                    class="{ 'selected': useColorFormatting }"
                    onSelected="() => this.toggleColorFormatting()"
                    closingMode="'none'"
                >
                    <i t-if="useColorFormatting" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    <i class="fa fa-tint me-1"/>
                    Aplicar Colores a Números
                </DropdownItem>

                <!-- Modo de color (solo si colores está activo) -->
                <t t-if="useColorFormatting and colorModes.length > 0">
                    <t t-foreach="colorModes" t-as="mode" t-key="mode.id">
                        <DropdownItem
                            class="{ 'selected': mode.selected, 'ps-4': true }"
                            onSelected="() => this.onColorModeChange(mode.id)"
                            closingMode="'none'"
                        >
                            <i t-if="mode.selected" class="fa fa-check me-2"/>
                            <i t-else="" class="fa fa-circle-o me-2 text-muted"/>
                            <t t-esc="mode.name"/>
                        </DropdownItem>
                    </t>
                </t>

                <!-- Símbolos contables -->
                <DropdownItem
                    class="{ 'selected': useAccountingSymbols }"
                    onSelected="() => this.toggleAccountingSymbols()"
                    closingMode="'none'"
                >
                    <i t-if="useAccountingSymbols" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    <i class="fa fa-arrows-v me-1"/>
                    Símbolos Contables (▲▼)
                </DropdownItem>

                <!-- Vista previa de colores -->
                <div class="dropdown-item-text px-3 py-2" t-if="useColorFormatting">
                    <small class="text-muted">Vista previa:</small>
                    <div class="d-flex gap-2 mt-1">
                        <span class="badge" style="background-color: #198754; color: white;">
                            <i class="fa fa-arrow-up"/> +1,234.56
                        </span>
                        <span class="badge" style="background-color: #dc3545; color: white;">
                            <i class="fa fa-arrow-down"/> (1,234.56)
                        </span>
                        <span class="badge bg-secondary">0.00</span>
                    </div>
                </div>
            </t>

            <!-- ============================================================= -->
            <!-- FILTRO DE MONEDA SECUNDARIA                                    -->
            <!-- ============================================================= -->
            <t t-if="hasSecondaryCurrencyFilter">
                <div class="dropdown-divider"/>
                <div class="dropdown-item-text px-3 py-1">
                    <small class="text-muted fw-bold">
                        <i class="fa fa-money me-1"/>Moneda Secundaria:
                    </small>
                </div>

                <!-- Toggle de moneda secundaria -->
                <DropdownItem
                    class="{ 'selected': showSecondaryCurrency }"
                    onSelected="() => this.toggleSecondaryCurrency()"
                    closingMode="'none'"
                >
                    <i t-if="showSecondaryCurrency" class="fa fa-check-square-o me-2"/>
                    <i t-else="" class="fa fa-square-o me-2"/>
                    <i class="fa fa-usd me-1"/>
                    Mostrar Moneda Secundaria
                </DropdownItem>

                <!-- Selector de moneda (solo si está activo) -->
                <t t-if="showSecondaryCurrency and availableCurrencies.length > 0">
                    <div class="dropdown-item-text px-3 py-2">
                        <label class="form-label small mb-1">Seleccionar moneda:</label>
                        <select class="form-select form-select-sm"
                                t-on-change="(ev) => this.onSecondaryCurrencyChange(ev.target.value)">
                            <option value="">-- Seleccionar --</option>
                            <t t-foreach="availableCurrencies" t-as="currency" t-key="currency.id">
                                <option t-att-value="currency.id"
                                        t-att-selected="currency.id === selectedSecondaryCurrency">
                                    <t t-esc="currency.name"/> (<t t-esc="currency.symbol"/>)
                                </option>
                            </t>
                        </select>
                    </div>
                </t>
            </t>

        </xpath>

    </t>

</templates>
