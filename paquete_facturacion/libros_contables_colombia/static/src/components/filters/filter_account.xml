<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <!--
    Template para el filtro de cuentas contables.

    Sigue el patrón exacto de account_reports.AccountReportFilterPartner:
    - Usa Dropdown con menuClass para estilos
    - Usa MultiRecordSelector para selección múltiple
    - Se conecta con getMultiRecordSelectorProps('account.account', 'account_ids')
    -->
    <t t-name="libros_contables_colombia.AccountReportFilterAccount">
        <Dropdown menuClass="'account_report_filter account'">
            <button class="btn btn-secondary">
                <i class="fa fa-book me-1"/>Cuentas
            </button>

            <t t-set-slot="content">
                <div class="dropdown-item gap-2 align-items-center">
                    <label>Cuentas Contables</label>
                    <MultiRecordSelector
                        t-props="getMultiRecordSelectorProps('account.account', 'account_ids')"
                    />
                </div>
            </t>
        </Dropdown>
    </t>
</templates>
