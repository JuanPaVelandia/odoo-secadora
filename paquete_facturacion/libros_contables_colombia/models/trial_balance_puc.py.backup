# -*- coding: utf-8 -*-
"""
Balance de Prueba Colombiano (PUC)
==================================
Reporte de Balance de Prueba con jerarquía del Plan Único de Cuentas Colombiano.

Niveles del PUC:
- Nivel 1: Clase (1 dígito) - Ej: 1 Activo, 2 Pasivo
- Nivel 2: Grupo (2 dígitos) - Ej: 11 Disponible
- Nivel 3: Cuenta (4 dígitos) - Ej: 1105 Caja
- Nivel 4: Subcuenta (6 dígitos) - Ej: 110505 Caja General
- Nivel 5: Auxiliar (8+ dígitos) - Detalle completo

Funcionalidades:
- Filtro de nivel de expansión inicial
- Filtro de cuentas específicas
- Expansión manual (unfoldable) para drill-down
- Columna de última fecha de movimiento
- Exportación PDF y Excel con outlines
"""

import re
import logging
from collections import defaultdict
from odoo import models, fields, api, _
from odoo.tools import SQL
from odoo.tools.misc import format_date

_logger = logging.getLogger(__name__)


class TrialBalancePUCHandler(models.AbstractModel):
    _name = 'account.trial.balance.puc.report.handler'
    _inherit = ['account.report.custom.handler', 'sql.helper.mixin']
    _description = 'Balance de Prueba PUC Colombia Handler'

    def _get_custom_display_config(self):
        return {
            'css_custom_class': 'trial_balance_puc_report',
            'templates': {
                'AccountReportLineName': 'account_reports.GeneralLedgerLineName',
            },
            'components': {
                'AccountReportFilters': 'libros_contables_colombia.TrialBalancePartnerFilters',
            },
        }

    def _custom_options_initializer(self, report, options, previous_options=None):
        """Inicializa opciones personalizadas para el reporte."""
        super()._custom_options_initializer(report, options, previous_options=previous_options)

        # Filtro de nivel de expansión (1-6)
        options['puc_level'] = previous_options.get('puc_level', 4) if previous_options else 4

        # Filtro de cuentas
        options['account_codes'] = previous_options.get('account_codes', '') if previous_options else ''

        # Agregar filtros personalizados a la UI
        options.setdefault('buttons', []).append({
            'name': _('Exportar Excel'),
            'sequence': 50,
            'action': 'export_to_xlsx',
        })

    def _dynamic_lines_generator(self, report, options, all_column_groups_expression_totals, warnings=None):
        """Genera las líneas del Balance de Prueba según el nivel seleccionado."""
        lines = []

        # Obtener nivel de expansión
        puc_level = options.get('puc_level', 4)

        # Obtener datos de cuentas
        account_data = self._get_account_balances(report, options)

        if not account_data:
            return [(0, self._get_no_data_line(report, options))]

        # Agrupar por nivel del PUC
        grouped_data = self._group_by_puc_level(account_data, puc_level)

        # Generar líneas
        totals = {'initial': 0, 'debit': 0, 'credit': 0, 'final': 0, 'last_move_date': None}

        for code, data in sorted(grouped_data.items()):
            line = self._get_account_line(report, options, code, data, puc_level)
            lines.append((0, line))

            totals['initial'] += data['initial']
            totals['debit'] += data['debit']
            totals['credit'] += data['credit']
            totals['final'] += data['final']

            # Actualizar última fecha de movimiento del total
            if data.get('last_move_date'):
                if not totals['last_move_date'] or data['last_move_date'] > totals['last_move_date']:
                    totals['last_move_date'] = data['last_move_date']

        # Línea de totales
        if lines:
            lines.append((0, self._get_total_line(report, options, totals)))

        return lines

    def _get_account_balances(self, report, options):
        """Obtiene los saldos de todas las cuentas usando patrón nativo Odoo 18."""
        queries = []

        for column_group_key, options_group in report._split_options_per_column_group(options).items():
            # ========== SALDOS DEL PERÍODO ==========
            query = report._get_report_query(options_group, date_scope='strict_range')

            account_alias = query.join(
                lhs_alias='account_move_line',
                lhs_column='account_id',
                rhs_table='account_account',
                rhs_column='id',
                link='account_id'
            )

            account_code = self.env['account.account']._field_to_sql(account_alias, 'code', query)
            account_name = self.env['account.account']._field_to_sql(account_alias, 'name')

            queries.append(SQL(
                """
                SELECT
                    account_move_line.account_id AS account_id,
                    %(account_code)s AS account_code,
                    %(account_name)s AS account_name,
                    'period' AS data_type,
                    %(column_group_key)s AS column_group_key,
                    COALESCE(SUM(%(debit_select)s), 0) AS debit,
                    COALESCE(SUM(%(credit_select)s), 0) AS credit,
                    COALESCE(SUM(%(balance_select)s), 0) AS balance,
                    MAX(account_move_line.date) AS last_move_date
                FROM %(table_references)s
                %(currency_table_join)s
                WHERE %(search_condition)s
                GROUP BY account_move_line.account_id, %(account_code)s, %(account_name)s
                HAVING COALESCE(SUM(%(debit_select)s), 0) != 0
                    OR COALESCE(SUM(%(credit_select)s), 0) != 0
                """,
                account_code=account_code,
                account_name=account_name,
                column_group_key=column_group_key,
                table_references=query.from_clause,
                search_condition=query.where_clause,
                debit_select=report._currency_table_apply_rate(SQL("account_move_line.debit")),
                credit_select=report._currency_table_apply_rate(SQL("account_move_line.credit")),
                balance_select=report._currency_table_apply_rate(SQL("account_move_line.balance")),
                currency_table_join=report._currency_table_aml_join(options_group),
            ))

            # ========== SALDOS INICIALES ==========
            initial_options = self._get_options_initial_balance(options_group)
            query_initial = report._get_report_query(initial_options, date_scope='from_beginning')

            account_alias_init = query_initial.join(
                lhs_alias='account_move_line',
                lhs_column='account_id',
                rhs_table='account_account',
                rhs_column='id',
                link='account_id'
            )

            account_code_init = self.env['account.account']._field_to_sql(account_alias_init, 'code', query_initial)
            account_name_init = self.env['account.account']._field_to_sql(account_alias_init, 'name')

            queries.append(SQL(
                """
                SELECT
                    account_move_line.account_id AS account_id,
                    %(account_code)s AS account_code,
                    %(account_name)s AS account_name,
                    'initial' AS data_type,
                    %(column_group_key)s AS column_group_key,
                    COALESCE(SUM(%(debit_select)s), 0) AS debit,
                    COALESCE(SUM(%(credit_select)s), 0) AS credit,
                    COALESCE(SUM(%(balance_select)s), 0) AS balance,
                    NULL::date AS last_move_date
                FROM %(table_references)s
                %(currency_table_join)s
                WHERE %(search_condition)s
                GROUP BY account_move_line.account_id, %(account_code)s, %(account_name)s
                HAVING COALESCE(SUM(%(balance_select)s), 0) != 0
                """,
                account_code=account_code_init,
                account_name=account_name_init,
                column_group_key=column_group_key,
                table_references=query_initial.from_clause,
                search_condition=query_initial.where_clause,
                debit_select=report._currency_table_apply_rate(SQL("account_move_line.debit")),
                credit_select=report._currency_table_apply_rate(SQL("account_move_line.credit")),
                balance_select=report._currency_table_apply_rate(SQL("account_move_line.balance")),
                currency_table_join=report._currency_table_aml_join(initial_options),
            ))

        full_query = SQL(" UNION ALL ").join(SQL("(%s)", q) for q in queries)
        self._cr.execute(full_query)

        # Procesar resultados
        accounts = {}
        for row in self._cr.dictfetchall():
            account_id = row['account_id']

            if account_id not in accounts:
                accounts[account_id] = {
                    'code': row['account_code'],
                    'name': row['account_name'],
                    'initial': 0.0,
                    'debit': 0.0,
                    'credit': 0.0,
                    'last_move_date': None,
                }

            if row['data_type'] == 'initial':
                accounts[account_id]['initial'] = float(row['balance'] or 0)
            else:  # period
                accounts[account_id]['debit'] = float(row['debit'] or 0)
                accounts[account_id]['credit'] = float(row['credit'] or 0)
                if row['last_move_date']:
                    accounts[account_id]['last_move_date'] = row['last_move_date']

        # Calcular saldo final
        for acc in accounts.values():
            acc['final'] = acc['initial'] + acc['debit'] - acc['credit']

        return accounts

    def _get_options_initial_balance(self, options):
        """Crea opciones para obtener saldo inicial (antes del período)."""
        from datetime import timedelta

        new_options = options.copy()
        date_from = fields.Date.from_string(options['date']['date_from'])
        new_date_to = date_from - timedelta(days=1)

        fiscalyear_dates = self.env.company.compute_fiscalyear_dates(date_from)

        if date_from == fiscalyear_dates['date_from']:
            prev_fiscalyear = self.env.company.compute_fiscalyear_dates(date_from - timedelta(days=1))
            new_date_from = prev_fiscalyear['date_from']
        else:
            new_date_from = fiscalyear_dates['date_from']

        new_options['date'] = self.env['account.report']._get_dates_period(
            new_date_from, new_date_to, 'range'
        )

        return new_options

    def _group_by_puc_level(self, account_data, level):
        """Agrupa cuentas según el nivel del PUC."""
        # Mapeo de nivel a longitud de código
        level_lengths = {1: 1, 2: 2, 3: 4, 4: 6, 5: 8, 6: 10}
        code_length = level_lengths.get(level, 6)

        grouped = defaultdict(lambda: {
            'name': '',
            'initial': 0,
            'debit': 0,
            'credit': 0,
            'final': 0,
            'last_move_date': None,
            'accounts': [],
            'has_children': False,
        })

        for account_id, data in account_data.items():
            code = data['code'] or ''
            # Truncar código al nivel solicitado
            prefix = code[:code_length] if len(code) >= code_length else code

            grouped[prefix]['initial'] += data['initial']
            grouped[prefix]['debit'] += data['debit']
            grouped[prefix]['credit'] += data['credit']
            grouped[prefix]['final'] += data['final']

            # Actualizar última fecha de movimiento del grupo
            if data.get('last_move_date'):
                if not grouped[prefix]['last_move_date'] or data['last_move_date'] > grouped[prefix]['last_move_date']:
                    grouped[prefix]['last_move_date'] = data['last_move_date']

            grouped[prefix]['accounts'].append({
                'id': account_id,
                'code': code,
                'name': data['name'],
                'initial': data['initial'],
                'debit': data['debit'],
                'credit': data['credit'],
                'final': data['final'],
                'last_move_date': data.get('last_move_date'),
            })

            # Nombre del grupo (usar el de la primera cuenta o del más corto)
            if not grouped[prefix]['name'] or len(data['code']) < len(grouped[prefix]['name']):
                grouped[prefix]['name'] = self._get_puc_name(prefix, data['name'])

        # Marcar si tiene hijos (cuentas con códigos más largos)
        for code, data in grouped.items():
            data['has_children'] = any(len(a['code']) > len(code) for a in data['accounts'])

        return grouped

    def _get_puc_name(self, code, account_name):
        """Obtiene el nombre según el nivel del PUC."""
        puc_names = {
            '1': 'ACTIVO',
            '2': 'PASIVO',
            '3': 'PATRIMONIO',
            '4': 'INGRESOS',
            '5': 'GASTOS',
            '6': 'COSTOS DE VENTAS',
            '7': 'COSTOS DE PRODUCCIÓN',
            '8': 'CUENTAS DE ORDEN DEUDORAS',
            '9': 'CUENTAS DE ORDEN ACREEDORAS',
        }

        if len(code) == 1:
            return puc_names.get(code, account_name)

        return account_name

    def _get_account_line(self, report, options, code, data, current_level):
        """Crea una línea para el reporte."""
        line_id = report._get_generic_line_id(None, None, markup=f'puc_{code}')

        # Determinar si es expandible
        has_children = data['has_children']
        is_unfolded = line_id in options.get('unfolded_lines', [])

        # Calcular nivel visual
        code_len = len(code)
        if code_len == 1:
            level = 1
        elif code_len == 2:
            level = 2
        elif code_len <= 4:
            level = 3
        else:
            level = 4

        columns = self._build_columns(report, options, data)

        return {
            'id': line_id,
            'name': f"{code} - {data['name']}",
            'level': level,
            'unfoldable': has_children,
            'unfolded': is_unfolded,
            'expand_function': '_report_expand_unfoldable_line_puc' if has_children else None,
            'columns': columns,
            'class': 'font-weight-bold' if code_len <= 2 else '',
        }

    def _build_columns(self, report, options, data):
        """Construye las columnas para una línea."""
        columns = []

        # Calcular variación
        initial = data.get('initial', 0) or 0
        final = data.get('final', 0) or 0
        variation = final - initial
        variation_percent = (variation / initial * 100) if initial != 0 else 0.0

        for col in options['columns']:
            label = col['expression_label']
            value = None

            if label == 'initial_balance':
                value = data['initial']
            elif label == 'debit':
                value = data['debit']
            elif label == 'credit':
                value = data['credit']
            elif label == 'final_balance':
                value = data['final']
            elif label == 'variation':
                value = variation
            elif label == 'variation_percent':
                value = variation_percent / 100  # Odoo espera 0.15 para 15%
            elif label == 'last_move_date':
                value = data.get('last_move_date')

            columns.append(report._build_column_dict(value, col, options=options))

        return columns

    def _get_total_line(self, report, options, totals):
        """Crea la línea de totales."""
        columns = []

        # Calcular variación para totales
        initial = totals.get('initial', 0) or 0
        final = totals.get('final', 0) or 0
        variation = final - initial
        variation_percent = (variation / initial * 100) if initial != 0 else 0.0

        for col in options['columns']:
            label = col['expression_label']
            value = None

            if label == 'initial_balance':
                value = totals['initial']
            elif label == 'debit':
                value = totals['debit']
            elif label == 'credit':
                value = totals['credit']
            elif label == 'final_balance':
                value = totals['final']
            elif label == 'variation':
                value = variation
            elif label == 'variation_percent':
                value = variation_percent / 100
            elif label == 'last_move_date':
                value = totals.get('last_move_date')

            columns.append(report._build_column_dict(value, col, options=options))

        return {
            'id': report._get_generic_line_id(None, None, markup='total'),
            'name': _('TOTAL'),
            'level': 1,
            'unfoldable': False,
            'columns': columns,
            'class': 'font-weight-bold o_account_reports_totals_below_sections',
        }

    def _get_no_data_line(self, report, options):
        """Línea cuando no hay datos."""
        return {
            'id': report._get_generic_line_id(None, None, markup='no_data'),
            'name': _('No hay movimientos en el período seleccionado'),
            'level': 1,
            'unfoldable': False,
            'columns': [{'name': ''} for _ in options['columns']],
        }

    def _report_expand_unfoldable_line_puc(self, line_dict_id, groupby, options, progress, offset, unfold_all_batch_data=None):
        """Expande una línea para mostrar sus subcuentas."""
        report = self.env['account.report'].browse(options['report_id'])
        lines = []

        # Extraer el ÚLTIMO código del PUC del line_id (puede haber múltiples puc_XXX)
        matches = re.findall(r'puc_(\d+)', line_dict_id)
        if not matches:
            return {'lines': [], 'offset_increment': 0, 'has_more': False}

        parent_code = matches[-1]  # Tomar el último código (el más específico)

        # Obtener datos de cuentas
        account_data = self._get_account_balances(report, options)

        # Filtrar cuentas que empiezan con el código padre
        child_accounts = {}
        for account_id, data in account_data.items():
            code = data['code'] or ''
            if code.startswith(parent_code) and len(code) > len(parent_code):
                child_accounts[account_id] = data

        if not child_accounts:
            return {'lines': [], 'offset_increment': 0, 'has_more': False}

        # Determinar el siguiente nivel
        next_level_length = len(parent_code) + (2 if len(parent_code) <= 2 else 2)

        # Agrupar por siguiente nivel
        grouped = self._group_by_puc_level_custom(child_accounts, next_level_length, parent_code)

        for code, data in sorted(grouped.items()):
            child_line = self._get_child_line(report, options, code, data, line_dict_id)
            lines.append(child_line)

        return {
            'lines': lines,
            'offset_increment': len(lines),
            'has_more': False,
        }

    def _group_by_puc_level_custom(self, account_data, code_length, parent_code):
        """Agrupa cuentas por un nivel específico."""
        grouped = defaultdict(lambda: {
            'name': '',
            'initial': 0,
            'debit': 0,
            'credit': 0,
            'final': 0,
            'last_move_date': None,
            'accounts': [],
            'has_children': False,
        })

        for account_id, data in account_data.items():
            code = data['code'] or ''
            if not code.startswith(parent_code):
                continue

            prefix = code[:code_length] if len(code) >= code_length else code

            grouped[prefix]['initial'] += data['initial']
            grouped[prefix]['debit'] += data['debit']
            grouped[prefix]['credit'] += data['credit']
            grouped[prefix]['final'] += data['final']

            # Actualizar última fecha de movimiento
            if data.get('last_move_date'):
                if not grouped[prefix]['last_move_date'] or data['last_move_date'] > grouped[prefix]['last_move_date']:
                    grouped[prefix]['last_move_date'] = data['last_move_date']

            grouped[prefix]['accounts'].append({
                'id': account_id,
                'code': code,
                'name': data['name'],
                'last_move_date': data.get('last_move_date'),
            })

            if not grouped[prefix]['name']:
                grouped[prefix]['name'] = data['name']

        for code, data in grouped.items():
            data['has_children'] = any(len(a['code']) > len(code) for a in data['accounts'])

        return grouped

    def _get_child_line(self, report, options, code, data, parent_line_id):
        """Crea una línea hija."""
        line_id = report._get_generic_line_id(None, None, markup=f'puc_{code}', parent_line_id=parent_line_id)
        has_children = data['has_children']
        is_unfolded = line_id in options.get('unfolded_lines', [])

        code_len = len(code)
        if code_len <= 2:
            level = 2
        elif code_len <= 4:
            level = 3
        else:
            level = 4

        columns = self._build_columns(report, options, data)

        return {
            'id': line_id,
            'name': f"{code} - {data['name']}",
            'level': level,
            'parent_id': parent_line_id,
            'unfoldable': has_children,
            'unfolded': is_unfolded,
            'expand_function': '_report_expand_unfoldable_line_puc' if has_children else None,
            'columns': columns,
        }

    # =========================================================================
    # MÉTODOS PARA PDF - Similar a Balance por Tercero
    # =========================================================================

    def _get_lines_for_pdf(self, report, options):
        """
        Obtiene todas las líneas expandidas para exportación PDF.
        Genera la jerarquía completa del PUC.
        """
        lines = []
        account_data = self._get_account_balances(report, options)

        if not account_data:
            return lines

        # Generar estructura jerárquica completa
        hierarchy = self._build_puc_hierarchy(account_data)

        # Convertir jerarquía a líneas planas
        totals = {'initial': 0, 'debit': 0, 'credit': 0, 'final': 0, 'last_move_date': None}
        self._flatten_hierarchy(hierarchy, lines, totals, report, options)

        # Agregar línea de totales
        lines.append({
            'name': 'TOTAL',
            'level': 1,
            'is_total': True,
            'initial': totals['initial'],
            'debit': totals['debit'],
            'credit': totals['credit'],
            'final': totals['final'],
            'last_move_date': totals['last_move_date'],
        })

        return lines

    def _build_puc_hierarchy(self, account_data):
        """
        Construye la jerarquía completa del PUC desde las cuentas.
        """
        hierarchy = {}

        for account_id, data in account_data.items():
            code = data['code'] or ''
            if not code:
                continue

            # Crear todos los niveles de la jerarquía
            # Nivel 1: 1 dígito
            # Nivel 2: 2 dígitos
            # Nivel 3: 4 dígitos
            # Nivel 4: 6 dígitos
            # Nivel 5: código completo

            levels = []
            if len(code) >= 1:
                levels.append(code[:1])
            if len(code) >= 2:
                levels.append(code[:2])
            if len(code) >= 4:
                levels.append(code[:4])
            if len(code) >= 6:
                levels.append(code[:6])
            if len(code) > 6:
                levels.append(code)

            # Agregar cuenta a cada nivel
            for i, level_code in enumerate(levels):
                if level_code not in hierarchy:
                    hierarchy[level_code] = {
                        'code': level_code,
                        'name': self._get_puc_name(level_code, data['name']) if i == 0 else data['name'],
                        'initial': 0,
                        'debit': 0,
                        'credit': 0,
                        'final': 0,
                        'last_move_date': None,
                        'level': i + 1,
                    }

                # Solo sumar valores en el nivel más bajo (cuenta real)
                if level_code == code:
                    hierarchy[level_code]['initial'] = data['initial']
                    hierarchy[level_code]['debit'] = data['debit']
                    hierarchy[level_code]['credit'] = data['credit']
                    hierarchy[level_code]['final'] = data['final']
                    hierarchy[level_code]['last_move_date'] = data.get('last_move_date')
                    hierarchy[level_code]['name'] = data['name']

        # Calcular totales de grupos (sumando sus hijos)
        sorted_codes = sorted(hierarchy.keys(), key=lambda x: (-len(x), x))

        for code in sorted_codes:
            if len(code) < max(len(c) for c in hierarchy.keys()):
                # Es un grupo, sumar sus hijos directos
                for child_code, child_data in hierarchy.items():
                    if child_code.startswith(code) and child_code != code:
                        # Verificar que es hijo directo
                        is_direct_child = True
                        for other_code in hierarchy.keys():
                            if (other_code.startswith(code) and
                                child_code.startswith(other_code) and
                                other_code != code and
                                other_code != child_code and
                                len(other_code) < len(child_code)):
                                is_direct_child = False
                                break

                        if is_direct_child:
                            hierarchy[code]['initial'] += child_data['initial']
                            hierarchy[code]['debit'] += child_data['debit']
                            hierarchy[code]['credit'] += child_data['credit']
                            hierarchy[code]['final'] += child_data['final']

                            if child_data.get('last_move_date'):
                                if not hierarchy[code]['last_move_date'] or child_data['last_move_date'] > hierarchy[code]['last_move_date']:
                                    hierarchy[code]['last_move_date'] = child_data['last_move_date']

        return hierarchy

    def _flatten_hierarchy(self, hierarchy, lines, totals, report, options):
        """
        Convierte la jerarquía en líneas planas ordenadas.
        """
        for code in sorted(hierarchy.keys()):
            data = hierarchy[code]

            # Determinar nivel visual
            code_len = len(code)
            if code_len == 1:
                level = 1
            elif code_len == 2:
                level = 2
            elif code_len <= 4:
                level = 3
            elif code_len <= 6:
                level = 4
            else:
                level = 5

            lines.append({
                'code': code,
                'name': data['name'],
                'level': level,
                'is_total': False,
                'initial': data['initial'],
                'debit': data['debit'],
                'credit': data['credit'],
                'final': data['final'],
                'last_move_date': data.get('last_move_date'),
            })

            # Solo sumar al total las cuentas de nivel 1 (clases)
            if level == 1:
                totals['initial'] += data['initial']
                totals['debit'] += data['debit']
                totals['credit'] += data['credit']
                totals['final'] += data['final']

                if data.get('last_move_date'):
                    if not totals['last_move_date'] or data['last_move_date'] > totals['last_move_date']:
                        totals['last_move_date'] = data['last_move_date']
