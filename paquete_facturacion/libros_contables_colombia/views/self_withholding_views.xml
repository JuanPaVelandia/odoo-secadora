<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================== -->
    <!-- SELF-WITHHOLDING CONFIGURATION VIEWS -->
    <!-- ============================================================== -->

    <!-- Configuration Tree View -->
    <record id="view_self_withholding_config_tree" model="ir.ui.view">
        <field name="name">self.withholding.config.tree</field>
        <field name="model">self.withholding.config</field>
        <field name="arch" type="xml">
            <list string="Self-Withholding Configurations">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="withholding_type" widget="badge"
                       decoration-info="withholding_type == 'ica'"
                       decoration-success="withholding_type == 'renta'"/>
                <field name="municipality_id"/>
                <field name="rate" string="Rate (%)"/>
                <field name="rate_per_mil" string="Rate (‰)" optional="show"/>
                <field name="income_account_prefix"/>
                <field name="expense_account_id" optional="show"/>
                <field name="liability_account_id" optional="show"/>
                <field name="min_base_uvt" optional="hide"/>
                <field name="min_base_amount" optional="hide" widget="monetary"/>
                <field name="date_from"/>
                <field name="date_to" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Configuration Form View -->
    <record id="view_self_withholding_config_form" model="ir.ui.view">
        <field name="name">self.withholding.config.form</field>
        <field name="model">self.withholding.config</field>
        <field name="arch" type="xml">
            <form string="Self-Withholding Configuration">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <group string="General">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="withholding_type" widget="radio"/>
                            <field name="municipality_id"
                                   placeholder="Leave empty for general config"
                                   invisible="withholding_type != 'ica'"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Rate">
                            <field name="rate" string="Rate (%)"/>
                            <field name="rate_per_mil" string="Rate (‰)"/>
                        </group>
                    </group>
                    <group>
                        <group string="Accounts">
                            <field name="income_account_prefix"
                                   placeholder="41 (all income)"
                                   help="Prefix of income accounts to apply self-withholding"/>
                            <field name="expense_account_id"
                                   placeholder="Select expense account..."/>
                            <field name="liability_account_id"
                                   placeholder="Select liability account..."/>
                        </group>
                        <group string="Validity">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group>
                        <group string="Minimum Base">
                            <field name="min_base_uvt"/>
                            <field name="min_base_amount" readonly="1"/>
                        </group>
                        <group string="Reference">
                            <field name="legal_reference" placeholder="Resolution, Decree..."/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>

                    <!-- Info Box -->
                    <group class="alert alert-info" role="alert">
                        <div>
                            <p><strong>Autoretenciones en Colombia:</strong></p>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Tasa Comun</th>
                                        <th>Cuenta PUC</th>
                                        <th>Base Legal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Autorretencion Renta</td>
                                        <td>0.4% - 1.6%</td>
                                        <td>2365 (por pagar)</td>
                                        <td>Art. 365 E.T., Decreto 2201/2016</td>
                                    </tr>
                                    <tr>
                                        <td>Autorretencion ICA</td>
                                        <td>Variable por municipio</td>
                                        <td>2368 (por pagar)</td>
                                        <td>Acuerdos municipales</td>
                                    </tr>
                                </tbody>
                            </table>
                            <p class="text-muted">
                                <strong>Nota:</strong> Los Grandes Contribuyentes y los autorretenedores
                                deben aplicar autoretenciones sobre sus ingresos.
                            </p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Configuration Search View -->
    <record id="view_self_withholding_config_search" model="ir.ui.view">
        <field name="name">self.withholding.config.search</field>
        <field name="model">self.withholding.config</field>
        <field name="arch" type="xml">
            <search string="Search Configurations">
                <field name="withholding_type"/>
                <field name="municipality_id"/>
                <filter string="ICA" name="ica" domain="[('withholding_type', '=', 'ica')]"/>
                <filter string="Renta" name="renta" domain="[('withholding_type', '=', 'renta')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'withholding_type'}"/>
                    <filter string="Municipality" name="group_municipality" context="{'group_by': 'municipality_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <!-- Configuration Action -->
    <record id="action_self_withholding_config" model="ir.actions.act_window">
        <field name="name">Self-Withholding Configuration</field>
        <field name="res_model">self.withholding.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure self-withholding rates
            </p>
            <p>
                Set up ICA and Renta self-withholding rates for your company.
                <br/>
                <strong>ICA:</strong> By municipality
                <br/>
                <strong>Renta:</strong> General rate (0.4% - 1.6%)
            </p>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- SELF-WITHHOLDING WIZARD VIEWS -->
    <!-- ============================================================== -->

    <!-- Wizard Form View -->
    <record id="view_self_withholding_wizard_form" model="ir.ui.view">
        <field name="name">self.withholding.wizard.form</field>
        <field name="model">self.withholding.wizard</field>
        <field name="arch" type="xml">
            <form string="Calculate Self-Withholdings">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span invisible="state != 'draft'">Calculate Self-Withholdings</span>
                            <span invisible="state != 'calculated'">Review Calculated Amounts</span>
                            <span invisible="state != 'applied'">Self-Withholdings Applied</span>
                        </h1>
                    </div>

                    <!-- Configuration Panel (only in draft) -->
                    <group invisible="state != 'draft'">
                        <group string="Period">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Options">
                            <field name="withholding_type" widget="radio"/>
                            <field name="municipality_id"
                                   invisible="withholding_type not in ('ica', 'both')"
                                   placeholder="Use company default"/>
                            <field name="include_posted_only"/>
                            <field name="exclude_already_applied"/>
                        </group>
                    </group>

                    <!-- Summary Panel (calculated and applied) -->
                    <group invisible="state == 'draft'">
                        <group string="ICA Self-Withholding">
                            <field name="total_base_ica" widget="monetary" readonly="1"/>
                            <field name="total_withholding_ica" widget="monetary" readonly="1"/>
                        </group>
                        <group string="Renta Self-Withholding">
                            <field name="total_base_renta" widget="monetary" readonly="1"/>
                            <field name="total_withholding_renta" widget="monetary" readonly="1"/>
                        </group>
                    </group>

                    <!-- Journal Selection (for apply) -->
                    <group invisible="state != 'calculated'">
                        <group string="Entry Configuration">
                            <field name="journal_id" required="state == 'calculated'"
                                   domain="[('type', '=', 'general'), ('company_id', '=', company_id)]"/>
                        </group>
                    </group>

                    <!-- Generated Entry (applied state) -->
                    <group invisible="state != 'applied'">
                        <group string="Generated Entry">
                            <field name="generated_move_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Lines (calculated and applied) -->
                    <notebook invisible="state == 'draft'">
                        <page string="Calculated Lines" name="lines">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="move_name"/>
                                    <field name="date"/>
                                    <field name="partner_id"/>
                                    <field name="withholding_type" widget="badge"
                                           decoration-info="withholding_type == 'ica'"
                                           decoration-success="withholding_type == 'renta'"/>
                                    <field name="municipality_id" optional="show"/>
                                    <field name="account_code" optional="show"/>
                                    <field name="base_amount" sum="Total Base"/>
                                    <field name="rate" string="Rate (%)"/>
                                    <field name="withholding_amount" sum="Total Withholding"/>
                                    <field name="state" widget="badge"
                                           decoration-muted="state == 'draft'"
                                           decoration-success="state == 'applied'"
                                           decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <field name="state" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_calculate" string="Calculate"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_apply" string="Generate Entry"
                            type="object" class="btn-primary"
                            invisible="state != 'calculated'"/>
                    <button name="action_view_entry" string="View Entry"
                            type="object" class="btn-secondary"
                            invisible="state != 'applied'"/>
                    <button name="action_reset" string="Reset"
                            type="object" class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_self_withholding_wizard" model="ir.actions.act_window">
        <field name="name">Calculate Self-Withholdings</field>
        <field name="res_model">self.withholding.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ============================================================== -->
    <!-- MENU ITEMS -->
    <!-- ============================================================== -->

    <!-- Add to existing Accounting menu -->
    <menuitem id="menu_self_withholding_root"
              name="Autoretenciones"
              parent="account.menu_finance_entries"
              sequence="50"/>

    <menuitem id="menu_self_withholding_config"
              name="Configuracion"
              parent="menu_self_withholding_root"
              action="action_self_withholding_config"
              sequence="10"/>

    <menuitem id="menu_self_withholding_wizard"
              name="Calcular Autoretenciones"
              parent="menu_self_withholding_root"
              action="action_self_withholding_wizard"
              sequence="20"/>

</odoo>
