                  parent="account_colombia_reports_menu"
                  sequence="20"/>

        <menuitem id="menu_action_account_report_trial_balance_puc"
                  name="Balance de Prueba PUC"
                  parent="menu_balances_prueba"
                  action="action_co_trial_balance_puc"
                  sequence="10"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_account_report_trial_balance_partner"
                  name="Balance de Prueba por Tercero"
                  parent="menu_balances_prueba"
                  action="action_co_trial_balance_partner"
                  sequence="20"
                  groups="account.group_account_readonly"/>

        <!-- ============================================================== -->
        <!-- SECCIÓN 3: ESTADOS FINANCIEROS                                 -->
        <!-- ============================================================== -->
        <menuitem id="menu_estados_financieros"
