<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================== -->
        <!-- MENÚ PRINCIPAL: REPORTES CONTABLES COLOMBIA                    -->
        <!-- Estructura reorganizada con todas las secciones                -->
        <!-- ============================================================== -->

        <!-- Menú principal -->
        <menuitem id="account_colombia_reports_menu"
                  name="Reportes Contables Colombia"
                  parent="account.menu_finance_reports"
                  sequence="4"/>

