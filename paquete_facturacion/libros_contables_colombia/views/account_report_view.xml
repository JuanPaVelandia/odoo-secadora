        <menuitem id="menu_audit_modified_entries"
                  name="Documentos Modificados"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_modified_entries"
                  sequence="20"
                  groups="account.group_account_manager"/>

        <menuitem id="menu_audit_monthly_count"
                  name="Conteo Mensual de Documentos"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_monthly_count"
                  sequence="30"
                  groups="account.group_account_manager"/>

        <menuitem id="menu_audit_bank_accounts"
                  name="Auditoría Cuentas Bancarias"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_bank_accounts"
                  sequence="40"
                  groups="account.group_account_manager"/>

        <menuitem id="menu_audit_imbalances"
                  name="Errores y Descuadres"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_imbalances"
                  sequence="50"
                  groups="account.group_account_manager"/>

        <menuitem id="menu_audit_inconsistencies"
                  name="Inconsistencias Contables"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_inconsistencies"
                  sequence="60"
                  groups="account.group_account_manager"/>

        <!-- ============================================================== -->
        <!-- VISTA HEREDADA: Configuración de Filtros Colombia              -->
        <!-- ============================================================== -->
        <record id="view_account_report_form_inherit_colombia" model="ir.ui.view">
            <field name="name">account.report.form.inherit.colombia</field>
            <field name="model">account.report</field>
            <field name="inherit_id" ref="account_reports.account_report_form"/>
            <field name="arch" type="xml">
                <!-- Agregar campos de filtros Colombia después del campo filter_hide_0_lines -->
                <xpath expr="//page[@name='page_options']//field[@name='filter_hide_0_lines']" position="after">
                    <field name="filter_account"
                           help="Filtro por cuentas contables específicas (selector múltiple)"/>
                    <field name="filter_tax"
                           help="Filtro por impuestos específicos (selector múltiple)"/>
                    <field name="filter_account_range"
                           help="Filtro por rango de cuentas contables (desde/hasta) con exclusión"/>
                    <field name="filter_hide_partners_no_movement"
                           help="Ocultar terceros sin movimiento en el período"/>
                    <field name="filter_withholding_filters"
                           help="Habilita todos los filtros de retención e impuestos"/>
                    <field name="filter_operation_type"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por tipo: Compras, Ventas, NC Proveedor, NC Cliente"/>
                    <field name="filter_concept_type"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por concepto: ReteFuente, ReteIVA, ReteICA, IVA, INC"/>
                    <field name="filter_withholding_concept"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por concepto específico de tax_base_threshold"/>
                    <field name="filter_person_type"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por tipo de persona: PJ (Jurídica) / PN (Natural)"/>
                    <field name="filter_product_type"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por tipo: Servicios / Bienes"/>
                    <field name="filter_city"
                           invisible="not filter_withholding_filters"
                           help="Filtrar por ciudad del tercero"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
