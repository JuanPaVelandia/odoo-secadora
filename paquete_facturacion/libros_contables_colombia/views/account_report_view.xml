                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_account_report_auxiliary_book_analytic"
                  name="Libro Auxiliar Analítico"
                  parent="menu_libros_legales"
                  action="action_co_auxiliary_book_analytic"
                  sequence="50"
                  groups="account.group_account_readonly"/>

