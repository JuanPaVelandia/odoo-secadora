                  action="action_co_monthly_balance"
                  sequence="60"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_monthly_income"
                  name="Estado de Resultados por Mes"
                  parent="menu_estados_financieros"
                  action="action_co_monthly_income"
                  sequence="70"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_period_movements"
                  name="Balance de Movimientos del Período"
                  parent="menu_estados_financieros"
                  action="action_co_period_movements"
                  sequence="75"
                  groups="account.group_account_readonly"/>

        <!-- ============================================================== -->
        <!-- SECCIÓN 4: REPORTES DE IMPUESTOS                               -->
        <!-- ============================================================== -->
        <menuitem id="menu_tax_reports_co"
                  name="Reportes de Impuestos"
                  parent="account_colombia_reports_menu"
                  sequence="40"/>

        <menuitem id="menu_tax_report_general_co"
                  name="Reporte General de Impuestos"
                  parent="menu_tax_reports_co"
                  action="action_co_tax_report"
                  sequence="10"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_tax_report_iva_co"
                  name="IVA"
                  parent="menu_tax_reports_co"
                  action="action_co_tax_report_iva"
                  sequence="20"
