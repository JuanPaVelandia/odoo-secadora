                  name="Libros Legales"
                  parent="account_colombia_reports_menu"
                  sequence="10"/>

        <menuitem id="menu_action_account_report_inventory_book"
                  name="Libro de Inventarios y Balances"
                  parent="menu_libros_legales"
                  action="action_co_inventory_book"
                  sequence="10"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_account_report_journal_book"
                  name="Libro Diario Oficial"
                  parent="menu_libros_legales"
                  action="action_co_journal_book"
                  sequence="20"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_action_account_report_ledger_book"
                  name="Libro Mayor Oficial"
                  parent="menu_libros_legales"
