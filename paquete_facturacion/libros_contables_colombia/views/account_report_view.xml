                  groups="account.group_account_readonly"/>

        <menuitem id="menu_tax_report_consumo_co"
                  name="Impuesto al Consumo (INC)"
                  parent="menu_tax_reports_co"
                  action="action_co_tax_report_inc"
                  sequence="60"
                  groups="account.group_account_readonly"/>

        <menuitem id="menu_tax_report_otros_co"
                  name="Otros Impuestos"
                  parent="menu_tax_reports_co"
                  action="action_co_tax_report_otros"
                  sequence="70"
                  groups="account.group_account_readonly"/>

        <!-- ============================================================== -->
        <!-- SECCIÓN 5: AUDITORÍA CONTABLE                                  -->
        <!-- ============================================================== -->
        <menuitem id="menu_auditoria_contable"
                  name="Auditoría Contable"
                  parent="account_colombia_reports_menu"
                  sequence="50"/>

        <menuitem id="menu_audit_sequences"
                  name="Auditoría de Consecutivos"
                  parent="menu_auditoria_contable"
                  action="action_co_audit_sequences"
