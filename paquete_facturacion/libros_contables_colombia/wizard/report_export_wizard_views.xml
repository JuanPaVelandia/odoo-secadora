<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =================================================================== -->
    <!-- Vista del Wizard de Exportación de Reportes Contables               -->
    <!-- =================================================================== -->

    <record id="view_libros_contables_export_wizard_form" model="ir.ui.view">
        <field name="name">libros.contables.export.wizard.form</field>
        <field name="model">libros.contables.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar Reporte Contable">
                <sheet>
                    <group>
                        <group string="Información del Reporte" col="2">
                            <field name="report_id" readonly="1"/>
                            <field name="doc_name"/>
                            <field name="report_options" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Pestaña de Formato -->
                        <page string="Formato de Exportación" name="format">
                            <group>
                                <group string="Formato de Archivo">
                                    <field name="export_format" widget="radio" options="{'horizontal': true}"/>
                                </group>
                            </group>

                            <group>
                                <group string="Modo de Expansión">
                                    <field name="expansion_mode" widget="radio"/>
                                    <field name="expansion_level"
                                           invisible="expansion_mode != 'level'"/>
                                </group>
                                <group string="Detalle">
                                    <field name="show_partners"/>
                                    <field name="show_movements"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña de Formato Visual -->
                        <page string="Formato Visual" name="visual">
                            <group>
                                <group string="Colores">
                                    <field name="use_colors"/>
                                    <field name="color_mode"
                                           invisible="not use_colors"/>
                                    <field name="use_symbols"/>
                                </group>
                                <group string="Encabezado">
                                    <field name="include_logo"/>
                                    <field name="include_header"/>
                                    <field name="include_filters_summary"/>
                                </group>
                            </group>

                            <group string="Vista Previa de Colores" invisible="not use_colors">
                                <div class="alert alert-info" role="alert">
                                    <strong>Modo Contable:</strong>
                                    <span style="color: #198754;">■ Positivo (Verde)</span> |
                                    <span style="color: #dc3545;">■ Negativo (Rojo)</span> |
                                    <span style="color: #999999;">■ Cero (Gris)</span>
                                </div>
                            </group>
                        </page>

                        <!-- Pestaña de Moneda -->
                        <page string="Moneda" name="currency">
                            <group>
                                <group string="Moneda Secundaria">
                                    <field name="show_secondary_currency"/>
                                    <field name="secondary_currency_id"
                                           invisible="not show_secondary_currency"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>

                            <group invisible="not show_secondary_currency">
                                <div class="alert alert-warning" role="alert">
                                    <i class="fa fa-info-circle"/> Al activar moneda secundaria,
                                    se agregarán columnas adicionales con los valores convertidos
                                    a la moneda seleccionada.
                                </div>
                            </group>
                        </page>

                        <!-- Pestaña de Impuestos (solo visible para reportes de impuestos) -->
                        <page string="Opciones de Impuestos" name="tax_options">
                            <group>
                                <group string="Saldo Inicial">
                                    <field name="include_initial_balance"/>
                                    <field name="initial_balance_date"
                                           invisible="not include_initial_balance"/>
                                </group>
                            </group>

                            <group invisible="not include_initial_balance">
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle"/> El saldo inicial
                                    incluirá los movimientos desde la fecha seleccionada
                                    hasta el inicio del período del reporte.
                                </div>
                            </group>
                        </page>

                        <!-- Pestaña de Opciones de Excel -->
                        <page string="Opciones de Excel" name="excel_options"
                              invisible="export_format != 'xlsx'">
                            <group>
                                <group string="Formato de Hoja">
                                    <field name="xlsx_freeze_panes"/>
                                    <field name="xlsx_auto_filter"/>
                                    <field name="xlsx_column_width_auto"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <footer>
                    <button name="action_export" type="object"
                            string="Exportar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir el wizard -->
    <record id="action_libros_contables_export_wizard" model="ir.actions.act_window">
        <field name="name">Exportar Reporte</field>
        <field name="res_model">libros.contables.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
