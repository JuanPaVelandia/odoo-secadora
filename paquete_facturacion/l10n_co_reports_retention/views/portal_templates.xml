<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_layout" name="Portal layout: certificate" inherit_id="portal.portal_breadcrumbs" priority="60">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'certificate' or certificate" t-attf-class="breadcrumb-item #{'active ' if not task else ''}">
                <a t-attf-href="/my/retention?{{ keep_query() }}">Certificados</a>
            </li>
            <li t-if="page_name == 'certificateica' or certificateica" t-attf-class="breadcrumb-item #{'active ' if not task else ''}">
                <span>Certificados Retención ICA</span>
            </li>
            <li t-if="page_name == 'certificateiva' or certificateiva" t-attf-class="breadcrumb-item #{'active ' if not task else ''}">
                <span>Certificados Retención IVA</span>
            </li>
            <li t-if="page_name == 'certificateretefu' or certificateretefu" t-attf-class="breadcrumb-item #{'active ' if not task else ''}">
                <span>Certificados Retención en Fuente</span>
            </li>
            
        </xpath>
    </template>

    <template id="portal_my_retention" name="Certificados">
      <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>

        <div class="o_portal_content">
            <div class="page-header">
                <h1>Certificados de Retención</h1>
            </div>
            <!-- Mensaje cuando NO hay retenciones -->
            <div t-if="not has_retentions" class="alert alert-warning mt-4" role="alert">
                <div class="d-flex align-items-center">
                    <i class="fa fa-info-circle fa-3x me-3"/>
                    <div>
                        <h4 class="alert-heading">No hay certificados disponibles</h4>
                        <p class="mb-0">
                            Estimado/a <strong t-out="partner_name"/>, actualmente no cuenta con certificados de retención disponibles para descargar.
                        </p>
                        <hr/>
                        <p class="mb-0 small">
                            Los certificados de retención estarán disponibles una vez que se hayan registrado operaciones con retenciones en el sistema.
                            Si considera que esto es un error, por favor contacte al administrador.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Listado de certificados cuando SÍ hay retenciones -->
            <div t-if="has_retentions" class="o_portal_my_home">
                <div class="alert alert-info" role="info">
                    <i class="fa fa-info-circle me-2"/>
                    Seleccione el tipo de certificado que desea descargar:
                </div>

                <div class="row mt-4">
                    <div class="col-lg-4 col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <i class="fa fa-file-pdf-o fa-3x text-danger mb-3"/>
                                <h5 class="card-title">Retención en ICA</h5>
                                <p class="card-text text-muted">Certificado de Retención de Industria y Comercio</p>
                                <a href="/my/retentionica" class="btn btn-primary">
                                    <i class="fa fa-download me-2"/>
                                    Descargar
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <i class="fa fa-file-pdf-o fa-3x text-danger mb-3"/>
                                <h5 class="card-title">Retención en IVA</h5>
                                <p class="card-text text-muted">Certificado de Retención de IVA</p>
                                <a href="/my/retentioniva" class="btn btn-primary">
                                    <i class="fa fa-download me-2"/>
                                    Descargar
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <i class="fa fa-file-pdf-o fa-3x text-danger mb-3"/>
                                <h5 class="card-title">Retención en Fuente</h5>
                                <p class="card-text text-muted">Certificado de Retención en la Fuente</p>
                                <a href="/my/retentionretefu" class="btn btn-primary">
                                    <i class="fa fa-download me-2"/>
                                    Descargar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </t>
    </template>

    <template id="portal_my_retentionica" name="Certificados ICA">
      <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>

        <div class="o_portal_content">
            <div class="page-header">
                <h1>Certificados de Retención en ICA</h1>
            </div>
            <div class="alert alert-danger" role="alert" t-if="msg">
                <i class="fa fa-exclamation-triangle me-2"/>
                <t t-out="msg"/>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0">Generar Certificado de Retención en ICA</h5>
                </div>
                <div class="card-body">
                    <form action="/my/retentionica/report" method="POST" class="row g-3">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <!-- Selector de Compañía - Solo si hay múltiples empresas -->
                        <div class="col-md-12" t-if="has_multiple_companies">
                            <label for="company_id" class="form-label">
                                Compañía
                                <span class="text-muted small">(seleccione la empresa para generar el certificado)</span>
                            </label>
                            <select name="company_id" id="company_id" class="form-select" required="required">
                                <t t-foreach="user_companies" t-as="company">
                                    <option t-att-value="company.id" t-att-selected="'selected' if company.id == default_company.id else None">
                                        <t t-out="company.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <!-- Campo oculto con la compañía cuando solo hay una -->
                        <input t-if="not has_multiple_companies" type="hidden" name="company_id" t-att-value="default_company.id"/>

                        <!-- Mensaje informativo cuando solo hay una empresa -->
                        <div class="col-md-12" t-if="not has_multiple_companies">
                            <div class="alert alert-info mb-0" role="info">
                                <i class="fa fa-building me-2"/>
                                Generando certificado para: <strong t-out="default_company.name"/>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="date_from" class="form-label">Fecha Inicial</label>
                            <input type="date" class="form-control" id="date_from" name="date_from" required="required"/>
                        </div>

                        <div class="col-md-6">
                            <label for="date_to" class="form-label">Fecha Final</label>
                            <input type="date" class="form-control" id="date_to" name="date_to" required="required"/>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-download me-2"/>
                                Descargar Certificado PDF
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3" role="info">
                <i class="fa fa-info-circle me-2"/>
                <strong>Nota:</strong> Las fechas inicial y final deben corresponder al mismo año fiscal.
            </div>
        </div>

      </t>
    </template>
    
