    <template id="portal_my_home_retention" name="Retención" inherit_id="portal.portal_my_home" customize_show="True" priority="70">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Certificados de Impuestos</t>
                <t t-set="icon" t-value="'/l10n_co_reports_retention/static/src/img/icono_certiciado.png'"/>
                <t t-set="text">Siga, descargue los certificados de retención</t>
                <t t-set="url" t-value="'/my/retention'"/>
                <t t-set="placeholder_count" t-value="'rention_count'"/>
            </t>
        </xpath>
    </template>

</odoo>
