<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista List: Plantillas -->
    <record id="view_tax_form_template_list" model="ir.ui.view">
        <field name="name">account.tax.form.template.list</field>
        <field name="model">account.tax.form.template</field>
        <field name="arch" type="xml">
            <list string="Plantillas Formularios DIAN">
                <field name="code"/>
                <field name="name"/>
                <field name="form_type"/>
                <field name="year"/>
                <field name="period_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vista Form: Plantilla -->
    <record id="view_tax_form_template_form" model="ir.ui.view">
        <field name="name">account.tax.form.template.form</field>
        <field name="model">account.tax.form.template</field>
        <field name="arch" type="xml">
            <form string="Plantilla Formulario DIAN">
                <header>
                    <button name="action_create_form_300" string="Generar Form. 300" type="object"
                            invisible="form_type != '300'" class="btn-primary"/>
                    <button name="action_create_form_350" string="Generar Form. 350" type="object"
                            invisible="form_type != '350'" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="form_type"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="period_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="city_id" placeholder="Todas las ciudades"
                                   invisible="form_type != 'ica'"/>
                            <field name="enable_proration" invisible="form_type != '300'"/>
                            <field name="proration_coefficient" invisible="not enable_proration or form_type != '300'"
                                   widget="percentage"/>
                        </group>
                    </group>
                    <group string="Cierre Contable">
                        <group>
                            <field name="closing_account_id"
                                   placeholder="Resultados del Ejercicio, Bancos, etc."
                                   required="1"/>
                            <field name="tax_agency_partner_id" placeholder="DIAN, Municipio, etc."/>
                            <field name="use_same_partner_for_closing"/>
                        </group>
                        <group>
                            <div class="alert alert-info" style="margin: 10px 0;">
                                <p><strong>Cuenta de Cierre:</strong> Se usa como contrapartida para cuadrar el asiento automáticamente.</p>
                                <p><strong>Tercero de Agencia:</strong> Se usa por defecto en líneas "Por Pagar" sin tercero específico.</p>
                            </div>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Descripción del formulario..."/>
                    </group>
                    <notebook>
                        <page string="Líneas del Formulario" name="lines">
                            <field name="line_ids">
                                <list string="Casillas" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="label" optional="hide"/>
                                    <field name="type"/>
                                    <field name="person_type"/>
                                    <field name="tax_rate" optional="show"/>
                                    <field name="formula" optional="hide"/>
                                    <field name="formula_tag" optional="hide"/>
                                    <field name="base_sequence_code" optional="hide"
                                           invisible="type != 'tax_base_seq'"/>
                                    <field name="account_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="journal_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="product_category_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="activity_id" optional="hide"/>
                                    <field name="debit_account_id" optional="hide"/>
                                    <field name="credit_account_id" optional="hide"/>
                                    <field name="partner_id" optional="hide" placeholder="Usa agencia si vacío"/>
                                    <field name="mark_as_payable" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Search: Plantillas -->
    <record id="view_tax_form_template_search" model="ir.ui.view">
        <field name="name">account.tax.form.template.search</field>
        <field name="model">account.tax.form.template</field>
        <field name="arch" type="xml">
            <search string="Buscar Plantillas">
                <field name="name"/>
                <field name="code"/>
                <filter string="Form. 300 IVA" name="form_300" domain="[('form_type', '=', '300')]"/>
                <filter string="Form. 350 ReteFuente" name="form_350" domain="[('form_type', '=', '350')]"/>
                <filter string="ICA Municipal" name="form_ica" domain="[('form_type', '=', 'ica')]"/>
                <separator/>
                <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                    <filter string="Tipo Formulario" name="group_form_type" context="{'group_by': 'form_type'}"/>
                    <filter string="Año" name="group_year" context="{'group_by': 'year'}"/>
            </search>
        </field>
    </record>

    <!-- Acción: Plantillas -->
    <record id="action_tax_form_template" model="ir.actions.act_window">
        <field name="name">Plantillas Formularios DIAN</field>
        <field name="res_model">account.tax.form.template</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_form_type': '300'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear nueva plantilla de formulario DIAN
            </p>
            <p>
                Las plantillas definen la estructura de los formularios fiscales:<br/>
                - Form. 300: IVA Bimestral<br/>
                - Form. 350: Retención en la Fuente<br/>
                - ICA: Impuesto de Industria y Comercio
            </p>
        </field>
    </record>

    <!-- =========================== -->
    <!-- DECLARACIONES -->
    <!-- =========================== -->

    <!-- Vista List: Declaraciones -->
    <record id="view_tax_form_declaration_list" model="ir.ui.view">
        <field name="name">account.tax.form.declaration.list</field>
        <field name="model">account.tax.form.declaration</field>
        <field name="arch" type="xml">
            <list string="Declaraciones Tributarias">
                <field name="name"/>
                <field name="template_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_amount" sum="Total"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'calculated'"
                       decoration-primary="state == 'submitted'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Vista List Agrupable (estilo cuentas): Declaraciones -->
    <record id="view_tax_form_declaration_list_grouped" model="ir.ui.view">
        <field name="name">account.tax.form.declaration.list.grouped</field>
        <field name="model">account.tax.form.declaration</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Declaraciones Agrupadas"
                  expand="1"
                  default_order="template_id, date_from desc"
                  multi_edit="1">
                <header>
                    <button name="action_calculate" string="Calcular" type="object"
                            class="btn-primary"/>
                    <button name="action_create_closing_entry" string="Crear Cierre" type="object"
                            class="btn-warning"/>
                </header>
                <field name="template_id" invisible="1"/>
                <field name="form_type" invisible="1"/>
                <field name="company_id" groups="base.group_multi_company" invisible="1"/>
                <field name="name"/>
                <field name="date_from" optional="show"/>
                <field name="date_to" optional="show"/>
                <field name="total_amount" sum="Total" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'calculated'"
                       decoration-primary="state == 'submitted'"
                       decoration-muted="state == 'cancelled'"/>
                <groupby name="template_id"/>
            </list>
        </field>
    </record>

    <!-- Vista Form: Declaración -->
    <record id="view_tax_form_declaration_form" model="ir.ui.view">
        <field name="name">account.tax.form.declaration.form</field>
        <field name="model">account.tax.form.declaration</field>
        <field name="arch" type="xml">
            <form string="Declaración Tributaria">
                <header>
                    <button name="action_calculate" string="Calcular" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_create_closing_entry" string="Crear Asiento de Cierre" type="object"
                            invisible="state != 'calculated'" class="btn-warning"/>
                    <button name="action_submit" string="Marcar como Presentado" type="object"
                            invisible="state != 'calculated'" class="btn-success"/>
                    <button name="action_back_to_draft" string="Regresar a Borrador" type="object"
                            invisible="state not in ['calculated', 'cancelled']"/>
                    <button name="action_cancel" string="Cancelar" type="object"
                            invisible="state in ['cancelled', 'submitted']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,calculated,submitted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Número de declaración..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="template_id" readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="form_type" invisible="1"/>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas Calculadas" name="lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list string="Casillas" create="false" delete="false">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="label" optional="hide"/>
                                    <field name="value_base" sum="Total Base" optional="show"/>
                                    <field name="value_tax" sum="Total Impuesto"/>
                                    <field name="debit" sum="Total Débito" optional="hide"/>
                                    <field name="credit" sum="Total Crédito" optional="hide"/>
                                    <field name="partner_id" optional="hide"/>
                                    <field name="mark_as_payable" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Asiento de Cierre" name="closing_entry">
                            <group>
                                <group string="Configuración Cierre">
                                    <field name="date_from" readonly="1"/>
                                    <field name="date_to" readonly="1"/>
                                </group>
                            </group>
                            <field name="line_ids" readonly="1">
                                <list string="Líneas para Cierre" create="false" delete="false">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="debit_account_id"/>
                                    <field name="debit"/>
                                    <field name="credit_account_id"/>
                                    <field name="credit"/>
                                    <field name="partner_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones" name="notes">
                            <field name="notes" placeholder="Observaciones sobre esta declaración..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Search: Declaraciones -->
    <record id="view_tax_form_declaration_search" model="ir.ui.view">
        <field name="name">account.tax.form.declaration.search</field>
        <field name="model">account.tax.form.declaration</field>
        <field name="arch" type="xml">
            <search string="Buscar Declaraciones">
                <field name="name"/>
                <field name="template_id"/>
                <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Calculado" name="calculated" domain="[('state', '=', 'calculated')]"/>
                <filter string="Presentado" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <separator/>
                <filter string="Este Mes" name="this_month"
                        domain="[('date_from', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date_to', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                    <filter string="Plantilla" name="group_template" context="{'group_by': 'template_id'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Fecha Desde" name="group_date" context="{'group_by': 'date_from'}"/>
            </search>
        </field>
    </record>

    <!-- Acción: Declaraciones -->
    <record id="action_tax_form_declaration" model="ir.actions.act_window">
        <field name="name">Declaraciones Tributarias</field>
        <field name="res_model">account.tax.form.declaration</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear nueva declaración tributaria
            </p>
            <p>
                Genere declaraciones fiscales a partir de las plantillas configuradas.<br/>
                El sistema calculará automáticamente las bases e impuestos del periodo.
            </p>
        </field>
    </record>

    <!-- Menú Principal -->
    <menuitem id="menu_tax_reports_root"
              name="Reportes DIAN"
              parent="account.menu_finance_reports"
              sequence="50"/>

    <menuitem id="menu_tax_form_template"
              name="Plantillas Formularios"
              parent="menu_tax_reports_root"
              action="action_tax_form_template"
              sequence="10"/>

    <menuitem id="menu_tax_form_declaration"
              name="Declaraciones"
              parent="menu_tax_reports_root"
              action="action_tax_form_declaration"
              sequence="20"/>

</odoo>
