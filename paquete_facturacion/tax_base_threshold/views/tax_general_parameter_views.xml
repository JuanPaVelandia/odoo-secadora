<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_tax_general_parameter_tree" model="ir.ui.view">
        <field name="name">tax.general.parameter.tree</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <list string="Tax General Parameters" editable="top">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="parameter_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="value"/>
                <field name="currency_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_tax_general_parameter_form" model="ir.ui.view">
        <field name="name">tax.general.parameter.form</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <form string="Tax General Parameter">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="parameter_type"/>
                        <h1>
                            <field name="parameter_type" placeholder="Select parameter type..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="value"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_tax_general_parameter_search" model="ir.ui.view">
        <field name="name">tax.general.parameter.search</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <search string="Search Tax Parameters">
                <field name="parameter_type"/>
                <field name="date_from"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <separator/>
                <filter string="SMMLV" name="smmlv" domain="[('parameter_type', '=', 'smmlv')]"/>
                <filter string="UVT" name="uvt" domain="[('parameter_type', '=', 'uvt')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Current" name="current" domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'parameter_type'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'date_from:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tax_general_parameter" model="ir.actions.act_window">
        <field name="name">Tax Parameters</field>
        <field name="res_model">tax.general.parameter</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tax parameter
            </p>
            <p>
                Configure SMMLV and UVT values for different periods.
                These values will be used to calculate tax base thresholds.
            </p>
        </field>
    </record>
</odoo>
