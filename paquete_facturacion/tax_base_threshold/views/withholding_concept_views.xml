<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== WITHHOLDING CONCEPT ==================== -->

    <!-- Tree View -->
    <record id="view_withholding_concept_tree" model="ir.ui.view">
        <field name="name">withholding.concept.tree</field>
        <field name="model">withholding.concept</field>
        <field name="arch" type="xml">
            <list string="Withholding Concepts" default_order="sequence, code">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="concept_type" widget="badge" decoration-info="concept_type == 'retefuente'" decoration-success="concept_type == 'reteiva'" decoration-warning="concept_type == 'reteica'"/>
                <field name="calculation_type"/>
                <field name="calculation_period" optional="show"/>
                <field name="tax_application_mode" optional="show"/>
                <field name="requires_minimum_base" optional="hide"/>
                <field name="base_type" optional="hide"/>
                <field name="base_evaluation" optional="hide"/>
                <field name="validate_base_enabled" widget="boolean_toggle" optional="hide"/>
                <field name="apply_on_sale" widget="boolean_toggle" optional="hide"/>
                <field name="apply_on_purchase" widget="boolean_toggle" optional="hide"/>
                <field name="current_min_base" optional="show" string="Min Base $"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_withholding_concept_form" model="ir.ui.view">
        <field name="name">withholding.concept.form</field>
        <field name="model">withholding.concept</field>
        <field name="arch" type="xml">
            <form string="Withholding Concept">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Retención Servicios"/>
                        </h1>
                        <h2>
                            <field name="code" placeholder="e.g., SERVICIOS"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="concept_type" widget="radio"/>
                            <field name="calculation_type" widget="radio"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Base Configuration">
                            <field name="requires_minimum_base"/>
                            <field name="base_type" invisible="not requires_minimum_base"/>
                            <field name="base_evaluation"/>
                            <field name="validate_base_enabled"/>
                            <field name="calculation_period"/>
                            <field name="legal_reference"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Document Application">
                            <field name="apply_on_sale"/>
                            <field name="apply_on_purchase"/>
                            <field name="tax_application_mode"/>
                        </group>
                        <group string="Current Values (Informative)">
                            <field name="current_uvt_value" readonly="1"/>
                            <field name="current_min_base" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Rates Tab (for fixed_rate and by_contributor) -->
                        <page string="Rates by Period" name="rates" invisible="calculation_type == 'progressive'">
                            <field name="rate_ids" context="{'default_concept_id': id}">
                                <list string="Rates" editable="bottom">
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="rate_percent" invisible="calculation_type == 'by_contributor'"/>
                                    <field name="rate_declarant" invisible="calculation_type != 'by_contributor'"/>
                                    <field name="rate_non_declarant" invisible="calculation_type != 'by_contributor'"/>
                                    <field name="min_base_uvt"/>
                                    <field name="min_base_fixed" optional="hide"/>
                                    <field name="min_base_computed" optional="show"/>
                                    <field name="legal_reference" optional="hide"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                            <group class="alert alert-info" role="alert">
                                <div>
                                    <p><strong>Tipos de Cálculo:</strong></p>
                                    <ul>
                                        <li><b>Tarifa Fija:</b> Una sola tarifa se aplica (ej: IVA 19%)</li>
                                        <li><b>Por Tipo Contribuyente:</b> Tarifa diferente para declarantes y no declarantes</li>
                                    </ul>
                                    <p><strong>Ejemplo 2025 (Decreto 0572):</strong></p>
                                    <ul>
                                        <li>Compras Declarantes: 2.5% sobre base ≥ 10 UVT ($497,990)</li>
                                        <li>Compras No Declarantes: 3.5% sobre base ≥ 10 UVT ($497,990)</li>
                                        <li>Servicios: 4% sobre base ≥ 2 UVT ($99,598)</li>
                                    </ul>
                                </div>
                            </group>
                        </page>

                        <!-- Progressive Brackets Tab (for progressive) -->
                        <page string="Progressive Brackets" name="brackets" invisible="calculation_type != 'progressive'">
                            <field name="bracket_ids" context="{'default_concept_id': id}">
                                <list string="Brackets" editable="bottom">
                                    <field name="date_from"/>
                                    <field name="date_to" optional="hide"/>
                                    <field name="bracket_number"/>
                                    <field name="from_uvt"/>
                                    <field name="to_uvt"/>
                                    <field name="rate_percent"/>
                                    <field name="subtract_uvt"/>
                                    <field name="plus_uvt"/>
                                    <field name="from_amount" optional="show"/>
                                    <field name="to_amount" optional="show"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                            <group class="alert alert-info" role="alert">
                                <div>
                                    <p><strong>Tabla Progresiva de Retención (Art. 383 E.T.)</strong></p>
                                    <p>Fórmula: <code>(Base_UVT - Resta) × Tarifa% + Más UVT</code></p>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Rango</th>
                                                <th>Desde UVT</th>
                                                <th>Hasta UVT</th>
                                                <th>Tarifa</th>
                                                <th>Resta</th>
                                                <th>Más</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr><td>1</td><td>0</td><td>95</td><td>0%</td><td>0</td><td>0</td></tr>
                                            <tr><td>2</td><td>95</td><td>150</td><td>19%</td><td>95</td><td>0</td></tr>
                                            <tr><td>3</td><td>150</td><td>360</td><td>28%</td><td>150</td><td>10</td></tr>
                                            <tr><td>4</td><td>360</td><td>640</td><td>33%</td><td>360</td><td>69</td></tr>
                                            <tr><td>5</td><td>640</td><td>945</td><td>35%</td><td>640</td><td>162</td></tr>
                                            <tr><td>6</td><td>945</td><td>2300</td><td>37%</td><td>945</td><td>268</td></tr>
                                            <tr><td>7</td><td>2300</td><td>∞</td><td>39%</td><td>2300</td><td>770</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                            </group>
                        </page>

                        <!-- Related Taxes -->
                        <page string="Related Taxes" name="taxes">
                            <field name="tax_ids" readonly="1">
                                <list string="Taxes">
                                    <field name="name"/>
                                    <field name="type_tax_use"/>
                                    <field name="amount"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </list>
                            </field>
                        </page>

                        <!-- Description -->
                        <page string="Description" name="description">
                            <field name="description" placeholder="Detailed description of this withholding concept..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_withholding_concept_search" model="ir.ui.view">
        <field name="name">withholding.concept.search</field>
        <field name="model">withholding.concept</field>
        <field name="arch" type="xml">
            <search string="Search Concepts">
                <field name="code"/>
                <field name="name"/>
                <field name="concept_type"/>
                <separator/>
                <filter string="Retención Fuente" name="retefuente" domain="[('concept_type', '=', 'retefuente')]"/>
                <filter string="ReteIVA" name="reteiva" domain="[('concept_type', '=', 'reteiva')]"/>
                <filter string="ReteICA" name="reteica" domain="[('concept_type', '=', 'reteica')]"/>
                <filter string="INC" name="inc" domain="[('concept_type', '=', 'inc')]"/>
                <separator/>
                <filter string="Fixed Rate" name="fixed" domain="[('calculation_type', '=', 'fixed_rate')]"/>
                <filter string="Progressive" name="progressive" domain="[('calculation_type', '=', 'progressive')]"/>
                <filter string="By Contributor" name="by_contributor" domain="[('calculation_type', '=', 'by_contributor')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'concept_type'}"/>
                    <filter string="Calculation" name="group_calc" context="{'group_by': 'calculation_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_withholding_concept" model="ir.actions.act_window">
        <field name="name">Withholding Concepts</field>
        <field name="res_model">withholding.concept</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new withholding concept
            </p>
            <p>
                Define Colombian withholding concepts with their rates and minimum bases.
                Examples: Retención Compras, Retención Servicios, Retención Honorarios, ReteIVA.
            </p>
        </field>
    </record>
</odoo>
