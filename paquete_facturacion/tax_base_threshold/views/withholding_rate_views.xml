<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== WITHHOLDING RATE ==================== -->

    <!-- Tree View -->
    <record id="view_withholding_rate_tree" model="ir.ui.view">
        <field name="name">withholding.rate.tree</field>
        <field name="model">withholding.rate</field>
        <field name="arch" type="xml">
            <list string="Withholding Rates" default_order="concept_id, date_from desc">
                <field name="concept_id"/>
                <field name="fiscal_year"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="rate_percent" invisible="calculation_type == 'by_contributor'"/>
                <field name="rate_declarant" invisible="calculation_type != 'by_contributor'"/>
                <field name="rate_non_declarant" invisible="calculation_type != 'by_contributor'"/>
                <field name="min_base_uvt"/>
                <field name="min_base_computed"/>
                <field name="legal_reference" optional="hide"/>
                <field name="calculation_type" column_invisible="1"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_withholding_rate_form" model="ir.ui.view">
        <field name="name">withholding.rate.form</field>
        <field name="model">withholding.rate</field>
        <field name="arch" type="xml">
            <form string="Withholding Rate">
                <sheet>
                    <group>
                        <group string="Concept">
                            <field name="concept_id"/>
                            <field name="concept_type" readonly="1"/>
                            <field name="calculation_type" readonly="1"/>
                        </group>
                        <group string="Validity">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="fiscal_year" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <group string="Rates" invisible="calculation_type == 'by_contributor'">
                            <field name="rate_percent"/>
                        </group>
                        <group string="Rates by Contributor Type" invisible="calculation_type != 'by_contributor'">
                            <field name="rate_declarant"/>
                            <field name="rate_non_declarant"/>
                        </group>
                        <group string="Minimum Base">
                            <field name="min_base_uvt"/>
                            <field name="min_base_fixed"/>
                            <field name="min_base_computed" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Reference">
                            <field name="legal_reference"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_withholding_rate_search" model="ir.ui.view">
        <field name="name">withholding.rate.search</field>
        <field name="model">withholding.rate</field>
        <field name="arch" type="xml">
            <search string="Search Rates">
                <field name="concept_id"/>
                <field name="fiscal_year"/>
                <field name="legal_reference"/>
                <separator/>
                <filter string="Current" name="current" domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <separator/>
                <filter string="2025" name="year_2025" domain="[('fiscal_year', '=', '2025')]"/>
                <filter string="2024" name="year_2024" domain="[('fiscal_year', '=', '2024')]"/>
                <filter string="2023" name="year_2023" domain="[('fiscal_year', '=', '2023')]"/>
                <group>
                    <filter string="Concept" name="group_concept" context="{'group_by': 'concept_id'}"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'fiscal_year'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'concept_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_withholding_rate" model="ir.actions.act_window">
        <field name="name">Withholding Rates</field>
        <field name="res_model">withholding.rate</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new withholding rate
            </p>
            <p>
                Configure rates for each withholding concept by year.
                Include minimum bases in UVT and differentiated rates for declarants/non-declarants.
            </p>
        </field>
    </record>

    <!-- ==================== WITHHOLDING BRACKET ==================== -->

    <!-- Tree View -->
    <record id="view_withholding_bracket_tree" model="ir.ui.view">
        <field name="name">withholding.bracket.tree</field>
        <field name="model">withholding.bracket</field>
        <field name="arch" type="xml">
            <list string="Progressive Brackets" default_order="concept_id, date_from desc, from_uvt">
                <field name="concept_id"/>
                <field name="date_from"/>
                <field name="bracket_number"/>
                <field name="from_uvt"/>
                <field name="to_uvt"/>
                <field name="rate_percent"/>
                <field name="subtract_uvt"/>
                <field name="plus_uvt"/>
                <field name="from_amount" optional="show"/>
                <field name="to_amount" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_withholding_bracket_form" model="ir.ui.view">
        <field name="name">withholding.bracket.form</field>
        <field name="model">withholding.bracket</field>
        <field name="arch" type="xml">
            <form string="Progressive Bracket">
                <sheet>
                    <group>
                        <group string="Concept">
                            <field name="concept_id" domain="[('calculation_type', '=', 'progressive')]"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Bracket Definition">
                            <field name="bracket_number"/>
                            <field name="from_uvt"/>
                            <field name="to_uvt"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Calculation Formula">
                        <div class="alert alert-info" role="alert">
                            <p>Formula: <strong>(Base_UVT - Subtract) × Rate% + Plus UVT</strong></p>
                        </div>
                        <group>
                            <field name="rate_percent"/>
                            <field name="subtract_uvt"/>
                            <field name="plus_uvt"/>
                        </group>
                        <group string="Computed Values (Current UVT)">
                            <field name="from_amount" readonly="1"/>
                            <field name="to_amount" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_withholding_bracket_search" model="ir.ui.view">
        <field name="name">withholding.bracket.search</field>
        <field name="model">withholding.bracket</field>
        <field name="arch" type="xml">
            <search string="Search Brackets">
                <field name="concept_id"/>
                <field name="bracket_number"/>
                <separator/>
                <filter string="Current" name="current" domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="Concept" name="group_concept" context="{'group_by': 'concept_id'}"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'date_from:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_withholding_bracket" model="ir.actions.act_window">
        <field name="name">Progressive Brackets</field>
        <field name="res_model">withholding.bracket</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create progressive tax brackets
            </p>
            <p>
                Configure progressive brackets for salary withholding (Art. 383 E.T.)
                Each bracket defines: Range (UVT), Rate %, Subtract UVT, Plus UVT.
            </p>
        </field>
    </record>
</odoo>
