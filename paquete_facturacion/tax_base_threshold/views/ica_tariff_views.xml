<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== ICA TARIFF ==================== -->

    <!-- Tree View -->
    <record id="view_ica_tariff_tree" model="ir.ui.view">
        <field name="name">ica.tariff.tree</field>
        <field name="model">ica.tariff</field>
        <field name="arch" type="xml">
            <list string="ICA Tariffs" default_order="municipality_id, ciiu_id">
                <field name="municipality_id"/>
                <field name="state_id" optional="show"/>
                <field name="ciiu_id"/>
                <field name="ciiu_code"/>
                <field name="activity_type" widget="badge"
                       decoration-info="activity_type == 'industrial'"
                       decoration-success="activity_type == 'commercial'"
                       decoration-warning="activity_type == 'services'"
                       decoration-danger="activity_type == 'financial'"/>
                <field name="rate" string="Rate (‰)"/>
                <field name="rate_percent" string="Rate (%)"/>
                <field name="min_base_type" optional="show"/>
                <field name="min_base_uvt" optional="hide"/>
                <field name="min_base_fixed" optional="hide"/>
                <field name="min_base_computed" string="Min Base" optional="show"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="date_from"/>
                <field name="date_to" optional="hide"/>
                <field name="fiscal_year" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ica_tariff_form" model="ir.ui.view">
        <field name="name">ica.tariff.form</field>
        <field name="model">ica.tariff</field>
        <field name="arch" type="xml">
            <form string="ICA Tariff">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="municipality_id"/>
                        <h1>
                            <field name="municipality_id" placeholder="Select municipality..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="state_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Activity">
                            <field name="ciiu_id"/>
                            <field name="ciiu_code" readonly="1"/>
                            <field name="activity_type" widget="radio"/>
                        </group>
                    </group>
                    <group>
                        <group string="Rate">
                            <field name="rate" string="Rate (‰)"/>
                            <field name="rate_percent" string="Rate (%)" readonly="1"/>
                        </group>
                        <group string="Validity">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="fiscal_year" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Minimum Base Threshold">
                            <field name="min_base_type" widget="radio"/>
                            <field name="min_base_uvt" invisible="min_base_type != 'uvt'"/>
                            <field name="min_base_fixed" invisible="min_base_type != 'fixed'"/>
                            <field name="min_base_computed" readonly="1" invisible="min_base_type == 'none'"
                                   widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group string="Reference">
                            <field name="legal_reference" placeholder="Acuerdo Municipal..."/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>

                    <group class="alert alert-info" role="alert">
                        <div>
                            <p><strong>Tarifas de ICA en Colombia:</strong></p>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Actividad</th>
                                        <th>Rango Típico</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Industrial</td><td>2 - 7 ‰</td></tr>
                                    <tr><td>Comercial</td><td>4 - 10 ‰</td></tr>
                                    <tr><td>Servicios</td><td>4 - 10 ‰</td></tr>
                                    <tr><td>Financiero</td><td>5 - 15 ‰</td></tr>
                                </tbody>
                            </table>
                            <p class="text-muted">Nota: Las tarifas varían según el municipio y deben consultarse en los acuerdos municipales.</p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ica_tariff_search" model="ir.ui.view">
        <field name="name">ica.tariff.search</field>
        <field name="model">ica.tariff</field>
        <field name="arch" type="xml">
            <search string="Search ICA Tariffs">
                <field name="municipality_id"/>
                <field name="state_id"/>
                <field name="ciiu_id"/>
                <field name="ciiu_code"/>
                <field name="activity_type"/>
                <separator/>
                <filter string="Industrial" name="industrial" domain="[('activity_type', '=', 'industrial')]"/>
                <filter string="Commercial" name="commercial" domain="[('activity_type', '=', 'commercial')]"/>
                <filter string="Services" name="services" domain="[('activity_type', '=', 'services')]"/>
                <filter string="Financial" name="financial" domain="[('activity_type', '=', 'financial')]"/>
                <separator/>
                <filter string="Current" name="current" domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Municipality" name="group_municipality" context="{'group_by': 'municipality_id'}"/>
                    <filter string="Department" name="group_state" context="{'group_by': 'state_id'}"/>
                    <filter string="CIIU" name="group_ciiu" context="{'group_by': 'ciiu_id'}"/>
                    <filter string="Activity Type" name="group_activity" context="{'group_by': 'activity_type'}"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'fiscal_year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_ica_tariff_pivot" model="ir.ui.view">
        <field name="name">ica.tariff.pivot</field>
        <field name="model">ica.tariff</field>
        <field name="arch" type="xml">
            <pivot string="ICA Tariffs">
                <field name="state_id" type="row"/>
                <field name="municipality_id" type="row"/>
                <field name="activity_type" type="col"/>
                <field name="rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ica_tariff" model="ir.actions.act_window">
        <field name="name">ICA Tariffs</field>
        <field name="res_model">ica.tariff</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new ICA tariff
            </p>
            <p>
                Configure ICA (Industry and Commerce) tariffs by municipality and CIIU activity.
                Rates are expressed in "per thousand" (‰).
            </p>
            <p>
                <strong>Example:</strong> A rate of 9.66‰ means the tax is 0.966% of the base.
            </p>
        </field>
    </record>

    <!-- ==================== ACCOUNT TAX ICA FIELDS ==================== -->

    <!-- Inherit Account Tax Form View for ICA -->
    <record id="view_tax_form_inherit_ica" model="ir.ui.view">
        <field name="name">account.tax.form.inherit.ica</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="is_ica_dynamic"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="ICA Dynamic" name="ica_dynamic" invisible="not is_ica_dynamic">
                    <group>
                        <group string="ICA Configuration">
                            <field name="ica_default_rate"/>
                        </group>
                    </group>
                    <group class="alert alert-info" role="alert">
                        <div>
                            <p><strong>Cálculo Dinámico de ICA:</strong></p>
                            <ul>
                                <li>El impuesto se calcula automáticamente según el municipio y CIIU del tercero</li>
                                <li>Si no se encuentra una tarifa específica, se usa la tarifa por defecto</li>
                                <li>El tercero debe tener configurado: <b>city_id</b> (municipio) y <b>ciiu_id</b> (actividad CIIU)</li>
                                <li>Asegúrese de que el campo <b>Aplicar ICA</b> esté activo en el tercero</li>
                            </ul>
                            <p><strong>Código Python para Impuesto (alternativo):</strong></p>
                            <pre><code>
# En un impuesto tipo "Código Python":
result = 0.0
if partner:
    municipality = partner.city_id
    ciiu = partner.ciiu_id
    if municipality and ciiu:
        tariff = env['ica.tariff'].get_tariff(
            municipality_id=municipality.id,
            ciiu_id=ciiu.id
        )
        if tariff:
            result = price_unit * quantity * (tariff.rate / 1000.0)
                            </code></pre>
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
