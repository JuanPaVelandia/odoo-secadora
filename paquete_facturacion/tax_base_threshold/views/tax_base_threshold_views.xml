<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_tax_base_threshold_tree" model="ir.ui.view">
        <field name="name">tax.base.threshold.tree</field>
        <field name="model">tax.base.threshold</field>
        <field name="arch" type="xml">
            <list string="Tax Base Thresholds" editable="top">
                <field name="tax_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="base_amount"/>
                <field name="base_uvt"/>
                <field name="base_amount_from_uvt" readonly="1"/>
                <field name="uvt_value" readonly="1" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_tax_base_threshold_form" model="ir.ui.view">
        <field name="name">tax.base.threshold.form</field>
        <field name="model">tax.base.threshold</field>
        <field name="arch" type="xml">
            <form string="Tax Base Threshold">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="tax_id"/>
                        <h1>
                            <field name="tax_id" placeholder="Select tax..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Threshold Configuration">
                            <field name="base_amount"/>
                            <field name="currency_id"/>
                            <separator string="or" colspan="2"/>
                            <field name="base_uvt"/>
                            <field name="uvt_value" readonly="1"/>
                            <field name="base_amount_from_uvt" readonly="1" string="Calculated Amount"/>
                        </group>
                    </group>
                    <group string="Help" class="alert alert-info" role="alert">
                        <div>
                            <p>Configure the minimum base amount required for this tax to apply.</p>
                            <p>You can specify either:</p>
                            <ul>
                                <li><b>A fixed amount</b> in the company currency</li>
                                <li><b>An amount in UVT</b> (Tax Value Units) which will be automatically calculated based on the current UVT value</li>
                            </ul>
                            <p>If the base amount is less than the threshold, the tax will not be applied.</p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_tax_base_threshold_search" model="ir.ui.view">
        <field name="name">tax.base.threshold.search</field>
        <field name="model">tax.base.threshold</field>
        <field name="arch" type="xml">
            <search string="Search Tax Base Thresholds">
                <field name="tax_id"/>
                <field name="date_from"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Current" name="current"
                        domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <filter string="With UVT" name="with_uvt" domain="[('base_uvt', '>', 0)]"/>
                <filter string="Fixed Amount" name="fixed_amount" domain="[('base_uvt', '=', 0)]"/>
                <group>
                    <filter string="Tax" name="group_tax" context="{'group_by': 'tax_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    <filter string="Year" name="group_year" context="{'group_by': 'date_from:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tax_base_threshold" model="ir.actions.act_window">
        <field name="name">Tax Base Thresholds</field>
        <field name="res_model">tax.base.threshold</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tax base threshold
            </p>
            <p>
                Define minimum base amounts for taxes to be applied.
                You can set thresholds in fixed amounts or UVT units.
            </p>
        </field>
    </record>
</odoo>
