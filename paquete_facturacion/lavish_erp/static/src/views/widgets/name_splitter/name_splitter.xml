<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lavish_erp.NameSplitterButton">
        <button t-if="isVisible"
                type="button"
                class="btn btn-sm btn-link text-primary p-0"
                t-on-click="splitName"
                title="Divide el nombre completo en primer nombre, segundo nombre, primer apellido y segundo apellido">
            <i class="fa fa-magic me-1"/>
            <span>Dividir Nombre</span>
        </button>
    </t>
</templates>
