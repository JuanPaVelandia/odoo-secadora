<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lavish_erp.AddressBuilderDialog">
        <Dialog size="'xl'" title="'🏗️ Constructor de Dirección Colombiana'">
            <div class="o_address_builder_dialog p-3">

                <!-- Vía Principal -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <strong>📍 Vía Principal</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <label class="form-label">Tipo de Vía</label>
                                <select class="form-select"
                                        t-model.number="state.main_road[0]"
                                        t-on-change="() => this.updatePreview()">
                                    <option value="">Seleccione...</option>
                                    <option t-foreach="state.main_road_options"
                                            t-as="option"
                                            t-key="option.id"
                                            t-att-value="option.id"
                                            t-esc="option.name"/>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Número</label>
                                <input type="text"
                                       class="form-control"
                                       t-model="state.name_road"
                                       t-on-input="() => this.updatePreview()"
                                       placeholder="45"/>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Letra</label>
                                <select class="form-select"
                                        t-model.number="state.main_letter_road[0]"
                                        t-on-change="() => this.updatePreview()">
                                    <option value="">-</option>
                                    <option t-foreach="state.main_letter_options"
                                            t-as="letter"
                                            t-key="letter.id"
                                            t-att-value="letter.id"
                                            t-esc="letter.name"/>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Prefijo</label>
                                <select class="form-select"
                                        t-model.number="state.prefix_main_road[0]"
                                        t-on-change="() => this.updatePreview()">
                                    <option value="">-</option>
                                    <option t-foreach="state.prefix_options"
                                            t-as="prefix"
                                            t-key="prefix.id"
                                            t-att-value="prefix.id"
                                            t-esc="prefix.name"/>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Sector</label>
                                <select class="form-select"
                                        t-model.number="state.sector_main_road[0]"
                                        t-on-change="() => this.updatePreview()">
                                    <option value="">-</option>
                                    <option t-foreach="state.sector_options"
                                            t-as="sector"
                                            t-key="sector.id"
                                            t-att-value="sector.id"
                                            t-esc="sector.name"/>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Vía Generadora -->
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header bg-success text-white">
                                <strong># Vía Generadora</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-4">
                                        <label class="form-label">Número</label>
                                        <input type="number"
                                               class="form-control"
                                               t-model.number="state.generator_road_number"
                                               t-on-input="() => this.updatePreview()"
                                               placeholder="23"/>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label">Letra</label>
                                        <select class="form-select"
                                                t-model.number="state.generator_road_letter[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">-</option>
                                            <option t-foreach="state.main_letter_options"
                                                    t-as="letter"
                                                    t-key="letter.id"
                                                    t-att-value="letter.id"
                                                    t-esc="letter.name"/>
                                        </select>
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label">Sector</label>
                                        <select class="form-select"
                                                t-model.number="state.generator_road_sector[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">-</option>
                                            <option t-foreach="state.sector_options"
                                                    t-as="sector"
                                                    t-key="sector.id"
                                                    t-att-value="sector.id"
                                                    t-esc="sector.name"/>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Placa -->
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header bg-info text-white">
                                <strong>- Placa</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label">Número</label>
                                        <input type="number"
                                               class="form-control"
                                               t-model.number="state.generator_plate_number"
                                               t-on-input="() => this.updatePreview()"
                                               placeholder="15"/>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Sector</label>
                                        <select class="form-select"
                                                t-model.number="state.generator_plate_sector[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">-</option>
                                            <option t-foreach="state.sector_options"
                                                    t-as="sector"
                                                    t-key="sector.id"
                                                    t-att-value="sector.id"
                                                    t-esc="sector.name"/>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Complementos -->
                <div class="card mb-3">
                    <div class="card-header bg-warning text-dark">
                        <strong>🏢 Complementos</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label">Complemento A</label>
                                <div class="row g-1">
                                    <div class="col-6">
                                        <select class="form-select form-select-sm"
                                                t-model.number="state.complement_name_a[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">Tipo...</option>
                                            <option t-foreach="state.complement_options"
                                                    t-as="comp"
                                                    t-key="comp.id"
                                                    t-att-value="comp.id"
                                                    t-esc="comp.name"/>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               t-model="state.complement_number_a"
                                               t-on-input="() => this.updatePreview()"
                                               placeholder="302"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Complemento B</label>
                                <div class="row g-1">
                                    <div class="col-6">
                                        <select class="form-select form-select-sm"
                                                t-model.number="state.complement_name_b[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">Tipo...</option>
                                            <option t-foreach="state.complement_options"
                                                    t-as="comp"
                                                    t-key="comp.id"
                                                    t-att-value="comp.id"
                                                    t-esc="comp.name"/>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               t-model="state.complement_number_b"
                                               t-on-input="() => this.updatePreview()"
                                               placeholder="B"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Complemento C</label>
                                <div class="row g-1">
                                    <div class="col-6">
                                        <select class="form-select form-select-sm"
                                                t-model.number="state.complement_name_c[0]"
                                                t-on-change="() => this.updatePreview()">
                                            <option value="">Tipo...</option>
                                            <option t-foreach="state.complement_options"
                                                    t-as="comp"
                                                    t-key="comp.id"
                                                    t-att-value="comp.id"
                                                    t-esc="comp.name"/>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               t-model="state.complement_text_c"
                                               t-on-input="() => this.updatePreview()"
                                               placeholder="Texto"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Barrio/Vereda (si hay código postal seleccionado) -->
                <div class="card mb-3" t-if="state.neighborhoods.length > 0">
                    <div class="card-header bg-secondary text-white">
                        <strong>🏘️ Barrio / Vereda</strong>
                    </div>
                    <div class="card-body">
                        <select class="form-select" t-model="state.selectedNeighborhood">
                            <option value="">Seleccione barrio o vereda...</option>
                            <option t-foreach="state.neighborhoods"
                                    t-as="neighborhood"
                                    t-key="neighborhood_index"
                                    t-att-value="neighborhood"
                                    t-esc="neighborhood"/>
                        </select>
                        <small class="form-text text-muted">
                            Información del código postal. Este campo es informativo y no se guarda en la dirección.
                        </small>
                    </div>
                </div>

                <!-- Preview de Dirección Generada -->
                <div class="alert alert-success mb-0">
                    <div class="d-flex align-items-start">
                        <i class="fa fa-check-circle fa-2x me-3 mt-1"/>
                        <div class="flex-grow-1">
                            <strong>✅ Dirección Generada:</strong>
                            <div class="mt-2 fs-5 font-monospace"
                                 style="word-wrap: break-word;"
                                 t-esc="state.previewAddress || 'Complete los datos para ver la dirección...'"/>
                        </div>
                    </div>
                </div>

            </div>

            <t t-set-slot="footer">
                <button class="btn btn-warning" t-on-click="clearAll">
                    <i class="fa fa-eraser"/> Limpiar Todo
                </button>
                <button class="btn btn-secondary" t-on-click="cancel">
                    <i class="fa fa-times"/> Cancelar
                </button>
                <button class="btn btn-primary" t-on-click="apply">
                    <i class="fa fa-check"/> Aplicar Dirección
                </button>
            </t>
        </Dialog>
    </t>
</templates>
