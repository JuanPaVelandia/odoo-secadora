<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de factura con info DIAN -->
        <record id="view_move_form_dian_info" model="ir.ui.view">
            <field name="name">account.move.form.dian.info</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!-- Campo de info DIAN visible debajo del diario -->
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="dian_resolution_info"
                           string="Resolución DIAN"
                           readonly="1"
                           invisible="dian_resolution_info == False"
                           class="text-muted small"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
