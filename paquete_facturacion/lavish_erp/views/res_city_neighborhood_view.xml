<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_res_city_neighborhood_tree" model="ir.ui.view">
            <field name="name">res.city.neighborhood.tree</field>
            <field name="model">res.city.neighborhood</field>
            <field name="arch" type="xml">
                <list string="Barrios">
                    <field name="name"/>
                    <field name="city_id"/>
                    <field name="state_id"/>
                    <field name="postal_code_id"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_res_city_neighborhood_form" model="ir.ui.view">
            <field name="name">res.city.neighborhood.form</field>
            <field name="model">res.city.neighborhood</field>
            <field name="arch" type="xml">
                <form string="Barrio">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object"
                                    class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button"
                                       options='{"terminology": "archive"}'/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="city_id"/>
                            </group>
                            <group>
                                <field name="state_id"/>
                                <field name="postal_code_id" domain="[('city_id', '=', city_id)]"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View with filters -->
        <record id="view_res_city_neighborhood_search" model="ir.ui.view">
            <field name="name">res.city.neighborhood.search</field>
            <field name="model">res.city.neighborhood</field>
            <field name="arch" type="xml">
                <search string="Buscar Barrios">
                    <field name="name" string="Barrio"/>
                    <field name="city_id"/>
                    <field name="state_id"/>
                    <field name="postal_code_id"/>
                    <separator/>
                    <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group name="group_by">
                        <filter string="Departamento" name="group_state" context="{'group_by': 'state_id'}"/>
                        <filter string="Ciudad" name="group_city" context="{'group_by': 'city_id'}"/>
                        <filter string="Codigo Postal" name="group_postal" context="{'group_by': 'postal_code_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_res_city_neighborhood" model="ir.actions.act_window">
            <field name="name">Barrios</field>
            <field name="res_model">res.city.neighborhood</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_res_city_neighborhood_search"/>
            <field name="context">{'search_default_group_state': 1, 'search_default_group_city': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo barrio
                </p>
                <p>
                    Los barrios se utilizan para estructurar las direcciones colombianas.
                </p>
            </field>
        </record>

    </data>
</odoo>
