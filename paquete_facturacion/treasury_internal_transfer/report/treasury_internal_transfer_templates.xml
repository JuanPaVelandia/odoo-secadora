<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_internal_transfer">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="mt-3 mb-0">Comprobante de Transferencia Interna</h2>
                        <h4 class="text-muted mt-0">
                            <span t-field="o.name"/>
                        </h4>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Fecha:</strong>
                                <span t-field="o.date"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Estado:</strong>
                                <span t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-4">
                            <tbody>
                                <tr>
                                    <td style="width: 30%;"><strong>Diario origen</strong></td>
                                    <td><span t-field="o.source_journal_id"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Diario destino</strong></td>
                                    <td><span t-field="o.destination_journal_id"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Monto</strong></td>
                                    <td>
                                        <span t-field="o.amount"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                                <tr t-if="o.bank_reference">
                                    <td><strong>Referencia bancaria</strong></td>
                                    <td><span t-field="o.bank_reference"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Motivo / Concepto</strong></td>
                                    <td><span t-field="o.reason"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid #000; width: 80%; margin: 40px auto 5px auto;"/>
                                <span t-field="o.sender_user_id"/><br/>
                                <span class="text-muted">Responsable que envía</span>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid #000; width: 80%; margin: 40px auto 5px auto;"/>
                                <span t-if="o.received_user_id" t-field="o.received_user_id"/>
                                <span t-else="" t-field="o.receiver_user_id"/><br/>
                                <span class="text-muted">Responsable que recibe</span>
                                <div t-if="o.received_date" class="text-muted">
                                    Recibido el <span t-field="o.received_date"/>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-5" t-if="o.outbound_payment_id or o.inbound_payment_id">
                            <div class="col-12">
                                <small class="text-muted">
                                    Pago de salida: <span t-field="o.outbound_payment_id"/> ·
                                    Cobro de entrada: <span t-field="o.inbound_payment_id"/> ·
                                    Cuenta puente: <span t-field="o.transfer_account_id"/>
                                </small>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
