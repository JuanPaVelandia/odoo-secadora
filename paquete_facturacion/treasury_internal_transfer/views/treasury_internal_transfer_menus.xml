<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menú principal: la nueva gestión automática de transferencias.
         Se cuelga del menú existente "Transferencias Internas" del módulo
         de Tesorería y queda de primero. -->
    <menuitem id="menu_treasury_internal_transfer"
        name="Transferencias"
        parent="custom_account_treasury.menu_treasury_transfers"
        action="action_treasury_internal_transfer"
        sequence="5"/>

    <!-- Se oculta la "Nueva Transferencia" manual del flujo anterior:
         queda reemplazada por el botón Nuevo de la vista de gestión. -->
    <record id="custom_account_treasury.menu_new_internal_transfer" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

</odoo>
