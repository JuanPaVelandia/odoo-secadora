<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================ FORM ============================ -->
    <record id="view_treasury_internal_transfer_form" model="ir.ui.view">
        <field name="name">treasury.internal.transfer.form</field>
        <field name="model">treasury.internal.transfer</field>
        <field name="arch" type="xml">
            <form string="Transferencia Interna">
                <header>
                    <button name="action_confirm" string="Confirmar y Transferir"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Se contabilizará y conciliará la transferencia. ¿Continuar?"/>
                    <button name="action_confirm_receipt" string="Confirmar Recepción"
                            type="object" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancelar"
                            type="object"
                            invisible="state in ('draft', 'cancelled')"
                            confirm="Se anularán los pagos generados y se revertirá la conciliación. ¿Continuar?"/>
                    <button name="action_draft" string="Volver a Borrador"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,received"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payments" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="payment_count == 0">
                            <field name="payment_count" widget="statinfo" string="Pagos"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Movimiento">
                            <field name="source_journal_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="destination_journal_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="bank_reference" readonly="state != 'draft'"/>
                        </group>
                        <group string="Responsables">
                            <field name="sender_user_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="receiver_user_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="received_user_id"
                                   invisible="state not in ('received',)"/>
                            <field name="received_date"
                                   invisible="state not in ('received',)"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Motivo">
                        <field name="reason" nolabel="1"
                               placeholder="¿Por qué se mueve este dinero?"
                               readonly="state != 'draft'"/>
                    </group>
                    <group string="Contabilidad" invisible="state == 'draft'">
                        <field name="transfer_account_id"/>
                        <field name="outbound_payment_id"/>
                        <field name="inbound_payment_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================ LIST ============================ -->
    <record id="view_treasury_internal_transfer_list" model="ir.ui.view">
        <field name="name">treasury.internal.transfer.list</field>
        <field name="model">treasury.internal.transfer</field>
        <field name="arch" type="xml">
            <list string="Transferencias Internas"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'received'"
                  decoration-info="state == 'confirmed'">
                <field name="name"/>
                <field name="date"/>
                <field name="source_journal_id"/>
                <field name="destination_journal_id"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="sender_user_id"/>
                <field name="receiver_user_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'confirmed'"
                       decoration-success="state == 'received'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ============================ KANBAN ============================ -->
    <record id="view_treasury_internal_transfer_kanban" model="ir.ui.view">
        <field name="name">treasury.internal.transfer.kanban</field>
        <field name="model">treasury.internal.transfer</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong><field name="name"/></strong>
                            <strong><field name="amount" widget="monetary"/></strong>
                        </div>
                        <div>
                            <field name="source_journal_id"/> →
                            <field name="destination_journal_id"/>
                        </div>
                        <div class="text-muted">
                            <i class="fa fa-calendar" title="Fecha"/> <field name="date"/>
                        </div>
                        <div class="text-muted">
                            <i class="fa fa-user" title="Responsable que recibe"/> <field name="receiver_user_id"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================ SEARCH ============================ -->
    <record id="view_treasury_internal_transfer_search" model="ir.ui.view">
        <field name="name">treasury.internal.transfer.search</field>
        <field name="model">treasury.internal.transfer</field>
        <field name="arch" type="xml">
            <search string="Transferencias Internas">
                <field name="name"/>
                <field name="source_journal_id"/>
                <field name="destination_journal_id"/>
                <field name="sender_user_id"/>
                <field name="receiver_user_id"/>
                <separator/>
                <filter name="filter_draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmadas" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_received" string="Recibidas" domain="[('state', '=', 'received')]"/>
                <separator/>
                <filter name="filter_my_receipts" string="Por confirmar (mías)"
                        domain="[('state', '=', 'confirmed'), ('receiver_user_id', '=', uid)]"/>
                <group>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_source" string="Diario origen" context="{'group_by': 'source_journal_id'}"/>
                    <filter name="group_destination" string="Diario destino" context="{'group_by': 'destination_journal_id'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================ ACTION ============================ -->
    <record id="action_treasury_internal_transfer" model="ir.actions.act_window">
        <field name="name">Transferencias Internas</field>
        <field name="res_model">treasury.internal.transfer</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_filter_my_receipts': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registra tu primera transferencia interna
            </p>
            <p>
                Mueve dinero entre tus diarios (banco/caja) en un solo paso:
                elige de dónde a dónde, cuánto y por qué. El sistema contabiliza
                y concilia automáticamente.
            </p>
        </field>
    </record>

</odoo>
