<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia de vista de formulario de hr.payslip para agregar información EPP -->
    <record id="view_hr_payslip_form_epp" model="ir.ui.view">
        <field name="name">hr.payslip.form.epp</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <!-- Agregar botones de EPP en el button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_epp_requests" type="object" class="oe_stat_button"
                        icon="fa-shield" invisible="not employee_id">
                    <field name="epp_pending_requests" widget="statinfo" string="Solicitudes EPP"/>
                </button>
                <button name="action_create_epp_request" type="object" class="oe_stat_button"
                        icon="fa-plus-circle" invisible="not needs_epp_request or not employee_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text text-warning">Solicitar</span>
                        <span class="o_stat_text">Dotación</span>
                    </div>
                </button>
            </xpath>

            <!-- Agregar campos EPP después del empleado -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="needs_epp_request" invisible="1"/>
                <field name="epp_pending_requests" invisible="1"/>
                <field name="last_epp_delivery_date" invisible="1"/>
                <field name="has_valid_medical" invisible="1"/>
            </xpath>

            <!-- Agregar alerta visual si necesita solicitar EPP -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning" role="alert" invisible="not needs_epp_request">
                    <i class="fa fa-exclamation-triangle me-2" title="Advertencia"></i>
                    <strong>Atención:</strong> El empleado necesita solicitar dotación/EPP.
                    <button name="action_create_epp_request" type="object" class="btn btn-sm btn-primary ms-2">
                        <i class="fa fa-plus-circle me-1" title="Agregar"></i>Crear Solicitud
                    </button>
                </div>
                <div class="alert alert-info" role="alert" invisible="epp_pending_requests == 0">
                    <i class="fa fa-info-circle me-2" title="Información"></i>
                    El empleado tiene <field name="epp_pending_requests" class="fw-bold"/> solicitud(es) de EPP pendientes.
                    <button name="action_view_epp_requests" type="object" class="btn btn-sm btn-info ms-2">
                        <i class="fa fa-eye me-1" title="Ver"></i>Ver Solicitudes
                    </button>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Herencia del form completo de hr.payslip.run (v19 lavish) para agregar
         smart button EPP + alertas. Heredamos del full_form en lugar del form
         minimo de v19 core porque solo el full_form tiene button_box. -->
    <record id="view_hr_payslip_run_form_epp" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.epp</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="lavish_hr_payroll.view_hr_payslip_run_full_form"/>
        <field name="arch" type="xml">
            <!-- Smart button EPP (regresado del v18) -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_generate_epp_requests" type="object"
                        class="oe_stat_button" icon="fa-shield"
                        invisible="employees_need_epp == 0">
                    <field name="employees_need_epp" widget="statinfo" string="Necesitan EPP"/>
                </button>
            </xpath>

            <!-- Campos computados invisibles -->
            <xpath expr="//field[@name='date_start']" position="after">
                <field name="employees_need_epp" invisible="1"/>
                <field name="employees_pending_epp" invisible="1"/>
            </xpath>

            <!-- Alertas EPP en el cuerpo del form -->
            <xpath expr="//group" position="after">
                <div class="alert alert-warning" role="alert" invisible="employees_need_epp == 0">
                    <i class="fa fa-exclamation-triangle me-2" title="Advertencia EPP"></i>
                    <strong>Atención:</strong>
                    <field name="employees_need_epp" class="fw-bold"/> empleado(s) requieren solicitud de dotación/EPP.
                    <button name="action_generate_epp_requests"
                            type="object"
                            class="btn btn-sm btn-primary ms-2"
                            icon="fa-magic"
                            string="Generar Solicitudes"/>
                </div>
                <div class="alert alert-info" role="alert" invisible="employees_pending_epp == 0">
                    <i class="fa fa-info-circle me-2" title="Información EPP"></i>
                    Hay <field name="employees_pending_epp" class="fw-bold"/> solicitud(es) de EPP pendientes en este lote.
                </div>
            </xpath>
        </field>
    </record>
</odoo>
