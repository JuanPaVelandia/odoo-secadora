<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_vacation_unused_line_tree" model="ir.ui.view">
            <field name="name">hr.vacation.unused.line.list</field>
            <field name="model">hr.vacation.unused.line</field>
            <field name="arch" type="xml">
                <list string="Días de Vacaciones No Usados">
                    <field name="employee_id"/>
                    <field name="vacation_id"/>
                    <field name="date"/>
                    <field name="is_business_day"/>
                    <field name="is_holiday"/>
                    <field name="is_weekend"/>
                    <field name="unused_reason_id"/>
                    <field name="description"/>
                    <field name="work_day_value" sum="Total"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_hr_vacation_unused_line_form" model="ir.ui.view">
            <field name="name">hr.vacation.unused.line.form</field>
            <field name="model">hr.vacation.unused.line</field>
            <field name="arch" type="xml">
                <form string="Día de Vacaciones No Usado">
                    <sheet>
                        <group>
                            <group string="Información Principal">
                                <field name="vacation_id"/>
                                <field name="employee_id"/>
                                <field name="date"/>
                                <field name="state"/>
                            </group>
                            <group string="Tipo de Día">
                                <field name="is_business_day"/>
                                <field name="is_holiday"/>
                                <field name="is_weekend"/>
                                <field name="work_day_value"/>
                            </group>
                        </group>
                        <group>
                            <group string="Motivo">
                                <field name="unused_reason_id"/>
                                <field name="description"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_vacation_unused_line_search" model="ir.ui.view">
            <field name="name">hr.vacation.unused.line.search</field>
            <field name="model">hr.vacation.unused.line</field>
            <field name="arch" type="xml">
                <search string="Buscar Días No Usados">
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="unused_reason_id"/>
                    <separator/>
                    <filter string="Días Hábiles" name="business_days" domain="[('is_business_day', '=', True)]"/>
                    <filter string="Festivos" name="holidays" domain="[('is_holiday', '=', True)]"/>
                    <filter string="Fin de Semana" name="weekends" domain="[('is_weekend', '=', True)]"/>
                    <separator/>
                    <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Validados" name="validated" domain="[('state', '=', 'validated')]"/>
                    <filter string="A Utilizar" name="used" domain="[('state', '=', 'used')]"/>
                    <separator/>
                    <group name="group_by">
                        <filter string="Empleado" name="group_employee" context="{'group_by': 'employee_id'}"/>
                        <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Motivo" name="group_reason" context="{'group_by': 'unused_reason_id'}"/>
                        <filter string="Fecha" name="group_date" context="{'group_by': 'date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hr_vacation_unused_line" model="ir.actions.act_window">
            <field name="name">Días de Vacaciones No Usados</field>
            <field name="res_model">hr.vacation.unused.line</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_vacation_unused_line_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay días de vacaciones no usados
                </p>
                <p>
                    Los días de vacaciones no usados se generan cuando se interrumpen las vacaciones de un empleado.
                </p>
            </field>
        </record>
    </data>
</odoo>
