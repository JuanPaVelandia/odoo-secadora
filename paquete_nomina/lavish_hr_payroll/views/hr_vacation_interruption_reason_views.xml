<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_vacation_interruption_reason_tree" model="ir.ui.view">
            <field name="name">hr.vacation.interruption.reason.list</field>
            <field name="model">hr.vacation.interruption.reason</field>
            <field name="arch" type="xml">
                <list string="Motivos de Interrupción" editable="bottom">
                    <field name="code"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_hr_vacation_interruption_reason_form" model="ir.ui.view">
            <field name="name">hr.vacation.interruption.reason.form</field>
            <field name="model">hr.vacation.interruption.reason</field>
            <field name="arch" type="xml">
                <form string="Motivo de Interrupción">
                    <sheet>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="name"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_vacation_interruption_reason_search" model="ir.ui.view">
            <field name="name">hr.vacation.interruption.reason.search</field>
            <field name="model">hr.vacation.interruption.reason</field>
            <field name="arch" type="xml">
                <search string="Buscar Motivos">
                    <field name="code"/>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="action_hr_vacation_interruption_reason" model="ir.actions.act_window">
            <field name="name">Motivos de Interrupción de Vacaciones</field>
            <field name="res_model">hr.vacation.interruption.reason</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_vacation_interruption_reason_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo motivo de interrupción
                </p>
            </field>
        </record>
    </data>
</odoo>
