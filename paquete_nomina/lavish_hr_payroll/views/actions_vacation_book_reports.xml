<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_vacation_book_form" model="ir.ui.view">
            <field name="name">hr.vacation.book.form</field>
            <field name="model">hr.vacation.book</field>
            <field name="arch" type="xml">
                <form string="Libro de Vacaciones">
                    <sheet>
                        <group>
                            <group string="Parametros">
                                <field name="company_id" readonly="1"/>
                                <field name="date_cut"/>
                                <field name="contract_state"/>
                            </group>
                            <group string="Filtros">
                                <field name="employee_ids" widget="many2many_tags"/>
                                <field name="department_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group>
                            <group string="Opciones">
                                <field name="include_zero_balance"/>
                                <field name="group_by_department"/>
                                <field name="show_detail"/>
                            </group>
                        </group>
                        <group invisible="not line_ids">
                            <group string="Resumen">
                                <field name="total_employees"/>
                                <field name="total_days_earned"/>
                                <field name="total_days_taken"/>
                                <field name="total_days_pending"/>
                            </group>
                            <group>
                                <field name="currency_id" invisible="1"/>
                                <field name="total_value"/>
                                <field name="excel_file" filename="excel_file_name"/>
                                <field name="excel_file_name" invisible="1"/>
                            </group>
                        </group>
                        <notebook invisible="not line_ids">
                            <page string="Detalle por Empleado">
                                <field name="line_ids" readonly="1">
                                    <list>
                                        <field name="employee_id"/>
                                        <field name="identification"/>
                                        <field name="department_id"/>
                                        <field name="date_start"/>
                                        <field name="days_worked"/>
                                        <field name="days_earned" sum="Total Causados"/>
                                        <field name="days_taken" sum="Total Tomados"/>
                                        <field name="days_pending" sum="Total Pendientes"/>
                                        <field name="provision_value" sum="Total Provision"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Generar Reporte" name="action_generate" type="object" class="btn-primary" invisible="line_ids"/>
                        <button string="Regenerar" name="action_generate" type="object" class="btn-secondary" invisible="not line_ids"/>
                        <button string="Generar Excel" name="action_generate_excel" type="object" class="btn-primary" invisible="not line_ids"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_hr_vacation_book_reports">
            <field name="name">Libro de Vacaciones</field>
            <field name="res_model">hr.vacation.book</field>
            <field name="target">new</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="hr_vacation_book_form"/>
        </record>
    </data>
</odoo>
