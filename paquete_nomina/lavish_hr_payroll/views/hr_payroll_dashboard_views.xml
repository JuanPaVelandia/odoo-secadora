<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Action -->
    <record id="lavish_hr_payroll_dashboard_action" model="ir.actions.client">
        <field name="name">Dashboard Nómina</field>
        <field name="tag">lavish_hr_payroll_dashboard</field>
        <field name="target">main</field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_lavish_hr_payroll_dashboard"
        name="Dashboard"
        parent="hr_payroll.menu_hr_payroll_payslips"
        action="lavish_hr_payroll_dashboard_action"
        sequence="0"/>

    <!-- =============================================== -->
    <!-- Dashboard Layout Management Views             -->
    <!-- =============================================== -->

    <!-- Dashboard Form View -->
    <record id="view_hr_dashboard_form" model="ir.ui.view">
        <field name="name">hr.dashboard.form</field>
        <field name="model">hr.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <header>
                    <button name="action_set_default" string="Establecer como Predeterminado" type="object" class="btn-primary" invisible="is_default"/>
                    <button name="action_duplicate" string="Duplicar Dashboard" type="object" class="btn-secondary"/>
                    <field name="is_default" widget="boolean_toggle" invisible="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Dashboard"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="grid_columns"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Widgets" name="widgets">
                            <field name="widget_ids">
                                <list string="Widgets" editable="bottom">
                                    <field name="widget_type"/>
                                    <field name="row"/>
                                    <field name="col"/>
                                    <field name="colspan"/>
                                    <field name="rowspan"/>
                                    <field name="visible" widget="boolean_toggle"/>
                                    <field name="collapsed" widget="boolean_toggle"/>
                                    <field name="sequence"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard List View -->
    <record id="view_hr_dashboard_list" model="ir.ui.view">
        <field name="name">hr.dashboard.list</field>
        <field name="model">hr.dashboard</field>
        <field name="arch" type="xml">
            <list string="Dashboards">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="is_default" widget="boolean_toggle"/>
                <field name="grid_columns"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Dashboard Search View -->
    <record id="view_hr_dashboard_search" model="ir.ui.view">
        <field name="name">hr.dashboard.search</field>
        <field name="model">hr.dashboard</field>
        <field name="arch" type="xml">
            <search string="Buscar Dashboards">
                <field name="name"/>
                <field name="user_id"/>
                <separator/>
                <filter string="Mis Dashboards" name="my_dashboards" domain="[('user_id', '=', uid)]"/>
                <filter string="Predeterminado" name="default_dashboard" domain="[('is_default', '=', True)]"/>
                <filter string="Activos" name="active_dashboards" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive_dashboards" domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Usuario" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Compañía" name="group_by_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_hr_dashboard" model="ir.actions.act_window">
        <field name="name">Configuración de Dashboards</field>
        <field name="res_model">hr.dashboard</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_dashboards': 1, 'search_default_active_dashboards': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer dashboard personalizado
            </p>
            <p>
                Los dashboards te permiten personalizar la visualización de información de nómina.<br/>
                Puedes crear múltiples dashboards y configurar qué widgets mostrar en cada uno.
            </p>
        </field>
    </record>

    <!-- Dashboard Configuration Menu -->
    <menuitem
        id="menu_hr_dashboard_config"
        name="Configuración de Dashboards"
        parent="hr_work_entry_enterprise.menu_hr_payroll_configuration"
        action="action_hr_dashboard"
        sequence="100"/>

    <!-- ═══════════════════════════════════════════════════════════════════════
         OVERRIDE: Dashboard de Nomina
         Reemplaza el dashboard nativo de hr_payroll por el dashboard de Lavish
         Debe estar DESPUES de la definicion de lavish_hr_payroll_dashboard_action
         ═══════════════════════════════════════════════════════════════════════ -->
    <record id="hr_payroll.menu_hr_payroll_dashboard_root" model="ir.ui.menu">
        <field name="action" ref="lavish_hr_payroll_dashboard_action"/>
    </record>

    <!-- Al abrir la app de Nómina, entrar directamente al dashboard Lavish -->
    <record id="hr_work_entry_enterprise.menu_hr_payroll_root" model="ir.ui.menu">
        <field name="action" ref="lavish_hr_payroll_dashboard_action"/>
    </record>

</odoo>
