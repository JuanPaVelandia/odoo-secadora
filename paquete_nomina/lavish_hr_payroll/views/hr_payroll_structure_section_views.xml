<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         VISTAS DE SECCIONES DE ESTRUCTURA SALARIAL
         Sistema para organizar reglas por seccion
         ================================================================ -->

    <!-- ================================================================
         VISTAS DE SECCION DE ESTRUCTURA
         ================================================================ -->

    <!-- Form View -->
    <record id="view_hr_payroll_structure_section_form" model="ir.ui.view">
        <field name="name">hr.payroll.structure.section.form</field>
        <field name="model">hr.payroll.structure.section</field>
        <field name="arch" type="xml">
            <form string="Seccion de Estructura Salarial">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list-alt"
                                name="action_view_rules" type="object">
                            <field name="rule_count" widget="statinfo" string="Reglas"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-file-text-o"
                                name="action_view_payslips" type="object">
                            <field name="payslip_count" widget="statinfo" string="Nominas"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-money"
                                name="action_view_payslip_lines" type="object">
                            <field name="payslip_line_count" widget="statinfo" string="Lineas"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre de la Seccion"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuracion">
                            <field name="structure_id"/>
                            <field name="section_type"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Filtro de Reglas">
                            <field name="category_codes"
                                   placeholder="BASIC,AUX,DEV (vacio = por defecto)"/>
                            <field name="exclude_codes"
                                   placeholder="REGLA1,REGLA2"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Reglas Salariales" name="rules">
                            <field name="rule_ids" readonly="1">
                                <list string="Reglas de esta Seccion">
                                    <field name="sequence"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="account_debit" optional="show"/>
                                    <field name="account_credit" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <page string="Configuracion Contable" name="accounting">
                            <group>
                                <group string="Modo de Contabilizacion">
                                    <field name="use_direct_accounts"/>
                                    <field name="accounting_config_id"
                                           invisible="use_direct_accounts"/>
                                </group>
                                <group string="Cuentas por Defecto"
                                       invisible="not use_direct_accounts">
                                    <field name="debit_account_id"/>
                                    <field name="credit_account_id"/>
                                </group>
                            </group>
                            <div class="alert alert-secondary" role="alert"
                                 invisible="not use_direct_accounts">
                                <p><strong>Modo Cuentas Directas:</strong></p>
                                <p>Usa las cuentas configuradas en cada regla salarial
                                   (hr.salary.rule.accounting). Si una regla no tiene cuenta,
                                   usa las cuentas por defecto de esta seccion.</p>
                            </div>
                            <div class="alert alert-secondary" role="alert"
                                 invisible="use_direct_accounts">
                                <p><strong>Modo Configuracion Avanzada:</strong></p>
                                <p>Usa la configuracion de estructura contable seleccionada
                                   para construir dinamicamente los codigos de cuenta
                                   basados en departamento, ubicacion, puesto, etc.</p>
                            </div>
                        </page>

                        <page string="Condiciones" name="conditions">
                            <group>
                                <group string="Tipo de Condicion">
                                    <field name="apply_condition" widget="radio"/>
                                </group>
                                <group string="Opciones Especiales">
                                    <field name="skip_on_leave"/>
                                    <field name="skip_on_termination"/>
                                    <field name="only_on_termination"/>
                                    <field name="min_days_worked"/>
                                </group>
                            </group>

                            <group string="Condicion Python"
                                   invisible="apply_condition != 'python'">
                                <field name="python_condition" nolabel="1"
                                       placeholder="Ejemplo: employee.department_id.name == 'Ventas'"/>
                            </group>

                            <group string="Filtros de Empleados"
                                   invisible="apply_condition != 'domain'">
                                <field name="employee_domain" widget="domain"
                                       options="{'model': 'hr.employee'}"/>
                                <field name="exclude_employee_domain" widget="domain"
                                       options="{'model': 'hr.employee'}"/>
                            </group>

                            <div class="alert alert-info" role="alert">
                                <strong>Variables disponibles en condicion Python:</strong>
                                <ul class="mb-0">
                                    <li><code>employee</code>: Empleado (hr.employee)</li>
                                    <li><code>contract</code>: Contrato (hr.contract)</li>
                                    <li><code>payslip</code>: Nomina (hr.payslip)</li>
                                    <li><code>date_from, date_to</code>: Fechas del periodo</li>
                                    <li><code>company</code>: Compania (res.company)</li>
                                </ul>
                            </div>

                            <separator string="Dependencias entre Secciones"/>
                            <group>
                                <group>
                                    <field name="depends_on_sections" widget="many2many_tags"
                                           options="{'color_field': 'color'}"
                                           placeholder="Secciones que deben ejecutarse antes..."/>
                                </group>
                                <group>
                                    <field name="skip_if_dependency_skipped"/>
                                </group>
                            </group>
                            <div class="alert alert-warning" role="alert"
                                 invisible="not depends_on_sections">
                                <i class="fa fa-link me-2" title="Dependencia"/>
                                <strong>Dependencias configuradas:</strong>
                                Esta seccion solo se ejecutara si las secciones seleccionadas
                                fueron ejecutadas previamente.
                            </div>
                        </page>

                        <page string="Notas" name="notes">
                            <field name="notes" placeholder="Notas sobre esta seccion..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_hr_payroll_structure_section_list" model="ir.ui.view">
        <field name="name">hr.payroll.structure.section.list</field>
        <field name="model">hr.payroll.structure.section</field>
        <field name="arch" type="xml">
            <list string="Secciones de Estructura"
                  decoration-muted="not active"
                  decoration-bf="section_type in ('totaldev', 'totalded', 'net')">
                <field name="sequence" widget="handle"/>
                <field name="structure_id"/>
                <field name="section_type" widget="badge"
                       decoration-info="section_type == 'devengos'"
                       decoration-success="section_type in ('totaldev', 'net')"
                       decoration-danger="section_type in ('deducciones', 'totalded')"
                       decoration-warning="section_type in ('provisiones', 'ibd_ss')"/>
                <field name="name"/>
                <field name="rule_count"/>
                <field name="use_direct_accounts" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Kanban View - Estilizada con Totales y Nominas -->
    <record id="view_hr_payroll_structure_section_kanban" model="ir.ui.view">
        <field name="name">hr.payroll.structure.section.kanban</field>
        <field name="model">hr.payroll.structure.section</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_hr_payroll_section_kanban"
                    default_group_by="section_type"
                    records_draggable="1"
                    group_create="0">
                <field name="id"/>
                <field name="name"/>
                <field name="section_type"/>
                <field name="sequence"/>
                <field name="rule_count"/>
                <field name="active"/>
                <field name="color"/>
                <field name="structure_id"/>
                <field name="use_direct_accounts"/>
                <field name="total_amount"/>
                <field name="last_month_total"/>
                <field name="payslip_count"/>
                <field name="currency_id"/>
                <progressbar field="active" colors='{"True": "success", "False": "muted"}'/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside>
                            <field name="color" widget="color_picker"/>
                        </aside>
                        <main class="ms-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <field name="name" class="fw-bold fs-5"/>
                                <field name="active" widget="boolean_toggle"/>
                            </div>
                            <div class="text-muted small mt-1">
                                <field name="structure_id"/>
                            </div>

                            <!-- Estadisticas -->
                            <div class="d-flex gap-3 mt-2">
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-list-alt me-1 text-primary" title="Reglas"/>
                                    <field name="rule_count"/>
                                    <span class="ms-1 text-muted small">reglas</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-file-text me-1 text-success" title="Nóminas"/>
                                    <field name="payslip_count"/>
                                    <span class="ms-1 text-muted small">nominas</span>
                                </div>
                            </div>

                            <!-- Total del mes -->
                            <div class="mt-2 p-2 bg-light rounded">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted small">Total Mes:</span>
                                    <strong class="text-primary">
                                        <field name="total_amount" widget="monetary"/>
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-1"
                                     t-if="record.last_month_total.raw_value">
                                    <span class="text-muted small">Mes Anterior:</span>
                                    <span class="text-muted">
                                        <field name="last_month_total" widget="monetary"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Tipo Badge -->
                            <div class="mt-2">
                                <field name="section_type" widget="badge"
                                       decoration-info="section_type == 'devengos'"
                                       decoration-success="section_type in ('totaldev', 'net')"
                                       decoration-danger="section_type in ('deducciones', 'totalded')"
                                       decoration-warning="section_type in ('provisiones', 'ibd_ss')"/>
                                <span t-if="record.use_direct_accounts.raw_value"
                                      class="badge text-bg-secondary ms-1">
                                    <i class="fa fa-check me-1" title="Configurado"/>Cuentas
                                </span>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hr_payroll_structure_section_search" model="ir.ui.view">
        <field name="name">hr.payroll.structure.section.search</field>
        <field name="model">hr.payroll.structure.section</field>
        <field name="arch" type="xml">
            <search string="Buscar Seccion">
                <field name="name"/>
                <field name="structure_id"/>
                <field name="section_type"/>
                <separator/>
                <filter string="Activas" name="active" domain="[('active', '=', True)]"/>
                <filter string="Devengos" name="devengos"
                        domain="[('section_type', '=', 'devengos')]"/>
                <filter string="Deducciones" name="deducciones"
                        domain="[('section_type', '=', 'deducciones')]"/>
                <filter string="Totales" name="totales"
                        domain="[('section_type', 'in', ['totaldev', 'totalded', 'net'])]"/>
                <filter string="Provisiones" name="provisiones"
                        domain="[('section_type', '=', 'provisiones')]"/>
                <filter string="IBD SS" name="ibd_ss"
                        domain="[('section_type', '=', 'ibd_ss')]"/>
                <separator/>
                <filter string="Archivadas" name="archived"
                        domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Estructura" name="group_structure"
                            context="{'group_by': 'structure_id'}"/>
                    <filter string="Tipo" name="group_type"
                            context="{'group_by': 'section_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action - DEBE estar ANTES de las vistas que la referencian -->
    <record id="action_hr_structure_section" model="ir.actions.act_window">
        <field name="name">Secciones de Estructura</field>
        <field name="res_model">hr.payroll.structure.section</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_group_structure': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear seccion de estructura salarial
            </p>
            <p>
                Las secciones permiten organizar las reglas salariales
                en grupos con configuracion contable independiente.
            </p>
            <p class="text-muted">
                <strong>Tipos disponibles:</strong> DEVENGOS, DEDUCCIONES,
                TOTALDEV, TOTALDED, NET, PROVISIONES, IBD_SS
            </p>
        </field>
    </record>

    <!-- Action para vista de flujo visual -->
    <record id="action_hr_structure_section_flow" model="ir.actions.client">
        <field name="name">Flujo de Secciones</field>
        <field name="tag">section_flow_action</field>
        <field name="context">{'embedded': False}</field>
    </record>

    <!-- ================================================================
         EXTENSION DE VISTA DE ESTRUCTURA SALARIAL
         Debe ir DESPUES de la accion para poder referenciarla
         ================================================================ -->
    <record id="view_hr_payroll_structure_form_sections" model="ir.ui.view">
        <field name="name">hr.payroll.structure.form.sections</field>
        <field name="model">hr.payroll.structure</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_employee_grade_form"/>
        <field name="arch" type="xml">
            <!-- Agregar boton en header -->
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_create_default_sections"
                            string="Crear Secciones"
                            type="object"
                            class="btn-secondary"
                            icon="fa-th-list"
                            invisible="not use_sections"/>
                    <button name="%(lavish_hr_payroll.action_hr_structure_section_flow)d"
                            string="Ver Flujo"
                            type="action"
                            class="btn-primary"
                            icon="fa-sitemap"
                            invisible="not use_sections or section_count == 0"
                            context="{'structureId': id}"/>
                </header>
            </xpath>

            <!-- Agregar button_box para stat buttons -->
            <xpath expr="//sheet/div[hasclass('oe_title')]" position="before">
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button" icon="fa-th-list"
                            invisible="not use_sections"
                            name="%(lavish_hr_payroll.action_hr_structure_section)d"
                            type="action"
                            context="{'default_structure_id': id}">
                        <field name="section_count" widget="statinfo" string="Secciones"/>
                    </button>
                </div>
            </xpath>

            <!-- Agregar campo use_sections despues del nombre -->
            <field name="name" position="after">
                <field name="use_sections"/>
            </field>

            <!-- Agregar pestana de secciones (lista editable para config detallada) -->
            <xpath expr="//notebook" position="inside">
                <page string="Secciones Detalle" name="sections_detail" invisible="not use_sections">
                    <field name="section_ids">
                        <list string="Secciones" editable="bottom"
                              decoration-muted="not active"
                              decoration-bf="section_type in ('totaldev', 'totalded', 'net')">
                            <field name="sequence" widget="handle"/>
                            <field name="section_type"/>
                            <field name="name"/>
                            <field name="rule_count" string="Reglas"/>
                            <field name="apply_condition" optional="show"/>
                            <field name="use_direct_accounts" optional="hide"/>
                            <field name="debit_account_id" optional="hide"/>
                            <field name="credit_account_id" optional="hide"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Menu (bajo Configuracion de Nomina) -->
    <menuitem id="menu_hr_structure_section"
              name="Secciones de Estructura"
              parent="hr_work_entry_enterprise.menu_hr_payroll_configuration"
              action="action_hr_structure_section"
              sequence="25"/>

</odoo>
