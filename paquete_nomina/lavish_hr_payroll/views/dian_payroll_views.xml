<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista Tree para Documentos DIAN de Nómina -->
        <record id="view_dian_payroll_document_tree" model="ir.ui.view">
            <field name="name">dian.payroll.document.tree</field>
            <field name="model">dian.payroll.document</field>
            <field name="arch" type="xml">
                <list string="Documentos DIAN de Nómina" decoration-info="state=='draft'"
                      decoration-success="state=='accepted'" decoration-danger="state=='rejected'">
                    <field name="name"/>
                    <field name="payroll_detail_id"/>
                    <field name="company_id"/>
                    <field name="environment"/>
                    <field name="state"/>
                    <field name="dian_status_code"/>
                    <field name="sent_date"/>
                    <field name="response_date"/>
                    <field name="cune"/>
                </list>
            </field>
        </record>

        <!-- Vista Form para Documentos DIAN de Nómina -->
        <record id="view_dian_payroll_document_form" model="ir.ui.view">
            <field name="name">dian.payroll.document.form</field>
            <field name="model">dian.payroll.document</field>
            <field name="arch" type="xml">
                <form string="Documento DIAN de Nómina">
                    <header>
                        <button name="action_generate_xml" type="object" string="Generar XML" 
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_sign_xml" type="object" string="Firmar XML" 
                                class="btn-primary" invisible="state != 'generated'"/>
                        <button name="action_send_to_dian" type="object" string="Enviar a DIAN" 
                                class="btn-primary" invisible="state != 'signed'"/>
                        <button name="action_check_status" type="object" string="Consultar Estado" 
                                class="btn-secondary" invisible="state not in ['sent', 'accepted', 'rejected']"/>
                        <button name="action_diagnose_security_error" type="object" string="🔍 Diagnóstico Seguridad" 
                                class="btn-warning" title="Diagnosticar errores de seguridad DIAN"/>
                        <button name="action_validate_xml_structure" type="object" string="🔍 Validar XML" 
                                class="btn-info" title="Validar estructura del XML generado" invisible="not xml_file"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,generated,signed,sent,accepted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="payroll_detail_id"/>
                                <field name="company_id"/>
                                <field name="environment"/>
                            </group>
                            <group>
                                <field name="transaction_id"/>
                                <field name="cune"/>
                                <field name="sent_date"/>
                                <field name="response_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Archivos">
                                <group>
                                    <group string="XML Original">
                                        <field name="xml_file" filename="xml_filename"/>
                                        <field name="xml_filename"/>
                                    </group>
                                    <group string="XML Firmado">
                                        <field name="signed_xml_file" filename="signed_xml_filename"/>
                                        <field name="signed_xml_filename"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Archivo ZIP">
                                        <field name="zip_file" filename="zip_filename"/>
                                        <field name="zip_filename"/>
                                    </group>
                                    <group string="Código QR">
                                        <field name="qr_code" widget="image"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Respuesta DIAN">
                                <group>
                                    <field name="dian_zip_key"/>
                                    <field name="dian_status_code"/>
                                </group>
                                <field name="dian_status_description"/>
                                <separator string="Respuesta Completa"/>
                                <field name="dian_response" widget="text"/>
                            </page>
                            <page string="Diagnósticos">
                                <group>
                                    <div class="alert alert-info" role="alert">
                                        <strong>Herramientas de Diagnóstico</strong><br/>
                                        Use estos botones para diagnosticar problemas específicos con la integración DIAN.
                                    </div>
                                </group>
                                <group>
                                    <group string="Validación de XML">
                                        <button name="action_validate_xml_structure" type="object" 
                                                string="Validar Estructura XML" class="btn-info" 
                                                invisible="not xml_file"/>
                                        <button name="action_inspect_xml_structure" type="object" 
                                                string="Inspeccionar XML Detallado" class="btn-secondary" 
                                                invisible="not xml_file"/>
                                    </group>
                                    <group string="Diagnóstico DIAN">
                                        <button name="action_diagnose_security_error" type="object" 
                                                string="Diagnóstico de Seguridad" class="btn-warning"/>
                                    </group>
                                </group>
                                <separator string="Información del Sistema"/>
                                <group>
                                    <group string="Configuración">
                                        <field name="environment" readonly="1"/>
                                        <field name="company_id" readonly="1"/>
                                    </group>
                                    <group string="Estado Técnico">
                                        <field name="state" readonly="1"/>
                                        <field name="transaction_id" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Acción para Documentos DIAN de Nómina -->
        <record id="action_dian_payroll_document" model="ir.actions.act_window">
            <field name="name">Documentos DIAN de Nómina</field>
            <field name="res_model">dian.payroll.document</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Gestión de documentos de nómina electrónica para DIAN
                </p>
                <p>
                    Aquí puede gestionar el envío directo de documentos de nómina electrónica a la DIAN
                    cuando utiliza Software Propio.
                </p>
            </field>
        </record>

        <!-- Menú para Documentos DIAN -->
        <menuitem id="menu_dian_payroll_document" 
                  name="Documentos DIAN" 
                  parent="hr_payroll.menu_hr_payroll_payslips" 
                  action="action_dian_payroll_document" 
                  sequence="15"/>

        <!-- Vista Form para Wizard de Envío a DIAN -->
        <record id="view_payroll_dian_send_wizard_form" model="ir.ui.view">
            <field name="name">payroll.dian.send.wizard.form</field>
            <field name="model">payroll.dian.send.wizard</field>
            <field name="arch" type="xml">
                <form string="Envío a DIAN">
                    <group>
                        <group>
                            <field name="environment"/>
                            <field name="action_type"/>
                        </group>
                        <group>
                            <field name="total_documents"/>
                        </group>
                    </group>
                    <group string="Documentos Seleccionados">
                        <field name="payroll_detail_ids" nolabel="1">
                            <list string="Detalles de Nómina">
                                <field name="employee_id"/>
                                <field name="sequence"/>
                                <field name="status"/>
                                <field name="electronic_payroll_id"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button name="action_validate_configuration" type="object" 
                                string="Validar Configuración" class="btn-secondary"/>
                        <button name="action_process_documents" type="object" 
                                string="Procesar" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Vista Form para Wizard de Consulta de Estado -->
        <record id="view_payroll_dian_status_wizard_form" model="ir.ui.view">
            <field name="name">payroll.dian.status.wizard.form</field>
            <field name="model">payroll.dian.status.wizard</field>
            <field name="arch" type="xml">
                <form string="Consulta de Estado en DIAN">
                    <group>
                        <field name="total_documents"/>
                    </group>
                    <group string="Documentos a Consultar">
                        <field name="dian_document_ids" nolabel="1">
                            <list string="Documentos DIAN">
                                <field name="name"/>
                                <field name="payroll_detail_id"/>
                                <field name="state"/>
                                <field name="dian_zip_key"/>
                                <field name="sent_date"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button name="action_check_status" type="object" 
                                string="Consultar Estado" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para Wizard de Envío -->
        <record id="action_payroll_dian_send_wizard" model="ir.actions.act_window">
            <field name="name">Enviar a DIAN</field>
            <field name="res_model">payroll.dian.send.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_hr_electronic_payroll_detail"/>
            <field name="binding_view_types">list</field>
        </record>

        <!-- Acción para Wizard de Consulta de Estado -->
        <record id="action_payroll_dian_status_wizard" model="ir.actions.act_window">
            <field name="name">Consultar Estado DIAN</field>
            <field name="res_model">payroll.dian.status.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_hr_electronic_payroll_detail"/>
            <field name="binding_view_types">list</field>
        </record>

    </data>
</odoo>
