<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

    <!--
        Form completo de hr.payslip.run para v19.
        En v18 enterprise el form era un sheet completo; v19 lo redujo a un modal
        de 4 campos y movió la UX al kanban. Esta vista restaura el sheet completo
        adaptando los nombres de estado:
            v18 'draft'/'verify'  ->  v19 '01_ready'
            v18 'close'           ->  v19 '02_close'
            v18 'done'            ->  v19 '02b_done'
            v18 'paid'            ->  v19 '03_paid'
            v18 'cancel'          ->  v19 '04_cancel'

        Botones backend (assign_status_verify, restart_payroll_batch,
        restart_payroll_account_batch) adaptados a v19 en hr_payslip_run.py.
    -->
    <record id="view_hr_payslip_run_full_form" model="ir.ui.view">
        <field name="name">hr.payslip.run.full.form</field>
        <field name="model">hr.payslip.run</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <form string="Lote de Nómina" js_class="hr_payslip_batch_form">
                <header>
                    <!-- Wizard custom de lavish (estilo v18): filtros + tabla de
                         empleados auto-poblada + opciones de liquidacion. -->
                    <button string="Generar recibos de nómina"
                            name="%(lavish_hr_payroll.action_lavish_hr_payslip_employees)d"
                            type="action"
                            class="btn-primary"
                            context="{'default_date_start': date_start, 'default_date_end': date_end}"
                            invisible="state != '01_ready' or payslip_count != 0"/>
                    <button string="Agregar recibos de nómina"
                            name="%(lavish_hr_payroll.action_lavish_hr_payslip_employees)d"
                            type="action"
                            class="btn-secondary"
                            context="{'default_date_start': date_start, 'default_date_end': date_end}"
                            invisible="state != '01_ready' or payslip_count == 0"/>

                    <!-- v18 'Marcar como Listo': valida slips + crea asiento contable.
                         Solo visible en Confirmado (02_close). Antes era 'Crear Asiento Borrador'. -->
                    <button string="Marcar como Listo"
                            name="action_set_done"
                            type="object"
                            class="oe_highlight"
                            invisible="state != '02_close'"
                            confirm="Esto validará las nóminas y creará el asiento contable en estado borrador. ¿Continuar?"/>
                    <button string="Marcar como Pagado"
                            name="action_paid"
                            type="object"
                            class="oe_highlight"
                            invisible="state != '02b_done'"/>
                    <button string="Volver a Confirmado"
                            name="action_back_to_close"
                            type="object"
                            class="btn-secondary"
                            invisible="state != '02b_done'"/>
                    <button string="Reporte de Pago"
                            name="action_payment_report"
                            type="object"
                            invisible="state not in ('02b_done', '03_paid')"/>
                    <button string="Establecer como borrador"
                            name="action_draft"
                            type="object"
                            invisible="state not in ('02_close', '02b_done')"
                            confirm="Esta acción revertirá los asientos contables asociados y dejará los recibos en borrador. ¿Desea continuar?"/>
                    <button string="Marcar No Pagado"
                            name="action_unpaid"
                            type="object"
                            invisible="state != '03_paid'"/>

                    <!-- Botones extendidos por lavish_hr_payroll -->
                    <button name="assign_status_verify"
                            type="object"
                            string="Verificar"
                            invisible="state != '01_ready'"/>
                    <button name="restart_payroll_batch"
                            type="object"
                            string="Reiniciar"
                            invisible="state not in ('01_ready', '02_close')"
                            confirm="Esta acción eliminará todos los recibos del lote y revertirá los asientos contables asociados. ¿Desea continuar?"/>
                    <button name="restart_payroll_account_batch"
                            type="object"
                            string="Reversar contabilización"
                            invisible="state not in ('02_close', '02b_done')"
                            confirm="Esta acción eliminará los asientos contables del lote y dejará los recibos en estado confirmado. Los recibos calculados se conservan. ¿Desea continuar?"/>
                    <button name="action_reverse_payslip_run"
                            type="object"
                            string="Crear Reversión"
                            invisible="state != '02b_done' or is_credit_note"
                            class="btn-secondary"/>
                    <button name="generate_settlement_report_entity"
                            type="object"
                            string="Reporte por entidad"
                            invisible="state not in ('02_close', '02b_done')"/>
                    <button name="action_send_payslip_emails"
                            type="object"
                            string="Enviar por Email"
                            class="btn-secondary"
                            icon="fa-paper-plane"
                            invisible="state not in ('02_close', '02b_done')"/>
                    <button name="action_compute_all_payslips"
                            type="object"
                            string="Computar Nóminas"
                            class="btn-warning"
                            icon="fa-calculator"
                            invisible="state not in ('01_ready', '02_close')"
                            confirm="¿Desea computar todas las nóminas en borrador?"/>
                    <!-- Publicar Asientos solo en Listo: los moves existen en draft
                         tras 'Crear Asiento Borrador'. En Confirmado no hay moves todavia. -->
                    <button name="action_post_account_moves"
                            type="object"
                            string="Publicar Asientos"
                            class="btn-success"
                            icon="fa-check"
                            invisible="state != '02b_done'"/>
                    <button name="action_draft_account_moves"
                            type="object"
                            string="Revertir Asientos a Borrador"
                            class="btn-secondary"
                            icon="fa-undo"
                            help="Revierte asientos publicados de vuelta a borrador (no crea nuevos)"
                            invisible="state not in ('02b_done', '03_paid')"/>

                    <field name="state" widget="statusbar" statusbar_visible="01_ready,02_close,02b_done,03_paid"/>
                </header>

                <!-- Alertas -->
                <div invisible="not vacation_count and not contract_state_warning">
                    <div invisible="not vacation_count"
                         class="alert alert-warning mb-0 text-center" role="alert">
                        <field name="vacation_count" nolabel="1"/>
                    </div>
                    <div invisible="not contract_state_warning"
                         class="alert alert-info mb-0 text-center" role="alert">
                        <field name="contract_state_warning" nolabel="1"/>
                    </div>
                </div>

                <!-- Panel Resumen de Totales -->
                <div invisible="payslip_count == 0" class="o_form_sheet" style="padding: 0; margin-bottom: 8px;">
                    <field name="lines_summary_html" nolabel="1" readonly="1"/>
                </div>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Usamos action_view_payslips (lavish) en vez de action_open_payslips (core).
                             action_open_payslips redirige a la accion v19 con path="payslips"
                             (URL /payslips/) que activa un JS class custom (hr_payroll_payslip_list)
                             que renderiza una PayRunCard arriba; si esa card falla la lista queda
                             en blanco aunque el pager diga 1-6/6. action_view_payslips devuelve
                             un dominio 'id in [...]' que NO incluye payslip_run_id, asi el JS no
                             activa la card y la lista renderiza normal. -->
                        <button name="action_view_payslips"
                                class="oe_stat_button" icon="fa-book" type="object"
                                help="Recibos de nomina del lote"
                                invisible="payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="payslip_count"/></span>
                                <span class="o_stat_text">Payslips</span>
                            </div>
                        </button>
                        <button name="action_open_summary_modal"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bar-chart">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Ver Resumen</span>
                                <span class="o_stat_text">Detallado</span>
                            </div>
                        </button>
                        <button name="action_view_employees" type="object"
                                class="oe_stat_button" icon="fa-users"
                                invisible="employee_count == 0">
                            <field name="employee_count" widget="statinfo" string="Empleados"/>
                        </button>
                        <button name="action_view_contracts" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="contract_count == 0">
                            <field name="contract_count" widget="statinfo" string="Contratos"/>
                        </button>
                        <button name="action_view_leaves" type="object"
                                class="oe_stat_button" icon="fa-user-md"
                                invisible="leave_count == 0">
                            <field name="leave_count" widget="statinfo" string="Ausencias/Vacaciones"/>
                        </button>
                        <button name="action_view_confirmed_payslips" type="object"
                                class="oe_stat_button" icon="fa-check-circle"
                                invisible="confirmed_payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value text-success">
                                    <field name="confirmed_payslip_count"/>
                                </span>
                                <span class="o_stat_text">Confirmadas</span>
                            </div>
                        </button>
                        <button name="action_view_paid_payslips" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="paid_payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value text-info">
                                    <field name="paid_payslip_count"/>
                                </span>
                                <span class="o_stat_text">Pagadas</span>
                            </div>
                        </button>
                        <button name="action_view_draft_payslips" type="object"
                                class="oe_stat_button" icon="fa-file-o"
                                invisible="draft_payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value text-warning">
                                    <field name="draft_payslip_count"/>
                                </span>
                                <span class="o_stat_text">Borradores</span>
                            </div>
                        </button>
                        <button name="action_open_account_move" type="object"
                                class="oe_stat_button" icon="fa-bars"
                                help="Generated Account Move"
                                invisible="account_move_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="account_move_count"/></span>
                                <span class="o_stat_text">Asientos Contables</span>
                            </div>
                        </button>
                        <button name="action_view_payslip_lines" type="object"
                                class="oe_stat_button" icon="fa-list-alt"
                                invisible="payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver Líneas</span>
                            </div>
                        </button>
                        <button name="action_view_novelties" type="object"
                                class="oe_stat_button" icon="fa-edit"
                                invisible="novelty_count == 0">
                            <field name="novelty_count" widget="statinfo" string="Novedades"/>
                        </button>
                    </div>

                    <field name="number" readonly="1" invisible="not number"/>
                    <field name="sequence_prefix" invisible="1"/>
                    <field name="is_credit_note" invisible="1"/>

                    <label for="name" string="Nombre del Lote"/>
                    <h1>
                        <field name="name" placeholder="ej. Abril 2026" readonly="state != '01_ready'"/>
                    </h1>

                    <group>
                        <group>
                            <label for="date_start" string="Período"/>
                            <div class="o_row">
                                <field name="date_start" class="oe_inline o_hr_narrow_field" readonly="state != '01_ready'"/>
                                <span> - </span>
                                <field name="date_end" class="oe_inline o_hr_narrow_field" readonly="state != '01_ready'"/>
                            </div>
                            <field name="structure_id" domain="[('country_id', 'in', [country_id, False])]" placeholder="Todas las estructuras"/>
                            <field name="schedule_pay"/>
                            <field name="method_schedule_pay" options="{'no_create': True}"/>
                            <field name="payment_report_filename" invisible="1"/>
                            <field name="payment_report" filename="payment_report_filename" invisible="not payment_report"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="country_id" invisible="1"/>
                            <field name="country_code" invisible="1"/>
                            <field name="definitive_plan"/>
                            <field name="liquidate_contract"/>
                            <field name="liquidation_structure_id"
                                   invisible="not liquidate_contract"
                                   required="liquidate_contract"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="liquidate_vacations"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Nóminas" name="payslips_page">
                            <field name="summary_widget" widget="payslip_run_summary" nolabel="1"/>
                            <group>
                                <field name="time_process" readonly="1" force_save="1"
                                       invisible="not time_process"/>
                                <field name="observations" readonly="1" force_save="1"
                                       invisible="not observations"/>
                            </group>
                        </page>

                        <page string="Agregar Novedades" name="novelties_actions_page">
                            <div class="row mt-2">
                                <div class="col-md-6 col-lg-3 mb-3">
                                    <div class="card h-100 border-info">
                                        <div class="card-header bg-info text-white py-2">
                                            <i class="fa fa-file-text-o me-2" title="Documento"/><strong>Novedades</strong>
                                        </div>
                                        <div class="card-body py-3">
                                            <p class="small text-muted mb-2">Bonificaciones, comisiones, auxilios, deducciones.</p>
                                            <button name="action_create_novelty" type="object"
                                                    class="btn btn-info btn-sm w-100 mb-1">
                                                <i class="fa fa-plus me-1" title="Agregar"/> Nueva
                                            </button>
                                            <button name="action_view_novelties" type="object"
                                                    class="btn btn-outline-info btn-sm w-100">
                                                <i class="fa fa-list me-1" title="Lista"/> Ver (<field name="novelty_count" readonly="1" class="d-inline"/>)
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-lg-3 mb-3">
                                    <div class="card h-100 border-warning">
                                        <div class="card-header bg-warning py-2">
                                            <i class="fa fa-money me-2" title="Dinero"/><strong>Préstamos</strong>
                                        </div>
                                        <div class="card-body py-3">
                                            <p class="small text-muted mb-2">Préstamos con cuotas automáticas.</p>
                                            <button name="action_create_loan" type="object"
                                                    class="btn btn-warning btn-sm w-100 mb-1">
                                                <i class="fa fa-plus me-1" title="Agregar"/> Nuevo
                                            </button>
                                            <button name="action_view_loans" type="object"
                                                    class="btn btn-outline-warning btn-sm w-100">
                                                <i class="fa fa-list me-1" title="Lista"/> Ver Existentes
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-lg-3 mb-3">
                                    <div class="card h-100 border-success">
                                        <div class="card-header bg-success text-white py-2">
                                            <i class="fa fa-clock-o me-2" title="Tiempo"/><strong>Horas Extra</strong>
                                        </div>
                                        <div class="card-body py-3">
                                            <p class="small text-muted mb-2">Recargos nocturnos y dominicales.</p>
                                            <button name="action_create_overtime" type="object"
                                                    class="btn btn-success btn-sm w-100 mb-1">
                                                <i class="fa fa-plus me-1" title="Agregar"/> Nueva
                                            </button>
                                            <button name="action_view_overtimes" type="object"
                                                    class="btn btn-outline-success btn-sm w-100">
                                                <i class="fa fa-list me-1" title="Lista"/> Ver Existentes
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 col-lg-3 mb-3">
                                    <div class="card h-100 border-secondary">
                                        <div class="card-header bg-secondary text-white py-2">
                                            <i class="fa fa-calendar-times-o me-2" title="Ausencia"/><strong>Ausencias</strong>
                                        </div>
                                        <div class="card-body py-3">
                                            <p class="small text-muted mb-2">Incapacidades, licencias, permisos.</p>
                                            <button name="action_create_leave" type="object"
                                                    class="btn btn-secondary btn-sm w-100 mb-1">
                                                <i class="fa fa-plus me-1" title="Agregar"/> Nueva
                                            </button>
                                            <button name="action_view_leaves" type="object"
                                                    class="btn btn-outline-secondary btn-sm w-100">
                                                <i class="fa fa-list me-1" title="Lista"/> Ver (<field name="leave_count" readonly="1" class="d-inline"/>)
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </page>

                        <page string="Historial Salarial" name="salary_history_page">
                            <div class="alert alert-secondary" role="alert" style="margin-bottom: 10px; padding: 10px;">
                                <i class="fa fa-line-chart" title="Gráfico"/> <b>Cambios Salariales del Lote</b>
                                <span class="text-muted ms-2">Historial de cambios de salario de todos los contratos incluidos en este lote</span>
                            </div>
                            <field name="batch_change_wage_ids" nolabel="1" readonly="1">
                                <list string="Cambios Salariales"
                                      decoration-success="reason in ['promotion', 'performance']"
                                      decoration-info="reason in ['annual_update', 'adjustment']"
                                      decoration-warning="reason in ['legal', 'collective']"
                                      decoration-muted="reason == 'start'"
                                      decoration-danger="difference &lt; 0"
                                      default_order="date_start desc">
                                    <field name="employee_id" string="Empleado"/>
                                    <field name="contract_id" string="Contrato" optional="show"/>
                                    <field name="date_start" string="Fecha"/>
                                    <field name="wage_old" string="Anterior"/>
                                    <field name="wage" string="Nuevo"/>
                                    <field name="difference" string="Diferencia"/>
                                    <field name="difference_percentage" string="% Variacion"/>
                                    <field name="reason" string="Motivo"/>
                                    <field name="job_id" string="Cargo" optional="show"/>
                                    <field name="department_id" string="Departamento" optional="show"/>
                                    <field name="state" string="Estado" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-success="state == 'approved'"/>
                                    <field name="origin_type" string="Origen" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action de Lotes: agregar list+form al view_mode. -->
    <!-- No registramos un ir.actions.act_window.view explícito: Odoo busca el form
         automáticamente por priority. La vista de arriba tiene priority=10
         (más baja que el form mínimo de hr_payroll que es priority por defecto)
         para ganar la resolución. -->
    <record id="hr_payroll.action_hr_payslip_run" model="ir.actions.act_window">
        <field name="view_mode">list,form,kanban,calendar,pivot,graph</field>
    </record>

    </data>
</odoo>
