<odoo>
    <data>
		<!-- Acumulados de nómina -->
		<record model="ir.actions.act_window"  id="action_hr_accumulated_payroll">
				<field name="name">Acumulados de nómina</field>
				<field name="res_model">hr.accumulated.payroll</field>
				<field name="view_mode">list,form</field>
		</record>

		<!-- Vista Form -->
		<record model="ir.ui.view" id="lavish_hr_payroll.form_hr_accumulated_payroll">
			<field name="name">hr accumulated payroll form</field>
			<field name="model">hr.accumulated.payroll</field>
			<field name="arch" type="xml">
				<form string="Acumulado de Nómina">
					<sheet>
						<group>
							<group string="Información Básica">
								<field name="accumulated_type" widget="radio"/>
								<field name="employee_id" required="1"/>
								<field name="contract_id"/>
								<field name="salary_rule_id"/>
							</group>
							<group string="Valores y Fechas">
								<field name="date"/>
								<field name="amount"/>
								<field name="quantity" invisible="accumulated_type not in ('novelty', 'absence')"/>
								<field name="date_from" invisible="accumulated_type not in ('novelty', 'absence')"/>
								<field name="date_to" invisible="accumulated_type not in ('novelty', 'absence')"/>
							</group>
						</group>
						<group string="Origen del Acumulado" invisible="accumulated_type == 'inception'">
							<field name="origin_payslip_id"/>
							<field name="origin_payslip_line_id"/>
						</group>
						<notebook>
							<page string="Reglas de Origen" name="source_rules" invisible="not source_rule_ids">
								<field name="source_rule_ids">
									<list>
										<field name="name"/>
										<field name="code"/>
										<field name="category_id"/>
									</list>
								</field>
							</page>
							<page string="Líneas Relacionadas" name="related_lines">
								<group>
									<group string="Líneas Contables">
										<field name="accounting_line_ids" nolabel="1">
											<list>
												<field name="date"/>
												<field name="account_id"/>
												<field name="debit"/>
												<field name="credit"/>
											</list>
										</field>
									</group>
									<group string="Líneas de Nómina">
										<field name="payslip_line_ids" nolabel="1">
											<list>
												<field name="slip_id"/>
												<field name="name"/>
												<field name="total"/>
											</list>
										</field>
									</group>
								</group>
							</page>
							<page string="Notas" name="notes">
								<field name="note" placeholder="Información adicional sobre este acumulado..."/>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>

        <record model="ir.ui.view" id="lavish_hr_payroll.list_hr_accumulated_payroll">
			    <field name="name">hr accumulated payroll list</field>
			    <field name="model">hr.accumulated.payroll</field>
			    <field name="arch" type="xml">
				<list editable="bottom">
                    <header>
                        <button name="%(lavish_hr_payroll.action_hr_accumulated_payroll)d"
                                type="action"
                                string="Crear Acumulado"
                                class="btn-primary"/>
                    </header>
					<field name="employee_id" required="1"/>
					<field name="accumulated_type" widget="badge"
                           decoration-success="accumulated_type == 'auto'"
                           decoration-info="accumulated_type == 'inception'"
                           decoration-warning="accumulated_type == 'novelty'"
                           decoration-danger="accumulated_type == 'absence'"/>
					<field name="salary_rule_id"/>
                    <field name="date"/>
                    <field name="date_from" optional="show"/>
                    <field name="date_to" optional="show"/>
                    <field name="quantity" optional="show"/>
                    <field name="amount"/>
                    <field name="contract_id" optional="hide"/>
                    <field name="origin_payslip_id" optional="hide"/>
                    <field name="note" optional="hide"/>
				</list>
			</field>
		</record>

		<record id="hr_accumulated_payroll_view_search" model="ir.ui.view">
                    <field name="name">hr.accumulated.payroll.view.search </field>
                    <field name="model">hr.accumulated.payroll</field>
                    <field name="arch" type="xml">
                        <search string="Acumulados">
                            <field name="employee_id"/>
                            <field name="salary_rule_id"/>
                            <field name="accumulated_type"/>
                            <field name="contract_id"/>
                            <separator/>
                            <filter string="Automáticos" name="filter_auto" domain="[('accumulated_type', '=', 'auto')]"/>
                            <filter string="Carga Inicial" name="filter_inception" domain="[('accumulated_type', '=', 'inception')]"/>
                            <filter string="Novedades" name="filter_novelty" domain="[('accumulated_type', '=', 'novelty')]"/>
                            <filter string="Ausencias" name="filter_absence" domain="[('accumulated_type', '=', 'absence')]"/>
                            <filter string="Ajustes" name="filter_adjustment" domain="[('accumulated_type', '=', 'adjustment')]"/>
                            <separator/>
                            <group name="group_by">
                                <filter string="Empleado" name="group_employee" context="{'group_by': 'employee_id'}"/>
                                <filter string="Regla Salarial" name="group_rule" context="{'group_by': 'salary_rule_id'}"/>
                                <filter string="Tipo" name="group_type" context="{'group_by': 'accumulated_type'}"/>
                                <filter string="Contrato" name="group_contract" context="{'group_by': 'contract_id'}"/>
                            </group>
                        </search>
                    </field>
        </record>
    </data>
</odoo>