<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de Resumen de Liquidacion para formulario de nomina -->
        <record id="view_hr_payslip_liquidation_form" model="ir.ui.view">
            <field name="name">hr.payslip.liquidation.form.inherit</field>
            <field name="model">hr.payslip</field>
            <field name="priority">25</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
            <field name="arch" type="xml">
                <!-- Agregar pestana de Resumen de Liquidacion despues del grupo de Gestion de Vacaciones -->
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='page_concepts']" position="after">
                    <page string="Resumen Liquidacion" name="page_liquidation_summary" invisible="struct_process != 'contrato'">
                        <!-- Header con informacion del empleado y fechas -->
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="card shadow-sm">
                                    <div class="card-header d-flex justify-content-between align-items-center" style="background-color: #333; color: #fff;">
                                        <div>
                                            <i class="fa fa-file-text-o me-2" title="Documento"/>
                                            <strong>Liquidacion de Contrato</strong>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <span class="text-muted small">Empleado</span>
                                                <div class="fw-bold"><field name="employee_id" readonly="1" nolabel="1"/></div>
                                            </div>
                                            <div class="col-md-4">
                                                <span class="text-muted small">Periodo</span>
                                                <div class="fw-bold">
                                                    <field name="date_from" readonly="1" nolabel="1"/> - <field name="date_to" readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <span class="text-muted small">Fecha Liquidacion</span>
                                                <div class="fw-bold"><field name="date_liquidacion" readonly="1" nolabel="1"/></div>
                                            </div>
                                        </div>
                                        <div class="row mt-2">
                                            <div class="col-md-4">
                                                <span class="text-muted small">Motivo Retiro</span>
                                                <div><field name="reason_retiro" readonly="1" nolabel="1"/></div>
                                            </div>
                                            <div class="col-md-4">
                                                <span class="text-muted small">Dias Trabajados</span>
                                                <div class="fw-bold" style="color: #333;"><field name="days_to_liquidacion" readonly="1" nolabel="1"/> dias</div>
                                            </div>
                                            <div class="col-md-4">
                                                <span class="text-muted small">Estado</span>
                                                <div><field name="state" widget="badge" nolabel="1"/></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- KPI Cards Resumen - Escala de Grises -->
                        <div class="row g-3 mb-4">
                            <!-- Total Devengos -->
                            <div class="col-md-3">
                                <div class="card h-100" style="border: 2px solid #666;">
                                    <div class="card-body text-center" style="background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);">
                                        <i class="fa fa-plus-circle fa-2x mb-2" style="color: #444;" title="Agregar"/>
                                        <h6 class="text-muted small mb-1">DEVENGOS</h6>
                                        <h4 class="mb-0 fw-bold" style="color: #333;"><field name="total_devengos" widget="monetary" nolabel="1"/></h4>
                                    </div>
                                </div>
                            </div>
                            <!-- Seguridad Social -->
                            <div class="col-md-3">
                                <div class="card h-100" style="border: 2px solid #888;">
                                    <div class="card-body text-center" style="background: linear-gradient(135deg, #e8e8e8 0%, #ddd 100%);">
                                        <i class="fa fa-shield fa-2x mb-2" style="color: #555;" title="Seguridad"/>
                                        <h6 class="text-muted small mb-1">SEGURIDAD SOCIAL</h6>
                                        <h4 class="mb-0 fw-bold" style="color: #444;"><field name="total_seguridad_social" widget="monetary" nolabel="1"/></h4>
                                    </div>
                                </div>
                            </div>
                            <!-- Total Deducciones -->
                            <div class="col-md-3">
                                <div class="card h-100" style="border: 2px solid #999;">
                                    <div class="card-body text-center" style="background: linear-gradient(135deg, #ddd 0%, #ccc 100%);">
                                        <i class="fa fa-minus-circle fa-2x mb-2" style="color: #666;" title="Reducir"/>
                                        <h6 class="text-muted small mb-1">DEDUCCIONES</h6>
                                        <h4 class="mb-0 fw-bold" style="color: #555;"><field name="total_deducciones" widget="monetary" nolabel="1"/></h4>
                                    </div>
                                </div>
                            </div>
                            <!-- Neto a Pagar -->
                            <div class="col-md-3">
                                <div class="card h-100" style="border: 2px solid #333;">
                                    <div class="card-body text-center" style="background: linear-gradient(135deg, #444 0%, #333 100%);">
                                        <i class="fa fa-money fa-2x mb-2" style="color: #fff;" title="Dinero"/>
                                        <h6 class="small mb-1" style="color: #ccc;">NETO A PAGAR</h6>
                                        <h4 class="mb-0 fw-bold" style="color: #fff;"><field name="net_amount" widget="monetary" nolabel="1"/></h4>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Todas las lineas agrupadas por categoria -->
                        <div class="card mb-3">
                            <div class="card-header d-flex justify-content-between align-items-center" style="background-color: #555; color: #fff;">
                                <div>
                                    <i class="fa fa-list me-2" title="Lista"/>
                                    <strong>Detalle de Conceptos</strong>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <field name="line_ids" nolabel="1" mode="list">
                                    <list editable="bottom" create="false" delete="false" default_order="category_id, sequence">
                                        <field name="sequence" column_invisible="1"/>
                                        <field name="category_id" string="Categoria" readonly="1"/>
                                        <field name="code" string="Codigo" readonly="1"/>
                                        <field name="name" string="Concepto" readonly="1"/>
                                        <field name="quantity" string="Cant." sum="Total" readonly="1"/>
                                        <field name="rate" string="Tasa %" readonly="1"/>
                                        <field name="amount" string="Base" widget="monetary" readonly="1"/>
                                        <field name="total" string="Total" widget="monetary" sum="Total"
                                               decoration-success="total > 0"
                                               decoration-danger="total &lt; 0"
                                               decoration-bf="code in ('TOTALDEV', 'TOTALDED', 'NET')"
                                               readonly="1"/>
                                    </list>
                                </field>
                            </div>
                        </div>

                        <!-- Plantilla de Formulas de Calculo -->
                        <div class="card mb-3">
                            <div class="card-header" style="background-color: #f5f5f5; border-bottom: 2px solid #333;">
                                <i class="fa fa-book me-2" title="Fórmulas"/>
                                <strong>Formulas de Calculo - Liquidacion</strong>
                            </div>
                            <div class="card-body" style="font-family: monospace; font-size: 0.9em;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead style="background-color: #333; color: #fff;">
                                                <tr><th colspan="2">PRESTACIONES SOCIALES</th></tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td style="width: 40%;"><strong>Cesantias</strong></td>
                                                    <td><code>(Salario x Dias) / 360</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Int. Cesantias</strong></td>
                                                    <td><code>(Cesantias x Dias x 12%) / 360</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Prima</strong></td>
                                                    <td><code>(Salario x Dias) / 360</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Vacaciones</strong></td>
                                                    <td><code>(Salario x Dias) / 720</code></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="col-md-6">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead style="background-color: #333; color: #fff;">
                                                <tr><th colspan="2">SEGURIDAD SOCIAL (Empleado)</th></tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td style="width: 40%;"><strong>Salud</strong></td>
                                                    <td><code>IBC x 4%</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Pension</strong></td>
                                                    <td><code>IBC x 4%</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Fondo Solidaridad</strong></td>
                                                    <td><code>IBC x 1% (si IBC > 4 SMLV)</code></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <table class="table table-sm table-bordered mb-0 mt-2">
                                            <thead style="background-color: #555; color: #fff;">
                                                <tr><th colspan="2">RETENCION EN LA FUENTE</th></tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td style="width: 40%;"><strong>Base</strong></td>
                                                    <td><code>Devengos - Ded. Ley</code></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Retencion</strong></td>
                                                    <td><code>Segun tabla Art. 383 ET</code></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="row mt-3">
                                    <div class="col-12">
                                        <div class="alert" style="background-color: #f0f0f0; border: 1px solid #ccc; margin-bottom: 0;">
                                            <strong>Leyenda:</strong>
                                            <span class="ms-3"><code>Salario</code> = Salario mensual</span>
                                            <span class="ms-3"><code>Dias</code> = Dias trabajados en el periodo</span>
                                            <span class="ms-3"><code>IBC</code> = Ingreso Base de Cotizacion</span>
                                            <span class="ms-3"><code>SMLV</code> = Salario Minimo Legal Vigente</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Resumen Final en Tabla -->
                        <div class="card">
                            <div class="card-header" style="background-color: #333; color: #fff;">
                                <i class="fa fa-calculator me-2" title="Cálculo"/>
                                <strong>Resumen de Liquidacion</strong>
                            </div>
                            <div class="card-body">
                                <table class="table table-bordered mb-0">
                                    <tbody>
                                        <tr style="background-color: #f5f5f5;">
                                            <td class="fw-bold"><i class="fa fa-plus-circle me-2" title="Agregar"/> Total Devengos</td>
                                            <td class="text-end fw-bold" style="width: 200px;">
                                                <field name="total_devengos" widget="monetary" nolabel="1"/>
                                            </td>
                                        </tr>
                                        <tr style="background-color: #e8e8e8;">
                                            <td class="fw-bold"><i class="fa fa-shield me-2" title="Seguridad"/> Seguridad Social</td>
                                            <td class="text-end fw-bold" style="width: 200px;">
                                                <field name="total_seguridad_social" widget="monetary" nolabel="1"/>
                                            </td>
                                        </tr>
                                        <tr style="background-color: #ddd;">
                                            <td class="fw-bold"><i class="fa fa-minus-circle me-2" title="Reducir"/> Total Deducciones</td>
                                            <td class="text-end fw-bold" style="width: 200px;">
                                                <field name="total_deducciones" widget="monetary" nolabel="1"/>
                                            </td>
                                        </tr>
                                        <tr style="background-color: #333; color: #fff; font-size: 1.2em;">
                                            <td class="fw-bold"><i class="fa fa-money me-2" title="Dinero"/> NETO A PAGAR</td>
                                            <td class="text-end fw-bold" style="width: 200px;">
                                                <field name="net_amount" widget="monetary" nolabel="1"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
