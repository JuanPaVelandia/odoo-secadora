<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista Kanban Horizontal Estilizada para Días Trabajados -->
        <record id="view_hr_payslip_worked_days_kanban" model="ir.ui.view">
            <field name="name">hr.payslip.worked.days.kanban</field>
            <field name="model">hr.payslip.worked_days</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile o_kanban_dashboard" sample="1">
                    <field name="id"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="number_of_days"/>
                    <field name="number_of_hours"/>
                    <field name="is_paid"/>
                    <field name="leave_type_id"/>
                    <field name="leave_type_code"/>
                    <field name="leave_type_novelty"/>
                    <field name="is_vacation_type"/>
                    <field name="is_vacation_money"/>
                    <field name="color_kanban"/>
                    <field name="display_info"/>

                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card oe_kanban_global_click"
                                 t-att-style="'border-left: 5px solid ' + (record.color_kanban.raw_value === 10 ? '#28a745' : record.color_kanban.raw_value === 7 ? '#007bff' : record.color_kanban.raw_value === 4 ? '#ffc107' : record.color_kanban.raw_value === 3 ? '#fd7e14' : record.color_kanban.raw_value === 1 ? '#dc3545' : '#6c757d') + ';'">
                                <div class="o_kanban_card_header">
                                    <div class="o_kanban_card_header_title">
                                        <div class="o_primary">
                                            <strong><field name="code"/></strong>
                                            <t t-if="record.leave_type_code.raw_value">
                                                <span class="badge badge-info ml-2">
                                                    <field name="leave_type_code"/>
                                                </span>
                                            </t>
                                        </div>
                                        <div class="text-muted">
                                            <small><field name="name"/></small>
                                        </div>
                                    </div>
                                </div>

                                <div class="o_kanban_card_content mt-2">
                                    <div class="row">
                                        <div class="col-6">
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-calendar mr-2 text-primary"/>
                                                <div>
                                                    <div class="font-weight-bold" style="font-size: 1.5em; color: #007bff;">
                                                        <field name="number_of_days" widget="float" digits="[16,2]"/>
                                                    </div>
                                                    <div class="text-muted" style="font-size: 0.8em;">días</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-clock mr-2 text-success"/>
                                                <div>
                                                    <div class="font-weight-bold" style="font-size: 1.5em; color: #28a745;">
                                                        <field name="number_of_hours" widget="float" digits="[16,2]"/>
                                                    </div>
                                                    <div class="text-muted" style="font-size: 0.8em;">horas</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="o_kanban_card_footer mt-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <t t-if="record.is_paid.raw_value">
                                                <span class="badge badge-success">
                                                    <i class="fa fa-check-circle"/> Pagado
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge badge-danger">
                                                    <i class="fa fa-times-circle"/> No Pagado
                                                </span>
                                            </t>
                                        </div>

                                        <div>
                                            <t t-if="record.is_vacation_type.raw_value">
                                                <span class="badge badge-warning">
                                                    <i class="fa fa-plane"/> Vacación
                                                </span>
                                            </t>
                                            <t t-elif="record.is_vacation_money.raw_value">
                                                <span class="badge badge-warning">
                                                    <i class="fa fa-money"/> Vac. Dinero
                                                </span>
                                            </t>
                                        </div>
                                    </div>

                                    <!-- Información del Tipo de Ausencia -->
                                    <t t-if="record.leave_type_id.raw_value">
                                        <div class="mt-2 p-2" style="background-color: #f8f9fa; border-radius: 4px;">
                                            <div class="d-flex align-items-center">
                                                <i class="fa fa-info-circle mr-2 text-info"/>
                                                <div class="flex-grow-1">
                                                    <div class="font-weight-bold" style="font-size: 0.9em;">
                                                        <field name="leave_type_id"/>
                                                    </div>
                                                    <t t-if="record.leave_type_novelty.raw_value">
                                                        <div class="text-muted" style="font-size: 0.75em;">
                                                            PILA: <field name="leave_type_novelty"/>
                                                        </div>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Vista Lista mejorada -->
        <record id="view_hr_payslip_worked_days_list" model="ir.ui.view">
            <field name="name">hr.payslip.worked.days.list</field>
            <field name="model">hr.payslip.worked_days</field>
            <field name="arch" type="xml">
                <list string="Días Trabajados"
                      decoration-success="code == 'WORK100'"
                      decoration-info="code == 'WORK_D'"
                      decoration-warning="is_vacation_type or is_vacation_money"
                      decoration-danger="not is_paid">
                    <field name="code" string="Código"/>
                    <field name="name" string="Descripción"/>
                    <field name="number_of_days" sum="Total Días" widget="float" digits="[16,2]"/>
                    <field name="number_of_hours" sum="Total Horas" widget="float" digits="[16,2]"/>
                    <field name="is_paid" widget="boolean_toggle"/>
                    <field name="leave_type_id" optional="show"/>
                    <field name="leave_type_code" optional="hide"/>
                    <field name="leave_type_novelty" optional="hide" widget="badge"/>
                    <field name="is_vacation_type" column_invisible="1"/>
                    <field name="is_vacation_money" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Vista Formulario mejorada -->
        <record id="view_hr_payslip_worked_days_form" model="ir.ui.view">
            <field name="name">hr.payslip.worked.days.form</field>
            <field name="model">hr.payslip.worked_days</field>
            <field name="arch" type="xml">
                <form string="Línea de Días Trabajados">
                    <sheet>
                        <group>
                            <group string="Información Básica">
                                <field name="code"/>
                                <field name="name"/>
                                <field name="payslip_id" readonly="1"/>
                            </group>
                            <group string="Cantidades">
                                <field name="number_of_days" widget="float" digits="[16,2]"/>
                                <field name="number_of_hours" widget="float" digits="[16,2]"/>
                                <field name="is_paid" widget="boolean_toggle"/>
                            </group>
                        </group>

                        <group string="Tipo de Ausencia Asociado" invisible="not leave_type_id">
                            <group>
                                <field name="leave_type_id"/>
                                <field name="leave_type_code"/>
                                <field name="leave_type_novelty" widget="badge"/>
                            </group>
                            <group>
                                <field name="is_vacation_type" widget="boolean_toggle" readonly="1"/>
                                <field name="is_vacation_money" widget="boolean_toggle" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de Búsqueda -->
        <record id="view_hr_payslip_worked_days_search" model="ir.ui.view">
            <field name="name">hr.payslip.worked.days.search</field>
            <field name="model">hr.payslip.worked_days</field>
            <field name="arch" type="xml">
                <search string="Buscar Días Trabajados">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="leave_type_id"/>
                    <field name="payslip_id"/>
                    <separator/>
                    <filter string="Días Normales (WORK100)" name="filter_work100" domain="[('code','=','WORK100')]"/>
                    <filter string="Días del Período (WORK_D)" name="filter_work_d" domain="[('code','=','WORK_D')]"/>
                    <filter string="Pagados" name="filter_paid" domain="[('is_paid','=',True)]"/>
                    <filter string="No Pagados" name="filter_not_paid" domain="[('is_paid','=',False)]"/>
                    <separator/>
                    <filter string="Vacaciones" name="filter_vacation" domain="[('is_vacation_type','=',True)]"/>
                    <filter string="Vacaciones en Dinero" name="filter_vacation_money" domain="[('is_vacation_money','=',True)]"/>
                    <filter string="Con Tipo de Ausencia" name="filter_with_leave_type" domain="[('leave_type_id','!=',False)]"/>
                    <separator/>
                    <group name="group_by">
                        <filter string="Código" name="group_code" context="{'group_by':'code'}"/>
                        <filter string="Tipo de Ausencia" name="group_leave_type" context="{'group_by':'leave_type_id'}"/>
                        <filter string="Nómina" name="group_payslip" context="{'group_by':'payslip_id'}"/>
                        <filter string="Pagado" name="group_paid" context="{'group_by':'is_paid'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción para abrir la vista -->
        <record id="action_hr_payslip_worked_days" model="ir.actions.act_window">
            <field name="name">Días Trabajados</field>
            <field name="res_model">hr.payslip.worked_days</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_hr_payslip_worked_days_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay líneas de días trabajados
                </p>
                <p>
                    Las líneas de días trabajados se generan automáticamente al procesar la nómina.
                    Cada línea representa un tipo de día (normal, ausencia, vacación, etc.).
                </p>
            </field>
        </record>

        <!-- Menú (opcional) -->
        <!--
        <menuitem id="menu_hr_payslip_worked_days"
                  name="Días Trabajados"
                  parent="hr_payroll.menu_hr_payroll_root"
                  action="action_hr_payslip_worked_days"
                  sequence="25"/>
        -->
    </data>
</odoo>
