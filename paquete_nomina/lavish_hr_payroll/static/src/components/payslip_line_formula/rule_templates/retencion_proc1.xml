<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ═══════════════════════════════════════════════════════════════════════
         TEMPLATE: RETENCIÓN EN LA FUENTE - PROCEDIMIENTO 1
         Base Legal: Art. 385, 387 y 383 E.T.
         ═══════════════════════════════════════════════════════════════════════ -->

    <t t-name="lavish_hr_payroll.RuleTemplate.RetencionProc1">
        <div class="retencion-proc1-widget" style="font-family: Inter, Arial, sans-serif;">

            <!-- HEADER DEL CONCEPTO -->
            <div style="background: linear-gradient(135deg, #DC2626 0%, #991B1B 100%); color: white; padding: 16px; border-radius: 12px 12px 0 0;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i class="fa fa-percent fa-lg" style="margin-right: 10px;"></i>
                        <span style="font-size: 18px; font-weight: 700;">RETENCIÓN EN LA FUENTE</span>
                        <span style="background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 20px; font-size: 12px; margin-left: 12px;">
                            Procedimiento 1
                        </span>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 24px; font-weight: 700;">
                            <t t-esc="widget.formatValue(data.retencion, 'currency')"/>
                        </div>
                        <div style="font-size: 11px; opacity: 0.9;">Art. 385, 387, 383 E.T.</div>
                    </div>
                </div>
            </div>

            <!-- CONTENIDO PRINCIPAL -->
            <div style="background: #FFFFFF; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 12px 12px; padding: 0;">

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 1: INGRESOS LABORALES DEL MES
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #DCFCE7; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('ingresos')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #22C55E; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">1</span>
                                <span style="font-weight: 600; color: #15803D;">INGRESOS LABORALES DEL MES</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 103 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.ingresos.total, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.ingresos ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #15803D;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.ingresos" style="padding: 12px 16px; background: #F0FDF4;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #86EFAC;">
                                <td style="padding: 6px 0; color: #374151;">Salario Básico</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.ingresos.salario, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #86EFAC;">
                                <td style="padding: 6px 0; color: #374151;">Devengos Salariales</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.ingresos.devengados, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #86EFAC;">
                                <td style="padding: 6px 0; color: #374151;">Devengos No Salariales</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.ingresos.dev_no_salarial, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #DCFCE7; font-weight: 600;">
                                <td style="padding: 8px 0; color: #15803D;">TOTAL INGRESOS</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.ingresos.total, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                        <!-- Líneas de detalle -->
                        <t t-if="data.ingresos.lineas and data.ingresos.lineas.length > 0">
                            <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #86EFAC;">
                                <div style="font-size: 10px; color: #6B7280; margin-bottom: 4px;">
                                    <i class="fa fa-list"></i> Líneas incluidas (<t t-esc="data.ingresos.lineas.length"/>)
                                </div>
                                <t t-call="lavish_hr_payroll.RuleTemplate.LinesTable">
                                    <t t-set="lines" t-value="data.ingresos.lineas"/>
                                    <t t-set="color" t-value="'#22C55E'"/>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 2: INGRESOS NO CONSTITUTIVOS DE RENTA (INCR)
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #DBEAFE; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('incr')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #3B82F6; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">2</span>
                                <span style="font-weight: 600; color: #1D4ED8;">(-) INGRESOS NO CONSTITUTIVOS DE RENTA</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 55, 56 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #1D4ED8;">
                                    -<t t-esc="widget.formatValue(data.incr.total, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.incr ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #1D4ED8;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.incr" style="padding: 12px 16px; background: #EFF6FF;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Aporte Salud (4%)
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Art. 56 E.T.</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.incr.salud, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Aporte Pensión Obligatoria (4%)
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Art. 55 E.T.</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.incr.pension, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Fondo de Solidaridad
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Ley 797/2003</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.incr.solidaridad, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">Fondo de Subsistencia</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.incr.subsistencia, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #DBEAFE; font-weight: 600;">
                                <td style="padding: 8px 0; color: #1D4ED8;">TOTAL INCR</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.incr.total, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     SUBTOTAL 1
                     ═══════════════════════════════════════════════════════════════ -->
                <div style="background: #F3F4F6; padding: 12px 16px; border-bottom: 2px solid #9CA3AF;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span style="font-weight: 700; color: #374151; font-size: 14px;">SUBTOTAL 1</span>
                            <span style="font-size: 11px; color: #6B7280; margin-left: 8px;">(Ingresos - INCR)</span>
                        </div>
                        <span style="font-weight: 700; color: #374151; font-size: 16px; font-family: monospace;">
                            <t t-esc="widget.formatValue(data.subtotal_1, 'currency')"/>
                        </span>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 3: DEDUCCIONES
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #FFEDD5; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('deducciones')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #F97316; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">3</span>
                                <span style="font-weight: 600; color: #C2410C;">(-) DEDUCCIONES</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 387 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #C2410C;">
                                    -<t t-esc="widget.formatValue(data.deducciones.total, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.deducciones ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #C2410C;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.deducciones" style="padding: 12px 16px; background: #FFF7ED;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #FDBA74;">
                                <td style="padding: 6px 0; color: #374151;">
                                    <i class="fa fa-users" style="color: #F97316; margin-right: 6px;"></i>
                                    Dependientes (10% ingreso)
                                    <span style="font-size: 9px; color: #6B7280; display: block; margin-left: 20px;">
                                        Art. 387 Num. 1 E.T. | Tope: 32 UVT/mes
                                    </span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #C2410C;">
                                    <t t-esc="widget.formatValue(data.deducciones.dependientes, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #FDBA74;">
                                <td style="padding: 6px 0; color: #374151;">
                                    <i class="fa fa-medkit" style="color: #F97316; margin-right: 6px;"></i>
                                    Medicina Prepagada
                                    <span style="font-size: 9px; color: #6B7280; display: block; margin-left: 20px;">
                                        Art. 387 Num. 2 E.T. | Tope: 16 UVT/mes
                                    </span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #C2410C;">
                                    <t t-esc="widget.formatValue(data.deducciones.prepagada, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #FDBA74;">
                                <td style="padding: 6px 0; color: #374151;">
                                    <i class="fa fa-home" style="color: #F97316; margin-right: 6px;"></i>
                                    Intereses Vivienda
                                    <span style="font-size: 9px; color: #6B7280; display: block; margin-left: 20px;">
                                        Art. 119/387 Num. 3 E.T. | Tope: 100 UVT/mes
                                    </span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #C2410C;">
                                    <t t-esc="widget.formatValue(data.deducciones.vivienda, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #FFEDD5; font-weight: 600;">
                                <td style="padding: 8px 0; color: #C2410C;">TOTAL DEDUCCIONES</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #C2410C;">
                                    <t t-esc="widget.formatValue(data.deducciones.total, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 4: RENTAS EXENTAS (AFC/AVC)
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #EDE9FE; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('rentas_exentas')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #8B5CF6; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">4</span>
                                <span style="font-weight: 600; color: #7C3AED;">(-) RENTAS EXENTAS AFC/AVC</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 126-1, 126-4 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #7C3AED;">
                                    -<t t-esc="widget.formatValue(data.rentas_exentas.total, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.rentas_exentas ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #7C3AED;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.rentas_exentas" style="padding: 12px 16px; background: #F5F3FF;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #C4B5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    <i class="fa fa-bank" style="color: #8B5CF6; margin-right: 6px;"></i>
                                    Aportes AFC
                                    <span style="font-size: 9px; color: #6B7280; display: block; margin-left: 20px;">Art. 126-4 E.T.</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #7C3AED;">
                                    <t t-esc="widget.formatValue(data.rentas_exentas.afc, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #C4B5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    <i class="fa fa-line-chart" style="color: #8B5CF6; margin-right: 6px;"></i>
                                    Aportes Voluntarios Pensión (AVC)
                                    <span style="font-size: 9px; color: #6B7280; display: block; margin-left: 20px;">Art. 126-1 E.T.</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #7C3AED;">
                                    <t t-esc="widget.formatValue(data.rentas_exentas.avc, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #EDE9FE;">
                                <td colspan="2" style="padding: 8px 0;">
                                    <div class="d-flex justify-content-between" style="font-size: 11px; color: #6B7280;">
                                        <span>Límite 30%: <t t-esc="widget.formatValue(data.rentas_exentas.limite_30_pct, 'currency')"/></span>
                                        <span>Límite 3800 UVT/año: <t t-esc="widget.formatValue(data.rentas_exentas.limite_uvt, 'currency')"/></span>
                                    </div>
                                </td>
                            </tr>
                            <tr style="background: #EDE9FE; font-weight: 600;">
                                <td style="padding: 8px 0; color: #7C3AED;">TOTAL AFC/AVC (limitado)</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #7C3AED;">
                                    <t t-esc="widget.formatValue(data.rentas_exentas.total, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 5: RENTA EXENTA 25%
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #CFFAFE; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('renta_25')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #06B6D4; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">5</span>
                                <span style="font-weight: 600; color: #0891B2;">(-) RENTA EXENTA 25%</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 206 Num. 10 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #0891B2;">
                                    -<t t-esc="widget.formatValue(data.renta_25.aplicado, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.renta_25 ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #0891B2;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.renta_25" style="padding: 12px 16px; background: #ECFEFF;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #67E8F9;">
                                <td style="padding: 6px 0; color: #374151;">Base para el 25%</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #0891B2;">
                                    <t t-esc="widget.formatValue(data.renta_25.base, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #67E8F9;">
                                <td style="padding: 6px 0; color: #374151;">25% Calculado</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #0891B2;">
                                    <t t-esc="widget.formatValue(data.renta_25.calculado, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #67E8F9;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Tope (790 UVT/año = 65.83 UVT/mes)
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Ley 2277/2022</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #0891B2;">
                                    <t t-esc="widget.formatValue(data.renta_25.tope, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #CFFAFE; font-weight: 600;">
                                <td style="padding: 8px 0; color: #0891B2;">RENTA 25% APLICADA</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #0891B2;">
                                    <t t-esc="widget.formatValue(data.renta_25.aplicado, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 6: LÍMITE GLOBAL 40%
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #FEE2E2; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('limite_global')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #EF4444; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">6</span>
                                <span style="font-weight: 600; color: #DC2626;">LÍMITE GLOBAL 40%</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 336 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #DC2626;">
                                    <t t-esc="widget.formatValue(data.limite_global.aplicado, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.limite_global ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #DC2626;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.limite_global" style="padding: 12px 16px; background: #FEF2F2;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #FCA5A5;">
                                <td style="padding: 6px 0; color: #374151;">Total Beneficios (Deducciones + Rentas Exentas)</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #DC2626;">
                                    <t t-esc="widget.formatValue(data.limite_global.total_beneficios, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #FCA5A5;">
                                <td style="padding: 6px 0; color: #374151;">Límite 40% del Subtotal 1</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #DC2626;">
                                    <t t-esc="widget.formatValue(data.limite_global.limite_40_pct, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #FCA5A5;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Límite 1340 UVT/año
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Ley 2277/2022</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #DC2626;">
                                    <t t-esc="widget.formatValue(data.limite_global.limite_uvt, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #FEE2E2; font-weight: 600;">
                                <td style="padding: 8px 0; color: #DC2626;">BENEFICIOS LIMITADOS</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #DC2626;">
                                    <t t-esc="widget.formatValue(data.limite_global.aplicado, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     BASE GRAVABLE
                     ═══════════════════════════════════════════════════════════════ -->
                <div style="background: #1F2937; color: white; padding: 12px 16px; border-bottom: 2px solid #374151;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span style="font-weight: 700; font-size: 14px;">BASE GRAVABLE</span>
                            <span style="font-size: 11px; opacity: 0.7; margin-left: 8px;">(Subtotal 1 - Beneficios Limitados)</span>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-weight: 700; font-size: 18px; font-family: monospace;">
                                <t t-esc="widget.formatValue(data.base_gravable, 'currency')"/>
                            </div>
                            <div style="font-size: 11px; opacity: 0.7;">
                                <t t-esc="widget.formatValue(data.base_uvt, 'number')"/> UVT
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     PASO 7: TABLA DE RETENCIÓN (Art. 383 E.T.)
                     ═══════════════════════════════════════════════════════════════ -->
                <div class="step-section">
                    <div class="step-header" style="background: #FEF3C7; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('tabla')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #F59E0B; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">7</span>
                                <span style="font-weight: 600; color: #B45309;">TABLA DE RETENCIÓN</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 383 E.T.</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span t-if="data.rango" style="background: #F59E0B; color: white; padding: 2px 10px; border-radius: 12px; font-size: 11px;">
                                    Rango: <t t-esc="data.rango"/>
                                </span>
                                <span style="background: #B45309; color: white; padding: 2px 10px; border-radius: 12px; font-size: 11px;">
                                    Tarifa: <t t-esc="data.tarifa"/>%
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.tabla ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #B45309;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.tabla" style="padding: 12px 16px; background: #FFFBEB;">
                        <table style="width: 100%; font-size: 11px; border-collapse: collapse; border: 1px solid #FCD34D;">
                            <thead>
                                <tr style="background: #FEF3C7;">
                                    <th style="padding: 8px; border: 1px solid #FCD34D; text-align: center;">Desde UVT</th>
                                    <th style="padding: 8px; border: 1px solid #FCD34D; text-align: center;">Hasta UVT</th>
                                    <th style="padding: 8px; border: 1px solid #FCD34D; text-align: center;">Tarifa Marginal</th>
                                    <th style="padding: 8px; border: 1px solid #FCD34D; text-align: left;">Fórmula</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-att-style="data.base_uvt > 0 and data.base_uvt &lt;= 95 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;0</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">95</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">0%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D;">$0</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 95 and data.base_uvt &lt;= 150 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;95</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">150</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">19%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 95) × 19%</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 150 and data.base_uvt &lt;= 360 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;150</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">360</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">28%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 150) × 28% + 10 UVT</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 360 and data.base_uvt &lt;= 640 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;360</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">640</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">33%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 360) × 33% + 69 UVT</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 640 and data.base_uvt &lt;= 945 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;640</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">945</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">35%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 640) × 35% + 162 UVT</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 945 and data.base_uvt &lt;= 2300 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;945</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">2300</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">37%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 945) × 37% + 268 UVT</td>
                                </tr>
                                <tr t-att-style="data.base_uvt > 2300 ? 'background: #FEF3C7; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">&gt;2300</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">∞</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; text-align: center;">39%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #FCD34D; font-size: 10px;">(Base UVT - 2300) × 39% + 770 UVT</td>
                                </tr>
                            </tbody>
                        </table>
                        <div style="margin-top: 8px; font-size: 10px; color: #6B7280;">
                            <i class="fa fa-info-circle"></i> UVT vigente: <t t-esc="widget.formatValue(data.uvt, 'currency')"/>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════════
                     RESULTADO FINAL
                     ═══════════════════════════════════════════════════════════════ -->
                <div style="background: linear-gradient(135deg, #DC2626 0%, #991B1B 100%); color: white; padding: 16px; border-radius: 0 0 12px 12px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fa fa-check-circle fa-lg" style="margin-right: 10px;"></i>
                            <span style="font-size: 16px; font-weight: 700;">RETENCIÓN A PRACTICAR</span>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 28px; font-weight: 700; font-family: monospace;">
                                <t t-esc="widget.formatValue(data.retencion, 'currency')"/>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SUB-TEMPLATE: TABLA DE LÍNEAS DE DETALLE
         ═══════════════════════════════════════════════════════════════════════ -->
    <t t-name="lavish_hr_payroll.RuleTemplate.LinesTable">
        <div style="overflow-x: auto;">
            <table style="width: 100%; font-size: 10px; border-collapse: collapse;">
                <thead>
                    <tr style="background: rgba(0,0,0,0.05);">
                        <th style="padding: 4px 6px; text-align: center; border-bottom: 1px solid rgba(0,0,0,0.1);">ID</th>
                        <th style="padding: 4px 6px; text-align: left; border-bottom: 1px solid rgba(0,0,0,0.1);">Código</th>
                        <th style="padding: 4px 6px; text-align: left; border-bottom: 1px solid rgba(0,0,0,0.1);">Concepto</th>
                        <th style="padding: 4px 6px; text-align: right; border-bottom: 1px solid rgba(0,0,0,0.1);">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="lines" t-as="ln" t-key="ln.id || ln_index">
                        <tr>
                            <td style="padding: 4px 6px; text-align: center;">
                                <span t-att-style="'background: ' + (color || '#3B82F6') + '; color: white; padding: 1px 6px; border-radius: 4px; cursor: pointer;'"
                                      t-on-click="() => widget.openPayslipLine(ln.id)">
                                    <t t-esc="ln.id"/>
                                </span>
                            </td>
                            <td style="padding: 4px 6px; font-family: monospace;">
                                <t t-esc="ln.code"/>
                            </td>
                            <td style="padding: 4px 6px;">
                                <t t-esc="ln.name"/>
                            </td>
                            <td style="padding: 4px 6px; text-align: right; font-family: monospace;">
                                <t t-esc="widget.formatValue(ln.total, 'currency')"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>

</templates>
