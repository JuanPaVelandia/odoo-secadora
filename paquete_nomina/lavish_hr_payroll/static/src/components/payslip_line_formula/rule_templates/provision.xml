<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- =======================================================================
         TEMPLATE: PROVISION INDIVIDUAL
         Vista simplificada: KPI principal + reglas relacionadas
         Base Legal: Art. 249, 306 C.S.T., Ley 52/1975
         ======================================================================= -->

    <t t-name="lavish_hr_payroll.RuleTemplate.Provision">
        <div class="provision-widget" style="font-family: Inter, Arial, sans-serif;">

            <!-- HEADER con color dinamico segun tipo -->
            <div t-att-style="'background: linear-gradient(135deg, ' + data.color_theme + ' 0%, ' + data.color_theme + 'DD 100%); color: white; padding: 16px; border-radius: 12px 12px 0 0;'">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i t-att-class="'fa ' + data.icon_class + ' fa-lg'" style="margin-right: 10px;"></i>
                        <span style="font-size: 18px; font-weight: 700;">
                            PROVISION <t t-esc="data.tipo_provision"/>
                        </span>
                        <t t-if="data.periodo">
                            <span style="background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 20px; font-size: 12px; margin-left: 12px;">
                                <t t-esc="data.periodo"/>
                            </span>
                        </t>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 24px; font-weight: 700; font-family: monospace;">
                            <t t-esc="widget.formatValue(data.total_provision, 'currency')"/>
                        </div>
                        <div style="font-size: 11px; opacity: 0.9;">
                            <t t-esc="data.tasa"/>% de la base
                        </div>
                    </div>
                </div>
            </div>

            <!-- CONTENIDO -->
            <div style="background: #FFFFFF; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 12px 12px;">

                <!-- FORMULA DE CALCULO - Base x Cantidad x Porcentaje -->
                <div style="padding: 16px; border-bottom: 1px solid #E5E7EB;">
                    <!-- Formula visual principal -->
                    <div style="background: #F8FAFC; border: 2px solid #E2E8F0; border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                        <div style="font-size: 11px; text-transform: uppercase; font-weight: 600; color: #64748B; margin-bottom: 12px; text-align: center;">
                            <i class="fa fa-calculator" style="margin-right: 6px;"></i>
                            Formula de Calculo
                        </div>
                        <div class="d-flex justify-content-center align-items-center flex-wrap gap-2" style="font-family: monospace;">
                            <!-- Base -->
                            <div style="background: #F0FDF4; border: 1px solid #86EFAC; border-radius: 8px; padding: 10px 16px; text-align: center;">
                                <div style="font-size: 9px; text-transform: uppercase; color: #6B7280; margin-bottom: 2px;">Base</div>
                                <div style="font-size: 16px; font-weight: 700; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.base_mensual, 'currency')"/>
                                </div>
                            </div>
                            <!-- Multiplicador -->
                            <div style="font-size: 20px; font-weight: 700; color: #64748B;">x</div>
                            <!-- Cantidad -->
                            <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: 8px; padding: 10px 16px; text-align: center;">
                                <div style="font-size: 9px; text-transform: uppercase; color: #6B7280; margin-bottom: 2px;">Cantidad</div>
                                <div style="font-size: 16px; font-weight: 700; color: #1D4ED8;">1</div>
                            </div>
                            <!-- Multiplicador -->
                            <div style="font-size: 20px; font-weight: 700; color: #64748B;">x</div>
                            <!-- Porcentaje -->
                            <div t-att-style="'background: ' + data.color_theme + '15; border: 1px solid ' + data.color_theme + '40; border-radius: 8px; padding: 10px 16px; text-align: center;'">
                                <div style="font-size: 9px; text-transform: uppercase; color: #6B7280; margin-bottom: 2px;">Porcentaje</div>
                                <div t-att-style="'font-size: 16px; font-weight: 700; color: ' + data.color_theme + ';'">
                                    <t t-esc="data.tasa"/>%
                                </div>
                            </div>
                            <!-- Igual -->
                            <div style="font-size: 20px; font-weight: 700; color: #64748B;">=</div>
                            <!-- Resultado -->
                            <div t-att-style="'background: ' + data.color_theme + '; border-radius: 8px; padding: 10px 16px; text-align: center;'">
                                <div style="font-size: 9px; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 2px;">Total</div>
                                <div style="font-size: 16px; font-weight: 700; color: white;">
                                    <t t-esc="widget.formatValue(data.total_provision, 'currency')"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Detalle de componentes en grid -->
                    <div class="row g-3">
                        <!-- Base de Calculo -->
                        <div class="col-6 col-md-3">
                            <div style="background: #F0FDF4; border: 1px solid #86EFAC; border-radius: 8px; padding: 12px; text-align: center;">
                                <div style="font-size: 10px; text-transform: uppercase; font-weight: 600; color: #6B7280; margin-bottom: 4px;">
                                    <i class="fa fa-money" style="color: #22C55E; margin-right: 4px;"></i>
                                    <t t-esc="data.base_field_label"/>
                                </div>
                                <div style="font-size: 14px; font-weight: 700; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(data.base_mensual, 'currency')"/>
                                </div>
                            </div>
                        </div>
                        <!-- Dias -->
                        <div class="col-6 col-md-3">
                            <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: 8px; padding: 12px; text-align: center;">
                                <div style="font-size: 10px; text-transform: uppercase; font-weight: 600; color: #6B7280; margin-bottom: 4px;">
                                    <i class="fa fa-calendar" style="color: #3B82F6; margin-right: 4px;"></i>
                                    Dias
                                </div>
                                <div style="font-size: 14px; font-weight: 700; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="data.dias_trabajados"/>
                                </div>
                            </div>
                        </div>
                        <!-- Tasa -->
                        <div class="col-6 col-md-3">
                            <div t-att-style="'background: ' + data.color_theme + '10; border: 1px solid ' + data.color_theme + '40; border-radius: 8px; padding: 12px; text-align: center;'">
                                <div style="font-size: 10px; text-transform: uppercase; font-weight: 600; color: #6B7280; margin-bottom: 4px;">
                                    <i class="fa fa-percent" t-att-style="'color: ' + data.color_theme + '; margin-right: 4px;'"></i>
                                    Tasa
                                </div>
                                <div t-att-style="'font-size: 14px; font-weight: 700; font-family: monospace; color: ' + data.color_theme + ';'">
                                    <t t-esc="data.tasa"/>%
                                </div>
                            </div>
                        </div>
                        <!-- Resultado -->
                        <div class="col-6 col-md-3">
                            <div t-att-style="'background: ' + data.color_theme + '; border-radius: 8px; padding: 12px; text-align: center;'">
                                <div style="font-size: 10px; text-transform: uppercase; font-weight: 600; color: rgba(255,255,255,0.8); margin-bottom: 4px;">
                                    <i class="fa fa-check-circle" style="margin-right: 4px;"></i>
                                    Provision
                                </div>
                                <div style="font-size: 14px; font-weight: 700; font-family: monospace; color: white;">
                                    <t t-esc="widget.formatValue(data.total_provision, 'currency')"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- REGLAS RELACIONADAS (trazabilidad) - Siempre visible -->
                <t t-if="data.reglas_relacionadas and data.reglas_relacionadas.length > 0">
                    <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                        <div class="step-header" style="background: #DBEAFE; padding: 10px 16px; cursor: pointer;"
                             t-on-click="() => widget.toggleSection('relacionadas')">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span style="background: #3B82F6; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">
                                        <i class="fa fa-link"></i>
                                    </span>
                                    <span style="font-weight: 600; color: #1D4ED8;">REGLAS RELACIONADAS</span>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span style="background: #3B82F6; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px;">
                                        <t t-esc="data.reglas_relacionadas.length"/>
                                    </span>
                                    <i t-att-class="'fa ' + (widget.state.expandedSections.relacionadas ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #1D4ED8;"></i>
                                </div>
                            </div>
                        </div>
                        <div t-if="widget.state.expandedSections.relacionadas" style="padding: 12px 16px; background: #EFF6FF;">
                            <div class="d-flex flex-wrap gap-2">
                                <t t-foreach="data.reglas_relacionadas" t-as="regla" t-key="regla.id">
                                    <div style="background: white; border: 1px solid #93C5FD; border-radius: 6px; padding: 8px 12px; font-size: 11px; cursor: pointer;"
                                         t-on-click="() => widget.openPayslipLine(regla.id)">
                                        <div style="font-weight: 600; color: #1D4ED8;">
                                            <span style="font-family: monospace; background: #DBEAFE; padding: 2px 6px; border-radius: 4px; margin-right: 6px;">
                                                <t t-esc="regla.code"/>
                                            </span>
                                            <t t-esc="regla.name"/>
                                        </div>
                                        <div style="color: #6B7280; margin-top: 2px;">
                                            Monto: <span style="font-family: monospace; font-weight: 600; color: #22C55E;">
                                                <t t-esc="widget.formatValue(regla.total, 'currency')"/>
                                            </span>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>

                <t t-if="false">
                    <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                        <div class="step-header" t-att-style="'background: ' + data.color_theme + '15; padding: 10px 16px; cursor: pointer;'"
                             t-on-click="() => widget.toggleSection('calculo')">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span t-att-style="'background: ' + data.color_theme + '; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;'">
                                        <i class="fa fa-calculator"></i>
                                    </span>
                                    <span style="font-weight: 600; color: #1F2937;">DETALLE DEL CALCULO</span>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span t-att-style="'color: ' + data.color_theme + '; font-size: 12px;'">
                                        <t t-esc="data.pasos_calculo.length"/> pasos
                                    </span>
                                    <i t-att-class="'fa ' + (widget.state.expandedSections.calculo ? 'fa-chevron-up' : 'fa-chevron-down')" t-att-style="'color: ' + data.color_theme + ';'"></i>
                                </div>
                            </div>
                        </div>
                        <div t-if="widget.state.expandedSections.calculo" style="padding: 16px; background: #FAFAFA;">
                            <t t-foreach="data.pasos_calculo" t-as="paso" t-key="paso.numero">
                                <div t-att-style="'background: white; border: 1px solid #E5E7EB; border-radius: 8px; padding: 12px; margin-bottom: 8px;' + (paso.esResultado ? 'border-color: ' + data.color_theme + '; border-width: 2px;' : '')">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span t-att-style="'background: ' + (paso.esResultado ? data.color_theme : '#6B7280') + '; color: white; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600;'">
                                                    <t t-esc="paso.numero"/>
                                                </span>
                                                <span style="font-weight: 600; color: #1F2937;"><t t-esc="paso.titulo"/></span>
                                            </div>
                                            <div style="font-size: 11px; color: #6B7280; margin-top: 4px; margin-left: 32px;">
                                                <t t-esc="paso.descripcion"/>
                                            </div>
                                            <t t-if="paso.desglose">
                                                <div style="margin-left: 32px; margin-top: 8px; font-size: 11px;">
                                                    <t t-foreach="paso.desglose" t-as="item" t-key="item.label">
                                                        <div class="d-flex justify-content-between" style="padding: 2px 0; color: #6B7280;">
                                                            <span><t t-esc="item.label"/></span>
                                                            <span style="font-family: monospace;"><t t-esc="widget.formatValue(item.valor, 'currency')"/></span>
                                                        </div>
                                                    </t>
                                                </div>
                                            </t>
                                        </div>
                                        <div t-att-style="'text-align: right; font-family: monospace; font-weight: 700; font-size: 14px; color: ' + (paso.esResultado ? data.color_theme : '#1F2937') + ';'">
                                            <t t-if="paso.formato === 'currency'" t-esc="widget.formatValue(paso.valor, 'currency')"/>
                                            <t t-elif="paso.formato === 'percent'"><t t-esc="paso.valor"/>%</t>
                                            <t t-else=""><t t-esc="paso.valor"/></t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- NOTA LEGAL -->
                <div style="padding: 12px 16px; background: #F9FAFB;">
                    <div style="font-size: 11px; color: #6B7280;">
                        <i class="fa fa-gavel" style="margin-right: 6px;"></i>
                        <strong><t t-esc="data.base_legal"/>:</strong>
                        <t t-esc="data.formula_calculo"/>
                    </div>
                </div>

            </div>
        </div>
    </t>

</templates>
