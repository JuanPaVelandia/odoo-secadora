<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ═══════════════════════════════════════════════════════════════════════
         TEMPLATE: SEGURIDAD SOCIAL - APORTES EMPLEADO
         Base Legal: Ley 100/1993, Ley 1393/2010
         ═══════════════════════════════════════════════════════════════════════ -->

    <t t-name="lavish_hr_payroll.RuleTemplate.SeguridadSocial">
        <div class="seguridad-social-widget" style="font-family: Inter, Arial, sans-serif;">

            <!-- HEADER DINÁMICO POR TIPO -->
            <div t-att-style="'background: linear-gradient(135deg, ' + ruleConfig.colorStart + ' 0%, ' + ruleConfig.colorEnd + ' 100%); color: white; padding: 16px; border-radius: 12px 12px 0 0;'">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i t-att-class="'fa ' + ruleConfig.icon + ' fa-lg'" style="margin-right: 10px;"></i>
                        <span style="font-size: 18px; font-weight: 700;"><t t-esc="ruleConfig.title"/></span>
                        <span style="background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 20px; font-size: 12px; margin-left: 12px;">
                            Aporte Empleado
                        </span>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 24px; font-weight: 700;">
                            <t t-esc="widget.formatValue(Math.abs(data.aporte), 'currency')"/>
                        </div>
                        <div style="font-size: 11px; opacity: 0.9;"><t t-esc="ruleConfig.baseLegal"/></div>
                    </div>
                </div>
            </div>

            <!-- CONTENIDO -->
            <div style="background: #FFFFFF; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 12px 12px;">

                <!-- PASO 1: IBC -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #DBEAFE; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('ibc')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #3B82F6; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">1</span>
                                <span style="font-weight: 600; color: #1D4ED8;">INGRESO BASE DE COTIZACIÓN (IBC)</span>
                                <span style="font-size: 10px; color: #6B7280; margin-left: 8px;">Art. 18 Ley 100/1993</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span style="font-weight: 600; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.ibc, 'currency')"/>
                                </span>
                                <i t-att-class="'fa ' + (widget.state.expandedSections.ibc ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #1D4ED8;"></i>
                            </div>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.ibc" style="padding: 12px 16px; background: #EFF6FF;">
                        <table style="width: 100%; font-size: 12px; border-collapse: collapse;">
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">Total Devengos Salariales</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.devengos_salariales, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">
                                    Pagos No Salariales
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Art. 128 C.S.T.</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.pagos_no_salariales, 'currency')"/>
                                </td>
                            </tr>
                            <tr t-if="data.excedente_40 > 0" style="border-bottom: 1px dashed #93C5FD; background: #FEF3C7;">
                                <td style="padding: 6px 0; color: #B45309;">
                                    <i class="fa fa-exclamation-triangle"></i>
                                    (+) Excedente Ley 1393
                                    <span style="font-size: 9px; color: #6B7280; display: block;">Excede 40% del total remunerado</span>
                                </td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #B45309;">
                                    <t t-esc="widget.formatValue(data.excedente_40, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px dashed #93C5FD;">
                                <td style="padding: 6px 0; color: #374151;">(-) Descuento Ausencias</td>
                                <td style="padding: 6px 0; text-align: right; font-family: monospace; color: #DC2626;">
                                    -<t t-esc="widget.formatValue(data.descuento_ausencias, 'currency')"/>
                                </td>
                            </tr>
                            <tr style="background: #DBEAFE; font-weight: 600;">
                                <td style="padding: 8px 0; color: #1D4ED8;">IBC FINAL</td>
                                <td style="padding: 8px 0; text-align: right; font-family: monospace; color: #1D4ED8;">
                                    <t t-esc="widget.formatValue(data.ibc, 'currency')"/>
                                </td>
                            </tr>
                        </table>
                        <!-- Validación de topes -->
                        <div style="margin-top: 8px; padding: 8px; background: #F3F4F6; border-radius: 6px; font-size: 11px;">
                            <div class="d-flex justify-content-between">
                                <span style="color: #6B7280;">Mínimo (1 SMMLV):</span>
                                <span t-att-style="data.ibc &lt; data.smmlv ? 'color: #DC2626; font-weight: 600;' : 'color: #374151;'">
                                    <t t-esc="widget.formatValue(data.smmlv, 'currency')"/>
                                    <t t-if="data.ibc &lt; data.smmlv"> <i class="fa fa-arrow-up"></i> Ajustado</t>
                                </span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span style="color: #6B7280;">Máximo (25 SMMLV):</span>
                                <span t-att-style="data.ibc &gt; data.tope_25_smmlv ? 'color: #DC2626; font-weight: 600;' : 'color: #374151;'">
                                    <t t-esc="widget.formatValue(data.tope_25_smmlv, 'currency')"/>
                                    <t t-if="data.ibc &gt; data.tope_25_smmlv"> <i class="fa fa-arrow-down"></i> Ajustado</t>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PASO 2: TARIFA -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #DCFCE7; padding: 10px 16px;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #22C55E; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">2</span>
                                <span style="font-weight: 600; color: #15803D;">TARIFA APLICADA</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span style="background: #22C55E; color: white; padding: 4px 16px; border-radius: 20px; font-weight: 700; font-size: 16px;">
                                    <t t-esc="data.tarifa"/>%
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- DISTRIBUCIÓN EMPLEADO/EMPLEADOR (si aplica) -->
                <div t-if="data.tarifa_empleador" class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #F3F4F6; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('distribucion')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="background: #6B7280; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-right: 8px;">3</span>
                                <span style="font-weight: 600; color: #374151;">DISTRIBUCIÓN DEL APORTE</span>
                            </div>
                            <i t-att-class="'fa ' + (widget.state.expandedSections.distribucion ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #6B7280;"></i>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.distribucion" style="padding: 12px 16px;">
                        <div class="row g-2">
                            <div class="col-6">
                                <div style="background: #DBEAFE; border-radius: 8px; padding: 12px; text-align: center;">
                                    <div style="font-size: 10px; color: #1D4ED8; text-transform: uppercase;">Empleado</div>
                                    <div style="font-size: 18px; font-weight: 700; color: #1D4ED8;">
                                        <t t-esc="data.tarifa"/>%
                                    </div>
                                    <div style="font-size: 12px; color: #1D4ED8; font-family: monospace;">
                                        <t t-esc="widget.formatValue(data.aporte, 'currency')"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="background: #DCFCE7; border-radius: 8px; padding: 12px; text-align: center;">
                                    <div style="font-size: 10px; color: #15803D; text-transform: uppercase;">Empleador</div>
                                    <div style="font-size: 18px; font-weight: 700; color: #15803D;">
                                        <t t-esc="data.tarifa_empleador"/>%
                                    </div>
                                    <div style="font-size: 12px; color: #15803D; font-family: monospace;">
                                        <t t-esc="widget.formatValue(data.aporte_empleador, 'currency')"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div style="margin-top: 8px; text-align: center; font-size: 11px; color: #6B7280;">
                            Total aporte: <strong><t t-esc="widget.formatValue(data.aporte_total, 'currency')"/></strong>
                            (<t t-esc="data.tarifa_total"/>%)
                        </div>
                    </div>
                </div>

                <!-- FÓRMULA -->
                <div style="padding: 16px; background: #F9FAFB; border-bottom: 1px solid #E5E7EB;">
                    <div style="background: white; border: 2px solid #E5E7EB; border-radius: 10px; padding: 12px; text-align: center;">
                        <div style="font-size: 11px; color: #6B7280; margin-bottom: 4px;">FÓRMULA</div>
                        <div style="font-size: 16px; font-family: monospace; color: #374151;">
                            Aporte = <span style="color: #3B82F6;">IBC</span> × <span style="color: #22C55E;">Tarifa%</span>
                        </div>
                        <div style="margin-top: 8px; font-size: 14px; font-family: monospace; color: #374151;">
                            <t t-esc="widget.formatValue(data.ibc, 'currency')"/> × <t t-esc="data.tarifa"/>% = <strong><t t-esc="widget.formatValue(Math.abs(data.aporte), 'currency')"/></strong>
                        </div>
                    </div>
                </div>

                <!-- INFORMACIÓN ADICIONAL FSP -->
                <t t-if="ruleConfig.showFSP and data.fsp_adicional > 0">
                    <div style="padding: 12px 16px; background: #FEF3C7; border-bottom: 1px solid #E5E7EB;">
                        <div style="font-size: 12px; color: #B45309;">
                            <i class="fa fa-info-circle"></i>
                            <strong>Fondo de Solidaridad Pensional Adicional</strong>
                        </div>
                        <div style="font-size: 11px; color: #92400E; margin-top: 4px;">
                            Por devengar más de 16 SMMLV, aplica aporte adicional del <t t-esc="data.fsp_porcentaje_adicional"/>%
                        </div>
                        <div style="font-size: 14px; color: #B45309; font-weight: 600; margin-top: 4px;">
                            Aporte adicional: <t t-esc="widget.formatValue(data.fsp_adicional, 'currency')"/>
                        </div>
                    </div>
                </t>

                <!-- RESULTADO -->
                <div t-att-style="'background: linear-gradient(135deg, ' + ruleConfig.colorStart + ' 0%, ' + ruleConfig.colorEnd + ' 100%); color: white; padding: 16px; border-radius: 0 0 12px 12px;'">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fa fa-check-circle fa-lg" style="margin-right: 10px;"></i>
                            <span style="font-size: 16px; font-weight: 700;">APORTE A DESCONTAR</span>
                        </div>
                        <div style="font-size: 28px; font-weight: 700; font-family: monospace;">
                            <t t-esc="widget.formatValue(Math.abs(data.aporte), 'currency')"/>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════════════
         TEMPLATE: FSP - FONDO DE SOLIDARIDAD PENSIONAL
         Base Legal: Art. 27 Ley 100/1993, Ley 797/2003
         ═══════════════════════════════════════════════════════════════════════ -->

    <t t-name="lavish_hr_payroll.RuleTemplate.FSP">
        <div class="fsp-widget" style="font-family: Inter, Arial, sans-serif;">

            <!-- HEADER -->
            <div style="background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); color: white; padding: 16px; border-radius: 12px 12px 0 0;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i class="fa fa-hand-holding-heart fa-lg" style="margin-right: 10px;"></i>
                        <span style="font-size: 18px; font-weight: 700;">FONDO DE SOLIDARIDAD PENSIONAL</span>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 24px; font-weight: 700;">
                            <t t-esc="widget.formatValue(Math.abs(data.aporte_total), 'currency')"/>
                        </div>
                        <div style="font-size: 11px; opacity: 0.9;">Ley 797/2003</div>
                    </div>
                </div>
            </div>

            <!-- CONTENIDO -->
            <div style="background: #FFFFFF; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 12px 12px;">

                <!-- RANGO IBC -->
                <div style="padding: 16px; background: #F5F3FF; border-bottom: 1px solid #E5E7EB;">
                    <div style="font-size: 12px; color: #6B7280; margin-bottom: 8px;">IBC en SMMLV:</div>
                    <div class="d-flex align-items-center gap-3">
                        <span style="font-size: 24px; font-weight: 700; color: #7C3AED;">
                            <t t-esc="data.ibc_smmlv"/> SMMLV
                        </span>
                        <span style="background: #8B5CF6; color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px;">
                            <t t-esc="widget.formatValue(data.ibc, 'currency')"/>
                        </span>
                    </div>
                </div>

                <!-- TABLA DE TARIFAS FSP -->
                <div class="step-section" style="border-bottom: 1px solid #E5E7EB;">
                    <div class="step-header" style="background: #EDE9FE; padding: 10px 16px; cursor: pointer;"
                         t-on-click="() => widget.toggleSection('tabla_fsp')">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span style="font-weight: 600; color: #7C3AED;">
                                    <i class="fa fa-table"></i> TABLA DE TARIFAS FSP
                                </span>
                            </div>
                            <i t-att-class="'fa ' + (widget.state.expandedSections.tabla_fsp ? 'fa-chevron-up' : 'fa-chevron-down')" style="color: #7C3AED;"></i>
                        </div>
                    </div>
                    <div t-if="widget.state.expandedSections.tabla_fsp" style="padding: 12px 16px;">
                        <table style="width: 100%; font-size: 11px; border-collapse: collapse; border: 1px solid #C4B5FD;">
                            <thead>
                                <tr style="background: #EDE9FE;">
                                    <th style="padding: 8px; border: 1px solid #C4B5FD; text-align: center;">Rango IBC</th>
                                    <th style="padding: 8px; border: 1px solid #C4B5FD; text-align: center;">Solidaridad</th>
                                    <th style="padding: 8px; border: 1px solid #C4B5FD; text-align: center;">Subsistencia</th>
                                    <th style="padding: 8px; border: 1px solid #C4B5FD; text-align: center;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-att-style="data.ibc_smmlv &gt;= 4 and data.ibc_smmlv &lt; 16 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">4 - 16 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">0%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                </tr>
                                <tr t-att-style="data.ibc_smmlv &gt;= 16 and data.ibc_smmlv &lt; 17 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">16 - 17 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">0.2%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1.2%</td>
                                </tr>
                                <tr t-att-style="data.ibc_smmlv &gt;= 17 and data.ibc_smmlv &lt; 18 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">17 - 18 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">0.4%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1.4%</td>
                                </tr>
                                <tr t-att-style="data.ibc_smmlv &gt;= 18 and data.ibc_smmlv &lt; 19 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">18 - 19 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">0.6%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1.6%</td>
                                </tr>
                                <tr t-att-style="data.ibc_smmlv &gt;= 19 and data.ibc_smmlv &lt; 20 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">19 - 20 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">0.8%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1.8%</td>
                                </tr>
                                <tr t-att-style="data.ibc_smmlv &gt;= 20 ? 'background: #F5F3FF; font-weight: 600;' : ''">
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD;">&gt;20 SMMLV</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">1%</td>
                                    <td style="padding: 6px 8px; border: 1px solid #C4B5FD; text-align: center;">2%</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- DESGLOSE -->
                <div style="padding: 16px;">
                    <div class="row g-2">
                        <div class="col-6">
                            <div style="background: #EDE9FE; border-radius: 8px; padding: 12px;">
                                <div style="font-size: 10px; color: #7C3AED; text-transform: uppercase;">Fondo Solidaridad</div>
                                <div style="font-size: 11px; color: #6B7280;">SSOCIAL003</div>
                                <div style="font-size: 18px; font-weight: 700; color: #7C3AED;">
                                    <t t-esc="widget.formatValue(data.aporte_solidaridad, 'currency')"/>
                                </div>
                                <div style="font-size: 11px; color: #6B7280;"><t t-esc="data.tarifa_solidaridad"/>%</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="background: #FEF3C7; border-radius: 8px; padding: 12px;">
                                <div style="font-size: 10px; color: #B45309; text-transform: uppercase;">Fondo Subsistencia</div>
                                <div style="font-size: 11px; color: #6B7280;">SSOCIAL004</div>
                                <div style="font-size: 18px; font-weight: 700; color: #B45309;">
                                    <t t-esc="widget.formatValue(data.aporte_subsistencia, 'currency')"/>
                                </div>
                                <div style="font-size: 11px; color: #6B7280;"><t t-esc="data.tarifa_subsistencia"/>%</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESULTADO -->
                <div style="background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); color: white; padding: 16px; border-radius: 0 0 12px 12px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fa fa-check-circle fa-lg" style="margin-right: 10px;"></i>
                            <span style="font-size: 16px; font-weight: 700;">TOTAL FSP</span>
                        </div>
                        <div style="font-size: 28px; font-weight: 700; font-family: monospace;">
                            <t t-esc="widget.formatValue(Math.abs(data.aporte_total), 'currency')"/>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>

</templates>
