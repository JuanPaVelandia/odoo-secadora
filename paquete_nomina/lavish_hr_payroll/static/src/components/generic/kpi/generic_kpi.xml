<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.GenericKPI">
        <div
            t-att-class="'generic-kpi ' + sizeClass + (isClickable ? ' generic-kpi--clickable' : '')"
            t-att-style="containerStyle"
            t-on-click="isClickable ? handleClick : null"
            t-att-title="props.helpText || ''"
        >
            <!-- Icono -->
            <div class="generic-kpi__icon-container">
                <t t-if="props.iconType === 'lottie'">
                    <!-- TODO: Integrar LottieIcon cuando sea necesario -->
                    <div class="generic-kpi__icon-placeholder">
                        <i class="fa fa-chart-line" t-att-style="iconStyle"/>
                    </div>
                </t>
                <t t-else="">
                    <i t-att-class="iconClass" t-att-style="iconStyle"/>
                </t>
            </div>

            <!-- Contenido -->
            <div class="generic-kpi__content">
                <!-- Label -->
                <div class="generic-kpi__label">
                    <t t-esc="props.label"/>
                </div>

                <!-- Valor -->
                <div class="generic-kpi__value">
                    <t t-esc="formattedValue"/>
                </div>

                <!-- Tendencia (opcional) -->
                <div t-if="props.trend" t-att-class="'generic-kpi__trend ' + trendClass">
                    <i t-att-class="trendIcon"/>
                    <span class="generic-kpi__trend-value">
                        <t t-esc="trendValue"/>
                    </span>
                </div>
            </div>
        </div>
    </t>

</templates>
