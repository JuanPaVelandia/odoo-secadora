<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Template Principal -->
    <t t-name="lavish_hr_payroll.GenericHierarchicalTable">
        <div class="generic-hierarchical-table">
            <!-- Header con título y búsqueda -->
            <div t-if="props.title or props.searchable" class="generic-table__header">
                <h5 t-if="props.title" class="generic-table__title">
                    <t t-esc="props.title"/>
                </h5>

                <div t-if="props.searchable" class="generic-table__search">
                    <i class="fa fa-search generic-table__search-icon"/>
                    <input
                        type="text"
                        class="form-control form-control-sm"
                        placeholder="Buscar..."
                        t-model="state.searchTerm"
                        t-on-input="onSearchChange"
                    />
                </div>
            </div>

            <!-- Tabla -->
            <div class="generic-table__container">
                <table class="table table-sm table-hover mb-0">
                    <!-- Encabezados de columnas -->
                    <thead class="generic-table__thead">
                        <tr>
                            <th class="generic-table__expand-col"></th>
                            <t t-foreach="props.config.columns" t-as="column" t-key="column.key">
                                <th
                                    t-att-style="column.width ? 'width: ' + column.width : ''"
                                    t-att-title="column.helpText || ''"
                                >
                                    <t t-esc="column.label"/>
                                </th>
                            </t>
                        </tr>
                    </thead>

                    <!-- Cuerpo de la tabla -->
                    <tbody class="generic-table__tbody">
                        <t t-call="lavish_hr_payroll.GenericHierarchicalTable.Rows">
                            <t t-set="nodes" t-value="filteredData"/>
                            <t t-set="level" t-value="0"/>
                        </t>
                    </tbody>
                </table>

                <!-- Mensaje si no hay datos -->
                <div t-if="filteredData.length === 0" class="generic-table__empty">
                    <i class="fa fa-inbox fa-3x text-muted mb-3"/>
                    <p class="text-muted">
                        <t t-if="state.searchTerm">
                            No se encontraron resultados para "<t t-esc="state.searchTerm"/>"
                        </t>
                        <t t-else="">
                            No hay datos para mostrar
                        </t>
                    </p>
                </div>
            </div>
        </div>
    </t>

    <!-- Template Recursivo para Filas -->
    <t t-name="lavish_hr_payroll.GenericHierarchicalTable.Rows">
        <t t-foreach="nodes" t-as="node" t-key="node.id">
            <!-- Fila del nodo -->
            <tr
                t-att-class="getRowClass(node)"
                t-att-style="getRowStyle(node)"
                t-on-click="() => handleRowClick(node)"
            >
                <!-- Columna de expansión -->
                <td class="generic-table__expand-col">
                    <t t-if="isExpandable(node)">
                        <button
                            class="btn btn-sm btn-link p-0 generic-table__expand-btn"
                            t-on-click.stop="() => toggleExpanded(node.id)"
                            t-att-style="'padding-left: ' + getIndentPadding(node)"
                        >
                            <i t-att-class="'fa ' + getExpandIcon(node.id)"/>
                        </button>
                    </t>
                    <t t-else="">
                        <span t-att-style="'padding-left: ' + getIndentPadding(node)" class="generic-table__indent"/>
                    </t>
                </td>

                <!-- Columnas de datos -->
                <t t-foreach="props.config.columns" t-as="column" t-key="column_index">
                    <td
                        t-att-class="'generic-table__cell generic-table__cell--' + column.key"
                        t-att-style="getCellStyle(node, column)"
                    >
                        <!-- Primera columna incluye icono si existe -->
                        <t t-if="column_index === 0 and node.icon">
                            <i t-att-class="'fa ' + node.icon + ' me-2'" t-att-style="'color: ' + (node.color || '#9E9E9E')"/>
                        </t>

                        <!-- Tipo: Link -->
                        <t t-if="isLinkColumn(column)">
                            <a
                                t-if="getFieldValue(node, column.key)"
                                t-att-href="getLinkUrl(node, column)"
                                target="_blank"
                                class="generic-table__link"
                                t-on-click.stop=""
                            >
                                <t t-esc="formatCellValue(node, column)"/>
                                <i class="fa fa-external-link-alt ms-1 small"/>
                            </a>
                        </t>

                        <!-- Tipo: Badge -->
                        <t t-elif="isBadgeColumn(column)">
                            <span class="badge badge-sm" t-att-style="getCellStyle(node, column)">
                                <t t-esc="formatCellValue(node, column)"/>
                            </span>
                        </t>

                        <!-- Tipo: Normal -->
                        <t t-else="">
                            <t t-esc="formatCellValue(node, column)"/>
                        </t>
                    </td>
                </t>
            </tr>

            <!-- Filas hijas (recursivo) -->
            <t t-if="isExpanded(node.id) and node.children and node.children.length > 0">
                <t t-call="lavish_hr_payroll.GenericHierarchicalTable.Rows">
                    <t t-set="nodes" t-value="node.children"/>
                    <t t-set="level" t-value="level + 1"/>
                </t>
            </t>
        </t>
    </t>

</templates>
