<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ═════════════════════════════════════════════════════════════════════
         SECCION: TRAZABILIDAD Y COMPARACION TEMPORAL
         Para agregar a payslip_line_formula.xml
         ══════════════════════════════════════════════════════════════════════ -->

    <t t-name="lavish_hr_payroll.TrazabilidadSection">
        <!-- Solo mostrar si hay datos de trazabilidad -->
        <t t-if="widget.hasTrazabilidad">

            <!-- ─────────────────────────────────────────────────────
                 COMPARACION TEMPORAL
                 ───────────────────────────────────────────────────── -->
            <div class="trazabilidad-section" style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 14px; margin-bottom: 16px;">
                <div style="background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%); padding: 12px 16px; border-radius: 14px 14px 0 0; border-bottom: 2px solid #93C5FD;">
                    <div style="font-size: 14px; font-weight: 600; color: #1D4ED8;">
                        <i class="fa fa-line-chart" style="margin-right: 8px;"></i>
                        COMPARACION TEMPORAL
                    </div>
                </div>

                <div style="padding: 20px;">
                    <div class="row g-3">
                        <!-- Valor Anterior -->
                        <div class="col-md-4">
                            <div style="text-align: center; padding: 16px; background: #F3F4F6; border-radius: 12px; border: 2px solid #D1D5DB;">
                                <div style="font-size: 11px; color: #6B7280; text-transform: uppercase; font-weight: 600; margin-bottom: 8px;">
                                    Periodo Anterior
                                </div>
                                <div style="font-size: 24px; font-weight: 700; color: #374151; font-family: 'JetBrains Mono', monospace; margin-bottom: 4px;">
                                    <t t-esc="widget.formatValue(widget.trazabilidadData.valorAnterior, 'currency')"/>
                                </div>
                                <div t-if="widget.trazabilidadData.valoresAnteriores.fecha_ultimo_calculo"
                                     style="font-size: 10px; color: #9CA3AF;">
                                    <t t-esc="widget.formatDate(widget.trazabilidadData.valoresAnteriores.fecha_ultimo_calculo)"/>
                                </div>
                            </div>
                        </div>

                        <!-- Diferencia -->
                        <div class="col-md-4">
                            <div t-att-style="'text-align: center; padding: 16px; border-radius: 12px; border: 2px solid; background: linear-gradient(135deg, ' + (widget.trazabilidadData.diferencia >= 0 ? '#DCFCE7 0%, #86EFAC 100%); border-color: #22C55E;' : '#FEE2E2 0%, #FECACA 100%); border-color: #EF4444;')">
                                <div t-att-style="'font-size: 11px; text-transform: uppercase; font-weight: 600; margin-bottom: 8px; ' + (widget.trazabilidadData.diferencia >= 0 ? 'color: #15803D;' : 'color: #DC2626;')">
                                    <i t-att-class="'fa ' + (widget.trazabilidadData.diferencia >= 0 ? 'fa-arrow-up' : 'fa-arrow-down')"
                                       style="margin-right: 4px;"></i>
                                    Diferencia
                                </div>
                                <div t-att-style="'font-size: 24px; font-weight: 700; font-family: monospace; margin-bottom: 4px; ' + (widget.trazabilidadData.diferencia >= 0 ? 'color: #15803D;' : 'color: #DC2626;')">
                                    <t t-if="widget.trazabilidadData.diferencia > 0">+</t>
                                    <t t-esc="widget.formatValue(widget.trazabilidadData.diferencia, 'currency')"/>
                                </div>
                                <div t-att-style="'font-size: 12px; font-weight: 600; ' + (widget.trazabilidadData.diferencia >= 0 ? 'color: #15803D;' : 'color: #DC2626;')">
                                    <i t-att-class="'fa ' + (widget.trazabilidadData.diferencia >= 0 ? 'fa-caret-up' : 'fa-caret-down')"></i>
                                    <t t-esc="Math.abs(widget.trazabilidadData.porcentajeCambio).toFixed(2)"/>%
                                </div>
                            </div>
                        </div>

                        <!-- Valor Actual -->
                        <div class="col-md-4">
                            <div style="text-align: center; padding: 16px; background: linear-gradient(135deg, #DCFCE7 0%, #86EFAC 100%); border-radius: 12px; border: 2px solid #22C55E;">
                                <div style="font-size: 11px; color: #15803D; text-transform: uppercase; font-weight: 600; margin-bottom: 8px;">
                                    Periodo Actual
                                </div>
                                <div style="font-size: 24px; font-weight: 700; color: #15803D; font-family: 'JetBrains Mono', monospace; margin-bottom: 4px;">
                                    <t t-esc="widget.formatValue(widget.trazabilidadData.valorActual, 'currency')"/>
                                </div>
                                <div style="font-size: 10px; color: #15803D;">
                                    <t t-esc="widget.formatDate(widget.state.payslip?.date_to)"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ─────────────────────────────────────────────────────
                 REGLAS USADAS EN EL CALCULO
                 ───────────────────────────────────────────────────── -->
            <div t-if="widget.trazabilidadData.reglasUsadas.length > 0"
                 style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 14px; margin-bottom: 16px;">

                <div style="background: #DCFCE7; padding: 12px 16px; border-radius: 14px 14px 0 0; border-bottom: 1px solid #86EFAC;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div style="font-size: 13px; font-weight: 600; color: #15803D;">
                            <i class="fa fa-list-alt"></i> CONCEPTOS USADOS EN EL CALCULO
                            <span style="background: #22C55E; color: white; padding: 2px 8px; border-radius: 10px; font-size: 10px; margin-left: 8px;">
                                <t t-esc="widget.trazabilidadData.reglasUsadas.length"/>
                            </span>
                        </div>
                        <button class="btn btn-sm btn-outline-success" style="font-size: 11px;"
                                t-on-click="() => widget.toggleSection('reglas_usadas')">
                            <t t-if="widget.state.expandedSections.reglas_usadas">
                                <i class="fa fa-chevron-up"></i> Ocultar
                            </t>
                            <t t-else="">
                                <i class="fa fa-chevron-down"></i> Mostrar
                            </t>
                        </button>
                    </div>
                </div>

                <div t-if="widget.state.expandedSections.reglas_usadas" style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #DCFCE7;">
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: left; color: #15803D;">Codigo</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: left; color: #15803D;">Nombre</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: center; color: #15803D;">Tipo</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: left; color: #15803D;">Nomina</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: left; color: #15803D;">Fecha</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: center; color: #15803D;">IDs</th>
                                <th style="padding: 8px 12px; border-bottom: 1px solid #86EFAC; text-align: right; color: #15803D;">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="widget.trazabilidadData.reglasUsadas" t-as="regla" t-key="regla.codigo">
                                <tr t-att-style="regla_index % 2 === 0 ? 'background: white;' : 'background: #F9FAFB;'">
                                    <!-- Codigo -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; font-family: monospace; color: #2563EB; font-weight: 500;">
                                        <t t-esc="regla.codigo"/>
                                    </td>

                                    <!-- Nombre -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; color: #1F2937;">
                                        <t t-esc="regla.nombre"/>
                                    </td>

                                    <!-- Tipo -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; text-align: center;">
                                        <span t-att-style="'padding: 2px 8px; border-radius: 10px; font-size: 9px; ' +
                                            (regla.tipo === 'basic_current' ? 'background: #DCFCE7; color: #15803D;' :
                                             regla.tipo === 'basic_accumulated' ? 'background: #DBEAFE; color: #1D4ED8;' :
                                             regla.tipo === 'variable_current' ? 'background: #FEF3C7; color: #B45309;' :
                                             'background: #EDE9FE; color: #7C3AED;')">
                                            <t t-if="regla.tipo === 'basic_current'">
                                                <i class="fa fa-circle"></i> Actual
                                            </t>
                                            <t t-elif="regla.tipo === 'basic_accumulated'">
                                                <i class="fa fa-calendar"></i> Acumulado
                                            </t>
                                            <t t-elif="regla.tipo === 'variable_current'">
                                                <i class="fa fa-money"></i> Var. Actual
                                            </t>
                                            <t t-else="">
                                                <i class="fa fa-line-chart"></i> Var. Acum
                                            </t>
                                        </span>
                                    </td>

                                    <!-- Nomina -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB;">
                                        <span style="color: #2563EB; cursor: pointer; text-decoration: underline;"
                                              t-on-click="() => widget.openPayslip(regla.payslip_id)">
                                            <t t-esc="regla.payslip_number"/>
                                        </span>
                                    </td>

                                    <!-- Fecha -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; color: #6B7280; font-size: 10px;">
                                        <t t-esc="widget.formatDate(regla.fecha_nomina)"/>
                                    </td>

                                    <!-- IDs (clickeables) -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; text-align: center;">
                                        <div style="display: flex; flex-wrap: wrap; gap: 4px; justify-content: center;">
                                            <t t-foreach="regla.line_ids || []" t-as="line_id" t-key="line_id">
                                                <span style="background: #DBEAFE; color: #2563EB; padding: 2px 6px; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: 10px;"
                                                      t-on-click="() => widget.openPayslipLine(line_id)">
                                                    <t t-esc="line_id"/>
                                                </span>
                                            </t>
                                        </div>
                                    </td>

                                    <!-- Valor -->
                                    <td style="padding: 6px 12px; border-bottom: 1px solid #E5E7EB; text-align: right; font-family: monospace; font-weight: 600; color: #22C55E;">
                                        <t t-esc="widget.formatValue(regla.total, 'currency')"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>

                        <!-- Total -->
                        <tfoot>
                            <tr style="background: #DCFCE7; font-weight: 600;">
                                <td colspan="6" style="padding: 8px 12px; border-top: 2px solid #86EFAC; text-align: right; color: #15803D;">
                                    TOTAL:
                                </td>
                                <td style="padding: 8px 12px; border-top: 2px solid #86EFAC; text-align: right; font-family: monospace; color: #15803D;">
                                    <t t-esc="widget.formatValue(widget.trazabilidadData.reglasUsadas.reduce((sum, r) => sum + (r.total || 0), 0), 'currency')"/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- ─────────────────────────────────────────────────────
                 HISTORIAL DE CALCULOS ANTERIORES
                 ───────────────────────────────────────────────────── -->
            <div t-if="widget.trazabilidadData.valoresAnteriores.payslip_lines and widget.trazabilidadData.valoresAnteriores.payslip_lines.length > 0"
                 style="background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 14px; margin-bottom: 16px;">

                <div style="background: #F3F4F6; padding: 12px 16px; border-radius: 14px 14px 0 0; border-bottom: 1px solid #D1D5DB;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div style="font-size: 13px; font-weight: 600; color: #374151;">
                            <i class="fa fa-history"></i> HISTORIAL DE CALCULOS
                            <span style="background: #6B7280; color: white; padding: 2px 8px; border-radius: 10px; font-size: 10px; margin-left: 8px;">
                                <t t-esc="widget.trazabilidadData.valoresAnteriores.payslip_lines.length"/>
                            </span>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 11px;"
                                t-on-click="() => widget.toggleSection('historial')">
                            <t t-if="widget.state.expandedSections.historial">
                                <i class="fa fa-chevron-up"></i>
                            </t>
                            <t t-else="">
                                <i class="fa fa-chevron-down"></i>
                            </t>
                        </button>
                    </div>
                </div>

                <div t-if="widget.state.expandedSections.historial" style="padding: 16px;">
                    <!-- Timeline visual -->
                    <div class="timeline" style="position: relative; padding-left: 30px;">
                        <t t-foreach="widget.trazabilidadData.valoresAnteriores.payslip_lines" t-as="prev_line" t-key="prev_line.id">
                            <div style="position: relative; margin-bottom: 20px; padding: 12px; background: #F9FAFB; border-radius: 8px; border-left: 3px solid #2563EB;">
                                <!-- Punto del timeline -->
                                <div style="position: absolute; left: -39px; top: 15px; width: 12px; height: 12px; background: #2563EB; border-radius: 50%; border: 3px solid white;"></div>

                                <!-- Contenido -->
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div style="font-size: 10px; color: #6B7280;">
                                            <t t-esc="widget.formatDate(prev_line.date_from)"/> - <t t-esc="widget.formatDate(prev_line.date_to)"/>
                                        </div>
                                        <div style="font-size: 12px; font-weight: 600; color: #2563EB; margin-top: 2px; cursor: pointer;"
                                             t-on-click="() => widget.openPayslip(prev_line.payslip_id)">
                                            <i class="fa fa-file-text-o"></i> <t t-esc="prev_line.payslip_number"/>
                                        </div>
                                        <div style="font-size: 10px; color: #9CA3AF; margin-top: 2px;">
                                            ID Linea: <span style="background: #DBEAFE; color: #2563EB; padding: 1px 6px; border-radius: 4px; cursor: pointer;"
                                                           t-on-click="() => widget.openPayslipLine(prev_line.id)">
                                                <t t-esc="prev_line.id"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <div style="font-size: 16px; font-weight: 600; color: #374151; font-family: monospace;">
                                            <t t-esc="widget.formatValue(prev_line.total, 'currency')"/>
                                        </div>
                                        <div style="font-size: 10px; color: #6B7280;">
                                            <t t-esc="prev_line.quantity"/> dias
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

        </t>
    </t>

</templates>
