<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PayslipLineHorasExtras">
        <div class="pld-horas-extras-container">
            <!-- Header -->
            <div class="pld-horas-header d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa fa-clock-o text-warning"/>
                    <span class="fw-bold">Horas Extras y Recargos</span>
                </div>
                <small class="text-muted" t-esc="baseLegal"/>
            </div>

            <!-- KPIs -->
            <div class="pld-horas-kpis d-flex flex-wrap gap-3 mb-3">
                <t t-foreach="kpis" t-as="kpi" t-key="kpi.id">
                    <div t-attf-class="pld-kpi-card p-2 rounded border #{kpi.highlight ? 'border-success bg-success-subtle' : 'bg-light'}">
                        <div class="d-flex align-items-center gap-1 mb-1">
                            <i t-attf-class="fa #{kpi.icon} text-#{kpi.color}" style="font-size: 12px;"/>
                            <small class="text-muted" t-esc="kpi.label"/>
                        </div>
                        <div t-attf-class="fw-bold #{kpi.highlight ? 'text-success fs-5' : ''}">
                            <t t-if="kpi.format === 'currency'">
                                <t t-esc="props.formatCurrency(kpi.value)"/>
                            </t>
                            <t t-elif="kpi.format === 'number'">
                                <t t-esc="kpi.value"/> hrs
                            </t>
                            <t t-else="">
                                <t t-esc="props.formatValue(kpi.value, kpi.format)"/>
                            </t>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Formula -->
            <div class="pld-horas-formula bg-light p-2 rounded mb-3 d-flex align-items-center gap-2">
                <i class="fa fa-calculator text-secondary"/>
                <code t-esc="formula"/>
            </div>

            <!-- Desglose por tipo de hora -->
            <t t-if="hasDesglose">
                <div class="pld-horas-desglose mb-3">
                    <div class="d-flex align-items-center justify-content-between cursor-pointer p-2 bg-warning-subtle rounded"
                         t-on-click="toggleDesglose">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-list text-warning"/>
                            <span class="fw-medium">Desglose por Tipo</span>
                            <span class="badge bg-warning text-dark" t-esc="desglose.length"/>
                        </div>
                        <i t-attf-class="fa fa-chevron-#{state.showDesglose ? 'up' : 'down'}"/>
                    </div>
                    <t t-if="state.showDesglose">
                        <div class="pld-desglose-content mt-2">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tipo</th>
                                        <th class="text-end">Horas</th>
                                        <th class="text-end">Recargo</th>
                                        <th class="text-end">Valor Hora</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="desglose" t-as="item" t-key="item.tipo">
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i t-attf-class="fa #{item.config.icon} text-#{item.config.color}"/>
                                                    <span t-esc="item.nombre || item.config.label"/>
                                                </div>
                                            </td>
                                            <td class="text-end" t-esc="item.horas"/>
                                            <td class="text-end">
                                                <span class="badge bg-secondary">+<t t-esc="item.porcentaje"/>%</span>
                                            </td>
                                            <td class="text-end" t-esc="props.formatCurrency(item.valor_hora)"/>
                                            <td class="text-end fw-bold" t-esc="props.formatCurrency(calcularSubtotal(item))"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </t>

            <!-- Detalle por dia (opcional) -->
            <t t-if="hasDetalleDias">
                <div class="pld-horas-detalle-dias mb-3">
                    <div class="d-flex align-items-center justify-content-between cursor-pointer p-2 bg-light rounded"
                         t-on-click="toggleDetalleDias">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-calendar text-secondary"/>
                            <span class="fw-medium">Detalle por Dia</span>
                        </div>
                        <i t-attf-class="fa fa-chevron-#{state.showDetalleDias ? 'up' : 'down'}"/>
                    </div>
                    <t t-if="state.showDetalleDias">
                        <div class="pld-detalle-dias-content mt-2 ps-3" style="max-height: 200px; overflow-y: auto;">
                            <t t-foreach="detalleDias" t-as="dia" t-key="dia_index">
                                <div class="d-flex justify-content-between py-1 border-bottom small">
                                    <div>
                                        <span class="fw-medium" t-esc="dia.fecha"/>
                                        <t t-if="dia.festivo">
                                            <span class="badge bg-danger ms-1">Festivo</span>
                                        </t>
                                    </div>
                                    <div class="d-flex gap-3">
                                        <span t-if="dia.horas" t-esc="dia.horas + ' hrs'"/>
                                        <span class="fw-medium" t-esc="props.formatCurrency(dia.valor)"/>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </t>

            <!-- Pasos de calculo (si hay) -->
            <t t-if="hasPasos">
                <div class="pld-horas-pasos mt-3 ps-3 border-start border-2 border-warning">
                    <t t-foreach="pasos" t-as="paso" t-key="paso_index">
                        <div t-attf-class="d-flex justify-content-between py-1 #{paso.highlight or paso.destacado ? 'fw-bold text-success' : 'small'}">
                            <span t-esc="paso.label || paso.nombre"/>
                            <span t-esc="formatPasoValue(paso)"/>
                        </div>
                    </t>
                </div>
            </t>

            <!-- Tabla de referencia de recargos -->
            <div class="pld-horas-referencia mt-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa fa-info-circle text-muted"/>
                    <small class="text-muted">Recargos segun CST Art. 168:</small>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">Diurna +25%</span>
                    <span class="badge bg-info text-dark">Nocturna +75%</span>
                    <span class="badge bg-secondary">Recargo Noct. +35%</span>
                    <span class="badge bg-warning text-dark">Fest. Diurna +100%</span>
                    <span class="badge bg-danger">Fest. Noct. +150%</span>
                </div>
            </div>
        </div>
    </t>

</templates>
