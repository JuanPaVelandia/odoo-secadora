<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.KPICard">
        <div class="card kpi-card h-100"
             t-att-class="'border-' + props.color + (isClickable ? ' cursor-pointer' : '')"
             t-att-style="isClickable ? 'cursor: pointer;' : ''"
             t-on-click="handleClick">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <h6 class="text-muted mb-2 text-uppercase" style="font-size: 0.75rem;">
                            <t t-esc="props.title"/>
                        </h6>
                        <h3 class="mb-0" t-att-class="'text-' + props.color">
                            <t t-esc="props.value"/>
                        </h3>
                        <p t-if="props.subtitle" class="text-muted mb-0 mt-1" style="font-size: 0.875rem;">
                            <t t-esc="props.subtitle"/>
                        </p>
                        <span t-if="props.state" class="badge mt-2" t-att-class="'bg-' + props.color">
                            <t t-esc="props.state"/>
                        </span>
                    </div>
                    <div class="ms-3">
                        <div class="icon-box" t-att-class="'bg-' + props.color + '-subtle text-' + props.color">
                            <t t-if="props.animatedIcon">
                                <lord-icon
                                    t-att-src="props.animatedIcon"
                                    trigger="loop"
                                    delay="2500"
                                    t-att-colors="'primary:' + colorHex"
                                    style="width:40px;height:40px;">
                                </lord-icon>
                            </t>
                            <t t-else="">
                                <i class="fa fa-2x" t-att-class="props.icon"/>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
