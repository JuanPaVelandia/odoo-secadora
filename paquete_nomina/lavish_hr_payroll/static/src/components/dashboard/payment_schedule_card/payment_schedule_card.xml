<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PaymentScheduleCard">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-calendar-check-o me-2"/>
                    Programación de Pagos
                </h5>
                <button class="btn btn-sm btn-light" t-on-click="onViewAllSchedule" t-if="hasData">
                    <i class="fa fa-external-link"/>
                </button>
            </div>
            <div class="card-body">
                <t t-if="!hasData">
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-check-circle fa-2x mb-2 text-success"/>
                        <p>No hay pagos pendientes programados</p>
                    </div>
                </t>
                <t t-else="">
                    <!-- Summary Card -->
                    <div class="card bg-primary bg-opacity-10 border-primary mb-3">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block">Total Programado</small>
                                    <h4 class="mb-0 text-primary" t-esc="totalScheduled"/>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">Fechas de Pago</small>
                                    <h4 class="mb-0 text-primary">
                                        <t t-esc="paymentDatesCount"/>
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Schedule Items -->
                    <div class="list-group list-group-flush">
                        <t t-foreach="scheduleItems" t-as="item" t-key="item_index">
                            <div class="list-group-item px-2 py-2">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <i class="fa fa-calendar text-primary"/>
                                            <strong t-esc="item.payment_date"/>
                                            <span t-att-class="'badge bg-' + getUrgencyClass(item.payment_date)">
                                                <t t-esc="getUrgencyText(item.payment_date)"/>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted">
                                                <i class="fa fa-money me-1"/>
                                                <t t-esc="item.formatted_amount"/>
                                            </small>
                                            <small class="text-muted">
                                                <i class="fa fa-users me-1"/>
                                                <t t-esc="item.batch_count"/> lote(s)
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Batches for this date -->
                                <t t-if="item.batches and item.batches.length > 0">
                                    <div class="ms-3 mt-2">
                                        <t t-foreach="item.batches" t-as="batch" t-key="batch.id">
                                            <div class="d-flex justify-content-between align-items-center py-1 cursor-pointer"
                                                 t-on-click="() => this.onViewBatch(batch.id)">
                                                <small class="text-muted">
                                                    <i class="fa fa-file-alt me-1"/>
                                                    <t t-esc="batch.name"/>
                                                </small>
                                                <small class="text-primary">
                                                    <t t-esc="batch.formatted_total"/>
                                                </small>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>

                    <!-- Show more indicator -->
                    <div class="mt-2 text-center" t-if="totalItems > 5">
                        <button class="btn btn-sm btn-link" t-on-click="onViewAllSchedule">
                            Ver todas las fechas (<t t-esc="totalItems"/>)
                            <i class="fa fa-arrow-right ms-1"/>
                        </button>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
