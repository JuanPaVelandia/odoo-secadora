<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.SocialSecurityChart">
        <div class="card h-100">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fa fa-shield text-warning me-2"/>
                        Seguridad Social
                    </h5>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-info">
                            Período: <t t-esc="props.period.month"/>/<t t-esc="props.period.year"/>
                        </span>
                        <button class="btn btn-sm btn-light" t-on-click="toggleCollapse" title="Ocultar/Mostrar" t-if="hasData">
                            <i t-att-class="'fa ' + (state.collapsed ? 'fa-eye' : 'fa-eye-slash')"/>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body" t-if="!state.collapsed">
                <t t-if="!hasData">
                    <div class="alert alert-info text-center">
                        <i class="fa fa-info-circle me-2"/>
                        No hay datos de seguridad social para este período.
                        <p class="mb-0 mt-2 small">
                            La seguridad social se genera automáticamente al confirmar nóminas.
                        </p>
                    </div>
                </t>
                <t t-else="">
                    <!-- Chart Canvas -->
                    <div class="mb-3" style="height: 250px; position: relative;">
                        <canvas t-ref="chartCanvas"/>
                    </div>

                    <!-- Totals by Type with Previous Month Comparison -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="p-2 border rounded">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-muted small">EPS</span>
                                    <strong class="text-primary">
                                        <t t-esc="props.socialSecurity.totals?.eps?.formatted || '$0'"/>
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Mes anterior:</small>
                                    <small class="text-muted">
                                        <t t-esc="props.socialSecurity.totals?.eps?.prev_formatted || '$0'"/>
                                        <span t-att-class="'ms-1 ' + (props.socialSecurity.totals?.eps?.change >= 0 ? 'text-success' : 'text-danger')">
                                            (<t t-if="props.socialSecurity.totals?.eps?.change >= 0">+</t><t t-esc="props.socialSecurity.totals?.eps?.change || 0"/>%)
                                        </span>
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 border rounded">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-muted small">AFP</span>
                                    <strong class="text-success">
                                        <t t-esc="props.socialSecurity.totals?.afp?.formatted || '$0'"/>
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Mes anterior:</small>
                                    <small class="text-muted">
                                        <t t-esc="props.socialSecurity.totals?.afp?.prev_formatted || '$0'"/>
                                        <span t-att-class="'ms-1 ' + (props.socialSecurity.totals?.afp?.change >= 0 ? 'text-success' : 'text-danger')">
                                            (<t t-if="props.socialSecurity.totals?.afp?.change >= 0">+</t><t t-esc="props.socialSecurity.totals?.afp?.change || 0"/>%)
                                        </span>
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 border rounded">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-muted small">ARL</span>
                                    <strong class="text-warning">
                                        <t t-esc="props.socialSecurity.totals?.arl?.formatted || '$0'"/>
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Mes anterior:</small>
                                    <small class="text-muted">
                                        <t t-esc="props.socialSecurity.totals?.arl?.prev_formatted || '$0'"/>
                                        <span t-att-class="'ms-1 ' + (props.socialSecurity.totals?.arl?.change >= 0 ? 'text-success' : 'text-danger')">
                                            (<t t-if="props.socialSecurity.totals?.arl?.change >= 0">+</t><t t-esc="props.socialSecurity.totals?.arl?.change || 0"/>%)
                                        </span>
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 border rounded">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-muted small">CCF</span>
                                    <strong class="text-danger">
                                        <t t-esc="props.socialSecurity.totals?.ccf?.formatted || '$0'"/>
                                    </strong>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Mes anterior:</small>
                                    <small class="text-muted">
                                        <t t-esc="props.socialSecurity.totals?.ccf?.prev_formatted || '$0'"/>
                                        <span t-att-class="'ms-1 ' + (props.socialSecurity.totals?.ccf?.change >= 0 ? 'text-success' : 'text-danger')">
                                            (<t t-if="props.socialSecurity.totals?.ccf?.change >= 0">+</t><t t-esc="props.socialSecurity.totals?.ccf?.change || 0"/>%)
                                        </span>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Detail by Entity (Collapsible) -->
                    <t t-if="detailByEntity.length > 0">
                        <div class="accordion accordion-flush" id="accordionSSDetail">
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSSDetail">
                                        Ver detalle por entidad (<t t-esc="detailByEntity.length"/> entidades)
                                    </button>
                                </h2>
                                <div id="collapseSSDetail" class="accordion-collapse collapse" data-bs-parent="#accordionSSDetail">
                                    <div class="accordion-body p-0">
                                        <div class="table-responsive scrollable-table" style="max-height: 250px;">
                                            <table class="table table-sm table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Entidad</th>
                                                        <th>Tipo</th>
                                                        <th class="text-end">Empleados</th>
                                                        <th class="text-end">Valor</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="detailByEntity" t-as="entity" t-key="entity_index">
                                                        <tr>
                                                            <td><t t-esc="entity.entity_name"/></td>
                                                            <td>
                                                                <span class="badge" t-att-class="'bg-' + (entity.type === 'EPS' ? 'primary' : entity.type === 'AFP' ? 'success' : entity.type === 'ARL' ? 'warning' : 'danger')">
                                                                    <t t-esc="entity.type"/>
                                                                </span>
                                                            </td>
                                                            <td class="text-end"><t t-esc="entity.employees"/></td>
                                                            <td class="text-end fw-bold"><t t-esc="entity.formatted_value"/></td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </div>
            <div class="card-footer bg-light" t-if="hasData">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Total: <t t-esc="props.socialSecurity.totals?.total?.formatted || '$0'"/></strong>
                    </div>
                    <div class="text-end">
                        <small class="text-muted">
                            Mes anterior: <t t-esc="props.socialSecurity.totals?.total?.prev_formatted || '$0'"/>
                            <span t-att-class="'ms-1 ' + (props.socialSecurity.totals?.total?.change >= 0 ? 'text-success' : 'text-danger')">
                                (<t t-if="props.socialSecurity.totals?.total?.change >= 0">+</t><t t-esc="props.socialSecurity.totals?.total?.change || 0"/>%)
                            </span>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
