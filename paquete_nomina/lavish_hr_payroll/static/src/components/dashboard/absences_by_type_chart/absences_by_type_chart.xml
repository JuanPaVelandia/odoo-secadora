<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.AbsencesByTypeChart">
        <div class="card h-100">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fa fa-user-times text-info me-2"/>
                        Ausencias por tipo
                    </h5>
                    <span class="badge bg-info text-white" t-if="hasData">
                        <t t-esc="totalDaysLabel"/>
                    </span>
                </div>
            </div>
            <div class="card-body">
                <t t-if="!hasData">
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-info-circle fa-2x mb-2"/>
                        <p class="mb-0">No hay ausencias registradas en el periodo</p>
                    </div>
                </t>
                <t t-else="">
                    <div style="height: 240px; position: relative;">
                        <canvas t-ref="chartCanvas"/>
                    </div>

                    <div class="list-group list-group-flush mt-3">
                        <t t-foreach="summaryItems" t-as="item" t-key="item.label">
                            <div class="list-group-item px-2 py-2 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-light text-dark border">
                                        <t t-esc="getPercentage(item.value)"/>%
                                    </span>
                                    <span t-esc="item.label"/>
                                </div>
                                <strong>
                                    <t t-esc="formatNumber(item.value, 1)"/>
                                </strong>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
