<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.BatchList">
        <div class="card h-100">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <lord-icon
                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/jmkrnisz.json"
                            trigger="hover"
                            colors="primary:#0d6efd"
                            style="width:28px;height:28px;vertical-align:middle;">
                        </lord-icon>
                        Lotes del Período
                    </h5>
                    <span class="badge bg-primary rounded-pill">
                        <t t-esc="props.batches.length"/>
                    </span>
                </div>
            </div>

            <!-- State Filters -->
            <div class="card-body py-2 border-bottom" t-if="props.batches.length > 0">
                <div class="d-flex gap-2 flex-wrap">
                    <t t-foreach="states" t-as="s" t-key="s.key">
                        <button
                            class="btn btn-sm state-filter-btn"
                            t-att-class="'btn-' + (state.selectedState === s.key ? '' : 'outline-') + s.color + (state.selectedState === s.key ? ' active' : '')"
                            t-on-click="() => this.setStateFilter(s.key)"
                            t-if="stateCount[s.key] > 0 || s.key === 'all'">
                            <i t-att-class="'fa ' + s.icon + ' me-1'"/>
                            <t t-esc="s.label"/>
                            <span class="badge bg-white text-dark ms-1" t-if="stateCount[s.key]">
                                <t t-esc="stateCount[s.key] || 0"/>
                            </span>
                        </button>
                    </t>
                </div>
            </div>

            <div class="card-body p-0">
                <t t-if="filteredBatches.length === 0">
                    <div class="p-4 text-center text-muted">
                        <lord-icon
                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/msoeawqm.json"
                            trigger="loop"
                            delay="2000"
                            colors="primary:#dee2e6"
                            style="width:64px;height:64px;">
                        </lord-icon>
                        <p class="mb-0 mt-2">
                            <t t-if="state.selectedState === 'all'">
                                No hay lotes en este período
                            </t>
                            <t t-else="">
                                No hay lotes con estado "<t t-esc="states.find(s => s.key === state.selectedState)?.label"/>"
                            </t>
                        </p>
                    </div>
                </t>
                <t t-else="">
                    <div class="list-group list-group-flush scrollable-list" style="max-height: 350px;">
                        <t t-foreach="filteredBatches" t-as="batch" t-key="batch.id">
                            <a href="#"
                               class="list-group-item list-group-item-action"
                               t-on-click.prevent="() => this.openBatch(batch.id)">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center mb-1">
                                            <i t-att-class="'fa ' + getStateIcon(batch.state) + ' me-2 text-' + getStateClass(batch.state)"/>
                                            <h6 class="mb-0 me-2">
                                                <t t-esc="batch.name"/>
                                            </h6>
                                            <span class="badge" t-att-class="'bg-' + getStateClass(batch.state)">
                                                <t t-esc="batch.state_label"/>
                                            </span>
                                        </div>
                                        <p class="mb-1 text-muted small">
                                            <i class="fa fa-calendar me-1"/>
                                            <t t-esc="batch.date_start"/> - <t t-esc="batch.date_end"/>
                                        </p>
                                        <div class="d-flex gap-3 small text-muted">
                                            <span>
                                                <i class="fa fa-users me-1"/>
                                                <t t-esc="batch.employee_count"/> empleado(s)
                                            </span>
                                            <span>
                                                <i class="fa fa-file-text me-1"/>
                                                <t t-esc="batch.payslip_count"/> nómina(s)
                                            </span>
                                        </div>
                                    </div>
                                    <div class="text-end ms-3">
                                        <strong class="text-success">
                                            <t t-esc="batch.formatted_amount"/>
                                        </strong>
                                        <div class="mt-1">
                                            <i class="fa fa-chevron-right text-muted"/>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </t>
                    </div>
                </t>
            </div>
            <div class="card-footer bg-light text-muted small" t-if="filteredBatches.length > 0">
                <div class="d-flex justify-content-between align-items-center">
                    <span>
                        Mostrando: <strong><t t-esc="filteredBatches.length"/></strong> lote(s)
                    </span>
                    <span t-if="state.selectedState !== 'all'">
                        de <t t-esc="props.batches.length"/> total
                    </span>
                </div>
            </div>
        </div>
    </t>

</templates>
