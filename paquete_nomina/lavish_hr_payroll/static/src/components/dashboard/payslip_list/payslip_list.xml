<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PayslipList">
        <div class="card h-100">
            <!-- Header -->
            <div class="card-header" style="background: linear-gradient(135deg, #5C6BC0 0%, #3949AB 100%); color: white;">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <lord-icon
                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/iltqorsz.json"
                            trigger="hover"
                            colors="primary:#ffffff"
                            style="width:28px;height:28px;vertical-align:middle;">
                        </lord-icon>
                        Nóminas del Período
                    </h5>
                    <span class="badge bg-white text-primary rounded-pill px-3">
                        <t t-esc="props.payslips.length"/> nóminas
                    </span>
                </div>
            </div>

            <div class="card-body p-0">
                <t t-if="props.payslips.length === 0">
                    <div class="p-5 text-center" style="color: #9E9E9E;">
                        <lord-icon
                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/msoeawqm.json"
                            trigger="loop"
                            delay="2000"
                            colors="primary:#dee2e6"
                            style="width:80px;height:80px;">
                        </lord-icon>
                        <p class="fs-5 mt-3">No hay nóminas en este período</p>
                    </div>
                </t>
                <t t-else="">
                    <!-- Barra de herramientas -->
                    <div class="p-3" style="background: #F5F5F5; border-bottom: 1px solid #E0E0E0;">
                        <!-- Fila 1: Filtros -->
                        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <!-- Filtros de estado -->
                                <t t-foreach="states" t-as="s" t-key="s.key">
                                    <button
                                        class="btn btn-sm"
                                        t-att-class="state.selectedState === s.key ? 'btn-' + s.color : 'btn-outline-' + s.color"
                                        t-on-click="() => this.setStateFilter(s.key)"
                                        t-if="stateCount[s.key] > 0 || s.key === 'all'"
                                        style="border-radius: 20px; font-size: 12px;">
                                        <t t-esc="s.label"/>
                                        <span class="badge bg-white text-dark ms-1" style="font-size: 10px;">
                                            <t t-esc="stateCount[s.key] || 0"/>
                                        </span>
                                    </button>
                                </t>
                            </div>
                            <div class="d-flex gap-2 align-items-center flex-wrap">
                                <!-- Búsqueda -->
                                <div class="input-group input-group-sm" style="width: 200px;">
                                    <span class="input-group-text" style="background: white; border-color: #E0E0E0;">
                                        <i class="fa fa-search" style="color: #757575;"></i>
                                    </span>
                                    <input type="text" class="form-control" placeholder="Buscar empleado..."
                                           t-on-input="onSearchInput" style="border-color: #E0E0E0;"/>
                                </div>
                                <!-- Items por página -->
                                <select class="form-select form-select-sm" style="width: 70px; border-color: #E0E0E0;"
                                        t-on-change="onPageSizeChange">
                                    <option value="5" t-att-selected="state.itemsPerPage === 5">5</option>
                                    <option value="10" t-att-selected="state.itemsPerPage === 10">10</option>
                                    <option value="20" t-att-selected="state.itemsPerPage === 20">20</option>
                                    <option value="50" t-att-selected="state.itemsPerPage === 50">50</option>
                                </select>
                                <!-- Botones expandir/colapsar -->
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-light" t-on-click="expandAll" title="Expandir todos">
                                        <i class="fa fa-expand"></i>
                                    </button>
                                    <button class="btn btn-light" t-on-click="collapseAll" title="Colapsar todos">
                                        <i class="fa fa-compress"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <!-- Fila 2: Totales -->
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <span class="badge px-3 py-2" style="background: #5C6BC0; color: white; font-size: 12px;">
                                    <i class="fa fa-users me-1"></i>
                                    <t t-esc="filteredPayslips.length"/> de <t t-esc="props.payslips.length"/>
                                </span>
                                <span class="px-2 py-1 rounded" style="background: #E8F5E9; color: #2E7D32; font-size: 11px;">
                                    <i class="fa fa-plus-circle me-1"></i>Dev: <strong><t t-esc="formatCurrency(filteredTotals.devengado)"/></strong>
                                </span>
                                <span class="px-2 py-1 rounded" style="background: #FFEBEE; color: #C62828; font-size: 11px;">
                                    <i class="fa fa-minus-circle me-1"></i>Ded: <strong><t t-esc="formatCurrency(filteredTotals.deducciones)"/></strong>
                                </span>
                                <span class="px-2 py-1 rounded" style="background: #E8EAF6; color: #3949AB; font-size: 11px;">
                                    <i class="fa fa-money me-1"></i>Neto: <strong><t t-esc="formatCurrency(filteredTotals.neto)"/></strong>
                                </span>
                            </div>
                            <!-- Paginación compacta -->
                            <div class="d-flex align-items-center gap-2" t-if="totalPages > 1">
                                <button class="btn btn-sm btn-light" t-on-click="prevPage" t-att-disabled="state.currentPage === 1">
                                    <i class="fa fa-chevron-left"></i>
                                </button>
                                <span class="small" style="color: #757575;">
                                    <strong><t t-esc="state.currentPage"/></strong> / <t t-esc="totalPages"/>
                                </span>
                                <button class="btn btn-sm btn-light" t-on-click="nextPage" t-att-disabled="state.currentPage === totalPages">
                                    <i class="fa fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Lista de Nóminas -->
                    <div class="payslips-container scrollable-list p-2" style="max-height: 500px;">
                        <t t-foreach="paginatedPayslips" t-as="payslip" t-key="payslip.id">
                            <div class="card mb-2 shadow-sm" t-att-style="'border-left: 4px solid ' + getStateColor(payslip.state) + ';'">
                                <!-- Header de la nómina -->
                                <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center"
                                     style="cursor: pointer; background: #FAFAFA; border-bottom: 1px solid #EEEEEE;"
                                     t-on-click="() => this.togglePayslip(payslip.id)">
                                    <div class="d-flex align-items-center gap-3">
                                        <i t-att-class="'fa fa-lg ' + (isExpanded(payslip.id) ? 'fa-chevron-down' : 'fa-chevron-right')"
                                           style="width: 16px; color: #9E9E9E;"></i>
                                        <!-- Avatar -->
                                        <t t-if="payslip.employee_image">
                                            <img t-att-src="'data:image/png;base64,' + payslip.employee_image"
                                                 class="rounded-circle"
                                                 style="width: 40px; height: 40px; object-fit: cover;"
                                                 t-att-alt="payslip.employee_name"/>
                                        </t>
                                        <t t-else="">
                                            <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 40px; height: 40px; font-size: 14px; background: #5C6BC0;">
                                                <t t-esc="payslip.employee_name.substring(0,2).toUpperCase()"/>
                                            </div>
                                        </t>
                                        <div>
                                            <div class="fw-bold" style="color: #212121; font-size: 14px;">
                                                <t t-esc="payslip.employee_name"/>
                                            </div>
                                            <small style="color: #757575;">
                                                <i class="fa fa-file-alt me-1"></i><t t-esc="payslip.number"/>
                                                <span class="mx-2">|</span>
                                                <i class="fa fa-calendar me-1"></i><t t-esc="payslip.dias_trabajados"/> días
                                            </small>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="text-end d-none d-md-block">
                                            <div class="small mb-1">
                                                <span style="color: #4CAF50;"><i class="fa fa-arrow-up me-1"></i><t t-esc="payslip.formatted_devengado"/></span>
                                                <span style="color: #9E9E9E;" class="mx-1">-</span>
                                                <span style="color: #F44336;"><i class="fa fa-arrow-down me-1"></i><t t-esc="payslip.formatted_deducciones"/></span>
                                            </div>
                                            <div class="fw-bold" style="color: #3949AB; font-size: 16px;">
                                                <t t-esc="payslip.formatted_neto"/>
                                            </div>
                                        </div>
                                        <span class="badge px-2 py-1" t-att-style="'background: ' + getStateBadge(payslip.state).bg + '; color: ' + getStateBadge(payslip.state).color + ';'">
                                            <t t-esc="getStateBadge(payslip.state).text"/>
                                        </span>
                                    </div>
                                </div>

                                <!-- Contenido expandido -->
                                <div t-if="isExpanded(payslip.id)" class="card-body p-0">
                                    <!-- Barra de acciones -->
                                    <div class="d-flex justify-content-between align-items-center px-3 py-2" style="background: #FAFAFA; border-bottom: 1px solid #EEEEEE;">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-light" t-on-click.stop="() => this.openPayslipModal(payslip.id, payslip.employee_name)" title="Ver nómina">
                                                <i class="fa fa-eye me-1"></i> Ver
                                            </button>
                                            <button class="btn btn-light" t-on-click.stop="() => this.openPayslip(payslip.id)" title="Abrir formulario">
                                                <i class="fa fa-external-link me-1"></i> Abrir
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Detalle en 2 columnas -->
                                    <div class="row g-0">
                                        <!-- DEVENGOS -->
                                        <div class="col-6" style="border-right: 1px solid #EEEEEE;">
                                            <div class="p-3">
                                                <div class="d-flex align-items-center mb-2 pb-1" style="border-bottom: 2px solid #4CAF50;">
                                                    <i class="fa fa-plus-circle me-2" style="color: #4CAF50;"></i>
                                                    <span class="fw-bold small" style="color: #2E7D32;">DEVENGOS</span>
                                                </div>
                                                <!-- Sueldo -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;">
                                                    <span style="color: #616161;"><i class="fa fa-briefcase me-2" style="color: #43A047;"></i>Sueldo Básico</span>
                                                    <strong style="color: #43A047;"><t t-esc="payslip.formatted_sueldo"/></strong>
                                                </div>
                                                <!-- Auxilio -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;">
                                                    <span style="color: #616161;"><i class="fa fa-bus me-2" style="color: #66BB6A;"></i>Auxilio Transporte</span>
                                                    <strong style="color: #66BB6A;"><t t-esc="payslip.formatted_auxilio"/></strong>
                                                </div>
                                                <!-- Total Devengos -->
                                                <div class="d-flex justify-content-between mt-2 pt-2 fw-bold" style="border-top: 2px solid #4CAF50; background: #E8F5E9; padding: 6px; border-radius: 4px;">
                                                    <span style="color: #2E7D32;"><i class="fa fa-calculator me-1"></i>TOTAL DEVENGOS</span>
                                                    <span style="color: #2E7D32;"><t t-esc="payslip.formatted_devengado"/></span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- DEDUCCIONES -->
                                        <div class="col-6">
                                            <div class="p-3">
                                                <div class="d-flex align-items-center mb-2 pb-1" style="border-bottom: 2px solid #EF5350;">
                                                    <i class="fa fa-minus-circle me-2" style="color: #EF5350;"></i>
                                                    <span class="fw-bold small" style="color: #C62828;">DEDUCCIONES</span>
                                                </div>
                                                <!-- Salud -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;">
                                                    <span style="color: #616161;"><i class="fa fa-medkit me-2" style="color: #EF5350;"></i>Salud (EPS)</span>
                                                    <strong style="color: #EF5350;"><t t-esc="payslip.formatted_salud"/></strong>
                                                </div>
                                                <!-- Pensión -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;">
                                                    <span style="color: #616161;"><i class="fa fa-shield me-2" style="color: #F44336;"></i>Pensión</span>
                                                    <strong style="color: #F44336;"><t t-esc="payslip.formatted_pension"/></strong>
                                                </div>
                                                <!-- Retención -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;" t-if="payslip.retencion > 0">
                                                    <span style="color: #616161;"><i class="fa fa-percent me-2" style="color: #FF7043;"></i>Retención Fuente</span>
                                                    <strong style="color: #FF7043;"><t t-esc="payslip.formatted_retencion"/></strong>
                                                </div>
                                                <!-- Préstamos -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;" t-if="payslip.prestamos > 0">
                                                    <span style="color: #616161;"><i class="fa fa-credit-card me-2" style="color: #7986CB;"></i>Préstamos</span>
                                                    <strong style="color: #7986CB;"><t t-esc="payslip.formatted_prestamos"/></strong>
                                                </div>
                                                <!-- Otras -->
                                                <div class="d-flex justify-content-between py-1" style="font-size: 12px;" t-if="payslip.otras_deducciones > 0">
                                                    <span style="color: #616161;"><i class="fa fa-minus me-2" style="color: #9E9E9E;"></i>Otras Deducciones</span>
                                                    <strong style="color: #9E9E9E;"><t t-esc="payslip.formatted_otras_deducciones"/></strong>
                                                </div>
                                                <!-- Total Deducciones -->
                                                <div class="d-flex justify-content-between mt-2 pt-2 fw-bold" style="border-top: 2px solid #EF5350; background: #FFEBEE; padding: 6px; border-radius: 4px;">
                                                    <span style="color: #C62828;"><i class="fa fa-calculator me-1"></i>TOTAL DEDUCCIONES</span>
                                                    <span style="color: #C62828;"><t t-esc="payslip.formatted_deducciones"/></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- NETO A PAGAR -->
                                    <div class="p-3 d-flex justify-content-between align-items-center" style="background: #3949AB; color: white;">
                                        <span class="fw-bold"><i class="fa fa-money me-2"></i>NETO A PAGAR</span>
                                        <span class="fs-4 fw-bold"><t t-esc="payslip.formatted_neto"/></span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </div>

            <!-- Footer con paginación -->
            <div class="card-footer bg-light" t-if="props.payslips.length > 0 and totalPages > 1">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="text-muted small">
                        Mostrando <t t-esc="(state.currentPage - 1) * state.itemsPerPage + 1"/>
                        a <t t-esc="Math.min(state.currentPage * state.itemsPerPage, filteredPayslips.length)"/>
                        de <t t-esc="filteredPayslips.length"/> nómina(s)
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item" t-att-class="state.currentPage === 1 ? 'disabled' : ''">
                                <a class="page-link" href="#" t-on-click.prevent="prevPage">
                                    <i class="fa fa-chevron-left"/>
                                </a>
                            </li>
                            <t t-foreach="pageNumbers" t-as="page" t-key="page">
                                <li class="page-item" t-att-class="state.currentPage === page ? 'active' : ''">
                                    <a class="page-link" href="#" t-on-click.prevent="() => this.goToPage(page)">
                                        <t t-esc="page"/>
                                    </a>
                                </li>
                            </t>
                            <li class="page-item" t-att-class="state.currentPage === totalPages ? 'disabled' : ''">
                                <a class="page-link" href="#" t-on-click.prevent="nextPage">
                                    <i class="fa fa-chevron-right"/>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </t>

</templates>
