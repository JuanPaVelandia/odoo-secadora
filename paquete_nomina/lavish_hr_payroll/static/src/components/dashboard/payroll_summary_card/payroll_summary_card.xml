<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PayrollSummaryCard">
        <div t-att-class="'payroll-summary-card ' + (state.isFullscreen ? 'fullscreen-modal' : '')">
            <div t-att-class="state.isFullscreen ? 'modal d-block' : ''">
                <div t-att-class="state.isFullscreen ? 'modal-dialog modal-xl modal-dialog-centered' : ''">
                    <div t-att-class="state.isFullscreen ? 'modal-content' : 'card h-100'">
                        <!-- Header -->
                        <div t-att-class="state.isFullscreen ? 'modal-header bg-primary text-white' : 'card-header d-flex justify-content-between align-items-center'">
                            <h5 class="mb-0">
                                <lord-icon
                                    src="/lavish_hr_payroll/static/src/lib/lottie/icons/qhviklyi.json"
                                    trigger="loop"
                                    delay="2000"
                                    colors="primary:#0d6efd,secondary:#ffc107"
                                    style="width:28px;height:28px;vertical-align:middle;">
                                </lord-icon>
                                Resumen de Nomina
                            </h5>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-light" t-on-click="toggleFullscreen" title="Pantalla completa">
                                    <i t-att-class="'fa ' + (state.isFullscreen ? 'fa-compress' : 'fa-expand')"/>
                                </button>
                                <button class="btn btn-sm btn-light" t-on-click="onViewPayslips" t-if="hasData" title="Ver Nominas">
                                    <i class="fa fa-external-link"/>
                                </button>
                            </div>
                        </div>

                        <!-- Body -->
                        <div t-att-class="state.isFullscreen ? 'modal-body' : 'card-body p-0'">
                            <t t-if="!hasData">
                                <div class="text-center text-muted py-4">
                                    <lord-icon
                                        src="/lavish_hr_payroll/static/src/lib/lottie/icons/qhviklyi.json"
                                        trigger="loop"
                                        delay="2000"
                                        colors="primary:#6c757d"
                                        style="width:64px;height:64px;">
                                    </lord-icon>
                                    <p class="mt-2 mb-0">No hay datos de nomina en el periodo</p>
                                </div>
                            </t>
                            <t t-else="">
                                <!-- Totals Summary -->
                                <div class="d-flex justify-content-around py-3 border-bottom bg-light">
                                    <div class="text-center">
                                        <lord-icon
                                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/qhviklyi.json"
                                            trigger="loop"
                                            delay="3000"
                                            colors="primary:#198754"
                                            style="width:32px;height:32px;">
                                        </lord-icon>
                                        <div class="fw-bold text-success" t-esc="totalDevengos"/>
                                        <small class="text-muted d-block">Devengos</small>
                                    </div>
                                    <div class="text-center">
                                        <lord-icon
                                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/vduvxizq.json"
                                            trigger="loop"
                                            delay="3000"
                                            colors="primary:#dc3545"
                                            style="width:32px;height:32px;">
                                        </lord-icon>
                                        <div class="fw-bold text-danger" t-esc="totalDeducciones"/>
                                        <small class="text-muted d-block">Deducciones</small>
                                    </div>
                                    <div class="text-center">
                                        <lord-icon
                                            src="/lavish_hr_payroll/static/src/lib/lottie/icons/yeallgsa.json"
                                            trigger="loop"
                                            delay="3000"
                                            colors="primary:#0d6efd"
                                            style="width:32px;height:32px;">
                                        </lord-icon>
                                        <div class="fw-bold text-primary" t-esc="totalNeto"/>
                                        <small class="text-muted d-block">Neto</small>
                                    </div>
                                </div>

                                <!-- Stats -->
                                <div class="d-flex justify-content-center gap-4 py-2 border-bottom">
                                    <span class="badge bg-secondary">
                                        <i class="fa fa-file-alt me-1"/>
                                        <t t-esc="payslipsCount"/> nominas
                                    </span>
                                    <span class="badge bg-secondary">
                                        <i class="fa fa-users me-1"/>
                                        <t t-esc="employeesCount"/> empleados
                                    </span>
                                </div>

                                <!-- Tabs -->
                                <ul class="nav nav-tabs nav-fill border-bottom-0 mt-2">
                                    <li class="nav-item">
                                        <a t-att-class="'nav-link ' + (state.activeTab === 'devengos' ? 'active' : '')"
                                           href="#" t-on-click.prevent="() => this.setActiveTab('devengos')">
                                            <i class="fa fa-plus-circle text-success me-1"/>
                                            Devengos
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a t-att-class="'nav-link ' + (state.activeTab === 'deducciones' ? 'active' : '')"
                                           href="#" t-on-click.prevent="() => this.setActiveTab('deducciones')">
                                            <i class="fa fa-minus-circle text-danger me-1"/>
                                            Deducciones
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a t-att-class="'nav-link ' + (state.activeTab === 'todos' ? 'active' : '')"
                                           href="#" t-on-click.prevent="() => this.setActiveTab('todos')">
                                            <i class="fa fa-list me-1"/>
                                            Todos
                                        </a>
                                    </li>
                                </ul>

                                <!-- Items List -->
                                <div class="list-group list-group-flush scrollable-list" t-att-style="state.isFullscreen ? 'max-height: 50vh;' : 'max-height: 250px;'">
                                    <!-- Devengos Tab -->
                                    <t t-if="state.activeTab === 'devengos'">
                                        <t t-foreach="devengosItems" t-as="item" t-key="'dev_' + item_index">
                                            <div class="list-group-item list-group-item-action px-3 py-2 cursor-pointer"
                                                 t-on-click="() => this.onViewDetail(item.key)"
                                                 style="cursor: pointer;">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <lord-icon
                                                            t-att-src="getLordicon(item.key)"
                                                            trigger="hover"
                                                            t-att-colors="'primary:#198754'"
                                                            style="width:24px;height:24px;">
                                                        </lord-icon>
                                                        <span t-esc="item.name"/>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="fw-bold text-success" t-esc="item.formatted"/>
                                                        <small class="text-muted d-block">
                                                            <t t-esc="item.employees_count"/> empleados
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="devengosItems.length === 0">
                                            <div class="text-center text-muted py-3">
                                                <i class="fa fa-info-circle me-1"/>
                                                No hay devengos en este periodo
                                            </div>
                                        </t>
                                    </t>

                                    <!-- Deducciones Tab -->
                                    <t t-if="state.activeTab === 'deducciones'">
                                        <t t-foreach="deduccionesItems" t-as="item" t-key="'ded_' + item_index">
                                            <div class="list-group-item list-group-item-action px-3 py-2 cursor-pointer"
                                                 t-on-click="() => this.onViewDetail(item.key)"
                                                 style="cursor: pointer;">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <lord-icon
                                                            t-att-src="getLordicon(item.key)"
                                                            trigger="hover"
                                                            t-att-colors="'primary:#dc3545'"
                                                            style="width:24px;height:24px;">
                                                        </lord-icon>
                                                        <span t-esc="item.name"/>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="fw-bold text-danger" t-esc="item.formatted"/>
                                                        <small class="text-muted d-block">
                                                            <t t-esc="item.employees_count"/> empleados
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="deduccionesItems.length === 0">
                                            <div class="text-center text-muted py-3">
                                                <i class="fa fa-info-circle me-1"/>
                                                No hay deducciones en este periodo
                                            </div>
                                        </t>
                                    </t>

                                    <!-- All Items Tab -->
                                    <t t-if="state.activeTab === 'todos'">
                                        <t t-foreach="allItems" t-as="item" t-key="'all_' + item_index">
                                            <div class="list-group-item list-group-item-action px-3 py-2 cursor-pointer"
                                                 t-on-click="() => this.onViewDetail(item.key)"
                                                 style="cursor: pointer;">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <lord-icon
                                                            t-att-src="getLordicon(item.key)"
                                                            trigger="hover"
                                                            t-att-colors="'primary:#0d6efd'"
                                                            style="width:24px;height:24px;">
                                                        </lord-icon>
                                                        <span t-esc="item.name"/>
                                                    </div>
                                                    <div class="text-end">
                                                        <span t-att-class="'fw-bold text-' + item.color" t-esc="item.formatted"/>
                                                        <small class="text-muted d-block">
                                                            <t t-esc="item.employees_count"/> empleados
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                </div>
                            </t>
                        </div>

                        <!-- Fullscreen Footer -->
                        <div t-if="state.isFullscreen" class="modal-footer">
                            <button class="btn btn-secondary" t-on-click="toggleFullscreen">
                                <i class="fa fa-times me-1"/> Cerrar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Backdrop for fullscreen -->
            <div t-if="state.isFullscreen" class="modal-backdrop fade show" t-on-click="toggleFullscreen"/>
        </div>
    </t>

</templates>
