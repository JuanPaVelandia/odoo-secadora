<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.DisabilityChart">
        <!-- Vista colapsada - solo recuadro con nombre -->
        <t t-if="state.collapsed">
            <div class="card h-100 cursor-pointer" t-on-click="toggleCollapse" style="background-color: #f8f9fa;">
                <div class="card-body d-flex justify-content-between align-items-center py-2">
                    <h6 class="mb-0 text-muted">
                        <i class="fa fa-medkit me-2"/>
                        Incapacidades por Tipo
                    </h6>
                    <i class="fa fa-eye text-muted"/>
                </div>
            </div>
        </t>

        <!-- Vista expandida - tarjeta completa -->
        <div class="card h-100" t-if="!state.collapsed">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fa fa-medkit me-2"/>
                    Incapacidades por Tipo
                </h5>
                <div class="d-flex gap-2" t-if="hasData">
                    <button class="btn btn-sm btn-light" t-on-click="toggleCollapse" title="Ocultar/Mostrar">
                        <i class="fa fa-eye-slash"/>
                    </button>
                    <button class="btn btn-sm btn-light" t-on-click="onViewAllDisabilities">
                        <i class="fa fa-external-link"/>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <t t-if="!hasData">
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-info-circle fa-2x mb-2"/>
                        <p>No hay incapacidades registradas en el período</p>
                    </div>
                </t>
                <t t-else="">
                    <!-- Summary Cards -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="card bg-info border-info">
                                <div class="card-body p-2 text-center">
                                    <small class="text-white d-block">Total Días</small>
                                    <h4 class="mb-0 text-white" t-esc="totalDays"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card bg-warning border-warning">
                                <div class="card-body p-2 text-center">
                                    <small class="text-white d-block">Total Casos</small>
                                    <h4 class="mb-0 text-white" t-esc="totalCases"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Disability Items -->
                    <div class="list-group list-group-flush">
                        <t t-foreach="disabilityItems" t-as="item" t-key="item_index">
                            <div class="list-group-item px-2 py-2 cursor-pointer" t-on-click="() => this.onViewDisability(item.code)">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <i t-att-class="'fa ' + item.icon + ' ' + item.color + ' fa-lg'"/>
                                        <div>
                                            <strong t-esc="item.code"/>
                                            <small class="text-muted d-block" t-esc="item.name"/>
                                        </div>
                                    </div>
                                    <!-- Trend Indicator -->
                                    <div class="d-flex align-items-center gap-1" t-if="item.trend !== undefined">
                                        <t t-set="trend" t-value="getTrendIcon(item)"/>
                                        <i t-att-class="'fa ' + trend.icon + ' ' + trend.color" t-att-title="trend.text"/>
                                        <small t-att-class="'fw-bold ' + trend.color" t-esc="trend.text"/>
                                    </div>
                                </div>

                                <div class="row g-2">
                                    <!-- Days -->
                                    <div class="col-6">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="small text-muted">
                                                <i class="fa fa-calendar me-1"/>
                                                Días
                                            </span>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-info bg-opacity-10 text-info">
                                                    <t t-esc="getPercentageDays(item.days)"/>%
                                                </span>
                                                <strong t-esc="item.days"/>
                                            </div>
                                        </div>
                                        <!-- Progress bar for days -->
                                        <div class="progress" style="height: 4px;">
                                            <div class="progress-bar bg-info"
                                                 t-att-style="'width: ' + getPercentageDays(item.days) + '%'"/>
                                        </div>
                                    </div>

                                    <!-- Cases -->
                                    <div class="col-6">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="small text-muted">
                                                <i class="fa fa-file-alt me-1"/>
                                                Casos
                                            </span>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-warning bg-opacity-10 text-warning">
                                                    <t t-esc="getPercentageCases(item.cases)"/>%
                                                </span>
                                                <strong t-esc="item.cases"/>
                                            </div>
                                        </div>
                                        <!-- Progress bar for cases -->
                                        <div class="progress" style="height: 4px;">
                                            <div class="progress-bar bg-warning"
                                                 t-att-style="'width: ' + getPercentageCases(item.cases) + '%'"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Rules Detail -->
                                <div class="mt-2 pt-2 border-top" t-if="hasRules(item)">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <i class="fa fa-cogs text-muted small"/>
                                        <small class="text-muted fw-bold">Reglas Aplicadas:</small>
                                    </div>
                                    <div class="d-flex flex-wrap gap-1">
                                        <t t-foreach="getRules(item)" t-as="rule" t-key="rule_index">
                                            <span class="badge bg-secondary bg-opacity-25 text-dark" t-att-title="rule.name">
                                                <i class="fa fa-code me-1"/>
                                                <t t-esc="rule.code"/>
                                                <t t-if="rule.amount">
                                                    - <t t-esc="rule.amount"/>
                                                </t>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>

                    <!-- Legend -->
                    <div class="mt-3 pt-2 border-top">
                        <small class="text-muted">
                            <i class="fa fa-info-circle me-1"/>
                            Haga clic en un tipo para ver detalles
                        </small>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
