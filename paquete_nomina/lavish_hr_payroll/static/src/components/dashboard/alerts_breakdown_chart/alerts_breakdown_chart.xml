<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.AlertsBreakdownChart">
        <div class="card h-100">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fa fa-bell text-danger me-2"/>
                        Distribucion de alertas
                    </h5>
                    <span class="badge bg-secondary" t-if="hasData">
                        Total: <t t-esc="total"/>
                    </span>
                </div>
            </div>
            <div class="card-body">
                <t t-if="!hasData">
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-info-circle fa-2x mb-2"/>
                        <p class="mb-0">No hay alertas para el periodo</p>
                    </div>
                </t>
                <t t-else="">
                    <div style="height: 220px; position: relative;">
                        <canvas t-ref="chartCanvas"/>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
