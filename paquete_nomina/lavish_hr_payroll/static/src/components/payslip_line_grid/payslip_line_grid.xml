<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PayslipLineGrid">
        <div class="o_payslip_line_grid h-100 d-flex flex-column">

            <!-- Header -->
            <div class="bg-white shadow-sm border-bottom px-3 py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="mb-0 d-flex align-items-center gap-2">
                        <span class="rounded-circle d-inline-flex align-items-center justify-content-center"
                              style="width: 36px; height: 36px; background-color: #333;">
                            <i class="fa fa-th text-white"/>
                        </span>
                        Grid de Nomina
                        <span class="badge" style="background-color: #666;" t-if="state.employees.length">
                            <t t-esc="state.employees.length"/> empleados
                        </span>
                        <span class="badge" style="background-color: #444;" t-if="state.concepts.length">
                            <t t-esc="state.concepts.length"/> conceptos
                        </span>
                    </h5>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm" style="background-color: #333; color: #fff; border-color: #333;" t-on-click="exportPDF">
                            <i class="fa fa-file-pdf-o me-1"/>PDF
                        </button>
                        <button class="btn btn-sm" style="background-color: #555; color: #fff; border-color: #555;" t-on-click="exportExcel">
                            <i class="fa fa-file-excel-o me-1"/>Excel
                        </button>
                        <button class="btn btn-sm" style="background-color: #1d4ed8; color: #fff; border-color: #1d4ed8;" t-on-click="exportExcelCompiled">
                            <i class="fa fa-table me-1"/>Excel Compilado
                        </button>
                        <button class="btn btn-sm" style="background-color: #777; color: #fff; border-color: #777;" t-on-click="loadGridData">
                            <i class="fa fa-refresh me-1"/>Actualizar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Filtros -->
            <div class="bg-light border-bottom px-3 py-2">
                <div class="row g-2 align-items-end">
                    <!-- Lote -->
                    <div class="col-auto">
                        <label class="form-label small text-muted mb-0">Lote</label>
                        <select class="form-select form-select-sm" style="min-width: 200px;"
                                t-on-change="onPayslipRunChange">
                            <option value="">-- Seleccionar --</option>
                            <t t-foreach="state.payslipRuns" t-as="run" t-key="run.id">
                                <option t-att-value="run.id"
                                        t-att-selected="run.id === state.filters.payslipRunId">
                                    <t t-esc="run.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <!-- Departamento -->
                    <div class="col-auto">
                        <label class="form-label small text-muted mb-0">Departamento</label>
                        <select class="form-select form-select-sm" style="min-width: 150px;"
                                t-on-change="onDepartmentChange">
                            <option value="">Todos</option>
                            <t t-foreach="state.departments" t-as="dept" t-key="dept.id">
                                <option t-att-value="dept.id">
                                    <t t-esc="dept.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <!-- Buscar -->
                    <div class="col-auto">
                        <label class="form-label small text-muted mb-0">Buscar empleado</label>
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Nombre o ID..."
                               style="min-width: 150px;"
                               t-att-value="state.filters.searchText"
                               t-on-input="onSearchChange"/>
                    </div>
                    <!-- Mostrar ceros -->
                    <div class="col-auto">
                        <div class="form-check form-switch">
                            <input type="checkbox" class="form-check-input" id="showZero"
                                   t-att-checked="state.showZeroColumns"
                                   disabled="disabled"
                                   t-on-change="onShowZeroChange"/>
                            <label class="form-check-label small" for="showZero">Mostrar columnas en cero (siempre activo)</label>
                        </div>
                    </div>
                    <!-- Mostrar nombre o codigo -->
                    <div class="col-auto">
                        <button class="btn btn-sm"
                                t-att-style="state.showRuleName ? 'background-color: #333; color: #fff; border-color: #333;' : 'background-color: #fff; color: #333; border-color: #333;'"
                                t-on-click="toggleRuleDisplay"
                                title="Alternar entre codigo y nombre de regla">
                            <i class="fa fa-exchange me-1"/>
                            <t t-if="state.showRuleName">Nombre</t>
                            <t t-else="">Codigo</t>
                        </button>
                    </div>
                </div>
                <!-- Estados -->
                <div class="d-flex align-items-center gap-2 mt-2">
                    <span class="small text-muted"><i class="fa fa-flag me-1"/>Estados:</span>
                    <t t-foreach="payslipStates" t-as="st" t-key="st.value">
                        <button class="btn btn-sm"
                                t-att-style="isStateSelected(st.value) ? 'background-color: #333; color: #fff; border-color: #333;' : 'background-color: #fff; color: #333; border-color: #999;'"
                                t-on-click="() => this.toggleState(st.value)"
                                style="padding: 2px 8px; font-size: 0.75rem;">
                            <i t-attf-class="fa {{ st.icon }} me-1"/>
                            <t t-esc="st.label"/>
                        </button>
                    </t>
                    <button class="btn btn-sm ms-2" style="background-color: #666; color: #fff; border-color: #666; padding: 2px 6px; font-size: 0.7rem;"
                            t-on-click="selectAllStates" title="Todos">
                        <i class="fa fa-check-square-o"/>
                    </button>
                    <button class="btn btn-sm" style="background-color: #999; color: #fff; border-color: #999; padding: 2px 6px; font-size: 0.7rem;"
                            t-on-click="clearAllStates" title="Ninguno">
                        <i class="fa fa-square-o"/>
                    </button>
                </div>
            </div>

            <!-- Loading -->
            <div t-if="state.loading" class="flex-grow-1 d-flex align-items-center justify-content-center">
                <div class="text-center text-muted">
                    <i class="fa fa-spinner fa-spin fa-3x mb-3"/>
                    <p>Cargando datos...</p>
                </div>
            </div>

            <!-- Sin datos -->
            <div t-elif="state.employees.length === 0" class="flex-grow-1 d-flex align-items-center justify-content-center">
                <div class="text-center text-muted">
                    <i class="fa fa-inbox fa-4x mb-3 opacity-50"/>
                    <h5>No hay datos para mostrar</h5>
                    <p>Selecciona un lote y ajusta los filtros</p>
                </div>
            </div>

            <!-- Grid Horizontal -->
            <div t-else="" class="flex-grow-1 overflow-auto">
                <div class="o_grid_wrapper" style="min-width: 100%;">
                    <table class="table table-sm table-bordered table-hover mb-0" style="font-size: 0.8rem;">
                        <thead class="table-dark sticky-top" style="top: 0; z-index: 10;">
                            <tr>
                                <!-- Columna fija: Empleado -->
                                <th class="sticky-start bg-dark text-white"
                                    style="position: sticky; left: 0; z-index: 11; min-width: 180px;">
                                    Empleado
                                </th>
                                <th class="sticky-start bg-dark text-white text-center"
                                    style="position: sticky; left: 180px; z-index: 11; min-width: 90px;">
                                    ID
                                </th>
                                <th class="sticky-start bg-dark text-white text-center"
                                    style="position: sticky; left: 270px; z-index: 11; min-width: 120px;">
                                    Departamento
                                </th>
                                <th class="sticky-start bg-dark text-white text-center"
                                    style="position: sticky; left: 390px; z-index: 11; min-width: 120px;">
                                    Cargo
                                </th>
                                <!-- Columnas de conceptos -->
                                <t t-foreach="state.concepts" t-as="concept" t-key="concept.code">
                                    <th class="text-center text-nowrap" style="min-width: 90px;"
                                        t-att-title="state.showRuleName ? concept.code : concept.name">
                                        <div class="small">
                                            <t t-if="state.showRuleName"><t t-esc="concept.name"/></t>
                                            <t t-else=""><t t-esc="concept.code"/></t>
                                        </div>
                                    </th>
                                </t>
                                <!-- Total empleado -->
                                <th class="text-white text-center sticky-end"
                                    style="position: sticky; right: 0; z-index: 11; min-width: 120px; background-color: #000;">
                                    TOTAL
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.employees" t-as="emp" t-key="emp.id">
                                <tr>
                                    <!-- Nombre empleado -->
                                    <td class="sticky-start bg-white fw-bold"
                                        style="position: sticky; left: 0; z-index: 5; cursor: pointer;"
                                        t-on-click="() => this.openEmployee(emp.id)">
                                        <i class="fa fa-user text-muted me-1"/>
                                        <t t-esc="emp.name"/>
                                    </td>
                                    <!-- ID empleado -->
                                    <td class="sticky-start bg-white text-center text-muted small"
                                        style="position: sticky; left: 180px; z-index: 5;">
                                        <t t-esc="emp.identification_id or '-'"/>
                                    </td>
                                    <!-- Departamento -->
                                    <td class="sticky-start bg-white text-center text-muted small"
                                        style="position: sticky; left: 270px; z-index: 5;">
                                        <t t-esc="emp.department_id ? emp.department_id[1] : '-'"/>
                                    </td>
                                    <!-- Cargo -->
                                    <td class="sticky-start bg-white text-center text-muted small"
                                        style="position: sticky; left: 390px; z-index: 5;">
                                        <t t-esc="emp.job_id ? emp.job_id[1] : '-'"/>
                                    </td>
                                    <!-- Valores por concepto -->
                                    <t t-foreach="state.concepts" t-as="concept" t-key="concept.code">
                                        <t t-set="cellValue" t-value="getCellValue(emp.id, concept.code)"/>
                                        <td class="text-end"
                                            t-att-class="getCellClass(cellValue)">
                                            <t t-if="cellValue !== null">
                                                <t t-esc="formatNumber(cellValue)"/>
                                            </t>
                                            <t t-else="">
                                                <span class="text-muted">-</span>
                                            </t>
                                        </td>
                                    </t>
                                    <!-- Total empleado -->
                                    <td class="sticky-end bg-light text-end fw-bold"
                                        style="position: sticky; right: 0; z-index: 5;">
                                        <t t-esc="formatCurrency(state.totals.byEmployee[emp.id] || 0)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot class="sticky-bottom" style="bottom: 0; z-index: 10;">
                            <tr class="fw-bold">
                                <td class="sticky-start text-white"
                                    style="position: sticky; left: 0; z-index: 11; background-color: #333;" colspan="4">
                                    TOTALES
                                </td>
                                <t t-foreach="state.concepts" t-as="concept" t-key="concept.code">
                                    <td class="text-end" style="background-color: #e0e0e0;">
                                        <t t-esc="formatNumber(state.totals.byConcept[concept.code] || 0)"/>
                                    </td>
                                </t>
                                <td class="sticky-end text-white text-end"
                                    style="position: sticky; right: 0; z-index: 11; background-color: #000;">
                                    <t t-esc="formatCurrency(state.totals.general)"/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

        </div>
    </t>

</templates>
