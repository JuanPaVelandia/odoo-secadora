<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="mail_template_vacation_approved" model="mail.template">
    <field name="name">Vacaciones: Notificacion de Aprobacion</field>
    <field name="model_id" ref="hr_holidays.model_hr_leave"/>
    <field name="subject">Vacaciones Aprobadas - {{ object.employee_id.name }}</field>
    <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
    <field name="email_to">{{ object.employee_id.work_email }}</field>
    <field name="body_html"><![CDATA[
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Estimado(a) <strong><t t-out="object.employee_id.name"/></strong>,
        <br/><br/>
        Le informamos que su solicitud de vacaciones ha sido <strong>APROBADA</strong>.
        <br/><br/>
    </p>
    <table border="0" cellpadding="5" cellspacing="0" style="width: 100%; border-collapse: collapse;">
        <tr style="background-color: #875A7B; color: white;">
            <th colspan="2" style="padding: 10px; text-align: left;">Detalle de Vacaciones</th>
        </tr>
        <tr>
            <td style="border: 1px solid #ddd; padding: 8px;"><strong>Tipo:</strong></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><t t-out="object.holiday_status_id.name"/></td>
        </tr>
        <tr>
            <td style="border: 1px solid #ddd; padding: 8px;"><strong>Fecha Inicio:</strong></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><t t-out="object.date_from.strftime('%d/%m/%Y')"/></td>
        </tr>
        <tr>
            <td style="border: 1px solid #ddd; padding: 8px;"><strong>Fecha Fin:</strong></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><t t-out="object.date_to.strftime('%d/%m/%Y')"/></td>
        </tr>
        <tr>
            <td style="border: 1px solid #ddd; padding: 8px;"><strong>Dias:</strong></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><t t-out="object.number_of_days"/> dias</td>
        </tr>
    </table>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Disfrute sus vacaciones.
        <br/><br/>
        Atentamente,<br/>
        <strong>Recursos Humanos</strong><br/>
        <t t-out="object.company_id.name"/>
    </p>
</div>
]]></field>
    <field name="auto_delete" eval="False"/>
</record>

</odoo>
