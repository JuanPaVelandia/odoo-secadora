<odoo>
    <data noupdate="1">
        <!-- Generador XML para Nómina Electrónica Carvajal -->
        <record id="xml_generator_nomina_carvajal" model="lavish.xml.generator.header">
            <field name="name">Nómina Electrónica Carvajal</field>
            <field name="code">NomElectronica_Carvajal</field>
            <field name="active">True</field>
            <field name="xml_template"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<NominaIndividual xmlns="dian:gov:co:facturaelectronica:NominaIndividual" 
                  xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ext:UBLExtensions/>
    <Informacion>
        <TipoNota>1</TipoNota>
        <TipoDocumento>102</TipoDocumento>
        <FechaGen>{fecha_generacion}</FechaGen>
        <HoraGen>{hora_generacion}</HoraGen>
        <PeriodoNomina>
            <FechaIngreso>{fecha_inicio_periodo}</FechaIngreso>
            <FechaRetiro>{fecha_fin_periodo}</FechaRetiro>
            <TiempoLaborado>{tiempo_laborado}</TiempoLaborado>
            <FechaGen>{fecha_generacion}</FechaGen>
        </PeriodoNomina>
        <NumeroSecuenciaXML>
            <Numero>{consecutivo}</Numero>
            <Prefijo>{prefijo}</Prefijo>
        </NumeroSecuenciaXML>
        <LugarGeneracionXML>
            <Pais>CO</Pais>
            <DepartamentoEstado>11</DepartamentoEstado>
            <MunicipioC>11001</MunicipioC>
            <Idioma>es</Idioma>
        </LugarGeneracionXML>
        <ProveedorXML>
            <RazonSocial>{razon_social_empleador}</RazonSocial>
            <NIT>{nit_empleador}</NIT>
        </ProveedorXML>
        <CodigoQR/>
    </Informacion>
    <Empleador>
        <RazonSocial>{razon_social_empleador}</RazonSocial>
        <NIT>{nit_empleador}</NIT>
        <DV>{dv_empleador}</DV>
        <Pais>CO</Pais>
        <DepartamentoEstado>11</DepartamentoEstado>
        <MunicipioC>11001</MunicipioC>
        <Direccion>{direccion_empleador}</Direccion>
    </Empleador>
    <Trabajador>
        <TipoTrabajador>{tipo_trabajador}</TipoTrabajador>
        <SubTipoTrabajador>{subtipo_trabajador}</SubTipoTrabajador>
        <AltoRiesgoPension>false</AltoRiesgoPension>
        <TipoDocumento>13</TipoDocumento>
        <NumeroDocumento>{numero_documento_empleado}</NumeroDocumento>
        <PrimerApellido>{primer_apellido}</PrimerApellido>
        <SegundoApellido>{segundo_apellido}</SegundoApellido>
        <PrimerNombre>{primer_nombre}</PrimerNombre>
        <OtrosNombres>{otros_nombres}</OtrosNombres>
        <LugarTrabajoPais>CO</LugarTrabajoPais>
        <LugarTrabajoDepartamentoEstado>11</LugarTrabajoDepartamentoEstado>
        <LugarTrabajoMunicipioC>11001</LugarTrabajoMunicipioC>
        <LugarTrabajoDireccion>{direccion_trabajo}</LugarTrabajoDireccion>
        <SalarioIntegral>false</SalarioIntegral>
        <TipoContrato>{tipo_contrato}</TipoContrato>
        <Sueldo>{sueldo}</Sueldo>
        <CodigoTrabajador>{codigo_trabajador}</CodigoTrabajador>
    </Trabajador>
    <Pago>
        <Forma>1</Forma>
        <Metodo>42</Metodo>
        <Banco>{banco}</Banco>
        <TipoCuenta>{tipo_cuenta}</TipoCuenta>
        <NumeroCuenta>{numero_cuenta}</NumeroCuenta>
    </Pago>
    <FechasPagos>
        <FechaPago>{fecha_pago}</FechaPago>
    </FechasPagos>
    <Devengados>
        <Basico>
            <DiasTrabajados>{dias_trabajados}</DiasTrabajados>
            <SueldoTrabajado>{sueldo_trabajado}</SueldoTrabajado>
        </Basico>
    </Devengados>
    <Deducciones>
        <Salud>
            <Porcentaje>4.00</Porcentaje>
            <Deduccion>{deduccion_salud}</Deduccion>
        </Salud>
        <FondoPension>
            <Porcentaje>4.00</Porcentaje>
            <Deduccion>{deduccion_pension}</Deduccion>
        </FondoPension>
    </Deducciones>
    <ComprobanteTotal>{comprobante_total}</ComprobanteTotal>
</NominaIndividual>]]></field>
        </record>

