<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_concept_reconcile_wizard_form" model="ir.ui.view">
        <field name="name">hr.concept.reconcile.wizard.form</field>
        <field name="model">hr.concept.reconcile.wizard</field>
        <field name="arch" type="xml">
            <form string="Conciliar Novedades">
                <sheet>
                    <group>
                        <group>
                            <field name="payslip_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="contract_id" readonly="1"/>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="lines_found" readonly="1"/>
                        </group>
                        <group>
                            <field name="lines_matched" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lineas a Conciliar" name="lines">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom" decoration-success="match_type == 'exact'" decoration-warning="match_type == 'rule'" decoration-danger="match_type == 'none'">
                                    <field name="apply_reconcile" widget="boolean_toggle"/>
                                    <field name="rule_code"/>
                                    <field name="salary_rule_id"/>
                                    <field name="line_amount" sum="Total"/>
                                    <field name="concept_id" options="{'no_create': True}"/>
                                    <field name="concept_amount"/>
                                    <field name="difference"/>
                                    <field name="match_type" widget="badge" decoration-success="match_type == 'exact'" decoration-warning="match_type == 'rule'" decoration-danger="match_type == 'none'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <footer>
                    <button name="action_search_matches" type="object" string="Buscar Coincidencias" class="btn-secondary" icon="fa-search"/>
                    <button name="action_apply_reconcile" type="object" string="Aplicar Conciliacion" class="btn-primary" icon="fa-check"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_concept_reconcile_wizard" model="ir.actions.act_window">
        <field name="name">Conciliar Novedades</field>
        <field name="res_model">hr.concept.reconcile.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
    </record>

</odoo>
