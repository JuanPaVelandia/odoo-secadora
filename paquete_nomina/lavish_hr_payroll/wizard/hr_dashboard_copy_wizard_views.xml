<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Copy Wizard Form View -->
    <record id="view_hr_dashboard_copy_wizard_form" model="ir.ui.view">
        <field name="name">hr.dashboard.copy.wizard.form</field>
        <field name="model">hr.dashboard.copy.wizard</field>
        <field name="arch" type="xml">
            <form string="Copiar Dashboard a Usuarios">
                <group>
                    <group>
                        <field name="dashboard_id" readonly="1"/>
                        <field name="user_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="copy_as_default"/>
                        <field name="replace_existing"/>
                    </group>
                </group>
                <footer>
                    <button string="Copiar Dashboard" name="action_copy_dashboard" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Dashboard Copy Wizard Action -->
    <record id="action_hr_dashboard_copy_wizard" model="ir.actions.act_window">
        <field name="name">Copiar Dashboard a Usuarios</field>
        <field name="res_model">hr.dashboard.copy.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_dashboard"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
