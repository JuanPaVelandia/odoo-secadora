<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="report_leave_certificate_action" model="ir.actions.report">
    <field name="name">Certificado de Ausencia</field>
    <field name="model">hr.leave</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">lavish_hr_payroll.report_leave_certificate_template</field>
    <field name="report_file">lavish_hr_payroll.report_leave_certificate_template</field>
    <field name="print_report_name">'Certificado_Ausencia_%s_%s' % (object.holiday_status_id.name, object.employee_id.name)</field>
    <field name="binding_model_id" ref="hr_holidays.model_hr_leave"/>
    <field name="binding_type">report</field>
</record>

<template id="report_leave_certificate_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="text-center mb-4">
                        <h3><strong>CERTIFICADO DE AUSENCIA</strong></h3>
                        <h5><span t-field="o.holiday_status_id.name"/></h5>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <p class="text-justify">
                                La empresa <strong><span t-field="o.employee_id.company_id.name"/></strong>,
                                identificada con NIT <strong><span t-field="o.employee_id.company_id.vat"/></strong>,
                                certifica que:
                            </p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <h5><strong>Datos del Empleado</strong></h5>
                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <td width="25%"><strong>Nombre Completo:</strong></td>
                                        <td width="25%"><span t-field="o.employee_id.name"/></td>
                                        <td width="25%"><strong>Identificacion:</strong></td>
                                        <td width="25%"><span t-field="o.employee_id.identification_id"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Cargo:</strong></td>
                                        <td><span t-field="o.employee_id.job_id.name"/></td>
                                        <td><strong>Departamento:</strong></td>
                                        <td><span t-field="o.employee_id.department_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Fecha Ingreso:</strong></td>
                                        <td><span t-field="o.employee_id.contract_id.date_start"/></td>
                                        <td><strong>Tipo Contrato:</strong></td>
                                        <td><span t-field="o.employee_id.contract_id.contract_type_id.name"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <h5><strong>Detalle de la Ausencia</strong></h5>
                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <td width="25%"><strong>Tipo de Ausencia:</strong></td>
                                        <td width="25%"><span t-field="o.holiday_status_id.name"/></td>
                                        <td width="25%"><strong>Estado:</strong></td>
                                        <td width="25%">
                                            <t t-if="o.state == 'draft'">Borrador</t>
                                            <t t-if="o.state == 'confirm'">Por Aprobar</t>
                                            <t t-if="o.state == 'validate1'">Segunda Aprobacion</t>
                                            <t t-if="o.state == 'validate'">Aprobada</t>
                                            <t t-if="o.state == 'refuse'">Rechazada</t>
                                            <t t-if="o.state == 'cancel'">Cancelada</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Fecha Inicio:</strong></td>
                                        <td><span t-field="o.date_from" t-options='{"widget": "date"}'/></td>
                                        <td><strong>Fecha Fin:</strong></td>
                                        <td><span t-field="o.date_to" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Numero de Dias:</strong></td>
                                        <td><span t-field="o.number_of_days"/></td>
                                        <td><strong>Dias Habiles:</strong></td>
                                        <td><span t-out="o.business_days or '-'"/></td>
                                    </tr>
                                    <tr t-if="o.payroll_value">
                                        <td><strong>Valor Reconocido:</strong></td>
                                        <td colspan="3"><span t-out="'{:,.0f}'.format(o.payroll_value or 0)"/> <span t-out="o.employee_id.company_id.currency_id.symbol or 'COP'"/></td>
                                    </tr>
                                    <tr t-if="o.return_date">
                                        <td><strong>Fecha de Regreso:</strong></td>
                                        <td colspan="3"><span t-field="o.return_date"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <t t-if="o.holiday_status_id.novelty in ['ige', 'irl']">
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5><strong>Informacion de Incapacidad</strong></h5>
                                <table class="table table-bordered">
                                    <tbody>
                                        <tr t-if="o.ibc">
                                            <td width="25%"><strong>IBC:</strong></td>
                                            <td><span t-out="'{:,.0f}'.format(o.ibc or 0)"/> <span t-out="o.employee_id.company_id.currency_id.symbol or 'COP'"/></td>
                                        </tr>
                                        <!-- entity_id no existe en hr.leave, comentado -->
                                        <!--<tr t-if="o.entity_id">
                                            <td width="25%"><strong>Entidad:</strong></td>
                                            <td><span t-field="o.entity_id.name"/></td>
                                        </tr>-->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>

                    <div class="row mb-4" t-if="o.name">
                        <div class="col-12">
                            <h5><strong>Observaciones</strong></h5>
                            <p class="border p-2"><span t-field="o.name"/></p>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <p class="text-justify">
                                Se expide el presente certificado a solicitud del interesado, para los fines que estime convenientes.
                            </p>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-12 text-center">
                            <p><strong>Fecha de expedicion:</strong> <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d de %B de %Y')"/></p>
                            <p><strong>Ciudad:</strong> <span t-out="o.employee_id.company_id.city or ''"/></p>
                        </div>
                    </div>

                    <div class="row mt-5">
                        <div class="col-6 text-center">
                            <br/><br/>
                            <p>____________________________</p>
                            <p><strong>Firma Empleado</strong></p>
                            <p><span t-field="o.employee_id.name"/></p>
                            <p>C.C. <span t-field="o.employee_id.identification_id"/></p>
                        </div>
                        <div class="col-6 text-center">
                            <br/><br/>
                            <p>____________________________</p>
                            <p><strong>Recursos Humanos</strong></p>
                            <p><span t-out="o.employee_id.company_id.name"/></p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </t>
</template>

</odoo>
