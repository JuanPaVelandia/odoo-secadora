<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_liquidacion_final_document">
    <head>
        <style>
            .clearfix:after {
                content: "";
                display: table;
                clear: both;
            }
            .table-wrapper {
                width: 48%;
                float: left;
                margin: 1%;
            }
        </style>
    </head>
    <t t-set="o" t-value="o.with_context(lang=o.employee_id.work_contact_id.lang or o.env.lang)"/>

    <div class="page" style="font-family: 'Helvetica', Arial, sans-serif;">

        <!-- Encabezado con logo -->
        <table style="width: 100%; margin-bottom: 20px;">
            <tr>
                <td style="width: 20%; vertical-align: middle;">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                         style="max-height: 70px;" alt="Logo"/>
                </td>
                <td style="width: 60%; text-align: center; vertical-align: middle;">
                    <div style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); padding: 15px; border-radius: 8px;">
                        <h2 style="color: white; margin: 0; font-size: 18px; letter-spacing: 1px;">
                            LIQUIDACION DE CONTRATO LABORAL
                        </h2>
                    </div>
                </td>
                <td style="width: 20%;"></td>
            </tr>
        </table>

        <!-- Informacion del empleado -->
        <div style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px;">
            <table style="width: 100%; font-size: 11px;">
                <tr>
                    <td style="width: 33%; padding: 5px; vertical-align: top;">
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Empleado:</strong>
                            <span t-field="o.employee_id.name"/>
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Identidad:</strong>
                            <span t-field="o.employee_id.identification_id"/>
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Fecha Ingreso:</strong>
                            <span t-field="o.contract_id.date_start"/>
                        </div>
                        <div style="margin-bottom: 8px; padding: 5px; background: #ffebee; border-radius: 4px; border-left: 3px solid #e74c3c;">
                            <strong style="color: #c0392b;">Fecha Retiro:</strong>
                            <span t-field="o.date_liquidacion"/>
                        </div>
                        <div>
                            <strong style="color: #2c3e50;">Dias Laborados:</strong>
                            <span style="background: #3498db; color: white; padding: 2px 8px; border-radius: 10px; font-size: 10px;">
                                <span t-out="o.dias360(o.contract_id.date_start,o.date_liquidacion)"/>
                            </span>
                        </div>
                    </td>
                    <td style="width: 33%; padding: 5px; vertical-align: top;">
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Tipo Contrato:</strong>
                            <span t-field="o.contract_id.contract_type"/>
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Ult. Cesantias:</strong>
                            <span t-field="o.date_cesantias"/>
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Ult. Prima:</strong>
                            <span t-field="o.date_prima"/>
                        </div>
                        <div>
                            <strong style="color: #2c3e50;">Ult. Vacaciones:</strong>
                            <span t-field="o.date_vacaciones"/>
                        </div>
                    </td>
                    <td style="width: 33%; padding: 5px; vertical-align: top;">
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Departamento:</strong>
                            <span t-field="o.employee_id.department_id.name"/>
                        </div>
                        <div style="margin-bottom: 8px; padding: 5px; background: #e8f5e9; border-radius: 4px; border-left: 3px solid #27ae60;">
                            <strong style="color: #27ae60;">Salario Basico:</strong>
                            <span t-field="o.contract_id.wage"/>
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong style="color: #2c3e50;">Cargo:</strong>
                            <span t-field="o.employee_id.job_id.name"/>
                        </div>
                        <div style="padding: 5px; background: #fff3e0; border-radius: 4px; border-left: 3px solid #e67e22;">
                            <strong style="color: #e67e22;">Motivo Retiro:</strong>
                            <span t-field="o.reason_retiro"/>
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Titulo detalle nomina -->
        <div style="text-align: center; margin-bottom: 15px;">
            <span style="background: linear-gradient(135deg, #34495e 0%, #2c3e50 100%); color: white; padding: 8px 25px; border-radius: 20px; font-size: 13px; font-weight: bold;">
                DETALLE NOMINA
            </span>
        </div>

        <!-- Grupos de conceptos -->
        <t t-set="groups" t-value="{
            'Devengos y Sueldo': ('DEV_SALARIAL', 'BASIC','COMISIONES','INDEM'),
            'Deducciones y Retenciones': ('DEDUCCIONES', 'EM','SSOCIAL'),
            'Horas extras y recargos': ('HEYREC',),
            'Devengos No Salariales': ('DEV_NO_SALARIAL','AUX'),
            'Licencias e Incapacidades': ('LICENCIA_MATERNIDAD', 'LICENCIA_NO_REMUNERADA', 'AUS','ACCIDENTE_TRABAJO','LICENCIA_REMUNERADA', 'INCAPACIDAD'),
            'Prestaciones' : ('PRESTACIONES_SOCIALES','PRIMA')
        }"/>

        <div class="clearfix" style="margin-bottom: 20px;">
            <t t-foreach="groups.items()" t-as="group">
                <t t-set="group_name" t-value="group[0]"/>
                <t t-set="group_categories" t-value="group[1]"/>
                <t t-set="group_lines" t-value="o.line_ids.filtered(lambda l: l.category_id.code in group_categories and l.salary_rule_id.appears_on_payslip)"/>
                <t t-if="group_lines">
                    <div class="table-wrapper">
                        <div style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); padding: 8px; border-radius: 6px 6px 0 0; text-align: center;">
                            <strong style="color: white; font-size: 11px;" t-out="group_name"/>
                        </div>
                        <table style="width: 100%; border-collapse: collapse; font-size: 10px; border: 1px solid #e0e0e0;">
                            <thead>
                                <tr style="background: #f8f9fa;">
                                    <th style="padding: 6px; border: 1px solid #e0e0e0; text-align: left; width: 50%;">CONCEPTO</th>
                                    <th style="padding: 6px; border: 1px solid #e0e0e0; text-align: center; width: 15%;">CANT.</th>
                                    <th style="padding: 6px; border: 1px solid #e0e0e0; text-align: right; width: 35%;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="group_lines" t-as="line" style="border-bottom: 1px solid #e0e0e0;">
                                    <td style="padding: 5px; border: 1px solid #e0e0e0;">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #e0e0e0; text-align: center;">
                                        <t t-if="line.salary_rule_id.display_days_worked">
                                            <span t-out="sum([i.number_of_days for i in o.worked_days_line_ids.filtered(lambda x: x.code == 'WORK100')])"/>
                                        </t>
                                        <t t-elif="line.code == 'VACCONTRATO'">
                                            <span t-out="'%.2f' % (line.quantity*0.0417)"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="line.quantity"/>
                                        </t>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #e0e0e0; text-align: right;">
                                        <span t-out="line.total" t-options="{'widget': 'monetary', 'precision': 0, 'display_currency': o.company_id.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr style="background: #f8f9fa; font-weight: bold;">
                                    <td style="padding: 6px; border: 1px solid #e0e0e0;">Total</td>
                                    <td style="padding: 6px; border: 1px solid #e0e0e0;"></td>
                                    <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: right;">
                                        <span t-out="sum(line.total for line in group_lines)" t-options="{'widget': 'monetary', 'precision': 0, 'display_currency': o.company_id.currency_id}"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </div>

        <!-- Neto a pagar -->
        <div style="margin-top: 20px; text-align: right;">
            <table style="width: 40%; margin-left: auto; border-collapse: collapse;">
                <tr style="background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);">
                    <td style="padding: 12px; color: white; font-weight: bold; font-size: 14px;">
                        NETO A PAGAR
                    </td>
                    <td style="padding: 12px; color: white; text-align: right; font-size: 16px; font-weight: bold;">
                        <span t-out="o.line_ids.filtered(lambda line: line.code == 'NET').total + o.line_ids.filtered(lambda line: line.code == 'NETO').total"
                              t-options="{'widget': 'monetary', 'precision': 0, 'display_currency': o.company_id.currency_id}"/>
                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="padding: 8px; font-size: 10px; font-style: italic; color: #666; text-align: right;">
                        <span t-out="o.contract_id.get_amount_text(o.line_ids.filtered(lambda line: line.code == 'NET').total + o.line_ids.filtered(lambda line: line.code == 'NETO').total).lower().capitalize()"/> pesos
                    </td>
                </tr>
            </table>
        </div>

    </div>
</template>

<template id="report_liquidacion_final">
     <t t-foreach="docs" t-as="o">
        <t t-set="inside_foreach_docs" t-value="o"/>
        <t t-call="lavish_hr_payroll.report_liquidacion_final_document" t-lang="o.employee_id.work_contact_id.lang"/>
    </t>
</template>

</odoo>
