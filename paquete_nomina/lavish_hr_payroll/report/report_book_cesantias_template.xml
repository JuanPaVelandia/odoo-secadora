<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_book_cesantias_document">
        <t t-call="web.html_container">
            <t t-foreach="inside_foreach_docs or docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', Arial, sans-serif;">

                        <!-- Encabezado -->
                        <div style="text-align: center; margin-bottom: 25px; padding: 15px; background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%); border-radius: 8px;">
                            <h2 style="color: white; margin: 0; font-size: 20px; letter-spacing: 1px;">
                                LIBRO DE CESANTIAS
                            </h2>
                        </div>

                        <!-- Informacion del empleado -->
                        <div style="margin-bottom: 20px; padding: 15px; border: 1px solid #e0e0e0; border-radius: 8px;">
                            <div style="background: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #9b59b6;">
                                <strong style="color: #2c3e50; font-size: 14px;">
                                    <span t-out="o.employee_id.identification_id"/> - <span t-out="o.employee_id.name"/>
                                </strong>
                            </div>
                        </div>

                        <!-- Tabla de cesantias -->
                        <div style="margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                                <thead>
                                    <tr style="background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);">
                                        <th style="padding: 10px; color: white; text-align: center; border: 1px solid #8e44ad; width: 14%;">
                                            Causacion Inicial
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: center; border: 1px solid #8e44ad; width: 14%;">
                                            Causacion Final
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: center; border: 1px solid #8e44ad; width: 14%;">
                                            Fecha de Corte
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: center; border: 1px solid #8e44ad; width: 12%;">
                                            Unidades Trabajadas
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: right; border: 1px solid #8e44ad; width: 15%;">
                                            Valor Base
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: right; border: 1px solid #8e44ad; width: 15%;">
                                            Valor Liquidado
                                        </th>
                                        <th style="padding: 10px; color: white; text-align: right; border: 1px solid #8e44ad; width: 16%;">
                                            Valor Int. Cesantias
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="total_base" t-value="0"/>
                                    <t t-set="total_cesantias" t-value="0"/>
                                    <t t-set="total_intereses" t-value="0"/>
                                    <tr t-foreach="o.get_info_book_cesantias()" t-as="info" style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.initial_accrual_date"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.final_accrual_date"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.settlement_date"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; background: #f3e5f5;">
                                            <span t-out="info.time"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="info.base_value" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                            <t t-set="total_base" t-value="total_base + info.base_value"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; background: #e8f5e9;">
                                            <strong style="color: #27ae60;">
                                                <span t-out="info.severance_value" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                            </strong>
                                            <t t-set="total_cesantias" t-value="total_cesantias + info.severance_value"/>
                                        </td>
                                        <td style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; background: #fff3e0;">
                                            <strong style="color: #e67e22;">
                                                <span t-out="info.severance_interest_value" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                            </strong>
                                            <t t-set="total_intereses" t-value="total_intereses + info.severance_interest_value"/>
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr style="background: #f8f9fa; font-weight: bold;">
                                        <td colspan="4" style="padding: 10px; border: 1px solid #e0e0e0; text-align: right;">
                                            TOTALES:
                                        </td>
                                        <td style="padding: 10px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="total_base" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                        <td style="padding: 10px; border: 1px solid #e0e0e0; text-align: right; background: #c8e6c9;">
                                            <strong style="color: #27ae60;">
                                                <span t-out="total_cesantias" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                            </strong>
                                        </td>
                                        <td style="padding: 10px; border: 1px solid #e0e0e0; text-align: right; background: #ffe0b2;">
                                            <strong style="color: #e67e22;">
                                                <span t-out="total_intereses" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Pie de pagina -->
                        <div style="margin-top: 30px; padding-top: 10px; border-top: 1px solid #e0e0e0; font-size: 9px; color: #999; text-align: center;">
                            Documento generado automaticamente -
                            <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_book_cesantias">
        <t t-foreach="docs" t-as="o">
            <t t-set="inside_foreach_docs" t-value="o"/>
            <t t-call="lavish_hr_payroll.report_book_cesantias_document"/>
        </t>
    </template>
</odoo>
