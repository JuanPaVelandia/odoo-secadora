<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="reports_payslip_header_footer_template">
            <t t-call="web.html_container">
            <t t-foreach="inside_foreach_docs or docs" t-as="o">
            <t t-set="cp_template" t-value="o.get_hr_payslip_reports_template()"/>
                <t t-if="cp_template.type_header_footer == 'default'">
                    <t t-call="web.external_layout">
                        <!-- Contenido dependiendo la estructura -->
                        <t t-if="cp_template.type_report == 'nomina'">
                            <t t-call="hr_payroll.report_payslip"/>
                        </t>
                        <t t-if="cp_template.type_report == 'vacaciones'">
                            <t t-call="lavish_hr_payroll.report_liquidacion_vacaciones_document"/>
                        </t>
                        <t t-if="cp_template.type_report in ('prima','cesantias','intereses_cesantias')">
                            <t t-call="lavish_hr_payroll.report_liquidacion_cesantias_prima_document"/>
                        </t>
                        <t t-if="cp_template.type_report == 'contrato'">
                            <t t-call="lavish_hr_payroll.report_liquidacion_final_document"/>
                        </t>

                        <!-- Firmas y observaciones con estilo moderno -->
                        <div style="font-family: 'Helvetica', Arial, sans-serif; font-size: 12px; margin-top: 20px;">

                            <!-- Observaciones -->
                            <t t-if="cp_template.show_observation">
                                <div style="margin-bottom: 15px; padding: 12px 15px; background: #fff8e1; border-radius: 8px; border-left: 4px solid #ffc107;">
                                    <strong style="color: #f57c00;">Observaciones:</strong>
                                    <t t-if="o.observation">
                                        <p style="margin: 8px 0 0 0;"><span t-field="o.observation"/></p>
                                    </t>
                                </div>
                            </t>

                            <!-- Notas adicionales -->
                            <t t-if="cp_template.notes">
                                <div style="margin-bottom: 15px; padding: 12px 15px; background: #e3f2fd; border-radius: 8px; border-left: 4px solid #2196f3;">
                                    <span t-out="cp_template.notes"/>
                                </div>
                            </t>

                            <!-- Firmas -->
                            <t t-if="cp_template.signature_prepared or cp_template.signature_reviewed or cp_template.signature_approved or cp_template.signature_employee">
                                <div style="margin-top: 40px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr style="text-align: center;">
                                            <t t-if="cp_template.signature_prepared">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #2c3e50; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #2c3e50; font-size: 10px;">ELABORO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_prepared == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_prepared"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_reviewed">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #3498db; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #3498db; font-size: 10px;">REVISO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_reviewed == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_reviewed"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_approved">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #27ae60; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #27ae60; font-size: 10px;">APROBO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_approved == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_approved"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_employee">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #9b59b6; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #9b59b6; font-size: 10px;">EMPLEADO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_employee == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_employee"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                        </tr>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>

                <t t-if="cp_template.type_header_footer == 'custom'">
                    <t t-call="web.basic_layout">
                        <!-- Encabezado personalizado -->
                        <div class="header">
                            <span t-out="cp_template.header_custom"/>
                        </div>

                        <!-- Contenido dependiendo la estructura -->
                        <t t-if="cp_template.type_report == 'nomina'">
                            <t t-call="hr_payroll.report_payslip"/>
                        </t>
                        <t t-if="cp_template.type_report == 'vacaciones'">
                            <t t-call="lavish_hr_payroll.report_liquidacion_vacaciones_document"/>
                        </t>
                        <t t-if="cp_template.type_report in ('prima','cesantias','intereses_cesantias')">
                            <t t-call="lavish_hr_payroll.report_liquidacion_cesantias_prima_document"/>
                        </t>
                        <t t-if="cp_template.type_report == 'contrato'">
                            <t t-call="lavish_hr_payroll.report_liquidacion_final_document"/>
                        </t>

                        <!-- Firmas y observaciones con estilo moderno -->
                        <div style="font-family: 'Helvetica', Arial, sans-serif; font-size: 12px; margin-top: 20px;">

                            <!-- Observaciones -->
                            <t t-if="cp_template.show_observation">
                                <div style="margin-bottom: 15px; padding: 12px 15px; background: #fff8e1; border-radius: 8px; border-left: 4px solid #ffc107;">
                                    <strong style="color: #f57c00;">Observaciones:</strong>
                                    <t t-if="o.observation">
                                        <p style="margin: 8px 0 0 0;"><span t-field="o.observation"/></p>
                                    </t>
                                </div>
                            </t>

                            <!-- Notas adicionales -->
                            <t t-if="cp_template.notes">
                                <div style="margin-bottom: 15px; padding: 12px 15px; background: #e3f2fd; border-radius: 8px; border-left: 4px solid #2196f3;">
                                    <span t-out="cp_template.notes"/>
                                </div>
                            </t>

                            <!-- Firmas -->
                            <t t-if="cp_template.signature_prepared or cp_template.signature_reviewed or cp_template.signature_approved or cp_template.signature_employee">
                                <div style="margin-top: 40px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr style="text-align: center;">
                                            <t t-if="cp_template.signature_prepared">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #2c3e50; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #2c3e50; font-size: 10px;">ELABORO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_prepared == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_prepared"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_reviewed">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #3498db; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #3498db; font-size: 10px;">REVISO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_reviewed == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_reviewed"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_approved">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #27ae60; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #27ae60; font-size: 10px;">APROBO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_approved == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_approved"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                            <t t-if="cp_template.signature_employee">
                                                <td style="width: 25%; padding: 15px; vertical-align: top;">
                                                    <div style="border-top: 2px solid #9b59b6; padding-top: 10px; margin: 0 10px;">
                                                        <strong style="color: #9b59b6; font-size: 10px;">EMPLEADO</strong><br/>
                                                        <t t-if="cp_template.txt_signature_employee == '$_name_employee'">
                                                            <span style="font-size: 11px;" t-out="o.employee_id.name"/><br/>
                                                            <span style="font-size: 10px; color: #666;">C.C. <span t-out="o.employee_id.identification_id"/></span>
                                                        </t>
                                                        <t t-else="">
                                                            <span style="font-size: 11px;" t-out="cp_template.txt_signature_employee"/>
                                                        </t>
                                                    </div>
                                                </td>
                                            </t>
                                        </tr>
                                    </table>
                                </div>
                            </t>
                        </div>

                        <!-- Pie de pagina personalizado -->
                        <div class="footer">
                            <span t-out="cp_template.footer_custom"/>
                        </div>
                    </t>
                </t>
            </t>
            </t>
        </template>

        <template id="reports_payslip_header_footer_template_final">
             <t t-foreach="docs" t-as="o">
                <t t-set="inside_foreach_docs" t-value="o"/>
                <t t-call="lavish_hr_payroll.reports_payslip_header_footer_template" t-lang="o.employee_id.work_contact_id.lang"/>
            </t>
        </template>

    </data>
</odoo>
