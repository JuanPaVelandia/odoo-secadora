<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_book_vacation_document">
        <t t-call="web.html_container">
            <t t-foreach="inside_foreach_docs or docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', Arial, sans-serif;">

                        <!-- Encabezado -->
                        <div style="text-align: center; margin-bottom: 25px; padding: 15px; background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%); border-radius: 8px;">
                            <h2 style="color: white; margin: 0; font-size: 20px; letter-spacing: 1px;">
                                LIBRO DE VACACIONES
                            </h2>
                        </div>

                        <!-- Informacion del empleado -->
                        <div style="margin-bottom: 20px; padding: 15px; border: 1px solid #e0e0e0; border-radius: 8px;">
                            <table style="width: 100%;">
                                <tr>
                                    <td style="width: 60%;">
                                        <div style="background: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #1abc9c;">
                                            <strong style="color: #2c3e50; font-size: 14px;">
                                                <span t-out="o.employee_id.identification_id"/> - <span t-out="o.employee_id.name"/>
                                            </strong>
                                        </div>
                                    </td>
                                    <td style="width: 40%; text-align: right;">
                                        <div style="background: #e8f5e9; padding: 10px; border-radius: 5px; border-right: 4px solid #27ae60;">
                                            <strong style="color: #27ae60;">Dias acumulados:</strong>
                                            <span style="background: #27ae60; color: white; padding: 3px 10px; border-radius: 12px; margin-left: 8px; font-weight: bold;">
                                                <span t-out="o.get_accumulated_vacation_days()"/>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Tabla de vacaciones -->
                        <div style="margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 10px;">
                                <thead>
                                    <tr>
                                        <th colspan="2" style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); color: white; padding: 10px; text-align: center; border: 1px solid #2980b9;">
                                            Periodo de Causacion
                                        </th>
                                        <th colspan="9" style="background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%); color: white; padding: 10px; text-align: center; border: 1px solid #16a085;">
                                            Vacaciones Tomadas
                                        </th>
                                    </tr>
                                    <tr style="background: #f8f9fa;">
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 8%;">Fecha Inicial</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 8%;">Fecha Final</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 8%;">Fecha Salida</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 8%;">Fecha Regreso</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; width: 10%;">Valor IBL</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 6%;">Dias Habiles</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; width: 10%;">Valor Habiles</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 6%;">Dias Festivos</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; width: 10%;">Valor Festivos</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: center; width: 6%;">Dias Dinero</th>
                                        <th style="padding: 8px; border: 1px solid #e0e0e0; text-align: right; width: 10%;">Valor Dinero</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.get_info_book_vacation()" t-as="info" style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.initial_accrual_date"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.final_accrual_date"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.departure_date"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center;">
                                            <span t-out="info.return_date"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="info.base_value + info.base_value_money" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center; background: #e3f2fd;">
                                            <span t-out="info.business_units"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="info.value_business_days" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center; background: #fff3e0;">
                                            <span t-out="info.holiday_units"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="info.holiday_value" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: center; background: #e8f5e9;">
                                            <span t-out="info.units_of_money"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid #e0e0e0; text-align: right;">
                                            <span t-out="info.money_value" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pie de pagina -->
                        <div style="margin-top: 30px; padding-top: 10px; border-top: 1px solid #e0e0e0; font-size: 9px; color: #999; text-align: center;">
                            Documento generado automaticamente -
                            <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_book_vacation">
        <t t-foreach="docs" t-as="o">
            <t t-set="inside_foreach_docs" t-value="o"/>
            <t t-call="lavish_hr_payroll.report_book_vacation_document"/>
        </t>
    </template>
</odoo>
