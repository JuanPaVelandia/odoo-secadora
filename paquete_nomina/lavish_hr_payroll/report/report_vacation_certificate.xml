<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="report_vacation_certificate_action" model="ir.actions.report">
    <field name="name">Certificado de Vacaciones</field>
    <field name="model">hr.leave</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">lavish_hr_payroll.report_vacation_certificate_template</field>
    <field name="report_file">lavish_hr_payroll.report_vacation_certificate_template</field>
    <field name="print_report_name">'Certificado_Vacaciones_%s' % object.employee_id.name</field>
    <field name="binding_model_id" ref="hr_holidays.model_hr_leave"/>
    <field name="binding_type">report</field>
</record>

<template id="report_vacation_certificate_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="text-center mb-4">
                        <h3><strong>CERTIFICADO DE VACACIONES</strong></h3>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <td width="25%"><strong>Empleado:</strong></td>
                                        <td width="25%"><span t-field="o.employee_id.name"/></td>
                                        <td width="25%"><strong>Identificacion:</strong></td>
                                        <td width="25%"><span t-field="o.employee_id.identification_id"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Cargo:</strong></td>
                                        <td><span t-field="o.employee_id.job_id.name"/></td>
                                        <td><strong>Departamento:</strong></td>
                                        <td><span t-field="o.employee_id.department_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Fecha Ingreso:</strong></td>
                                        <td><span t-field="o.employee_id.contract_id.date_start"/></td>
                                        <td><strong>Tipo Contrato:</strong></td>
                                        <td><span t-field="o.employee_id.contract_id.contract_type_id.name"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <h5><strong>Detalle de Vacaciones</strong></h5>
                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <td width="25%"><strong>Tipo:</strong></td>
                                        <td width="25%"><span t-field="o.holiday_status_id.name"/></td>
                                        <td width="25%"><strong>Estado:</strong></td>
                                        <td width="25%"><span t-field="o.state"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Fecha Inicio:</strong></td>
                                        <td><span t-field="o.date_from" t-options='{"widget": "date"}'/></td>
                                        <td><strong>Fecha Fin:</strong></td>
                                        <td><span t-field="o.date_to" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Dias:</strong></td>
                                        <td><span t-field="o.number_of_days"/></td>
                                        <td><strong>Valor:</strong></td>
                                        <td><span t-out="'{:,.0f}'.format(o.payroll_value or 0)"/> <span t-out="o.employee_id.company_id.currency_id.symbol or 'COP'"/></td>
                                    </tr>
                                    <tr t-if="o.return_date">
                                        <td><strong>Fecha Regreso:</strong></td>
                                        <td><span t-field="o.return_date"/></td>
                                        <td><strong>Dias Habiles:</strong></td>
                                        <td><span t-field="o.business_days"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row mb-4" t-if="o.name">
                        <div class="col-12">
                            <h5><strong>Descripcion</strong></h5>
                            <p><span t-field="o.name"/></p>
                        </div>
                    </div>

                    <div class="row mt-5">
                        <div class="col-12 text-center">
                            <p>Se expide el presente certificado a solicitud del interesado.</p>
                            <br/><br/>
                            <p>Fecha de expedicion: <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d de %B de %Y')"/></p>
                        </div>
                    </div>

                    <div class="row mt-5">
                        <div class="col-6 text-center">
                            <p>____________________________</p>
                            <p><strong>Firma Empleado</strong></p>
                            <p><span t-field="o.employee_id.name"/></p>
                        </div>
                        <div class="col-6 text-center">
                            <p>____________________________</p>
                            <p><strong>Firma Recursos Humanos</strong></p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </t>
</template>

</odoo>
