        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>

    <template id="report_payslip_hide_fields_layout_striped" inherit_id="web.external_layout_striped">
        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>

    <template id="report_payslip_hide_fields_layout_folder" inherit_id="web.external_layout_folder">
        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>

    <template id="report_payslip_hide_fields_layout_wave" inherit_id="web.external_layout_wave">
        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>

    <template id="report_payslip_hide_fields_layout_bubble" inherit_id="web.external_layout_bubble">
        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>
</odoo>
