<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_payslip_hide_fields" inherit_id="hr_payroll.report_payslip">
        <!-- Forzar contexto para ocultar footer solo en este reporte -->
        <xpath expr="//t[@t-call='web.external_layout']" position="before">
            <t t-set="o" t-value="o.with_context(hide_footer=True)"/>
        </xpath>

        <!-- Ocultar pie de pagina del layout externo -->
        <xpath expr="//div[hasclass('page')][1]" position="before">
            <style>
                .footer {
                    display: none !important;
                }
                .page, .page * {
                    font-size: 14px;
                    line-height: 1.25;
                }
                .page .table td,
                .page .table th {
                    padding-top: 4px !important;
                    padding-bottom: 4px !important;
                }
            </style>
        </xpath>

        <!-- Quitar campos de informacion del empleado -->
        <xpath expr="//div[@id='employee_marital']" position="replace"/>
        <xpath expr="//div[@id='employee_person_in_charge']" position="replace"/>
        <xpath expr="//div[@id='employee_private_address']" position="replace"/>

        <!-- Quitar campos de otra informacion -->
        <xpath expr="//div[@id='contract_type']" position="replace"/>
        <xpath expr="//div[@id='working_schedule']" position="replace"/>
        <xpath expr="//div[@id='wage']/strong" position="replace">
            <strong class="me-2">Salario del contrato:</strong>
        </xpath>

        <!-- Quitar resumen de Ganancias / Horas / Dias / Importe -->
        <xpath expr="//div[@id='worked_days_table']" position="replace"/>

        <!-- Ocultar advertencia de documento no valido en liquidaciones -->
        <xpath expr="//div[@t-if='is_invalid']" position="replace">
            <div t-if="is_invalid and not (o.struct_id and o.struct_id.process in ['vacaciones','prima','cesantias','intereses_cesantias','contrato'])">
                <strong id="invalid_warning">
                    <span t-out="is_invalid">This payslip is not validated. This is not a legal document.</span>
                </strong>
            </div>
        </xpath>

        <!-- Ajuste de bloque de pago compatible con estructura Odoo 19 -->
        <xpath expr="//div[@id='to_pay']" position="replace">
            <div id="to_pay">
                <p t-if="o.net_wage &gt;= 0">
                    Pagar a cuenta de <i><span t-field="o.employee_id.legal_name"/></i>:
                    <span t-field="o.net_wage" class="fw-bold"/>
                </p>
                <p t-if="o.net_wage &lt; 0">
                    El valor neto se recuperará en la primera remuneración positiva posterior.
                </p>
            </div>
        </xpath>

        <!-- Agrupar devengos y deducciones -->
        <xpath expr="//div[@id='payslip_lines_table']" position="replace">
            <div id="payslip_lines_table">
                <t t-set="base_lines"
                   t-value="o.line_ids.filtered(lambda l: l.appears_on_payslip and l.code not in ('TOTALDEV', 'TOTALDED', 'NET'))"/>
                <!-- Clasificación por parámetro afecta_totales -->
                <t t-set="dev_lines" t-value="base_lines.filtered(lambda l: l.afecta_totales_effective == 'devengo')"/>
                <t t-set="ded_lines" t-value="base_lines.filtered(lambda l: l.afecta_totales_effective == 'deduccion')"/>
                <t t-set="info_lines" t-value="base_lines.filtered(lambda l: l.afecta_totales_effective == 'ninguno')"/>

                <div style="margin-top: 10px; padding: 10px 12px; border: 1px solid #e5e7eb; border-radius: 6px;">
                    <div style="padding: 0 0 6px 0; font-weight: 600; color: #374151; letter-spacing: .2px;">
                        Devengos
                    </div>
                    <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                        <thead>
                            <tr style="color: #6b7280; font-weight: 600;">
                                <th style="width: 40%;">Concepto</th>
                                <th class="text-end" style="width: 15%;">Importe</th>
                                <th class="text-end" style="width: 15%;">Cantidad</th>
                                <th class="text-end" style="width: 15%;">Tasa</th>
                                <th class="text-end" style="width: 15%;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="dev_lines" t-as="line">
                                <td><span t-out="line.salary_rule_id and line.salary_rule_id.name or line.name"/></td>
                                <td class="text-end">
                                    <span t-out="line.amount"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                                <td class="text-end"><span t-out="round(line.quantity, 2)"/></td>
                                <td class="text-end">
                                    <span t-if="line.rate and abs(line.rate - 100.0) &gt; 0.0001" t-out="str(round(line.rate, 2)) + ' %'"/>
                                </td>
                                <td class="text-end">
                                    <span t-out="line.total"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr style="font-weight: 600; color: #374151;">
                                <td>Total Devengos</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td class="text-end">
                                    <span t-out="sum(dev_lines.mapped('total'))"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div style="margin-top: 12px; padding: 10px 12px; border: 1px solid #e5e7eb; border-radius: 6px;">
                    <div style="padding: 0 0 6px 0; font-weight: 600; color: #374151; letter-spacing: .2px;">
                        Deducciones
                    </div>
                    <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                        <thead>
                            <tr style="color: #6b7280; font-weight: 600;">
                                <th style="width: 40%;">Concepto</th>
                                <th class="text-end" style="width: 15%;">Importe</th>
                                <th class="text-end" style="width: 15%;">Cantidad</th>
                                <th class="text-end" style="width: 15%;">Tasa</th>
                                <th class="text-end" style="width: 15%;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="ded_lines" t-as="line">
                                <td><span t-out="line.salary_rule_id and line.salary_rule_id.name or line.name"/></td>
                                <td class="text-end">
                                    <span t-out="line.amount"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                                <td class="text-end"><span t-out="round(line.quantity, 2)"/></td>
                                <td class="text-end">
                                    <span t-if="line.rate and abs(line.rate - 100.0) &gt; 0.0001" t-out="str(round(line.rate, 2)) + ' %'"/>
                                </td>
                                <td class="text-end">
                                    <span t-out="abs(line.total)"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr style="font-weight: 600; color: #374151;">
                                <td>Total Deducciones</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td class="text-end">
                                    <span t-out="abs(sum(ded_lines.mapped('total')))"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div t-if="len(info_lines) &gt; 0" style="margin-top: 12px; padding: 10px 12px; border: 1px solid #fde68a; background: #fffbeb; border-radius: 6px;">
                    <div style="padding: 0 0 6px 0; font-weight: 600; color: #92400e; letter-spacing: .2px;">
                        Conceptos Informativos
                    </div>
                    <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                        <thead>
                            <tr style="color: #78350f; font-weight: 600;">
                                <th style="width: 40%;">Concepto</th>
                                <th class="text-end" style="width: 15%;">Importe</th>
                                <th class="text-end" style="width: 15%;">Cantidad</th>
                                <th class="text-end" style="width: 15%;">Tasa</th>
                                <th class="text-end" style="width: 15%;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="info_lines" t-as="line">
                                <td><span t-out="line.salary_rule_id and line.salary_rule_id.name or line.name"/></td>
                                <td class="text-end">
                                    <span t-out="line.amount"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                                <td class="text-end"><span t-out="round(line.quantity, 2)"/></td>
                                <td class="text-end">
                                    <span t-if="line.rate and abs(line.rate - 100.0) &gt; 0.0001" t-out="str(round(line.rate, 2)) + ' %'"/>
                                </td>
                                <td class="text-end">
                                    <span t-out="line.total"
                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Totales generales -->
                <div style="margin-top: 12px; border: 1px solid #e5e7eb; border-radius: 6px; padding: 10px 12px; font-size: 15px; line-height: 1.3;">
                    <table style="width: 100%; font-size: 15px; border-collapse: separate; border-spacing: 0;">
                        <tr style="background: #ffffff;">
                            <td style="width: 60%; padding: 6px 10px; color: #6b7280; font-weight: 600; font-size: 15px;">
                                <span style="font-size: 15px;">Total Devengos</span>
                            </td>
                            <td class="text-end" style="width: 40%; padding: 6px 10px; font-weight: 600; color: #111827; font-size: 15px;">
                                <span style="font-size: 15px;" t-out="sum(dev_lines.mapped('total'))"
                                    t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            </td>
                        </tr>
                        <tr style="background: #fafafa;">
                            <td style="padding: 6px 10px; color: #6b7280; font-weight: 600; font-size: 15px;">
                                <span style="font-size: 15px;">Total Deducciones</span>
                            </td>
                            <td class="text-end" style="padding: 6px 10px; font-weight: 600; color: #111827; font-size: 15px;">
                                <span style="font-size: 15px;" t-out="abs(sum(ded_lines.mapped('total')))"
                                    t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            </td>
                        </tr>
                        <tr style="background: #f3f4f6; color: #111827;">
                            <td style="padding: 9px; font-weight: 700; letter-spacing: .2px; font-size: 15px;">
                                <span style="font-size: 15px;">Neto a Pagar</span>
                            </td>
                            <td class="text-end" style="padding: 9px; font-weight: 800; font-size: 15px;">
                                <span style="font-size: 15px;" t-field="o.net_wage"
                                    t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Ocultar footer en layouts externos cuando hide_footer=True -->
    <template id="report_payslip_hide_fields_layout_standard" inherit_id="web.external_layout_standard">
        <xpath expr="//div[contains(@t-attf-class, 'footer')]" position="attributes">
            <attribute name="t-if">not (o and o.env.context.get('hide_footer'))</attribute>
        </xpath>
    </template>

