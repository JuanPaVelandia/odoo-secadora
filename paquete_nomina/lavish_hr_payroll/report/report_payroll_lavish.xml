<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Paper format para el reporte V2 (Letter Landscape) -->
        <record id="report_payroll_lavish_paperformat_v2" model="report.paperformat">
            <field name="name">Formato Informe de Liquidacion Lavish V2</field>
            <field name="default" eval="False"/>
            <field name="format">Letter</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">25</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">20</field>
            <field name="dpi">90</field>
        </record>

        <!-- Paper format para el reporte simple (A4 Landscape) -->
        <record id="report_payroll_lavish_paperformat" model="report.paperformat">
            <field name="name">Formato Informe de Liquidacion Lavish</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">1</field>
            <field name="margin_bottom">1</field>
            <field name="margin_left">1</field>
            <field name="margin_right">1</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">80</field>
        </record>

        <!-- Accion de reporte para el wizard de filtros -->
        <record id="report_payroll_lavish_filter_action" model="ir.actions.report">
            <field name="name">Informe de Liquidacion</field>
            <field name="model">hr.payroll.report.lavish.filter</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lavish_hr_payroll.report_payroll_lavish</field>
            <field name="report_file">lavish_hr_payroll.report_payroll_lavish</field>
            <field name="paperformat_id" ref="report_payroll_lavish_paperformat"/>
            <field name="binding_model_id" ref="model_hr_payroll_report_lavish_filter"/>
        </record>

        <!-- Accion de reporte para nominas individuales (V2) -->
        <record id="report_payroll_lavish_v2_action" model="ir.actions.report">
            <field name="name">Lavish Nomina</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lavish_hr_payroll.report_payroll_lavish_v2</field>
            <field name="report_file">lavish_hr_payroll.report_payroll_lavish_v2</field>
            <field name="paperformat_id" ref="report_payroll_lavish_paperformat_v2"/>
            <field name="print_report_name">'NOMINA - %s' % (object.name)</field>
            <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="binding_type">report</field>
            <field name="attachment"></field>
            <field name="attachment_use" eval="False"/>
        </record>

        <!-- Template simple para el wizard (usa HTML generado) -->
        <template id="report_payroll_lavish">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.basic_layout">
                        <style>
                            #table-report {
                                font-size: 6px;
                            }
                        </style>
                        <div class="page">
                            <t t-out="doc.pdf_report_payroll"/>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Template V2 detallado para nominas individuales -->
        <template id="report_payroll_lavish_v2">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div class="article container-fluid p-0" style="font-family: 'Helvetica', Arial, sans-serif; font-size: 10px; line-height: 1.1;">
                        <!-- Encabezado -->
                        <div class="row header">
                            <div class="col-3 text-start">
                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" class="img-fluid" style="max-height: 80px;" alt="Logo"/>
                            </div>
                            <div class="col-6 text-center">
                                <h5 class="font-weight-bold mb-1">
                                    <span t-field="o.company_id.name"/>
                                </h5>
                                <p class="mb-0">NIT: <span t-field="o.company_id.vat"/></p>
                                <p class="mb-0" style="font-size: 10px; line-height: 1.1">
                                    <span t-field="o.company_id.street"/> - <span t-field="o.company_id.city"/>
                                </p>
                                <p class="mb-0" style="font-size: 10px; line-height: 1.1">
                                    <span t-field="o.company_id.email"/> - <span t-field="o.company_id.phone"/>
                                </p>
                            </div>
                            <div class="col-3 text-end">
                                <h5 class="mb-1">No. <span t-field="o.number"/></h5>
                                <p class="mb-0" style="font-size: 10px; line-height: 1.1">
                                    FECHA: <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                                </p>
                                <p class="mb-0" style="font-size: 10px; line-height: 1.1">
                                    LOTE: <span t-field="o.payslip_run_id.name"/>
                                </p>
                            </div>
                        </div>

                        <!-- Titulo segun tipo de liquidacion -->
                        <div style="text-align: center">
                            <div style="text-transform: uppercase; font-weight: bold; font-size: 13px;">
                                <t t-if="o.struct_process == 'contrato'">
                                    LIQUIDACION DE CONTRATO DE TRABAJO
                                </t>
                                <t t-else="">
                                    <t t-set="titulos" t-value="{'nomina': 'LIQUIDACION DE NOMINA', 'vacaciones': 'LIQUIDACION DE VACACIONES', 'prima': 'LIQUIDACION DE PRIMA', 'cesantias': 'LIQUIDACION DE CESANTIAS', 'intereses_cesantias': 'LIQUIDACION DE INTERESES DE CESANTIAS', 'otro': 'LIQUIDACION'}"/>
                                    <t t-out="titulos.get(o.struct_process, 'LIQUIDACION DE NOMINA')"/>
                                </t>
                            </div>
                            <div style="font-size: 10px; margin-top: 2px;">
                                <t t-set="antiguedad_years" t-value="((o.date_to - o.contract_id.date_start).days // 365) if o.contract_id.date_start else 0"/>
                                <t t-set="antiguedad_months" t-value="((o.date_to - o.contract_id.date_start).days % 365) // 30 if o.contract_id.date_start else 0"/>
                                ANTIGUEDAD: <t t-out="antiguedad_years"/> ANOS, <t t-out="antiguedad_months"/> MESES
                                - NIVEL DE RIESGO: <span t-field="o.contract_id.risk_id"/>
                            </div>
                        </div>

                        <!-- INFORMACION DEL EMPLEADO -->
                        <div>
                            <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                <strong>INFORMACION DEL EMPLEADO</strong>
                            </div>
                            <table class="table table-sm table-borderless mb-0" style="line-height: 1;">
                                <tr>
                                    <th class="table-light" style="width: 20%">NOMBRE:</th>
                                    <td style="width: 30%"><span t-field="o.employee_id.name"/></td>
                                    <th class="table-light" style="width: 20%">IDENTIFICACION:</th>
                                    <td style="width: 30%">
                                        <t t-set="doc_types" t-value="{'11': 'RC', '12': 'TI', '13': 'CC', '21': 'TE', '22': 'CE', '31': 'NIT', '41': 'PP', '42': 'DE', '47': 'PEP', '50': 'NV', '91': 'NUIP'}"/>
                                        <t t-set="dian_code" t-value="o.employee_id.l10n_latam_identification_type_id.dian_code or (o.employee_id.work_contact_id.l10n_latam_identification_type_id.dian_code if o.employee_id.work_contact_id else '')"/>
                                        <t t-out="doc_types.get(dian_code, dian_code)"/> - <span t-field="o.employee_id.identification_id"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="table-light">No.:</th>
                                    <td><span t-field="o.contract_id.sequence"/></td>
                                    <th class="table-light">CONTRATO:</th>
                                    <td>
                                        <t t-set="contract_types" t-value="{'Contrato por Obra o Labor': 'OBRA', 'Contrato de Trabajo a Termino Fijo': 'FIJO', 'Contrato de Trabajo a Termino Fijo Tiempo Parcial': 'PARCIAL', 'Contrato de Trabajo a Termino Indefinido': 'INDEF', 'Contrato de Aprendizaje': 'APREND', 'Contrato Temporal, ocasional o accidental': 'TEMP'}"/>
                                        <span class="text-uppercase" t-out="contract_types.get(o.contract_id.contract_type, o.contract_id.contract_type or '')"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="table-light">CARGO:</th>
                                    <td><span t-field="o.employee_id.job_id"/></td>
                                    <th class="table-light">DEPARTAMENTO:</th>
                                    <td><span t-field="o.employee_id.department_id"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- PERIODO DE LIQUIDACION (Contrato) -->
                        <div t-if="o.struct_process == 'contrato'">
                            <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                <strong>PERIODO DE LIQUIDACION</strong>
                            </div>
                            <table class="table table-sm table-borderless" style="line-height: 1;">
                                <t t-set="antiguedad_data" t-value="o.get_holiday_book(o.contract_id, o.contract_id.date_start) if hasattr(o, 'get_holiday_book') else {'worked_days': 0, 'days_suspension': 0}"/>
                                <tr>
                                    <th class="table-light" style="width: 20%">INICIO:</th>
                                    <td style="width: 30%"><span t-field="o.contract_id.date_start" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                    <th class="table-light" style="width: 20%">FIN:</th>
                                    <td style="width: 30%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                </tr>
                                <tr>
                                    <th class="table-light">DIAS LABORADOS:</th>
                                    <td><span t-out="antiguedad_data.get('worked_days', 0)"/> dias</td>
                                    <th class="table-light">AUSENCIAS:</th>
                                    <td>
                                        <t t-if="antiguedad_data.get('days_suspension', 0) > 0">
                                            <span t-out="antiguedad_data.get('days_suspension', 0)"/> dias
                                        </t>
                                        <t t-else="">N/A</t>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="table-light">SALARIO BASE:</th>
                                    <td><span t-field="o.contract_id.wage" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/></td>
                                    <th class="table-light">AUXILIO TRANSP.:</th>
                                    <td><span t-out="sum(o.line_ids.filtered(lambda l: l.code == 'AUX000').mapped('total'))" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- PERIODO DE LIQUIDACION (Otros) -->
                        <div t-if="o.struct_process != 'contrato'">
                            <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                <strong>PERIODO DE LIQUIDACION</strong>
                            </div>
                            <table class="table table-sm table-borderless" style="line-height: 1;">
                                <tr>
                                    <th class="table-light" style="width: 20%">INICIO:</th>
                                    <td style="width: 30%"><span t-field="o.date_from" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                    <th class="table-light" style="width: 20%">FIN:</th>
                                    <td style="width: 30%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                </tr>
                                <tr>
                                    <th class="table-light">DIAS LABORADOS:</th>
                                    <td><span t-out="sum([i.number_of_days for i in o.worked_days_line_ids.filtered(lambda x: x.code == 'WORK100')])"/> dias</td>
                                    <th class="table-light">AUSENCIAS:</th>
                                    <td>
                                        <t t-set="ausencias" t-value="sum([i.days_payslip for i in o.leave_days_ids.filtered(lambda x: x.amount &lt; 0)]) if hasattr(o, 'leave_days_ids') else 0"/>
                                        <t t-if="ausencias > 0"><span t-out="ausencias"/> dias</t>
                                        <t t-else="">N/A</t>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="table-light">SALARIO BASE:</th>
                                    <td><span t-field="o.contract_id.wage" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/></td>
                                    <th class="table-light">AUXILIO TRANSP.:</th>
                                    <td><span t-out="sum(o.line_ids.filtered(lambda l: l.code == 'AUX000').mapped('total'))" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- DATOS DE LIQUIDACION (Solo contrato) -->
                        <t t-if="o.struct_process == 'contrato'">
                            <div>
                                <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                    <strong>DATOS DE LIQUIDACION</strong>
                                </div>
                                <table class="table table-sm table-borderless mb-0" style="line-height: 1;">
                                    <tr>
                                        <th class="table-light" style="width: 20%">FECHA LIQUIDACION:</th>
                                        <td style="width: 30%"><span t-field="o.date_liquidacion" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                        <th class="table-light" style="width: 20%">MOTIVO:</th>
                                        <td style="width: 30%">
                                            <t t-if="o.have_compensation">RENUNCIA SIN JUSTA CAUSA</t>
                                            <t t-else="">RENUNCIA CON JUSTA CAUSA</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th class="table-light">INICIO DE CONTRATO:</th>
                                        <td><span t-field="o.contract_id.date_start" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                        <th class="table-light">FIN DE CONTRATO:</th>
                                        <td><span t-field="o.contract_id.date_end"/></td>
                                    </tr>
                                </table>
                            </div>
                        </t>

                        <!-- Secciones de prestaciones -->
                        <t t-if="o.struct_process in ['contrato', 'prima', 'cesantias', 'intereses_cesantias', 'vacaciones']">
                            <div class="row">
                                <!-- PRIMA -->
                                <div class="col-6" style="line-height: 1;">
                                    <t t-if="o.struct_process in ['contrato', 'prima']">
                                        <div>
                                            <div class="py-1" style="background-color: #f0f0f0; border-radius: 5px">
                                                <strong>PRIMA</strong>
                                            </div>
                                            <table class="table table-sm table-borderless mb-0">
                                                <tr>
                                                    <th class="table-light" style="width: 60%">FECHA DE LIQUIDACION PRIMA:</th>
                                                    <td style="width: 40%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">FECHA DE CORTE PRIMA:</th>
                                                    <td><span t-field="o.date_prima" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">DIAS PRIMA (30/ANO):</th>
                                                    <td>
                                                        <t t-set="prima_days" t-value="sum(o.line_ids.filtered(lambda l: l.code == 'PRIMA').mapped('quantity')) * 0.0833333"/>
                                                        <span t-out="round(prima_days, 2)"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                                <!-- CESANTIAS -->
                                <div class="col-6" style="line-height: 1;">
                                    <t t-if="o.struct_process in ['contrato', 'cesantias']">
                                        <div>
                                            <div class="py-1" style="background-color: #f0f0f0; border-radius: 5px">
                                                <strong>CESANTIAS</strong>
                                            </div>
                                            <table class="table table-sm table-borderless" style="line-height: 1;">
                                                <tr>
                                                    <th class="table-light" style="width: 60%">FECHA DE LIQUIDACION CESANTIAS:</th>
                                                    <td style="width: 40%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">FECHA DE CORTE CESANTIAS:</th>
                                                    <td><span t-field="o.date_cesantias" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">DIAS CESANTIAS (30/ANO):</th>
                                                    <td>
                                                        <t t-set="cesantias_days" t-value="sum(o.line_ids.filtered(lambda l: l.code == 'CESANTIAS').mapped('quantity')) * 0.0833333"/>
                                                        <span t-out="round(cesantias_days, 2)"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="row" style="line-height: 1;">
                                <!-- VACACIONES -->
                                <div class="col-6">
                                    <t t-if="o.struct_process in ['contrato', 'vacaciones']">
                                        <div class="mb-3">
                                            <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                                <strong>VACACIONES</strong>
                                            </div>
                                            <table class="table table-sm table-borderless mb-0">
                                                <tr>
                                                    <th class="table-light" style="width: 60%">FECHA DE LIQUIDACION VACACIONES:</th>
                                                    <td style="width: 40%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">FECHA DE CORTE VACACIONES:</th>
                                                    <td><span t-field="o.date_vacaciones" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">DIAS VACACIONES (15/ANO):</th>
                                                    <td>
                                                        <t t-set="vacation_days" t-value="sum(o.line_ids.filtered(lambda l: l.code == 'VACCONTRATO').mapped('quantity'))"/>
                                                        <span t-out="vacation_days"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">DIAS PENDIENTES:</th>
                                                    <td>
                                                        <t t-set="wage_daily" t-value="o.contract_id.wage / 30 if o.contract_id.wage else 1"/>
                                                        <t t-set="pending_vacations" t-value="sum(o.line_ids.filtered(lambda l: l.code == 'VACCONTRATO').mapped('total')) / wage_daily"/>
                                                        <span t-out="'%.2f' % pending_vacations"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                                <!-- INTERESES A LAS CESANTIAS -->
                                <div class="col-6">
                                    <t t-if="o.struct_process in ['contrato', 'intereses_cesantias']">
                                        <div>
                                            <div class="py-1 px-2" style="background-color: #f0f0f0; border-radius: 5px">
                                                <strong>INTERESES A LAS CESANTIAS</strong>
                                            </div>
                                            <table class="table table-sm table-borderless mb-0">
                                                <tr>
                                                    <th class="table-light" style="width: 60%">FECHA DE LIQUIDACION INTERESES:</th>
                                                    <td style="width: 40%"><span t-field="o.date_to" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">FECHA DE CORTE INTERESES:</th>
                                                    <td><span t-field="o.date_cesantias" t-options="{'format':'dd/MM/yyyy'}"/></td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">DIAS INTERESES:</th>
                                                    <td>
                                                        <t t-set="interest_days" t-value="sum(o.line_ids.filtered(lambda l: l.code == 'CESANTIAS').mapped('quantity')) * 0.0833333"/>
                                                        <span t-out="'%.2f' % interest_days"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th class="table-light">TASA INTERES:</th>
                                                    <td>12%</td>
                                                </tr>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <!-- DETALLE DE CONCEPTOS LIQUIDADOS -->
                        <div>
                            <div class="py-1 px-2">
                                <strong>DETALLE DE CONCEPTOS LIQUIDADOS</strong>
                            </div>
                            <div>
                                <table class="table table-borderless" style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-bottom: 1px solid #000; background-color: #f0f0f0;">
                                        <th style="padding: 2px; text-align: left; font-weight: bold;">CONCEPTO</th>
                                        <th style="padding: 2px; text-align: right; font-weight: bold;">BASE</th>
                                        <th style="padding: 2px; text-align: center; font-weight: bold;">CANT</th>
                                        <th style="padding: 2px; text-align: center; font-weight: bold;">DESDE</th>
                                        <th style="padding: 2px; text-align: center; font-weight: bold;">HASTA</th>
                                        <th style="padding: 2px; text-align: right; font-weight: bold;">VALOR</th>
                                    </tr>
                                    <t t-foreach="sorted([l for l in o.line_ids if l.salary_rule_id.appears_on_payslip], key=lambda l: (l.salary_rule_id.sequence, l.salary_rule_id.id))" t-as="line">
                                        <tr t-att-style="'border-bottom: 1px solid #eee; background-color: #f0f0f0;' if line.code.startswith('TOTAL') else 'border-bottom: 1px solid #eee;'">
                                            <td style="padding: 1px 2px;">
                                                <t t-if="line.code not in ['TOTALDEV', 'TOTALDED']">
                                                    <span t-out="line.name.upper()"/>
                                                    <t t-if="line.entity_id">
                                                        <span style="font-size: 6px; color: #666;">
                                                            [<span t-out="line.entity_id.code_pila_eps"/>]
                                                            <t t-out="(line.entity_id.name or '')[:30]"/>
                                                        </span>
                                                    </t>
                                                    <t t-if="line.loan_id">
                                                        <span style="font-size: 6px; color: #666;">
                                                            Credito #<t t-out="line.loan_id.name"/>
                                                        </span>
                                                    </t>
                                                </t>
                                                <t t-elif="line.code in ['TOTALDEV', 'TOTALDED']">
                                                    <span style="padding: 2px; text-align: left; font-weight: bold;" t-out="line.name.upper()"/>
                                                </t>
                                            </td>
                                            <td style="padding: 1px 2px; text-align: right;">
                                                <t t-if="line.leave_id">
                                                    <span t-field="line.leave_id.ibc" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> /30
                                                </t>
                                                <t t-elif="line.category_id.code in ['SSOCIAL', 'HEYREC']">
                                                    <span t-field="line.amount" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                                </t>
                                                <t t-elif="line.category_id.code in ['BASIC', 'BASICD']">
                                                    <span t-out="o.contract_id.wage" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> / 30
                                                </t>
                                                <t t-elif="line.code == 'AUX000'">
                                                    <span t-out="round(line.amount * 30)" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> / 30
                                                </t>
                                                <t t-elif="line.code in ['CESANTIAS', 'PRIMA']">
                                                    <span t-field="line.amount_base" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> / 360
                                                </t>
                                                <t t-elif="line.code == 'VACCONTRATO'">
                                                    <span t-field="line.amount_base" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> / 720
                                                </t>
                                                <t t-elif="line.code in ['INTCESANTIAS', 'INTCES_YEAR']">
                                                    <span t-out="sum(o.line_ids.filtered(lambda l: l.code == 'CESANTIAS').mapped('total'))" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/> / 360
                                                </t>
                                                <t t-elif="line.code not in ['TOTALDEV', 'TOTALDED']">
                                                    <span t-field="line.amount_base" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                                </t>
                                            </td>
                                            <td style="padding: 1px 2px; text-align: center;">
                                                <t t-if="line.code not in ['TOTALDEV', 'TOTALDED']">
                                                    <span t-field="line.quantity" t-options="{'precision': 2}"/>
                                                    <t t-if="line.rate != 100.0">
                                                        <span style="display: inline-block; padding: 0 1px; font-size: 8px;">
                                                            x <t t-out="line.rate"/> %
                                                        </span>
                                                    </t>
                                                </t>
                                                <t t-if="line.category_id.code in ['HEYREC', 'HED', 'HEN', 'HEDDF', 'HENDF']">
                                                    <span style="font-size: 6px; color: #666;">/hr</span>
                                                </t>
                                            </td>
                                            <td style="padding: 1px 2px; text-align: center;">
                                                <span t-field="line.initial_accrual_date"/>
                                            </td>
                                            <td style="padding: 1px 2px; text-align: center;">
                                                <span t-field="line.final_accrual_date"/>
                                            </td>
                                            <td style="padding: 1px 2px; text-align: right; font-weight: bold;">
                                                <t t-if="line.leave_id.unpaid_absences if line.leave_id else False">N/A</t>
                                                <t t-else="">
                                                    <span t-field="line.total" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- Neto final -->
                                    <tr style="border-top: 1px solid #000; background-color: #f0f0f0;">
                                        <td colspan="5" style="padding: 3px; font-weight: bold;">TOTAL NETO</td>
                                        <td style="padding: 3px; text-align: right; font-weight: bold;">
                                            <span t-field="o.net_wage" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- RESUMEN LIQUIDACION -->
                        <div class="resumen-liquidacion" style="margin-bottom: 10px; margin-top: 15px;">
                            <div style="background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%); color: white; padding: 8px 15px; border-radius: 5px 5px 0 0; font-weight: bold; font-size: 12px;">
                                RESUMEN LIQUIDACION
                            </div>
                            <div style="border: 2px solid #3498db; border-top: none; border-radius: 0 0 5px 5px; padding: 15px; background: #f8f9fa;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div>
                                        <div style="font-size: 10px; color: #666; margin-bottom: 3px;">VALOR NETO A PAGAR</div>
                                        <div style="font-size: 18px; font-weight: bold; color: #2c3e50;">
                                            <span t-field="o.net_wage" t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <t t-set="net_line" t-value="o.line_ids.filtered(lambda line: line.code == 'NET')[:1]"/>
                                        <t t-if="net_line and o.contract_id and o.contract_id.get_amount_text">
                                            <div style="font-size: 9px; font-style: italic; color: #666; max-width: 250px;">
                                                <span t-out="o.contract_id.get_amount_text(net_line.total).lower().capitalize()"/> pesos M/CTE
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed #ccc;">
                                    <t t-set="main_bank" t-value="o.employee_id.work_contact_id.bank_ids.filtered(lambda bank: bank.is_main and bank.company_id == o.employee_id.company_id)[:1] if o.employee_id.work_contact_id else False"/>
                                    <t t-if="main_bank">
                                        <div style="display: flex; align-items: center; font-size: 9px;">
                                            <span style="background: #e9ecef; padding: 3px 8px; border-radius: 3px; margin-right: 8px;">
                                                <strong>Cuenta:</strong>
                                            </span>
                                            <span t-out="main_bank.display_name"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Texto legal (Solo contrato) -->
                        <div t-if="o.struct_process == 'contrato'" class="mb-3 py-2 text-justify">
                            <p class="mb-1"><strong>SE HACE CONSTAR:</strong></p>
                            <p class="mb-1">
                                1. Que el patrono ha incorporado en la presente liquidacion los importes correspondientes a salarios, horas extras, descansos remunerados, cesantias, vacaciones, prima de servicios, auxilio de transporte, y en si, todo concepto relacionado con salarios, prestaciones e indemnizaciones causadas al quedar extinguido el contrato de trabajo.
                            </p>
                            <p class="mb-0">
                                2. Que con el pago del dinero anotado en la presente liquidacion, queda tramitada cualquier diferencia relativa al contrato de trabajo extinguido, o a cualquier diferencia anterior. Por lo tanto, esta transaccion tiene como efecto la terminacion de las obligaciones provenientes de la relacion laboral que existio entre
                                <span t-field="o.company_id.name"/> y el trabajador, quienes declaran estar a paz y salvo por todo concepto.
                            </p>
                        </div>

                        <!-- Firmas -->
                        <table class="table table-borderless" style="width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 10px;">
                            <tr>
                                <td style="width: 30%; text-align: center; vertical-align: bottom; padding: 3px">
                                    <div style="border-top: 1px solid #000; margin-top: 30px; margin-bottom: 2px;"/>
                                    <div style="font-size: 8px; font-weight: bold;">EMPLEADOR</div>
                                    <div style="font-size: 7px;">C.C. <span t-field="o.company_id.vat"/></div>
                                </td>
                                <td style="width: 30%; text-align: center; vertical-align: bottom; padding: 3px">
                                    <div style="border-top: 1px solid #000; margin-top: 30px; margin-bottom: 2px;"/>
                                    <div style="font-size: 8px; font-weight: bold;">FIRMA DEL TRABAJADOR</div>
                                    <div style="font-size: 7px;">C.C. <span t-field="o.employee_id.identification_id"/></div>
                                </td>
                                <td style="width: 30%; text-align: center; vertical-align: bottom; padding: 3px">
                                    <div style="border-top: 1px solid #000; margin-top: 30px; margin-bottom: 2px;"/>
                                    <div style="font-size: 8px; font-weight: bold;">REVISOR</div>
                                    <div style="font-size: 7px;">C.C. <span t-field="o.contract_id.hr_responsible_id.vat"/></div>
                                </td>
                            </tr>
                        </table>

                        <!-- Pie de pagina -->
                        <div class="footer" style="margin-top: 5px; padding-top: 3px; border-top: 1px solid #000; display: flex; justify-content: space-between; font-size: 7px;">
                            <div>Para cualquier inquietud por favor comunicarse con el departamento de nomina</div>
                            <div style="text-align: right;">
                                Elaborado por: <span t-field="o.contract_id.hr_responsible_id"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>
