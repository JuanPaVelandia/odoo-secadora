<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <!-- Template de correo para nómina electrónica validada -->
    <record id="email_template_payslip_edi_validated" model="mail.template">
        <field name="name">Nómina Electrónica - Validada DIAN</field>
        <field name="model_id" ref="model_hr_payslip_edi"/>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="email_to">{{ object.employee_id.work_email or object.employee_id.work_contact_id.email }}</field>
        <field name="subject">{{ object.company_id.name }} - Documento Soporte de Pago Nómina Electrónica {{ object.number }}</field>
        <field name="report_template_ids" eval="[(6, 0, [ref('action_report_payslip_edi_electronic')])]"/>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5;">
    <table style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;" width="100%" cellpadding="0" cellspacing="0">
        <!-- Header -->
        <tr>
            <td style="background-color: #1a237e; padding: 20px; text-align: center;">
                <h2 style="color: #ffffff; margin: 0; font-size: 18px;">DOCUMENTO SOPORTE DE PAGO</h2>
                <p style="color: #c5cae9; margin: 4px 0 0; font-size: 13px;">Nómina Electrónica DIAN</p>
            </td>
        </tr>
        <!-- Saludo -->
        <tr>
            <td style="padding: 20px 24px 10px;">
                <p style="margin: 0; font-size: 14px; color: #333;">
                    Estimado(a) <strong><t t-out="object.employee_id.name"/></strong>,
                </p>
                <p style="margin: 8px 0 0; font-size: 13px; color: #555;">
                    Le informamos que su documento soporte de pago de nómina electrónica ha sido validado exitosamente por la DIAN.
                </p>
            </td>
        </tr>
        <!-- Datos del documento -->
        <tr>
            <td style="padding: 10px 24px;">
                <table style="width: 100%; border-collapse: collapse; border: 1px solid #e0e0e0; border-radius: 6px; overflow: hidden;" cellpadding="0" cellspacing="0">
                    <tr style="background-color: #e8eaf6;">
                        <td colspan="2" style="padding: 8px 12px; font-size: 12px; font-weight: bold; color: #1a237e; text-transform: uppercase;">
                            Detalle del Documento
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; width: 40%; font-size: 12px; color: #666; border-bottom: 1px solid #f0f0f0;"><strong>Número:</strong></td>
                        <td style="padding: 8px 12px; font-size: 12px; color: #333; border-bottom: 1px solid #f0f0f0;"><t t-out="object.number"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; font-size: 12px; color: #666; border-bottom: 1px solid #f0f0f0;"><strong>Período:</strong></td>
                        <td style="padding: 8px 12px; font-size: 12px; color: #333; border-bottom: 1px solid #f0f0f0;"><t t-out="object.date_from"/> a <t t-out="object.date_to"/></td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 12px; font-size: 12px; color: #666; border-bottom: 1px solid #f0f0f0;"><strong>Fecha de Pago:</strong></td>
                        <td style="padding: 8px 12px; font-size: 12px; color: #333; border-bottom: 1px solid #f0f0f0;"><t t-out="object.payment_date"/></td>
                    </tr>
                    <tr style="background-color: #e8f5e9;">
                        <td style="padding: 8px 12px; font-size: 12px; color: #2e7d32; border-bottom: 1px solid #f0f0f0;"><strong>Total Devengados:</strong></td>
                        <td style="padding: 8px 12px; font-size: 12px; color: #2e7d32; border-bottom: 1px solid #f0f0f0;"><strong>$ <t t-out="'{:,.0f}'.format(object.total_devengos)"/></strong></td>
                    </tr>
                    <tr style="background-color: #ffebee;">
                        <td style="padding: 8px 12px; font-size: 12px; color: #c62828; border-bottom: 1px solid #f0f0f0;"><strong>Total Deducciones:</strong></td>
                        <td style="padding: 8px 12px; font-size: 12px; color: #c62828; border-bottom: 1px solid #f0f0f0;"><strong>$ <t t-out="'{:,.0f}'.format(abs(object.total_deducciones))"/></strong></td>
                    </tr>
                    <tr style="background-color: #1a237e;">
                        <td style="padding: 10px 12px; font-size: 14px; color: #ffffff;"><strong>Neto a Pagar:</strong></td>
                        <td style="padding: 10px 12px; font-size: 16px; color: #ffffff;"><strong>$ <t t-out="'{:,.0f}'.format(object.total_paid)"/></strong></td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- CUNE -->
        <tr>
            <td style="padding: 10px 24px;">
                <div style="background-color: #f5f5f5; border: 1px solid #e0e0e0; border-radius: 4px; padding: 10px 12px;">
                    <p style="margin: 0 0 4px; font-size: 11px; color: #1a237e; font-weight: bold;">CUNE (SHA-384):</p>
                    <p style="margin: 0; font-size: 10px; color: #666; font-family: monospace; word-break: break-all;">
                        <t t-out="object.current_cune or 'Pendiente'"/>
                    </p>
                </div>
            </td>
        </tr>
        <!-- Nota -->
        <tr>
            <td style="padding: 10px 24px;">
                <p style="margin: 0; font-size: 12px; color: #555;">
                    Adjunto encontrará el documento soporte de pago en formato PDF. Puede verificar su documento en el portal de la DIAN con el CUNE indicado.
                </p>
            </td>
        </tr>
        <!-- Footer -->
        <tr>
            <td style="padding: 16px 24px; background-color: #fafafa; border-top: 1px solid #e0e0e0;">
                <p style="margin: 0; font-size: 12px; color: #555;">
                    Atentamente,<br/>
                    <strong style="color: #1a237e;"><t t-out="object.company_id.name"/></strong>
                </p>
                <p style="margin: 6px 0 0; font-size: 10px; color: #999;">
                    NIT: <t t-out="object.company_id.partner_id.vat_co or object.company_id.vat or ''"/>
                    | <t t-out="object.company_id.partner_id.street or ''"/>
                    | <t t-out="object.company_id.partner_id.city_id.name if object.company_id.partner_id.city_id else ''"/>
                </p>
                <p style="margin: 4px 0 0; font-size: 9px; color: #bbb;">
                    Este es un correo generado automáticamente. Documento Soporte de Pago de Nómina Electrónica - DIAN Colombia.
                </p>
            </td>
        </tr>
    </table>
</div>
        </field>
    </record>

    <!-- Template de correo para nómina electrónica rechazada -->
    <record id="email_template_payslip_edi_rejected" model="mail.template">
        <field name="name">Nómina Electrónica - Rechazada DIAN</field>
        <field name="model_id" ref="model_hr_payslip_edi"/>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="email_to">{{ object.create_uid.email_formatted }}</field>
        <field name="subject">ALERTA: Nómina Electrónica Rechazada - {{ object.number }}</field>
        <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px; color: #cc0000;">
        <strong>ALERTA: Documento rechazado por DIAN</strong>
    </p>
    <br/>
    <table style="border-collapse: collapse; width: 100%;">
        <tr>
            <td style="padding: 5px; border: 1px solid #ddd;"><strong>Número:</strong></td>
            <td style="padding: 5px; border: 1px solid #ddd;"><t t-out="object.number"/></td>
        </tr>
        <tr>
            <td style="padding: 5px; border: 1px solid #ddd;"><strong>Empleado:</strong></td>
            <td style="padding: 5px; border: 1px solid #ddd;"><t t-out="object.employee_id.name"/></td>
        </tr>
        <tr>
            <td style="padding: 5px; border: 1px solid #ddd;"><strong>Período:</strong></td>
            <td style="padding: 5px; border: 1px solid #ddd;"><t t-out="object.date_from"/> - <t t-out="object.date_to"/></td>
        </tr>
        <tr>
            <td style="padding: 5px; border: 1px solid #ddd;"><strong>Error:</strong></td>
            <td style="padding: 5px; border: 1px solid #ddd; color: #cc0000;"><t t-out="object.response_message_dian"/></td>
        </tr>
    </table>
    <br/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Por favor revise el documento y corrija los errores antes de reintentar el envío.
    </p>
</div>
        </field>
    </record>
</odoo>
