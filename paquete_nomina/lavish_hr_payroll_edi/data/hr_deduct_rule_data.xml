<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <!-- ============================================================ -->
    <!-- REGLAS DE DEDUCCIONES DIAN V1.0.6 - Nómina Electrónica       -->
    <!-- Códigos alineados con NominaIndividualElectronicaXSDV1.0.6   -->
    <!-- ============================================================ -->

    <!-- SEGURIDAD SOCIAL -->
    <record id="deduct_salud" model="hr.deduct.rule">
        <field name="name">Salud</field>
        <field name="code">Salud</field>
        <field name="description">Aporte a salud del trabajador (4%)</field>
    </record>
    <record id="deduct_pension" model="hr.deduct.rule">
        <field name="name">Fondo Pensión</field>
        <field name="code">FondoPension</field>
        <field name="description">Aporte a pensión del trabajador (4%)</field>
    </record>
    <record id="deduct_fondo_sp" model="hr.deduct.rule">
        <field name="name">Fondo de Solidaridad Pensional</field>
        <field name="code">FondoSP</field>
        <field name="description">Fondo de solidaridad pensional. La Subsistencia se reporta como atributo DeduccionSub del nodo FondoSP.</field>
    </record>

    <!-- SINDICATOS (XSD: nodo Sindicatos con hijos Sindicato) -->
    <record id="deduct_sindicato" model="hr.deduct.rule">
        <field name="name">Sindicatos</field>
        <field name="code">Sindicatos</field>
        <field name="description">Cuota sindical (XSD: nodo Sindicatos)</field>
    </record>

    <!-- SANCIONES (XSD: nodo Sancion con atributos SancionPublic / SancionPriv) -->
    <record id="deduct_sancion_publica" model="hr.deduct.rule">
        <field name="name">Sanción Pública</field>
        <field name="code">SancionPublica</field>
        <field name="description">Sanciones públicas (atributo SancionPublic del nodo Sancion)</field>
    </record>
    <record id="deduct_sancion_privada" model="hr.deduct.rule">
        <field name="name">Sanción Privada</field>
        <field name="code">SancionPrivada</field>
        <field name="description">Sanciones privadas (atributo SancionPriv del nodo Sancion)</field>
    </record>

    <!-- LIBRANZAS -->
    <record id="deduct_libranza" model="hr.deduct.rule">
        <field name="name">Libranza</field>
        <field name="code">Libranza</field>
        <field name="description">Descuento por libranza</field>
    </record>

    <!-- OTROS DESCUENTOS -->
    <record id="deduct_embargo" model="hr.deduct.rule">
        <field name="name">Embargo Fiscal</field>
        <field name="code">EmbargoFiscal</field>
        <field name="description">Embargo fiscal (DIAN: EmbargoFiscal)</field>
    </record>
    <record id="deduct_plan_comple" model="hr.deduct.rule">
        <field name="name">Plan Complementarios</field>
        <field name="code">PlanComplementarios</field>
        <field name="description">Planes complementarios de salud (DIAN: PlanComplementarios)</field>
    </record>
    <record id="deduct_educacion" model="hr.deduct.rule">
        <field name="name">Educación</field>
        <field name="code">Educacion</field>
        <field name="description">Descuentos por educación</field>
    </record>
    <record id="deduct_reintegro" model="hr.deduct.rule">
        <field name="name">Reintegro</field>
        <field name="code">Reintegro</field>
        <field name="description">Reintegro de valores</field>
    </record>
    <record id="deduct_deuda" model="hr.deduct.rule">
        <field name="name">Deuda</field>
        <field name="code">Deuda</field>
        <field name="description">Descuento por deuda con la empresa</field>
    </record>

    <!-- RETENCIONES -->
    <record id="deduct_retencion_fuente" model="hr.deduct.rule">
        <field name="name">Retención en la Fuente</field>
        <field name="code">RetencionFuente</field>
        <field name="description">Retención en la fuente por ingresos laborales</field>
    </record>

    <!-- AFC Y VOLUNTARIAS -->
    <record id="deduct_afc" model="hr.deduct.rule">
        <field name="name">AFC</field>
        <field name="code">AFC</field>
        <field name="description">Ahorro para el Fomento de la Construcción</field>
    </record>
    <record id="deduct_cooperativa" model="hr.deduct.rule">
        <field name="name">Cooperativa</field>
        <field name="code">Cooperativa</field>
        <field name="description">Aportes a cooperativa</field>
    </record>
    <record id="deduct_pension_voluntaria" model="hr.deduct.rule">
        <field name="name">Pensión Voluntaria</field>
        <field name="code">PensionVoluntaria</field>
        <field name="description">Aportes voluntarios a pensión</field>
    </record>

    <!-- ANTICIPOS -->
    <record id="deduct_anticipo" model="hr.deduct.rule">
        <field name="name">Anticipo</field>
        <field name="code">Anticipo</field>
        <field name="description">Descuento de anticipo de nómina</field>
    </record>

    <!-- OTROS -->
    <record id="deduct_otra" model="hr.deduct.rule">
        <field name="name">Otra Deducción</field>
        <field name="code">OtraDeduccion</field>
        <field name="description">Otras deducciones (XSD: hijos OtraDeduccion del nodo OtrasDeducciones)</field>
    </record>
    <record id="deduct_pago_tercero" model="hr.deduct.rule">
        <field name="name">Pago a Terceros</field>
        <field name="code">PagoTercero</field>
        <field name="description">Pagos a terceros</field>
    </record>
</odoo>
