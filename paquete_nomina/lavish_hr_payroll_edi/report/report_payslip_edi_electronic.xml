<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- PAPER FORMAT -->
    <record id="paperformat_nomina_electronica" model="report.paperformat">
        <field name="name">Nómina Electrónica</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">38</field>
        <field name="margin_bottom">18</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">33</field>
        <field name="dpi">90</field>
    </record>

    <!-- REPORT ACTION -->
    <record id="action_report_payslip_edi_electronic" model="ir.actions.report">
        <field name="name">Documento Electrónico de Nómina</field>
        <field name="model">hr.payslip.edi</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_payroll_edi.report_payslip_edi_electronic</field>
        <field name="report_file">lavish_hr_payroll_edi.report_payslip_edi_electronic</field>
        <field name="print_report_name">'NominaElectronica_%s_%s' % (object.number or '', object.employee_id.identification_id or '')</field>
        <field name="binding_model_id" ref="model_hr_payslip_edi"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_nomina_electronica"/>
    </record>

    <!-- WRAPPER -->
    <template id="report_payslip_edi_electronic">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="o" t-value="o.with_context(lang=o.employee_id.work_contact_id.lang or o.env.lang)"/>
                <t t-set="company" t-value="o.company_id"/>
                <t t-set="partner" t-value="company.partner_id"/>

                <div class="article"
                     t-att-data-oe-model="o and o._name"
                     t-att-data-oe-id="o and o.id">

                    <!-- HEADER -->
                    <div class="header" style="font-family: sans-serif; font-size: 10px; color: #333; padding-bottom: 4px; border-bottom: 2px solid #333;">
                        <style>
                            .header table, .header table tbody, .header table thead,
                            .header table tr, .header table td, .header table th {
                                border: 0 none !important; border-style: none !important;
                            }
                        </style>
                        <table class="table-borderless" style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 14%; text-align: center; vertical-align: middle; padding: 2px;">
                                    <t t-if="o.QR_code">
                                        <img t-att-src="image_data_uri(o.QR_code)" style="width: 80px; height: 80px;"/>
                                    </t>
                                    <t t-else="">
                                        <img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('QR', 'PENDIENTE', 150, 150)"
                                             style="width: 80px; height: 80px;"/>
                                    </t>
                                </td>
                                <td style="width: 52%; vertical-align: middle; padding: 2px 10px; text-align: center;">
                                    <t t-if="company.logo">
                                        <img t-att-src="image_data_uri(company.logo)" style="max-height: 28px; margin-bottom: 2px;"/><br/>
                                    </t>
                                    <div style="font-size: 11px; font-weight: bold;"><t t-out="partner.name"/></div>
                                    <div style="font-size: 9px;">NIT: <b><t t-out="partner.vat_co or company.vat or ''"/>-<t t-out="partner.dv or ''"/></b></div>
                                    <div style="font-size: 8px; color: #555;">
                                        <t t-out="partner.street or ''"/> -
                                        <t t-out="partner.city_id.name if partner.city_id else ''"/>,
                                        <t t-out="partner.state_id.name if partner.state_id else ''"/>
                                    </div>
                                    <div style="font-size: 9px; font-weight: bold; margin-top: 3px;">DOCUMENTO SOPORTE DE PAGO DE NOMINA ELECTRONICA</div>
                                </td>
                                <td style="width: 34%; vertical-align: middle; padding: 2px 6px; font-size: 9px;">
                                    <div style="font-size: 7px; text-transform: uppercase; color: #888;">Número</div>
                                    <div style="font-size: 13px; font-weight: bold; margin-bottom: 3px;"><t t-out="o.number"/></div>
                                    <div style="font-size: 7px; text-transform: uppercase; color: #888;">Tipo</div>
                                    <div style="margin-bottom: 3px;">
                                        <t t-if="not o.credit_note">102 - NominaIndividual</t>
                                        <t t-else="">103 - NominaDeAjuste</t>
                                    </div>
                                    <div style="font-size: 7px; text-transform: uppercase; color: #888;">Estado DIAN</div>
                                    <div style="font-weight: bold; margin-bottom: 3px;">
                                        <t t-out="dict(o._fields['state_dian'].selection).get(o.state_dian, o.state_dian or '')"/>
                                    </div>
                                    <div style="font-size: 7px; text-transform: uppercase; color: #888;">Fecha</div>
                                    <div style="font-size: 8px;"><t t-out="o.write_date.strftime('%Y-%m-%d') if o.write_date else '-'"/></div>
                                </td>
                            </tr>
                        </table>
                        <div style="font-size: 7px; margin-top: 2px;">
                            <b>CUNE: </b>
                            <span style="font-family: monospace; word-break: break-all;"><t t-out="o.current_cune or 'Pendiente'"/></span>
                        </div>
                    </div>

                    <!-- FOOTER -->
                    <div class="footer" style="font-family: sans-serif; font-size: 8px; color: #888; border-top: 1px solid #ccc; padding-top: 3px;">
                        <style>
                            .footer table, .footer table tr, .footer table td {
                                border: 0 none !important; border-style: none !important;
                            }
                        </style>
                        <table class="table-borderless" style="width: 100%;">
                            <tr>
                                <td style="width: 40%;"><b><t t-out="partner.name"/></b> - NIT: <t t-out="partner.vat_co or company.vat or ''"/></td>
                                <td style="width: 30%; text-align: center;">Nómina Electrónica DIAN</td>
                                <td style="width: 30%; text-align: right;"><t t-out="o.number"/> | Pág. <span class="page"/> de <span class="topage"/></td>
                            </tr>
                        </table>
                    </div>

                    <!-- PAGE -->
                    <div class="page" style="font-family: sans-serif; font-size: 10px; color: #333;">
                        <t t-call="lavish_hr_payroll_edi.report_payslip_edi_electronic_content"/>
                    </div>

                </div>
            </t>
        </t>
    </template>

    <!-- CONTENIDO -->
    <template id="report_payslip_edi_electronic_content">

        <t t-set="emp" t-value="o.employee_id"/>
        <t t-set="contact" t-value="emp.work_contact_id or emp"/>
        <t t-set="contract" t-value="o.contract_id"/>

        <!-- Calcular antigüedad -->
        <t t-set="today_date" t-value="o.date_to or o.payment_date"/>
        <t t-set="start_date" t-value="contract.date_start if contract else False"/>
        <t t-set="seniority_days" t-value="(today_date - start_date).days if start_date and today_date else 0"/>
        <t t-set="seniority_years" t-value="seniority_days // 365"/>
        <t t-set="seniority_months" t-value="(seniority_days % 365) // 30"/>
        <t t-set="seniority_rem" t-value="(seniority_days % 365) % 30"/>

        <!-- Líneas con ausencias -->
        <t t-set="leave_lines" t-value="o.line_ids.filtered(lambda l: l.departure_date or l.return_date)"/>

        <style>
            .page table, .page table tbody, .page table thead, .page table tfoot,
            .page table tr, .page table td, .page table th {
                border: 0 none !important; border-style: none !important;
            }
            .ne-title {
                font-size: 9px; font-weight: bold; text-transform: uppercase; color: #333;
                padding: 5px 0 3px; margin-top: 8px;
                border-bottom: 2px solid #333 !important; margin-bottom: 5px;
            }
            .ne-lbl { font-size: 7px; text-transform: uppercase; color: #888; }
            .ne-val { font-size: 10px; color: #222; }
            .ne-tbl { width: 100%; border-collapse: collapse; font-size: 9px; }
            .ne-tbl th {
                padding: 3px 4px; text-align: left; font-size: 8px;
                text-transform: uppercase; color: #555;
                border-bottom: 1px solid #333 !important;
            }
            .ne-tbl td { padding: 2px 4px; border-bottom: 1px solid #eee !important; }
            .ne-tbl .r { text-align: right; }
            .ne-total-row td {
                padding: 4px; font-weight: bold;
                border-top: 2px solid #333 !important; border-bottom: none !important;
            }
        </style>

        <!-- INFO GENERAL -->
        <div class="ne-title">Información General y Periodo</div>
        <table class="table-borderless" style="width: 100%; border-collapse: collapse;">
            <tr>
                <td style="width: 12%; padding: 2px 4px;">
                    <div class="ne-lbl">Prefijo</div>
                    <div class="ne-val"><t t-out="o._get_sequence().prefix if o._get_sequence() else ''"/></div>
                </td>
                <td style="width: 12%; padding: 2px 4px;">
                    <div class="ne-lbl">Consecutivo</div>
                    <div class="ne-val"><t t-out="o._get_consecutivo()"/></div>
                </td>
                <td style="width: 16%; padding: 2px 4px;">
                    <div class="ne-lbl">No. Contrato</div>
                    <div class="ne-val"><b><t t-out="contract.name if contract else '-'"/></b></div>
                </td>
                <td style="width: 15%; padding: 2px 4px;">
                    <div class="ne-lbl">Periodo Inicio</div>
                    <div class="ne-val"><t t-out="o.date_from"/></div>
                </td>
                <td style="width: 15%; padding: 2px 4px;">
                    <div class="ne-lbl">Periodo Fin</div>
                    <div class="ne-val"><t t-out="o.date_to"/></div>
                </td>
                <td style="width: 15%; padding: 2px 4px;">
                    <div class="ne-lbl">Fecha de Pago</div>
                    <div class="ne-val"><b><t t-out="o.payment_date"/></b></div>
                </td>
                <td style="width: 15%; padding: 2px 4px;">
                    <div class="ne-lbl">Archivo XML</div>
                    <div class="ne-val" style="font-family: monospace; font-size: 7px;"><t t-out="o.name_xml or '-'"/></div>
                </td>
            </tr>
            <tr>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Fecha Ingreso</div>
                    <div class="ne-val"><t t-out="contract.date_start if contract else '-'"/></div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Fecha Retiro</div>
                    <div class="ne-val"><t t-out="o.date_end_contract or '-'"/></div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Antigüedad</div>
                    <div class="ne-val">
                        <b><t t-out="seniority_years"/>a <t t-out="seniority_months"/>m <t t-out="seniority_rem"/>d</b>
                    </div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Nóminas Incluidas</div>
                    <div class="ne-val"><t t-out="o.payslip_count"/> nómina(s)</div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Moneda</div>
                    <div class="ne-val">COP</div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Ambiente</div>
                    <div class="ne-val">
                        <t t-if="o.company_id.production_payroll">Producción</t>
                        <t t-else="">Pruebas</t>
                    </div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Liquidación</div>
                    <div class="ne-val"><t t-out="'Sí' if o.is_liquidacion else 'No'"/></div>
                </td>
            </tr>
        </table>

        <!-- Nóminas usadas -->
        <t t-if="o.payslip_ids">
            <div style="font-size: 8px; color: #666; margin-top: 2px;">
                <b>Nóminas: </b>
                <t t-foreach="o.payslip_ids" t-as="ps">
                    <t t-out="ps.number or ps.name"/><t t-if="not ps_last"> | </t>
                </t>
            </div>
        </t>

        <!-- TRABAJADOR -->
        <div class="ne-title">Trabajador</div>
        <table class="table-borderless" style="width: 100%; border-collapse: collapse;">
            <tr>
                <td style="width: 28%; padding: 2px 4px;">
                    <div class="ne-lbl">Nombre Completo</div>
                    <div class="ne-val"><b><t t-out="emp.name"/></b></div>
                </td>
                <td style="width: 12%; padding: 2px 4px;">
                    <div class="ne-lbl">Tipo Doc</div>
                    <div class="ne-val"><t t-out="contact.l10n_latam_identification_type_id.name if contact.l10n_latam_identification_type_id else '-'"/></div>
                </td>
                <td style="width: 14%; padding: 2px 4px;">
                    <div class="ne-lbl">No. Documento</div>
                    <div class="ne-val"><b><t t-out="contact.vat_co or emp.identification_id or ''"/></b></div>
                </td>
                <td style="width: 14%; padding: 2px 4px;">
                    <div class="ne-lbl">Tipo / Subtipo</div>
                    <div class="ne-val">
                        <t t-out="emp.tipo_coti_id.code if emp.tipo_coti_id else ''"/> -
                        <t t-out="emp.subtipo_coti_id.code if emp.subtipo_coti_id else '00'"/>
                    </div>
                </td>
                <td style="width: 16%; padding: 2px 4px;">
                    <div class="ne-lbl">Tipo Contrato</div>
                    <div class="ne-val"><t t-out="contract.contract_type_id.name if contract and contract.contract_type_id else '-'"/></div>
                </td>
                <td style="width: 16%; padding: 2px 4px;">
                    <div class="ne-lbl">Sueldo</div>
                    <div class="ne-val"><b>$ <t t-out="'{:,.0f}'.format(contract.wage if contract else 0)"/></b></div>
                </td>
            </tr>
            <tr>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Lugar Trabajo</div>
                    <div class="ne-val">
                        <t t-out="contact.city_id.name if contact.city_id else ''"/>,
                        <t t-out="contact.state_id.name if contact.state_id else ''"/>
                    </div>
                </td>
                <td colspan="2" style="padding: 2px 4px;">
                    <div class="ne-lbl">Forma / Método Pago</div>
                    <div class="ne-val">
                        <t t-out="contract.way_pay_id.name if contract and contract.way_pay_id else '-'"/> /
                        <t t-out="contract.payment_method_dian_id.name if contract and contract.payment_method_dian_id else '-'"/>
                    </div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Banco</div>
                    <div class="ne-val"><t t-out="emp.bank_account_id.bank_id.name if emp.bank_account_id and emp.bank_account_id.bank_id else '-'"/></div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">Tipo Cuenta</div>
                    <div class="ne-val"><t t-out="o.get_bank_information(r_type=1) or '-'"/></div>
                </td>
                <td style="padding: 2px 4px;">
                    <div class="ne-lbl">No. Cuenta</div>
                    <div class="ne-val"><t t-out="o.get_bank_information(r_account=1) or '-'"/></div>
                </td>
            </tr>
        </table>

        <!-- AUSENCIAS (si hay líneas con fechas de ausencia) -->
        <t t-if="leave_lines">
            <div class="ne-title">Ausencias</div>
            <table class="ne-tbl">
                <thead>
                    <tr>
                        <th style="width: 30%;">Concepto</th>
                        <th style="width: 15%;">Cód. DIAN</th>
                        <th style="width: 15%;">Fecha Inicio</th>
                        <th style="width: 15%;">Fecha Fin</th>
                        <th style="width: 10%;" class="r">Días</th>
                        <th style="width: 15%;" class="r">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="leave_lines.sorted(key=lambda l: l.departure_date or l.date_from)" t-as="ll">
                        <tr>
                            <td><t t-out="ll.name"/></td>
                            <td style="font-family: monospace; font-size: 8px;">
                                <t t-out="ll.dian_code or ll.code or ''"/>
                            </td>
                            <td><t t-out="ll.departure_date or '-'"/></td>
                            <td><t t-out="ll.return_date or '-'"/></td>
                            <td class="r"><t t-out="'{:.1f}'.format(ll.quantity) if ll.quantity else ''"/></td>
                            <td class="r"><b>$ <t t-out="'{:,.0f}'.format(ll.total)"/></b></td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>

        <!-- DEVENGADOS Y DEDUCCIONES -->
        <t t-set="devengos" t-value="o.line_ids.filtered(lambda l: l.dev_or_ded == 'devengo' and l.total != 0)"/>
        <t t-set="deducciones" t-value="o.line_ids.filtered(lambda l: l.dev_or_ded == 'deduccion' and l.total != 0)"/>

        <div style="display: table; width: 100%; table-layout: fixed;">
            <!-- DEVENGADOS -->
            <div style="display: table-cell; width: 50%; padding-right: 5px; vertical-align: top;">
                <div class="ne-title">Devengados</div>
                <table class="ne-tbl">
                    <thead>
                        <tr>
                            <th style="width: 18%;">Cód.</th>
                            <th style="width: 44%;">Concepto</th>
                            <th style="width: 13%;" class="r">Cant.</th>
                            <th style="width: 25%;" class="r">Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="devengos.sorted(key=lambda l: l.sequence)" t-as="line">
                            <tr>
                                <td style="font-family: monospace; font-size: 8px;">
                                    <t t-out="line.dian_code or line.code"/>
                                </td>
                                <td><t t-out="line.name"/></td>
                                <td class="r"><t t-out="'{:.1f}'.format(line.quantity) if line.quantity != 1 else ''"/></td>
                                <td class="r"><b>$ <t t-out="'{:,.0f}'.format(line.total)"/></b></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="ne-total-row">
                            <td colspan="3">Total Devengados</td>
                            <td class="r">$ <t t-out="'{:,.0f}'.format(o.total_devengos)"/></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- DEDUCCIONES -->
            <div style="display: table-cell; width: 50%; padding-left: 5px; vertical-align: top;">
                <div class="ne-title">Deducciones</div>
                <table class="ne-tbl">
                    <thead>
                        <tr>
                            <th style="width: 18%;">Cód.</th>
                            <th style="width: 44%;">Concepto</th>
                            <th style="width: 13%;" class="r">%</th>
                            <th style="width: 25%;" class="r">Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="deducciones.sorted(key=lambda l: l.sequence)" t-as="line">
                            <tr>
                                <td style="font-family: monospace; font-size: 8px;">
                                    <t t-out="line.dian_code or line.code"/>
                                </td>
                                <td><t t-out="line.name"/></td>
                                <td class="r"><t t-out="'{:.1f}'.format(line.rate) if line.rate and line.rate != 100 else ''"/></td>
                                <td class="r"><b>$ <t t-out="'{:,.0f}'.format(abs(line.total))"/></b></td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="ne-total-row">
                            <td colspan="3">Total Deducciones</td>
                            <td class="r">$ <t t-out="'{:,.0f}'.format(abs(o.total_deducciones))"/></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- TOTALES -->
        <div style="margin-top: 8px; padding: 8px 0; border-top: 2px solid #333 !important; border-bottom: 2px solid #333 !important;">
            <table class="table-borderless" style="width: 100%;">
                <tr>
                    <td style="width: 33%; text-align: center;">
                        <div class="ne-lbl">Total Devengados</div>
                        <div style="font-size: 13px; font-weight: bold;">$ <t t-out="'{:,.0f}'.format(o.total_devengos)"/></div>
                    </td>
                    <td style="width: 34%; text-align: center;">
                        <div class="ne-lbl">Total Deducciones</div>
                        <div style="font-size: 13px; font-weight: bold;">$ <t t-out="'{:,.0f}'.format(abs(o.total_deducciones))"/></div>
                    </td>
                    <td style="width: 33%; text-align: center;">
                        <div class="ne-lbl">Neto a Pagar</div>
                        <div style="font-size: 16px; font-weight: bold;">$ <t t-out="'{:,.0f}'.format(o.total_paid)"/></div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- NOTA DE AJUSTE -->
        <t t-if="o.credit_note">
            <div class="ne-title">Nota de Ajuste</div>
            <table class="table-borderless" style="width: 100%; border-collapse: collapse;">
                <tr>
                    <td style="width: 20%; padding: 2px 4px;">
                        <div class="ne-lbl">Tipo Nota</div>
                        <div class="ne-val"><t t-out="'1 - Reemplazar' if o.type_note == '1' else '2 - Eliminar'"/></div>
                    </td>
                    <td style="width: 50%; padding: 2px 4px;">
                        <div class="ne-lbl">CUNE Predecesor</div>
                        <div style="font-family: monospace; font-size: 7px; word-break: break-all;"><t t-out="o.previous_cune or '-'"/></div>
                    </td>
                    <td style="width: 30%; padding: 2px 4px;">
                        <div class="ne-lbl">Documento Ajustado</div>
                        <div class="ne-val"><t t-out="o.parent_edi_id.number if o.parent_edi_id else '-'"/></div>
                    </td>
                </tr>
            </table>
        </t>

        <!-- INFORMACIÓN COMPLEMENTARIA -->
        <t t-set="info_lines" t-value="o.info_line_ids"/>
        <t t-if="info_lines">
            <div class="ne-title">Información Complementaria</div>
            <table class="ne-tbl">
                <thead>
                    <tr>
                        <th style="width: 25%;">Tipo</th>
                        <th style="width: 45%;">Descripción</th>
                        <th style="width: 30%;" class="r">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="info_lines" t-as="info">
                        <tr>
                            <td><t t-out="dict(info._fields['info_type'].selection).get(info.info_type, info.info_type or '-')"/></td>
                            <td><t t-out="info.name"/></td>
                            <td class="r"><t t-out="info.total if info.total else ''"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>

        <!-- SELLO DIAN -->
        <div style="margin-top: 10px; font-size: 8px; color: #666;">
            <table class="table-borderless" style="width: 100%;">
                <tr>
                    <td style="width: 50%; vertical-align: top;">
                        <div class="ne-lbl">URL Verificación DIAN</div>
                        <span style="font-family: monospace; font-size: 7px; word-break: break-all;">
                            <t t-out="o.cune_url or 'Pendiente'"/>
                        </span>
                    </td>
                    <td style="width: 50%; vertical-align: top; padding-left: 10px;">
                        <div class="ne-lbl">Respuesta DIAN</div>
                        <span style="font-size: 8px;"><t t-out="o.response_message_dian or '-'"/></span>
                    </td>
                </tr>
            </table>
        </div>

        <t t-if="o.note">
            <div style="margin-top: 6px; font-size: 8px; color: #666;">
                <b>Notas: </b><t t-out="o.note"/>
            </div>
        </t>

    </template>

</odoo>
