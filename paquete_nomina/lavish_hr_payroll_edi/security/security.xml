<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Privilege (reemplaza ir.module.category en Odoo 19) -->
    <record id="privilege_nomina_electronica" model="res.groups.privilege">
        <field name="name">Nómina Electrónica</field>
        <field name="sequence">25</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <record id="group_payroll_edi_user" model="res.groups">
        <field name="name">Usuario</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_nomina_electronica"/>
        <field name="implied_ids" eval="[(4, ref('hr_payroll.group_hr_payroll_user'))]"/>
    </record>

    <record id="group_payroll_edi_manager" model="res.groups">
        <field name="name">Administrador</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="privilege_nomina_electronica"/>
        <field name="implied_ids" eval="[(4, ref('lavish_hr_payroll_edi.group_payroll_edi_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
