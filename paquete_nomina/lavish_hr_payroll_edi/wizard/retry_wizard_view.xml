<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_payslip_edi_retry_wizard_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.retry.wizard.form</field>
        <field name="model">hr.payslip.edi.retry.wizard</field>
        <field name="arch" type="xml">
            <form string="Reintentar Envío DIAN">
                <group>
                    <group>
                        <field name="payslip_edi_id" invisible="1"/>
                        <field name="has_zipkey" invisible="1"/>
                        <field name="zipkey" invisible="not has_zipkey"/>
                    </group>
                    <group>
                        <field name="action_type" widget="radio"/>
                    </group>
                </group>
                <separator string="Comparación de Valores"/>
                <group>
                    <field name="comparison_text" widget="text" nolabel="1"
                        style="font-family: monospace; white-space: pre-wrap;"/>
                </group>
                <footer>
                    <button name="action_execute" string="Ejecutar" type="object"
                        class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
