<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payslip_edi_batch_adjustment_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.batch.adjustment.form</field>
        <field name="model">hr.payslip.edi.batch.adjustment</field>
        <field name="arch" type="xml">
            <form string="Ajuste Masivo de Nómina Electrónica">
                <div class="alert alert-warning" role="alert"
                     invisible="not deadline_warning">
                    <i class="fa fa-clock-o me-1"/>
                    <field name="deadline_warning" readonly="1" nolabel="1"/>
                </div>
                <group>
                    <group>
                        <field name="type_note"/>
                        <field name="adjustment_reason"
                            placeholder="Describa la razón del ajuste masivo..."/>
                    </group>
                    <group>
                        <field name="create_new_run"/>
                        <field name="new_run_name"
                            invisible="not create_new_run"
                            placeholder="Ej: Ajustes Enero 2025"/>
                        <field name="payslip_run_id"
                            invisible="create_new_run"/>
                    </group>
                </group>
                <separator string="Documentos Seleccionados"/>
                <field name="source_ids">
                    <list string="Documentos a Ajustar" create="0" delete="1"
                          decoration-success="state_dian == 'exitoso'">
                        <field name="number" decoration-bf="1"/>
                        <field name="employee_id" widget="many2one_avatar_employee"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="total_devengos"/>
                        <field name="total_deducciones"/>
                        <field name="total_paid" decoration-bf="1"/>
                        <field name="state_dian" widget="badge"/>
                    </list>
                </field>
                <footer>
                    <button string="Crear Ajustes Masivos"
                        name="action_create_batch_adjustments"
                        type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
