<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payslip_edi_selective_dian_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.selective.dian.form</field>
        <field name="model">hr.payslip.edi.selective.dian</field>
        <field name="arch" type="xml">
            <form string="Envío Selectivo a DIAN">
                <div class="alert alert-info" role="alert">
                    Seleccione los documentos que desea validar y enviar a DIAN.
                    Primero valide los datos para verificar que están completos.
                </div>
                <group>
                    <group>
                        <field name="run_id" readonly="1" invisible="not run_id"/>
                        <field name="total_selected"/>
                    </group>
                    <group>
                        <field name="total_ready"
                            decoration-success="total_ready > 0"/>
                        <field name="total_errors"
                            decoration-danger="total_errors > 0"/>
                    </group>
                </group>
                <field name="line_ids">
                    <list string="Documentos" editable="bottom"
                          decoration-success="validation_status == 'ok'"
                          decoration-danger="validation_status == 'error'"
                          decoration-muted="not selected">
                        <field name="selected" widget="boolean_toggle"/>
                        <field name="number" decoration-bf="1"/>
                        <field name="employee_id" widget="many2one_avatar_employee"/>
                        <field name="total_paid"/>
                        <field name="state_dian" widget="badge"
                            decoration-success="state_dian == 'exitoso'"
                            decoration-danger="state_dian in ('rechazado', 'error')"
                            decoration-muted="state_dian == 'por_notificar'"/>
                        <field name="validation_status" widget="badge"
                            decoration-success="validation_status == 'ok'"
                            decoration-danger="validation_status == 'error'"
                            decoration-muted="validation_status == 'pending'"/>
                        <field name="validation_errors" optional="hide"
                            widget="text"/>
                    </list>
                </field>
                <footer>
                    <button string="Validar Datos" name="action_validate_selected"
                        type="object" class="btn-secondary"
                        icon="fa-check-circle"
                        title="Valida datos sin enviar a DIAN"/>
                    <button string="Enviar a DIAN" name="action_send_selected"
                        type="object" class="btn-primary"
                        icon="fa-cloud-upload"
                        title="Envía los documentos seleccionados y validados"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- TREE/FORM: hr.payslip.edi.log                                    -->
    <!-- ================================================================ -->
    <record id="view_hr_payslip_edi_log_tree" model="ir.ui.view">
        <field name="name">hr.payslip.edi.log.tree</field>
        <field name="model">hr.payslip.edi.log</field>
        <field name="arch" type="xml">
            <list string="Logs Nómina Electrónica"
                  decoration-success="level == 'success'"
                  decoration-danger="level == 'error'"
                  decoration-warning="level == 'warning'"
                  decoration-info="level == 'info'"
                  default_order="create_date desc">
                <field name="create_date" string="Fecha"/>
                <field name="payslip_edi_id"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="log_type" widget="badge"/>
                <field name="level" widget="badge"
                    decoration-success="level == 'success'"
                    decoration-danger="level == 'error'"
                    decoration-warning="level == 'warning'"
                    decoration-info="level == 'info'"/>
                <field name="dian_code"/>
                <field name="summary"/>
                <field name="state_dian_result" widget="badge" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payslip_edi_log_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.log.form</field>
        <field name="model">hr.payslip.edi.log</field>
        <field name="arch" type="xml">
            <form string="Log Nómina Electrónica">
                <sheet>
                    <group>
                        <group>
                            <field name="payslip_edi_id"/>
                            <field name="employee_id"/>
                            <field name="payslip_run_id"/>
                        </group>
                        <group>
                            <field name="log_type"/>
                            <field name="level"/>
                            <field name="dian_code"/>
                            <field name="state_dian_result"/>
                        </group>
                    </group>
                    <group string="Detalle">
                        <field name="summary"/>
                        <field name="detail"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_payslip_edi_log_search" model="ir.ui.view">
        <field name="name">hr.payslip.edi.log.search</field>
        <field name="model">hr.payslip.edi.log</field>
        <field name="arch" type="xml">
            <search string="Buscar Logs">
                <field name="payslip_edi_id"/>
                <field name="employee_id"/>
                <field name="dian_code"/>
                <field name="summary"/>
                <separator/>
                <filter string="Errores" name="errors" domain="[('level', '=', 'error')]"/>
                <filter string="Advertencias" name="warnings" domain="[('level', '=', 'warning')]"/>
                <filter string="Éxito" name="success" domain="[('level', '=', 'success')]"/>
                <separator/>
                <filter string="Validación" name="validation" domain="[('log_type', '=', 'validation')]"/>
                <filter string="Respuesta DIAN" name="response" domain="[('log_type', '=', 'response')]"/>
                <separator/>
                <group>
                    <filter string="Empleado" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Nivel" name="group_level" context="{'group_by': 'level'}"/>
                    <filter string="Tipo" name="group_type" context="{'group_by': 'log_type'}"/>
                    <filter string="Código DIAN" name="group_code" context="{'group_by': 'dian_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_payslip_edi_log" model="ir.actions.act_window">
        <field name="name">Logs Nómina Electrónica</field>
        <field name="res_model">hr.payslip.edi.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_errors": 1}</field>
    </record>

    <menuitem id="menu_hr_payroll_edi_logs"
        name="Logs DIAN"
        parent="menu_hr_payroll_edi_root"
        action="action_hr_payslip_edi_log"
        sequence="30"/>
</odoo>
