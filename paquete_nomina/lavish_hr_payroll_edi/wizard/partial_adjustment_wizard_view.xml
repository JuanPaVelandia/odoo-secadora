<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payslip_edi_partial_adjustment_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.partial.adjustment.form</field>
        <field name="model">hr.payslip.edi.partial.adjustment</field>
        <field name="arch" type="xml">
            <form string="Ajuste Parcial de Nómina Electrónica">
                <div class="alert alert-info" role="alert">
                    <i class="fa fa-info-circle me-1"/>
                    <strong>Importante:</strong> DIAN requiere el documento completo en notas tipo Reemplazar.
                    Se copiarán TODAS las líneas del documento original, pero solo se modificarán
                    los conceptos que usted seleccione aquí.
                </div>
                <group>
                    <group>
                        <field name="source_edi_id"/>
                        <field name="employee_id"/>
                    </group>
                    <group>
                        <field name="adjustment_reason" placeholder="Describa la razón del ajuste..."/>
                    </group>
                </group>
                <separator string="Conceptos del Documento Original"/>
                <field name="line_ids">
                    <list string="Líneas" editable="bottom"
                          decoration-info="selected"
                          decoration-muted="not selected">
                        <field name="selected" widget="boolean_toggle"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="original_quantity"/>
                        <field name="original_amount"/>
                        <field name="original_total" sum="Total Original"/>
                        <field name="new_quantity" readonly="not selected"
                               decoration-bf="selected"/>
                        <field name="new_amount" readonly="not selected"
                               decoration-bf="selected"/>
                        <field name="new_total" sum="Total Nuevo"
                               decoration-bf="selected"/>
                        <field name="difference" sum="Diferencia Total"
                               decoration-danger="difference &lt; 0"
                               decoration-success="difference &gt; 0"/>
                    </list>
                </field>
                <footer>
                    <button string="Crear Nota de Ajuste" name="action_create_partial_adjustment"
                        type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
