<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_dian_rejection_glossary_tree" model="ir.ui.view">
        <field name="name">dian.rejection.glossary.tree</field>
        <field name="model">dian.rejection.glossary</field>
        <field name="arch" type="xml">
            <list string="Glosario Reglas DIAN">
                <field name="code"/>
                <field name="rule"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_dian_rejection_glossary_form" model="ir.ui.view">
        <field name="name">dian.rejection.glossary.form</field>
        <field name="model">dian.rejection.glossary</field>
        <field name="arch" type="xml">
            <form string="Regla de Rechazo DIAN">
                <sheet>
                    <div class="oe_title">
                        <label for="rule"/>
                        <h1><field name="rule" placeholder="Nombre de la regla"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mensaje de Error" name="message">
                            <field name="message" placeholder="Mensaje de error DIAN..."/>
                        </page>
                        <page string="Solución Sugerida" name="solution">
                            <field name="solution" placeholder="Solución sugerida..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dian_rejection_glossary" model="ir.actions.act_window">
        <field name="name">Glosario Reglas DIAN</field>
        <field name="res_model">dian.rejection.glossary</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_dian_rejection_glossary"
        name="Glosario Reglas DIAN"
        parent="menu_hr_payroll_edi_config"
        action="action_dian_rejection_glossary"
        sequence="50"/>
</odoo>
