<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Agregar estado DIAN al formulario de nomina normal -->
    <record id="view_hr_payslip_edi_status_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.status.form.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="state_dian_display" widget="badge"
                    decoration-muted="state_dian_display == 'sin_documento'"
                    decoration-info="state_dian_display == 'por_notificar'"
                    decoration-warning="state_dian_display == 'por_validar'"
                    decoration-success="state_dian_display == 'exitoso'"
                    decoration-danger="state_dian_display in ('error', 'rechazado')"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Nómina Electrónica" name="edi_info">
                    <group>
                        <group string="Estado EDI">
                            <field name="state_dian_display" readonly="1"/>
                            <field name="epayslip_edi_count" string="Documentos EDI"/>
                            <button name="action_open_edi_documents" type="object"
                                string="Ver Documentos EDI"
                                class="btn-link" icon="fa-external-link"
                                invisible="epayslip_edi_count == 0"/>
                        </group>
                    </group>
                    <field name="epayslip_edi_ids" readonly="1">
                        <list string="Documentos de Nómina Electrónica">
                            <field name="number"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="credit_note"/>
                            <field name="state" widget="badge"
                                decoration-info="state == 'draft'"
                                decoration-warning="state == 'verify'"
                                decoration-success="state == 'done'"
                                decoration-danger="state == 'cancel'"/>
                            <field name="state_dian" widget="badge"
                                decoration-muted="state_dian == 'por_notificar'"
                                decoration-warning="state_dian == 'por_validar'"
                                decoration-success="state_dian == 'exitoso'"
                                decoration-danger="state_dian in ('error', 'rechazado')"/>
                            <field name="current_cune"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Agregar estado DIAN al tree de nominas normales -->
    <record id="view_hr_payslip_edi_status_tree" model="ir.ui.view">
        <field name="name">hr.payslip.edi.status.tree.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state_display']" position="after">
                <field name="state_dian_display" widget="badge" optional="show"
                    decoration-muted="state_dian_display == 'sin_documento'"
                    decoration-info="state_dian_display == 'por_notificar'"
                    decoration-warning="state_dian_display == 'por_validar'"
                    decoration-success="state_dian_display == 'exitoso'"
                    decoration-danger="state_dian_display in ('error', 'rechazado')"/>
            </xpath>
        </field>
    </record>
</odoo>
