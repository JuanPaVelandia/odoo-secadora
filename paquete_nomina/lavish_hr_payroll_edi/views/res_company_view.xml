<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_payroll_edi" model="ir.ui.view">
        <field name="name">res.company.form.payroll.edi</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Nómina Electrónica DIAN" name="payroll_edi">
                    <group>
                        <group string="Ambiente">
                            <field name="production_payroll"/>
                            <field name="password_environment_payroll" password="True"/>
                            <field name="identificador_set_pruebas_payroll"
                                invisible="production_payroll"/>
                        </group>
                        <group string="Software">
                            <field name="software_identification_code_payroll"/>
                            <field name="software_pin_payroll" password="True"/>
                            <field name="seed_code_payroll"/>
                        </group>
                    </group>
                    <group>
                        <group string="Certificado Digital">
                            <field name="certificate_file_payroll" filename="certificate_filename"/>
                            <field name="certificate_key_payroll" password="True"/>
                            <button name="action_extract_certificate_payroll" type="object"
                                string="Extraer"
                                class="btn-primary btn-sm mb-2"
                                icon="fa-key"
                                title="Extrae serial, certificado público y PEM desde el archivo P12"/>
                            <field name="serial_number_payroll" readonly="1"/>
                            <field name="certificate_expiry_payroll" readonly="1"/>
                            <field name="certificate_issuer_payroll" readonly="1"/>
                            <field name="pem_file_payroll" filename="pem_filename" readonly="1" invisible="1"/>
                            <field name="digital_certificate_payroll" readonly="1" invisible="1"/>
                        </group>
                        <group string="Repositorio">
                            <field name="document_repository_payroll"/>
                        </group>
                    </group>
                    <group>
                        <group string="Secuencias">
                            <field name="sequence_payroll_id"/>
                            <field name="sequence_payroll_note_id"/>
                        </group>
                        <group string="Reglas Salariales">
                            <button name="action_auto_assign_dian_concepts" type="object"
                                string="Asociar Reglas con Conceptos DIAN"
                                class="btn-primary btn-sm"
                                icon="fa-link"
                                title="Asocia automáticamente cada regla salarial con su concepto DIAN (devengado o deducción)"
                                confirm="Esto asignará conceptos DIAN a todas las reglas salariales que aún no tengan asignación. ¿Continuar?"/>
                            <button name="action_audit_salary_rules_dian" type="object"
                                string="Auditar Reglas con Cuenta sin Concepto DIAN"
                                class="btn-warning btn-sm"
                                icon="fa-exclamation-triangle"
                                title="Lista las reglas salariales que tienen cuenta contable configurada pero no tienen concepto DIAN asignado. Estas reglas generan asiento pero NO se reportan en XML DIAN."/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
