<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_type_note_tree" model="ir.ui.view">
        <field name="name">hr.type.note.tree</field>
        <field name="model">hr.type.note</field>
        <field name="arch" type="xml">
            <list string="Tipos de Nota">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_hr_type_note" model="ir.actions.act_window">
        <field name="name">Tipos de Nota</field>
        <field name="res_model">hr.type.note</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_type_note"
        name="Tipos de Nota"
        parent="menu_hr_payroll_edi_config"
        action="action_hr_type_note"
        sequence="20"/>
</odoo>
