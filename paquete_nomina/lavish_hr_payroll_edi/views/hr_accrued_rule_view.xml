<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_accrued_rule_tree" model="ir.ui.view">
        <field name="name">hr.accrued.rule.tree</field>
        <field name="model">hr.accrued.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de Devengado">
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hr_accrued_rule_form" model="ir.ui.view">
        <field name="name">hr.accrued.rule.form</field>
        <field name="model">hr.accrued.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Devengado DIAN">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del devengado"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reglas Salariales" name="salary_rules">
                            <field name="salary_rule_ids" readonly="1">
                                <list string="Reglas Salariales Asociadas">
                                    <field name="sequence"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="struct_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_accrued_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Devengado</field>
        <field name="res_model">hr.accrued.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_accrued_rule"
        name="Reglas Devengado"
        parent="menu_hr_payroll_edi_config"
        action="action_hr_accrued_rule"
        sequence="40"/>
</odoo>
