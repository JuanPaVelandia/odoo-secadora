<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        En Odoo 19, hr.contract fue reemplazado por hr.version.
        Los campos del contrato/versión se muestran directamente en el formulario
        del empleado a través de _inherits = {'hr.version': 'version_id'}.
        Los campos EDI se agregan en la página "Payroll" del empleado.
    -->
    <record id="view_hr_version_edi_form" model="ir.ui.view">
        <field name="name">hr.version.edi.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='payroll_information']" position="inside">
                <group string="Nómina Electrónica DIAN">
                    <group>
                        <field name="way_pay_id"/>
                        <field name="payment_method_dian_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
