<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_way_pay_tree" model="ir.ui.view">
        <field name="name">hr.way.pay.tree</field>
        <field name="model">hr.way.pay</field>
        <field name="arch" type="xml">
            <list string="Formas de Pago">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_hr_way_pay" model="ir.actions.act_window">
        <field name="name">Formas de Pago</field>
        <field name="res_model">hr.way.pay</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_way_pay"
        name="Formas de Pago"
        parent="menu_hr_payroll_edi_config"
        action="action_hr_way_pay"
        sequence="35"/>
</odoo>
