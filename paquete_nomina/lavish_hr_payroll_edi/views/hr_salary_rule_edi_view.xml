<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Agregar campos de configuración EDI al formulario de reglas salariales -->
    <record id="view_hr_salary_rule_edi_form" model="ir.ui.view">
        <field name="name">hr.salary.rule.edi.form.inherit</field>
        <field name="model">hr.salary.rule</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_rule_form"/>
        <field name="priority">25</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Nómina Electrónica" name="edi_config">
                    <group>
                        <group string="Configuración DIAN">
                            <field name="devengado_rule_id"/>
                            <field name="deduccion_rule_id"/>
                            <field name="dev_or_ded"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
