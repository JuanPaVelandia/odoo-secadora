<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payment_method_dian_tree" model="ir.ui.view">
        <field name="name">hr.payment.method.dian.tree</field>
        <field name="model">hr.payment.method.dian</field>
        <field name="arch" type="xml">
            <list string="Métodos de Pago">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_hr_payment_method_dian" model="ir.actions.act_window">
        <field name="name">Métodos de Pago DIAN</field>
        <field name="res_model">hr.payment.method.dian</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_payment_method_dian"
        name="Métodos de Pago"
        parent="menu_hr_payroll_edi_config"
        action="action_hr_payment_method_dian"
        sequence="30"/>
</odoo>
