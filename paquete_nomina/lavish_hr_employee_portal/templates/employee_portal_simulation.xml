<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template de Selección de Empleado para Simulación -->
    <template id="employee_portal_simulation_selector" name="Employee Portal Simulation - Select Employee">
        <t t-call="portal.portal_layout">
            <div id="wrap" class="oe_structure">
                <div class="container my-5">
                    <!-- Encabezado -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card shadow-sm border-warning">
                                <div class="card-body bg-warning bg-opacity-10">
                                    <h2 class="mb-2">
                                        <i class="fa fa-user-secret me-2"></i>
                                        Simulación de Portal de Empleado
                                    </h2>
                                    <p class="text-muted mb-0">
                                        <i class="fa fa-info-circle me-1"></i>
                                        Seleccione un empleado para ver su portal en modo solo lectura
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Filtros de Búsqueda -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="fa fa-filter me-2"></i>Filtros de Búsqueda
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Buscar por Nombre/Identificación</label>
                                            <input type="text"
                                                   id="search_name"
                                                   class="form-control"
                                                   placeholder="Nombre o identificación..."/>
                                        </div>
                                        <div class="col-md-3 mb-3">
                                            <label class="form-label">Departamento</label>
                                            <select id="filter_department" class="form-select">
                                                <option value="">Todos</option>
                                                <t t-foreach="departments" t-as="dept">
                                                    <option t-att-value="dept['id']" t-out="dept['name']"/>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-md-3 mb-3">
                                            <label class="form-label">Cargo</label>
                                            <select id="filter_job" class="form-select">
                                                <option value="">Todos</option>
                                                <t t-foreach="jobs" t-as="job">
                                                    <option t-att-value="job['id']" t-out="job['name']"/>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-md-2 mb-3">
                                            <label class="form-label">Estado</label>
                                            <select id="filter_active" class="form-select">
                                                <option value="active">Activos</option>
                                                <option value="inactive">Inactivos</option>
                                                <option value="all">Todos</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Lista de Empleados -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0">
                                        <i class="fa fa-users me-2"></i>
                                        Empleados Disponibles (<span id="employee_count"><t t-out="len(employees)"/></span>)
                                    </h5>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-striped mb-0" id="employees_table">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th width="60">Foto</th>
                                                    <th>Nombre</th>
                                                    <th>Identificación</th>
                                                    <th>Cargo</th>
                                                    <th>Departamento</th>
                                                    <th>Estado</th>
                                                    <th class="text-center" width="150">Acción</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="employees" t-as="emp">
                                                    <tr class="employee-row"
                                                        t-att-data-name="emp['name'].lower()"
                                                        t-att-data-identification="emp['identification'].lower() if emp['identification'] else ''"
                                                        t-att-data-department="emp['department_id']"
                                                        t-att-data-job="emp['job_id']"
                                                        t-att-data-active="'active' if emp['active'] else 'inactive'">
                                                        <td class="text-center">
                                                            <t t-if="emp['image_128']">
                                                                <img t-att-src="'data:image/png;base64,%s' % emp['image_128'].decode('utf-8')"
                                                                     class="rounded-circle"
                                                                     style="width: 40px; height: 40px; object-fit: cover;"
                                                                     t-att-alt="emp['name']"/>
                                                            </t>
                                                            <t t-else="">
                                                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                                                                     style="width: 40px; height: 40px; margin: 0 auto;">
                                                                    <i class="fa fa-user text-white"></i>
                                                                </div>
                                                            </t>
                                                        </td>
                                                        <td>
                                                            <strong t-out="emp['name']"/>
                                                            <t t-if="not emp['active']">
                                                                <span class="badge bg-secondary ms-2">Inactivo</span>
                                                            </t>
                                                        </td>
                                                        <td t-out="emp['identification'] or '-'"/>
                                                        <td t-out="emp['job'] or '-'"/>
                                                        <td t-out="emp['department'] or '-'"/>
                                                        <td>
                                                            <t t-if="emp['show_in_portal']">
                                                                <span class="badge bg-success">
                                                                    <i class="fa fa-check me-1"></i>Portal Activo
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="badge bg-warning">
                                                                    <i class="fa fa-times me-1"></i>Portal Inactivo
                                                                </span>
                                                            </t>
                                                        </td>
                                                        <td class="text-center">
                                                            <a t-attf-href="/my/employee/simulate/#{emp['id']}"
                                                               class="btn btn-sm btn-primary"
                                                               target="_blank">
                                                                <i class="fa fa-eye me-1"></i>Ver Portal
                                                            </a>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Mensaje si no hay resultados -->
                                    <div id="no_results" class="alert alert-info m-3" style="display: none;">
                                        <i class="fa fa-info-circle me-2"></i>
                                        No se encontraron empleados con los filtros seleccionados
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información Adicional -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="alert alert-info">
                                <h6 class="alert-heading">
                                    <i class="fa fa-lightbulb-o me-2"></i>Instrucciones de Uso
                                </h6>
                                <ul class="mb-0">
                                    <li>Haga clic en "Ver Portal" para acceder al portal del empleado seleccionado</li>
                                    <li>El portal se abrirá en una nueva pestaña en modo solo lectura</li>
                                    <li>Si el empleado no tiene portal activo, se activará automáticamente</li>
                                    <li>Use los filtros para encontrar empleados específicos rápidamente</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- JavaScript para Filtros -->
            <script>
                (function() {
                    const searchInput = document.getElementById('search_name');
                    const deptFilter = document.getElementById('filter_department');
                    const jobFilter = document.getElementById('filter_job');
                    const activeFilter = document.getElementById('filter_active');
                    const rows = document.querySelectorAll('.employee-row');
                    const noResults = document.getElementById('no_results');
                    const countSpan = document.getElementById('employee_count');

                    function applyFilters() {
                        const searchTerm = searchInput.value.toLowerCase();
                        const deptId = deptFilter.value;
                        const jobId = jobFilter.value;
                        const activeStatus = activeFilter.value;

                        let visibleCount = 0;

                        rows.forEach(row => {
                            const name = row.getAttribute('data-name') || '';
                            const identification = row.getAttribute('data-identification') || '';
                            const department = row.getAttribute('data-department');
                            const job = row.getAttribute('data-job');
                            const active = row.getAttribute('data-active');

                            // Filtro de búsqueda
                            const matchesSearch = !searchTerm ||
                                                name.includes(searchTerm) ||
                                                identification.includes(searchTerm);

                            // Filtro de departamento
                            const matchesDept = !deptId || department === deptId;

                            // Filtro de cargo
                            const matchesJob = !jobId || job === jobId;

                            // Filtro de estado
                            const matchesActive = activeStatus === 'all' ||
                                                active === activeStatus;

                            const show = matchesSearch &amp;&amp; matchesDept &amp;&amp; matchesJob &amp;&amp; matchesActive;

                            if (show) {
                                row.style.display = '';
                                visibleCount++;
                            } else {
                                row.style.display = 'none';
                            }
                        });

                        // Actualizar contador
                        countSpan.textContent = visibleCount;

                        // Mostrar/ocultar mensaje de sin resultados
                        if (visibleCount === 0) {
                            noResults.style.display = 'block';
                        } else {
                            noResults.style.display = 'none';
                        }
                    }

                    // Event listeners
                    searchInput.addEventListener('input', applyFilters);
                    deptFilter.addEventListener('change', applyFilters);
                    jobFilter.addEventListener('change', applyFilters);
                    activeFilter.addEventListener('change', applyFilters);

                    // Inicializar filtro por defecto (solo activos)
                    applyFilters();
                })();
            </script>
        </t>
    </template>
</odoo>
