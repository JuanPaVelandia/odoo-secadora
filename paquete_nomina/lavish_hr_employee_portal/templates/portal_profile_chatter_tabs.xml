<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESTE ARCHIVO CONTIENE LOS TABS DE MI PERFIL Y CHATTER -->
    <!-- DEBE SER INSERTADO EN employee_portal_templates.xml DESPUÉS DEL TAB RESUMEN -->

    <!-- Tab Mi Perfil con Contrato y Organigrama -->
    <template id="portal_tab_mi_perfil" name="Portal Tab - Mi Perfil">
        <div class="tab-pane fade" id="mi_perfil" role="tabpanel">
            <div class="row">
                <!-- Información del Contrato -->
                <div class="col-md-8 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fa fa-file-contract me-2"></i>Mi Contrato
                            </h5>
                        </div>
                        <div class="card-body">
                            <t t-if="portal_data.get('contract')">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="text-muted small">Tipo de Contrato</label>
                                            <p class="fw-bold">
                                                <t t-out="portal_data['contract']['contract_type']"/>
                                            </p>
                                        </div>
                                        <div class="mb-3">
                                            <label class="text-muted small">Cargo</label>
                                            <p class="fw-bold">
                                                <t t-out="portal_data['contract']['job']"/>
                                            </p>
                                        </div>
                                        <div class="mb-3">
                                            <label class="text-muted small">Departamento</label>
                                            <p class="fw-bold">
                                                <t t-out="portal_data['contract']['department']"/>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="text-muted small">Fecha de Inicio</label>
                                            <p class="fw-bold">
                                                <i class="fa fa-calendar me-1 text-success"></i>
                                                <t t-out="portal_data['contract']['date_start'].strftime('%d/%m/%Y')"/>
                                            </p>
                                        </div>
                                        <div class="mb-3">
                                            <label class="text-muted small">Fecha de Fin</label>
                                            <p class="fw-bold">
                                                <t t-if="portal_data['contract']['date_end']">
                                                    <i class="fa fa-calendar me-1 text-danger"></i>
                                                    <t t-out="portal_data['contract']['date_end'].strftime('%d/%m/%Y')"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-success">
                                                        <i class="fa fa-infinity me-1"></i>Indefinido
                                                    </span>
                                                </t>
                                            </p>
                                        </div>
                                        <div class="mb-3">
                                            <label class="text-muted small">Estado</label>
                                            <p>
                                                <span t-attf-class="badge bg-#{portal_data['contract']['state'] == 'open' and 'success' or 'secondary'}">
                                                    <t t-out="portal_data['contract']['state_label']"/>
                                                </span>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="text-muted small">Horario</label>
                                            <p class="fw-bold">
                                                <i class="fa fa-clock-o me-1"></i>
                                                <t t-out="portal_data['contract']['resource_calendar']"/>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="text-muted small">Horas Semanales</label>
                                            <p class="fw-bold">
                                                <i class="fa fa-hourglass-half me-1"></i>
                                                <t t-out="portal_data['contract']['work_hours_per_week']"/> horas
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <t t-if="portal_data['contract']['trial_date_end']">
                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle me-2"></i>
                                        <strong>Período de Prueba:</strong> Finaliza el
                                        <t t-out="portal_data['contract']['trial_date_end'].strftime('%d/%m/%Y')"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="alert alert-warning">
                                    <i class="fa fa-exclamation-triangle me-2"></i>
                                    No tiene un contrato activo registrado
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Mini Organigrama -->
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fa fa-sitemap me-2"></i>Organigrama
                            </h5>
                        </div>
                        <div class="card-body">
                            <!-- Jefe Directo -->
                            <t t-if="portal_data['org_chart']['manager']">
                                <div class="text-center mb-4">
                                    <p class="small text-muted mb-2">Reporta a:</p>
                                    <t t-if="portal_data['org_chart']['manager']['photo']">
                                        <img t-att-src="'data:image/png;base64,%s' % portal_data['org_chart']['manager']['photo'].decode('utf-8')"
                                             class="rounded-circle mb-2"
                                             style="width: 80px; height: 80px; object-fit: cover; border: 3px solid #17a2b8;"
                                             alt="Jefe"/>
                                    </t>
                                    <t t-else="">
                                        <div class="rounded-circle bg-info d-inline-flex align-items-center justify-content-center mb-2"
                                             style="width: 80px; height: 80px;">
                                            <i class="fa fa-user text-white" style="font-size: 2rem;"></i>
                                        </div>
                                    </t>
                                    <h6 class="mb-0">
                                        <t t-out="portal_data['org_chart']['manager']['name']"/>
                                    </h6>
                                    <p class="small text-muted mb-1">
                                        <t t-out="portal_data['org_chart']['manager']['job']"/>
                                    </p>
                                    <p class="small mb-0">
                                        <t t-if="portal_data['org_chart']['manager']['email']">
                                            <i class="fa fa-envelope me-1"></i>
                                            <t t-out="portal_data['org_chart']['manager']['email']"/>
                                        </t>
                                    </p>
                                </div>
                                <hr/>
                            </t>

                            <!-- Compañeros de Equipo -->
                            <t t-if="portal_data['org_chart']['peers']">
                                <p class="small text-muted mb-2">Compañeros:</p>
                                <div class="list-group list-group-flush">
                                    <t t-foreach="portal_data['org_chart']['peers']" t-as="peer">
                                        <div class="list-group-item px-0 py-2">
                                            <div class="d-flex align-items-center">
                                                <t t-if="peer['photo']">
                                                    <img t-att-src="'data:image/png;base64,%s' % peer['photo'].decode('utf-8')"
                                                         class="rounded-circle me-2"
                                                         style="width: 40px; height: 40px; object-fit: cover;"
                                                         alt="Compañero"/>
                                                </t>
                                                <t t-else="">
                                                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-2"
                                                         style="width: 40px; height: 40px;">
                                                        <i class="fa fa-user text-white"></i>
                                                    </div>
                                                </t>
                                                <div>
                                                    <p class="mb-0 fw-bold" style="font-size: 0.9rem;">
                                                        <t t-out="peer['name']"/>
                                                    </p>
                                                    <p class="mb-0 small text-muted">
                                                        <t t-out="peer['job']"/>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>

                            <!-- Subordinados -->
                            <t t-if="portal_data['org_chart']['subordinates']">
                                <hr/>
                                <p class="small text-muted mb-2">A cargo:</p>
                                <div class="list-group list-group-flush">
                                    <t t-foreach="portal_data['org_chart']['subordinates']" t-as="subordinate">
                                        <div class="list-group-item px-0 py-2">
                                            <div class="d-flex align-items-center">
                                                <t t-if="subordinate['photo']">
                                                    <img t-att-src="'data:image/png;base64,%s' % subordinate['photo'].decode('utf-8')"
                                                         class="rounded-circle me-2"
                                                         style="width: 35px; height: 35px; object-fit: cover;"
                                                         alt="Subordinado"/>
                                                </t>
                                                <t t-else="">
                                                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-2"
                                                         style="width: 35px; height: 35px;">
                                                        <i class="fa fa-user text-white" style="font-size: 0.8rem;"></i>
                                                    </div>
                                                </t>
                                                <div>
                                                    <p class="mb-0 fw-bold" style="font-size: 0.85rem;">
                                                        <t t-out="subordinate['name']"/>
                                                    </p>
                                                    <p class="mb-0 small text-muted">
                                                        <t t-out="subordinate['job']"/>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>

                            <t t-if="not portal_data['org_chart']['manager'] and not portal_data['org_chart']['peers'] and not portal_data['org_chart']['subordinates']">
                                <div class="alert alert-info mb-0">
                                    <i class="fa fa-info-circle me-2"></i>
                                    No hay información de organigrama disponible
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <!-- Tab Chatter -->
    <template id="portal_tab_chatter" name="Portal Tab - Chatter">
        <div class="tab-pane fade" id="chatter" role="tabpanel">
            <div class="row">
                <div class="col-12">
                    <!-- Mensajes de éxito -->
                    <t t-if="request.params.get('message_posted')">
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fa fa-check-circle me-2"></i>
                            <strong>¡Mensaje publicado!</strong> Tu mensaje ha sido agregado correctamente.
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    </t>

                    <!-- Formulario para Publicar Mensaje -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fa fa-comment-o me-2"></i>Publicar Mensaje
                            </h5>
                        </div>
                        <div class="card-body">
                            <form method="post" t-attf-action="/my/employee/#{employee.id}/post_message?token=#{token}" enctype="multipart/form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="mb-3">
                                    <label class="form-label">Mensaje</label>
                                    <textarea name="message_body"
                                              class="form-control"
                                              rows="4"
                                              placeholder="Escribe tu mensaje aquí..."
                                              required="required"></textarea>
                                    <small class="form-text text-muted">
                                        Puedes usar este espacio para comunicarte con RRHH, hacer preguntas o compartir información.
                                    </small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Adjuntar Archivo (Opcional)</label>
                                    <input type="file"
                                           name="attachment"
                                           class="form-control"
                                           accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png"/>
                                    <small class="form-text text-muted">
                                        Máximo 10MB. Formatos permitidos: PDF, DOC, DOCX, XLS, XLSX, JPG, PNG
                                    </small>
                                </div>

                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa fa-paper-plane me-2"></i>Publicar Mensaje
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Lista de Mensajes -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">
                                <i class="fa fa-comments me-2"></i>Historial de Mensajes
                            </h5>
                        </div>
                        <div class="card-body">
                            <t t-if="portal_data.get('chatter', {}).get('messages')">
                                <div class="timeline">
                                    <t t-foreach="portal_data['chatter']['messages']" t-as="message">
                                        <div class="card mb-3 border-start border-primary border-4">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <div>
                                                        <h6 class="mb-0">
                                                            <i class="fa fa-user-circle me-1 text-primary"></i>
                                                            <t t-out="message['author']"/>
                                                        </h6>
                                                        <small class="text-muted">
                                                            <i class="fa fa-clock-o me-1"></i>
                                                            <t t-out="message['date'].strftime('%d/%m/%Y %H:%M')"/>
                                                        </small>
                                                    </div>
                                                </div>

                                                <div class="message-body" t-out="message['body']"/>

                                                <!-- Adjuntos -->
                                                <t t-if="message['attachments']">
                                                    <div class="mt-3">
                                                        <h6 class="small text-muted mb-2">
                                                            <i class="fa fa-paperclip me-1"></i>Adjuntos:
                                                        </h6>
                                                        <div class="list-group">
                                                            <t t-foreach="message['attachments']" t-as="att">
                                                                <a t-attf-href="/my/employee/#{employee.id}/download_attachment/#{att['id']}?token=#{token}"
                                                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                                                   target="_blank">
                                                                    <div>
                                                                        <i class="fa fa-file me-2"></i>
                                                                        <t t-out="att['name']"/>
                                                                    </div>
                                                                    <span class="badge bg-secondary">
                                                                        <t t-out="'{:.1f}'.format(att['file_size'] / 1024)"/> KB
                                                                    </span>
                                                                </a>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="alert alert-info">
                                    <i class="fa fa-info-circle me-2"></i>
                                    No hay mensajes aún. Sé el primero en publicar un mensaje.
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
