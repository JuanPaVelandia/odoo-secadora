<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para hr.employee - Campos del portal -->
    <record id="view_employee_form_portal_fields" model="ir.ui.view">
        <field name="name">hr.employee.form.portal.fields</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page name="portal_settings" string="Portal">
                    <group>
                        <group string="Configuración del Portal">
                            <field name="show_in_portal"/>
                            <field name="portal_access_token" readonly="1" groups="hr.group_hr_manager"/>
                            <button name="action_open_portal"
                                    string="Abrir Portal"
                                    type="object"
                                    class="btn-primary"
                                    invisible="not show_in_portal"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Vista de formulario para solicitudes de certificados de ingresos -->
    <record id="view_hr_income_certificate_request_form" model="ir.ui.view">
        <field name="name">hr.income.certificate.request.form</field>
        <field name="model">hr.income.certificate.request</field>
        <field name="arch" type="xml">
            <form string="Solicitud Certificado de Ingresos">
                <header>
                    <button name="action_generate" string="Generar Certificado" type="object"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_cancel" string="Cancelar" type="object"
                            invisible="state not in ['draft', 'pending']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="year"/>
                            <field name="header_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="request_date" readonly="1"/>
                            <field name="generation_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Motivo de la solicitud..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_income_certificate_request_tree" model="ir.ui.view">
        <field name="name">hr.income.certificate.request.tree</field>
        <field name="model">hr.income.certificate.request</field>
        <field name="arch" type="xml">
            <list string="Solicitudes de Certificados de Ingresos">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="year"/>
                <field name="request_date"/>
                <field name="generation_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="view_hr_income_certificate_request_search" model="ir.ui.view">
        <field name="name">hr.income.certificate.request.search</field>
        <field name="model">hr.income.certificate.request</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="year"/>
                <filter name="my_requests" string="Mis Solicitudes"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter name="pending" string="Pendientes"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="done" string="Completadas"
                        domain="[('state', '=', 'done')]"/>
                <group name="group_by">
                    <filter name="group_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_year" string="Año" context="{'group_by': 'year'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_income_certificate_request" model="ir.actions.act_window">
        <field name="name">Certificados de Ingresos</field>
        <field name="res_model">hr.income.certificate.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Solicitar un certificado de ingresos y retenciones
            </p>
        </field>
    </record>


</odoo>
