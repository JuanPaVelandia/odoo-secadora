<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista del Wizard de Pago -->
        <record id="view_hr_social_security_payment_wizard_form" model="ir.ui.view">
            <field name="name">hr.social.security.payment.wizard.form</field>
            <field name="model">hr.social.security.payment.wizard</field>
            <field name="arch" type="xml">
                <form string="Registrar Pago de Seguridad Social">
                    <group>
                        <group string="Información del Periodo">
                            <field name="social_security_id" readonly="1"/>
                            <field name="amount_to_pay" widget="monetary"/>
                            <field name="amount_already_paid" widget="monetary"/>
                            <field name="current_balance" widget="monetary"/>
                            <field name="is_vacation_liquidation" invisible="1"/>
                        </group>
                        <group string="Datos del Pago">
                            <field name="payment_date"/>
                            <field name="amount" widget="monetary"/>
                            <field name="journal_id"/>
                            <field name="reference"/>
                        </group>
                    </group>
                    <group>
                        <field name="create_accounting_entry"/>
                        <field name="notes" placeholder="Notas adicionales..."/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="is_vacation_liquidation == False">
                        <strong>Este periodo está marcado como liquidación de vacaciones.</strong>
                        <br/>No se generará asiento contable automáticamente.
                    </div>
                    <footer>
                        <button name="action_register_payment" string="Registrar Pago" type="object" class="btn-primary"/>
                        <button name="action_register_and_mark_vacation" string="Registrar como Vacaciones Liquidadas" type="object" class="btn-secondary" invisible="is_vacation_liquidation == True"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Vista de Líneas de Pago - Lista -->
        <record id="view_hr_social_security_payment_line_list" model="ir.ui.view">
            <field name="name">hr.social.security.payment.line.list</field>
            <field name="model">hr.social.security.payment.line</field>
            <field name="arch" type="xml">
                <list string="Historial de Pagos" create="0" edit="0">
                    <field name="payment_date"/>
                    <field name="social_security_id"/>
                    <field name="year"/>
                    <field name="month"/>
                    <field name="payment_type" widget="badge"
                        decoration-success="payment_type == 'payment'"
                        decoration-info="payment_type == 'overpayment_applied'"
                        decoration-warning="payment_type == 'adjustment'"
                        decoration-danger="payment_type == 'refund'"/>
                    <field name="amount" sum="Total"/>
                    <field name="journal_id"/>
                    <field name="reference"/>
                    <field name="source_social_security_id" optional="hide"/>
                    <field name="move_id" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Vista de Líneas de Pago - Formulario -->
        <record id="view_hr_social_security_payment_line_form" model="ir.ui.view">
            <field name="name">hr.social.security.payment.line.form</field>
            <field name="model">hr.social.security.payment.line</field>
            <field name="arch" type="xml">
                <form string="Detalle de Pago">
                    <sheet>
                        <group>
                            <group string="Información del Pago">
                                <field name="social_security_id"/>
                                <field name="payment_date"/>
                                <field name="payment_type"/>
                                <field name="amount"/>
                            </group>
                            <group string="Detalles">
                                <field name="journal_id"/>
                                <field name="reference"/>
                                <field name="move_id"/>
                                <field name="source_social_security_id"/>
                            </group>
                        </group>
                        <group string="Notas">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de Búsqueda para Líneas de Pago -->
        <record id="view_hr_social_security_payment_line_search" model="ir.ui.view">
            <field name="name">hr.social.security.payment.line.search</field>
            <field name="model">hr.social.security.payment.line</field>
            <field name="arch" type="xml">
                <search string="Buscar Pagos">
                    <field name="social_security_id"/>
                    <field name="payment_date"/>
                    <field name="reference"/>
                    <filter string="Pagos Directos" name="direct_payments" domain="[('payment_type','=','payment')]"/>
                    <filter string="Sobrepagos Aplicados" name="overpayment_applied" domain="[('payment_type','=','overpayment_applied')]"/>
                    <filter string="Ajustes" name="adjustments" domain="[('payment_type','=','adjustment')]"/>
                    <separator/>
                    <filter string="Este Mes" name="this_month" domain="[('payment_date','&gt;=', (context_today() - relativedelta(day=1)).strftime('%%Y-%%m-%%d'))]"/>
                    <filter string="Este Año" name="this_year" domain="[('year','=',time.strftime('%%Y'))]"/>
                    <group name="group_by">
                        <filter string="Fecha de Pago" name="group_date" context="{'group_by':'payment_date'}"/>
                        <filter string="Periodo SS" name="group_ss" context="{'group_by':'social_security_id'}"/>
                        <filter string="Tipo de Pago" name="group_type" context="{'group_by':'payment_type'}"/>
                        <filter string="Año" name="group_year" context="{'group_by':'year'}"/>
                        <filter string="Mes" name="group_month" context="{'group_by':'month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción para Ver Historial de Pagos -->
        <record id="action_hr_social_security_payment_line" model="ir.actions.act_window">
            <field name="name">Historial de Pagos SS</field>
            <field name="res_model">hr.social.security.payment.line</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_social_security_payment_line_search"/>
            <field name="context">{'search_default_this_year': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay pagos registrados
                </p>
                <p>
                    Registre pagos desde el formulario de Seguridad Social.
                </p>
            </field>
        </record>

        <!-- Menú para Historial de Pagos (opcional - se puede agregar al menú de nómina) -->
        <!--
        <menuitem id="menu_hr_social_security_payment_line"
            name="Historial de Pagos SS"
            parent="hr_payroll.menu_hr_payroll_root"
            action="action_hr_social_security_payment_line"
            sequence="50"/>
        -->

    </data>
</odoo>
