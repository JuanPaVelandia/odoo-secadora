<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista Tree para hr.closing.social.security.line -->
        <record id="view_hr_closing_social_security_line_tree" model="ir.ui.view">
            <field name="name">hr.closing.social.security.line.tree</field>
            <field name="model">hr.closing.social.security.line</field>
            <field name="arch" type="xml">
                <list string="Hr Closing Social Security Line" create="true" edit="true" delete="true">
                    <field name="display_name" optional="show"/>
                    <field name="create_date" optional="hide"/>
                    <field name="write_date" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Vista Form para hr.closing.social.security.line -->
        <record id="view_hr_closing_social_security_line_form" model="ir.ui.view">
            <field name="name">hr.closing.social.security.line.form</field>
            <field name="model">hr.closing.social.security.line</field>
            <field name="arch" type="xml">
                <form string="Hr Closing Social Security Line">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="display_name" placeholder="Nombre"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Información General">
                                <!-- Agregar campos específicos del modelo aquí -->
                            </group>
                            <group string="Información Adicional">
                                <field name="create_uid" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                                <field name="write_uid" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detalles">
                                <group>
                                    <!-- Agregar más campos aquí -->
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    </form>
            </field>
        </record>

        <!-- Vista Search para hr.closing.social.security.line -->
        <record id="view_hr_closing_social_security_line_search" model="ir.ui.view">
            <field name="name">hr.closing.social.security.line.search</field>
            <field name="model">hr.closing.social.security.line</field>
            <field name="arch" type="xml">
                <search string="Buscar Hr Closing Social Security Line">
                    <field name="display_name"/>
                    <separator/>
                    <filter string="Creados Hoy" name="created_today"
                            domain="[('create_date', '>=', (context_today()).strftime('%Y-%m-%d'))]"/>
                    <filter string="Modificados Hoy" name="modified_today"
                            domain="[('write_date', '>=', (context_today()).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group name="group_by">
                        <filter string="Usuario Creación" name="group_create_uid"
                                context="{'group_by': 'create_uid'}"/>
                        <filter string="Fecha Creación" name="group_create_date"
                                context="{'group_by': 'create_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Acción para hr.closing.social.security.line -->
        <record id="action_hr_closing_social_security_line" model="ir.actions.act_window">
            <field name="name">Hr Closing Social Security Line</field>
            <field name="res_model">hr.closing.social.security.line</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_closing_social_security_line_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo registro de Hr Closing Social Security Line
                </p>
                <p>
                    Gestione los registros de Hr Closing Social Security Line desde esta vista.
                </p>
            </field>
        </record>

        <!-- Menú para hr.closing.social.security.line -->
        <menuitem id="menu_hr_closing_social_security_line_root"
            name="Hr Closing Social Security Line"
            parent="lavish_hr_social_security.menu_root"
            sequence="50"/>
            
        <menuitem id="menu_hr_closing_social_security_line"
            name="Hr Closing Social Security Line"
            parent="menu_hr_closing_social_security_line_root"
            action="action_hr_closing_social_security_line"
            sequence="10"/>
    </data>
</odoo>
