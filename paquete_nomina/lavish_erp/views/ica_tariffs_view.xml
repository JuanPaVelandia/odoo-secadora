<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_lavish_ica_tariffs_tree" model="ir.ui.view">
            <field name="name">lavish.ica.tariffs.tree</field>
            <field name="model">lavish.ica.tariffs</field>
            <field name="arch" type="xml">
                <list string="Tarifas ICA" editable="bottom">
                    <field name="state_id"/>
                    <field name="city_id"/>
                    <field name="ciiu_id"/>
                    <field name="rate"/>
                    <field name="rate_percent" readonly="1"/>
                    <field name="rte_ica_percent"/>
                    <field name="description" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_lavish_ica_tariffs_search" model="ir.ui.view">
            <field name="name">lavish.ica.tariffs.search</field>
            <field name="model">lavish.ica.tariffs</field>
            <field name="arch" type="xml">
                <search string="Buscar Tarifas ICA">
                    <field name="city_id"/>
                    <field name="ciiu_id"/>
                    <field name="state_id"/>
                    <group name="group_by">
                        <filter string="Departamento" name="group_state" context="{'group_by': 'state_id'}"/>
                        <filter string="Municipio" name="group_city" context="{'group_by': 'city_id'}"/>
                        <filter string="CIIU" name="group_ciiu" context="{'group_by': 'ciiu_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_lavish_ica_tariffs_form" model="ir.ui.view">
            <field name="name">lavish.ica.tariffs.form</field>
            <field name="model">lavish.ica.tariffs</field>
            <field name="arch" type="xml">
                <form string="Tarifa ICA">
                    <sheet>
                        <group>
                            <group string="Ubicacion">
                                <field name="state_id"/>
                                <field name="city_id"/>
                            </group>
                            <group string="Actividad">
                                <field name="ciiu_id"/>
                                <field name="description"/>
                            </group>
                        </group>
                        <group>
                            <group string="Tarifas">
                                <field name="rate"/>
                                <field name="rate_percent" readonly="1"/>
                                <field name="rte_ica_percent"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_lavish_ica_tariffs" model="ir.actions.act_window">
            <field name="name">Tarifas ICA</field>
            <field name="res_model">lavish.ica.tariffs</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear una nueva tarifa ICA
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_lavish_ica_tariffs"
                  name="Tarifas ICA"
                  parent="lavish_erp.menus_parameterization"
                  action="action_lavish_ica_tariffs"
                  sequence="15"/>
    </data>
</odoo>
