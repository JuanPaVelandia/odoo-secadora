<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ==================== DIAN TYPE CODE VIEWS ==================== -->
        <record id="view_dian_type_code_tree" model="ir.ui.view">
            <field name="name">dian.type_code.tree</field>
            <field name="model">dian.type_code</field>
            <field name="arch" type="xml">
                <list string="Codigos DIAN">
                    <field name="dian_code"/>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="is_required_dian"/>
                </list>
            </field>
        </record>

        <record id="view_dian_type_code_form" model="ir.ui.view">
            <field name="name">dian.type_code.form</field>
            <field name="model">dian.type_code</field>
            <field name="arch" type="xml">
                <form string="Codigo DIAN">
                    <sheet>
                        <group>
                            <group>
                                <field name="dian_code"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="type"/>
                                <field name="is_required_dian"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_dian_type_code_search" model="ir.ui.view">
            <field name="name">dian.type_code.search</field>
            <field name="model">dian.type_code</field>
            <field name="arch" type="xml">
                <search string="Buscar Codigos DIAN">
                    <field name="dian_code"/>
                    <field name="name"/>
                    <separator/>
                    <filter string="Representacion" name="representation" domain="[('type', '=', 'representation')]"/>
                    <filter string="Obligacion" name="obligation" domain="[('type', '=', 'obligation')]"/>
                    <filter string="Aduanas" name="customs" domain="[('type', '=', 'customs')]"/>
                    <filter string="Establecimiento" name="establishment" domain="[('type', '=', 'establishment')]"/>
                    <separator/>
                    <filter string="Requerido DIAN" name="required_dian" domain="[('is_required_dian', '=', True)]"/>
                    <group name="group_by">
                        <filter string="Tipo" name="group_type" context="{'group_by': 'type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_dian_type_code" model="ir.actions.act_window">
            <field name="name">Codigos DIAN</field>
            <field name="res_model">dian.type_code</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_type': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo codigo DIAN
                </p>
            </field>
        </record>

        <!-- ==================== DIAN TAX TYPE VIEWS ==================== -->
        <record id="view_dian_tax_type_tree" model="ir.ui.view">
            <field name="name">dian.tax.type.tree</field>
            <field name="model">dian.tax.type</field>
            <field name="arch" type="xml">
                <list string="Tipos de Impuesto DIAN">
                    <field name="dian_code"/>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="retention"/>
                </list>
            </field>
        </record>

        <record id="view_dian_tax_type_form" model="ir.ui.view">
            <field name="name">dian.tax.type.form</field>
            <field name="model">dian.tax.type</field>
            <field name="arch" type="xml">
                <form string="Tipo de Impuesto DIAN">
                    <sheet>
                        <group>
                            <group>
                                <field name="dian_code"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="retention"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_dian_tax_type_search" model="ir.ui.view">
            <field name="name">dian.tax.type.search</field>
            <field name="model">dian.tax.type</field>
            <field name="arch" type="xml">
                <search string="Buscar Tipos de Impuesto">
                    <field name="dian_code"/>
                    <field name="name"/>
                    <separator/>
                    <filter string="Retenciones" name="retention" domain="[('retention', '=', True)]"/>
                    <filter string="Impuestos" name="taxes" domain="[('retention', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="action_dian_tax_type" model="ir.actions.act_window">
            <field name="name">Tipos de Impuesto DIAN</field>
            <field name="res_model">dian.tax.type</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo tipo de impuesto DIAN
                </p>
            </field>
        </record>

        <!-- ==================== DIAN UOM CODE VIEWS ==================== -->
        <record id="view_dian_uom_code_tree" model="ir.ui.view">
            <field name="name">dian.uom.code.tree</field>
            <field name="model">dian.uom.code</field>
            <field name="arch" type="xml">
                <list string="Unidades de Medida DIAN">
                    <field name="dian_code"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_dian_uom_code_form" model="ir.ui.view">
            <field name="name">dian.uom.code.form</field>
            <field name="model">dian.uom.code</field>
            <field name="arch" type="xml">
                <form string="Unidad de Medida DIAN">
                    <sheet>
                        <group>
                            <field name="dian_code"/>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_dian_uom_code" model="ir.actions.act_window">
            <field name="name">Unidades de Medida DIAN</field>
            <field name="res_model">dian.uom.code</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear una nueva unidad de medida DIAN
                </p>
            </field>
        </record>

        <!-- ==================== NOMENCLATURE CODE VIEWS ==================== -->
        <record id="view_nomenclature_code_tree" model="ir.ui.view">
            <field name="name">account.nomenclature.code.tree</field>
            <field name="model">account.nomenclature.code</field>
            <field name="arch" type="xml">
                <list string="Codigos de Nomenclatura" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="abbreviation"/>
                    <field name="name"/>
                    <field name="type_code"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_nomenclature_code_form" model="ir.ui.view">
            <field name="name">account.nomenclature.code.form</field>
            <field name="model">account.nomenclature.code</field>
            <field name="arch" type="xml">
                <form string="Codigo de Nomenclatura">
                    <sheet>
                        <group>
                            <group>
                                <field name="abbreviation"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="type_code"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_nomenclature_code_search" model="ir.ui.view">
            <field name="name">account.nomenclature.code.search</field>
            <field name="model">account.nomenclature.code</field>
            <field name="arch" type="xml">
                <search string="Buscar Codigos de Nomenclatura">
                    <field name="abbreviation"/>
                    <field name="name"/>
                    <separator/>
                    <filter string="Via Principal" name="principal" domain="[('type_code', '=', 'principal')]"/>
                    <filter string="Calificador" name="qualifying" domain="[('type_code', '=', 'qualifying')]"/>
                    <filter string="Letra" name="letter" domain="[('type_code', '=', 'letter')]"/>
                    <filter string="Complemento" name="additional" domain="[('type_code', '=', 'additional')]"/>
                    <separator/>
                    <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Archivados" name="archived" domain="[('active', '=', False)]"/>
                    <group name="group_by">
                        <filter string="Tipo" name="group_type" context="{'group_by': 'type_code'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nomenclature_code" model="ir.actions.act_window">
            <field name="name">Codigos de Nomenclatura</field>
            <field name="res_model">account.nomenclature.code</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_type': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo codigo de nomenclatura
                </p>
                <p>
                    Los codigos de nomenclatura se usan para construir direcciones colombianas estructuradas.
                </p>
            </field>
        </record>

        <!-- ==================== IDENTIFICATION TYPE VIEWS ==================== -->
        <record id="view_identification_type_tree" model="ir.ui.view">
            <field name="name">l10n_latam.identification.type.tree.inherit.lavish</field>
            <field name="model">l10n_latam.identification.type</field>
            <field name="inherit_id" ref="l10n_latam_base.view_l10n_latam_identification_type_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="before">
                    <field name="dian_code"/>
                </field>
            </field>
        </record>

        <record id="action_identification_type" model="ir.actions.act_window">
            <field name="name">Tipos de Identificacion</field>
            <field name="res_model">l10n_latam.identification.type</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo tipo de identificacion
                </p>
            </field>
        </record>
    </data>
</odoo>
