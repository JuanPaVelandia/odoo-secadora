<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_lavish" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.lavish</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='languages_setting']" position="after">
                <setting id="partner_names_order_setting" string="Orden de nombres" help="Define como se muestra el nombre completo de los contactos tipo persona natural">
                    <field name="partner_names_order" class="w-50"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
