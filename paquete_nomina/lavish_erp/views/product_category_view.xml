<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_category_taxes_form" model="ir.ui.view">
            <field name="name">product.category.taxes.form.inherit</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="account.view_category_property_form"/>
            <field name="arch" type="xml">
                <group name="account_property" position="inside">
                    <group name="account_taxes">
                        <group string="Impuestos por Defecto" groups="account.group_account_user">
                            <field name="taxes_ids" widget="many2many_tags"/>
                            <field name="supplier_taxes_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Cuentas de Devolución" groups="account.group_account_user">
                            <field name="property_account_refund_income_categ_id"/>
                            <field name="property_account_refund_expense_categ_id"/>
                        </group>
                    </group>
                </group>
            </field>
        </record>
    </data>
</odoo>
