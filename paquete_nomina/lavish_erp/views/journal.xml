<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="sequence_view" model="ir.ui.view">
            <field name="model">ir.sequence</field>
            <field name="inherit_id" ref="base.sequence_view" />
            <field name="arch" type="xml">
                <xpath
                    expr="//form/sheet/notebook/page/group/group[1]"
                    position="inside"
                >
                    <field name="use_dian_control" />
                </xpath>
                <xpath expr="//field[@name='number_increment']" position="replace">
                    <field
                        name="number_increment"
                        invisible="use_dian_control == True"
                    />
                </xpath>
                <xpath
                    expr="//form/sheet/notebook/page/group/group[2]"
                    position="inside"
                >
                    <field
                        name="sequence_dian_type"
                        invisible="use_dian_control == False"
                    />
                    <field
                        name="remaining_numbers"
                        invisible="use_dian_control == False"
                    />
                    <field
                        name="remaining_days"
                        invisible="use_dian_control == False"
                    />
                </xpath>
                <xpath expr="//field[@name='date_range_ids']" position="after">
                    <field
                        name="dian_resolution_ids"
                        string="Resoluciones DIAN"
                        invisible="use_dian_control == False"
                    >
                        <list
                            string="Resoluciones DIAN"
                            editable="top"
                            default_order="id desc"
                        >
                            <field name="resolution_number" string="Número Resolución"/>
                            <field name="number_from" string="Número Desde"/>
                            <field name="number_to" string="Número Hasta"/>
                            <field name="number_next" string="Próximo Número" readonly="0"/>
                            <field name="date_from" string="Fecha Desde"/>
                            <field name="date_to" string="Fecha Hasta"/>
                            <field name="active_resolution" string="Activa"/>
                        </list>
                    </field>
                </xpath>
            </field>
        </record>
        <record id="view_account_journal_form" model="ir.ui.view">
            <field name="name">account.journal.form</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <!-- Info DIAN visible en la parte superior del diario -->
                <xpath expr="//sheet" position="inside">
                    <group string="Control DIAN" invisible="use_dian_control == False">
                        <group>
                            <field name="use_dian_control" invisible="1"/>
                            <field name="dian_resolution_number" string="Resolución Activa"/>
                            <field name="dian_resolution_date_to" string="Fecha Vencimiento"/>
                        </group>
                        <group>
                            <field name="dian_remaining_numbers" string="Números Restantes"
                                   decoration-danger="dian_remaining_numbers &lt; 50"
                                   decoration-warning="dian_remaining_numbers &gt;= 50 and dian_remaining_numbers &lt; 200"/>
                            <field name="dian_remaining_days" string="Días Restantes"
                                   decoration-danger="dian_remaining_days &lt; 30"
                                   decoration-warning="dian_remaining_days &gt;= 30 and dian_remaining_days &lt; 90"/>
                        </group>
                    </group>
                </xpath>
                <xpath expr="//page[@name='advanced_settings']" position="after">
                    <page name="colombia_settings" string="Ajustes Colombia">
                        <group string="Secuencias de Numeración">
                            <group string="Secuencia de Documentos">
                                <field name="sequence_number_next" string="Próximo Número"/>
                                <field name="sequence_id" string="Secuencia" required="0"
                                       context="{'default_name': name, 'default_company_id': company_id, 'default_implementation': 'no_gap',
                                       'default_padding': 4, 'default_use_date_range': True, 'default_prefix': code + '/%%(range_year)s/'}"/>
                            </group>
                            <group string="Secuencia de Notas Crédito">
                                <field name="refund_sequence_number_next" string="Próximo Número NC"/>
                                <field name="refund_sequence_id" string="Secuencia NC" required="0"
                                       context="{'default_name': name, 'default_company_id': company_id, 'default_implementation': 'no_gap',
                                        'default_padding': 4, 'default_use_date_range': True, 'default_prefix': 'R' + code + '/%%(range_year)s/'}"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
