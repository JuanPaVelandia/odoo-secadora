<!-- //////////////////////////////// Parameterization VIEWS //////////////////////////////// -->
<odoo>
    <data>
        <!-- DIAS FESTIVOS VIEWS -->
        <record id="lavish_menu_action_holidays" model="ir.actions.act_window">
            <field name="name">Dias Festivos</field>
            <field name="res_model">lavish.holidays</field>
            <field name="view_mode">calendar,list,form</field>
            <field name="domain">[]</field>
            <field name="context">{'search_default_year': True}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crear día festivo o generar festivos para un año</p>
            </field>
        </record>
        <!-- Server action to generate holidays -->
        <record id="action_generate_holidays" model="ir.actions.server">
            <field name="name">Generar festivos colombianos</field>
            <field name="model_id" ref="model_lavish_holidays"/>
            <field name="binding_model_id" ref="model_lavish_holidays"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
year = datetime.date.today().year
created = model.generate_holidays_for_year(year)
if created:
    action = {'type': 'ir.actions.client', 'tag': 'display_notification', 'params': {'title': 'Festivos generados', 'message': 'Se crearon %d festivos para %d' % (len(created), year), 'type': 'success', 'sticky': False}}
else:
    action = {'type': 'ir.actions.client', 'tag': 'display_notification', 'params': {'title': 'Sin cambios', 'message': 'Los festivos de %d ya existen' % year, 'type': 'warning', 'sticky': False}}
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.search_holidays">
            <field name="name">lavish search holidays</field>
            <field name="model">lavish.holidays</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="date"/>
                    <filter string="Año actual" name="year" domain="[('year', '=', context_today().year)]"/>
                    <filter string="Religiosos" name="religious" domain="[('holiday_type', '=', 'religious')]"/>
                    <filter string="Cívicos" name="civic" domain="[('holiday_type', '=', 'civic')]"/>
                    <separator/>
                    <filter string="Fijos" name="fixed" domain="[('date_type', '=', 'fixed')]"/>
                    <filter string="Trasladables" name="movable" domain="[('date_type', '=', 'movable')]"/>
                    <filter string="Semana Santa" name="easter" domain="[('date_type', '=', 'easter')]"/>
                    <group name="group_by">
                        <filter string="Año" name="group_year" context="{'group_by': 'year'}"/>
                        <filter string="Tipo" name="group_type" context="{'group_by': 'holiday_type'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.list_holidays">
            <field name="name">lavish list holidays</field>
            <field name="model">lavish.holidays</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="year" optional="show"/>
                    <field name="holiday_type" optional="show"/>
                    <field name="date_type" optional="hide"/>
                </list>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.form_holidays">
            <field name="name">lavish form holidays</field>
            <field name="model">lavish.holidays</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="date"/>
                                <field name="year" readonly="1"/>
                            </group>
                            <group>
                                <field name="holiday_type"/>
                                <field name="date_type"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group string="Configuracion de fecha" invisible="date_type == 'fixed'">
                            <group invisible="date_type != 'easter'">
                                <field name="easter_offset"/>
                            </group>
                            <group invisible="date_type == 'easter'">
                                <field name="fixed_month"/>
                                <field name="fixed_day"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.calendar_holidays">
            <field name="name">lavish calendar holidays</field>
            <field name="model">lavish.holidays</field>
            <field name="arch" type="xml">
                <calendar date_start="date" date_stop="date" string="Dias Festivos" mode="month" color="holiday_type"></calendar>
            </field>
        </record>

        <!-- CITY VIEWS -->
        <record id="lavish_menu_action_city" model="ir.actions.act_window">
            <field name="name">Ciudad</field>
            <field name="res_model">res.city</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crear ciudad</p>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.list_city">
            <field name="name">lavish list city</field>
            <field name="model">res.city</field>
            <field name="arch" type="xml">
                <list>
                    <field name="state_id"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="code_zip"/>
                    <field name="postal_code_count"/>
                </list>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.form_city">
            <field name="name">lavish form city</field>
            <field name="model">res.city</field>
            <field name="arch" type="xml">
                <form string="Ciudad">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="country_id"/>
                                <field name="code" string="Codigo DANE"/>
                            </group>
                            <group>
                                <field name="code_zip" string="Codigo Postal Principal"/>
                                <field name="state_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Codigos Postales" name="postal_codes">
                                <field name="postal_code_ids">
                                    <list editable="bottom">
                                        <field name="postal_code"/>
                                        <field name="postal_zone"/>
                                        <field name="zone_type"/>
                                        <field name="neighborhoods" optional="hide"/>
                                        <field name="villages" optional="hide"/>
                                    </list>
                                </field>
                                <field name="postal_code_count" string="Cantidad Codigos Postales"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Postal Code Views -->
        <record model="ir.ui.view" id="lavish_erp.list_postal_code">
            <field name="name">res.city.postal.list</field>
            <field name="model">res.city.postal</field>
            <field name="arch" type="xml">
                <list string="Codigos Postales">
                    <field name="postal_code"/>
                    <field name="postal_zone"/>
                    <field name="city_id"/>
                    <field name="state_id"/>
                    <field name="zone_type"/>
                </list>
            </field>
        </record>
        <record model="ir.ui.view" id="lavish_erp.form_postal_code">
            <field name="name">res.city.postal.form</field>
            <field name="model">res.city.postal</field>
            <field name="arch" type="xml">
                <form string="Codigo Postal">
                    <sheet>
                        <group>
                            <group>
                                <field name="postal_code"/>
                                <field name="postal_zone"/>
                                <field name="zone_type"/>
                            </group>
                            <group>
                                <field name="city_id"/>
                                <field name="state_id"/>
                                <field name="country_id"/>
                            </group>
                        </group>
                        <group>
                            <field name="neighborhoods"/>
                            <field name="villages"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_postal_codes">
            <field name="name">Codigos Postales</field>
            <field name="res_model">res.city.postal</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay codigos postales definidos
                </p>
            </field>
        </record>

        <!-- CIIU VIEWS -->
        <record model="ir.actions.act_window" id="action_hierarchy_ciiu">
            <field name="name">Actividades Economicas CIIU</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">lavish.ciiu</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_section': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay actividades CIIU definidas
                </p>
            </field>
        </record>

        <!-- CIIU Solo Clases -->
        <record model="ir.actions.act_window" id="action_ciiu_classes">
            <field name="name">CIIU - Clases</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">lavish.ciiu</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('ciiu_type', '=', 'class')]</field>
            <field name="context">{'search_default_group_section': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay clases CIIU definidas
                </p>
            </field>
        </record>

        <!-- CIIU Search View -->
        <record id="view_search_ciiu" model="ir.ui.view">
            <field name="name">lavish.ciiu.search</field>
            <field name="model">lavish.ciiu</field>
            <field name="arch" type="xml">
                <search string="Buscar CIIU">
                    <field name="code" string="Codigo"/>
                    <field name="name" string="Descripcion"/>
                    <field name="section" string="Seccion"/>
                    <separator/>
                    <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter string="DIAN Especial" name="dian_special" domain="[('is_dian_special', '=', True)]"/>
                    <separator/>
                    <filter string="Secciones" name="type_section" domain="[('ciiu_type', '=', 'section')]"/>
                    <filter string="Divisiones" name="type_division" domain="[('ciiu_type', '=', 'division')]"/>
                    <filter string="Grupos" name="type_group" domain="[('ciiu_type', '=', 'group')]"/>
                    <filter string="Clases" name="type_class" domain="[('ciiu_type', '=', 'class')]"/>
                    <separator/>
                    <group name="group_by">
                        <filter string="Seccion" name="group_section" context="{'group_by': 'section'}"/>
                        <filter string="Tipo" name="group_type" context="{'group_by': 'ciiu_type'}"/>
                        <filter string="Padre" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- CIIU Form View -->
        <record id="view_form_ciiu" model="ir.ui.view">
            <field name="name">lavish.ciiu.form</field>
            <field name="model">lavish.ciiu</field>
            <field name="arch" type="xml">
                <form string="Actividad CIIU">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="code" placeholder="Codigo" class="oe_inline"/>
                                <span> - </span>
                                <field name="name" placeholder="Descripcion" class="oe_inline"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Clasificacion">
                                <field name="ciiu_type"/>
                                <field name="section"/>
                                <field name="parent_id"/>
                                <field name="is_dian_special"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Actividades Hijas" invisible="not child_ids">
                                <field name="child_ids" readonly="1">
                                    <list>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="ciiu_type"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- CIIU Tree View -->
        <record id="view_tree_ciiu" model="ir.ui.view">
            <field name="name">lavish.ciiu.tree</field>
            <field name="model">lavish.ciiu</field>
            <field name="arch" type="xml">
                <list string="Actividades CIIU" decoration-info="ciiu_type == 'section'" decoration-muted="not active">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="section" optional="show"/>
                    <field name="ciiu_type" optional="show"/>
                    <field name="parent_id" optional="hide"/>
                    <field name="is_dian_special" optional="hide"/>
                    <field name="active" column_invisible="1"/>
                </list>
            </field>
        </record>
    </data>
</odoo>
