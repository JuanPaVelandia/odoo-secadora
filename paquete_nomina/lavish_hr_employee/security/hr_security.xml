<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule for HR Officers to see all employees -->
        <record id="hr_employee_rule_hr_user" model="ir.rule">
            <field name="name">HR Employee: HR Officer access</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Rule for HR Managers to see and manage all employees -->
        <record id="hr_employee_rule_hr_manager" model="ir.rule">
            <field name="name">HR Employee: HR Manager access</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Rule for Payroll users to see all employees -->
        <record id="hr_employee_rule_payroll_user" model="ir.rule">
            <field name="name">HR Employee: Payroll User access</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Rule for Payroll Managers to see and manage all employees -->
        <record id="hr_employee_rule_payroll_manager" model="ir.rule">
            <field name="name">HR Employee: Payroll Manager access</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- ======================================== -->
        <!-- REGLAS DE DOMINIO PARA PORTAL DE EMPLEADO -->
        <!-- ======================================== -->

        <!-- Portal User: Solo puede ver su propio perfil de empleado -->
        <record id="hr_employee_portal_rule" model="ir.rule">
            <field name="name">HR Employee: Portal User - Own Profile Only</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Solo puede ver sus propios desprendibles de pago -->
        <record id="hr_payslip_portal_rule" model="ir.rule">
            <field name="name">HR Payslip: Portal User - Own Payslips Only</field>
            <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id), ('state', '=', 'done')]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Solo puede ver las líneas de sus propios desprendibles -->
        <record id="hr_payslip_line_portal_rule" model="ir.rule">
            <field name="name">HR Payslip Line: Portal User - Own Lines Only</field>
            <field name="model_id" ref="hr_payroll.model_hr_payslip_line"/>
            <field name="domain_force">[('slip_id.employee_id.user_id', '=', user.id), ('slip_id.state', '=', 'done')]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Puede ver y crear sus propias ausencias/permisos -->
        <record id="hr_leave_portal_rule" model="ir.rule">
            <field name="name">HR Leave: Portal User - Own Leaves Only</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Solo puede ver sus propios certificados médicos -->
        <record id="hr_medical_certificate_portal_rule" model="ir.rule">
            <field name="name">HR Medical Certificate: Portal User - Own Certificates Only</field>
            <field name="model_id" ref="model_hr_medical_certificate"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Solo puede ver sus propias solicitudes de EPP/Dotación -->
        <record id="hr_epp_request_portal_rule" model="ir.rule">
            <field name="name">HR EPP Request: Portal User - Own Requests Only</field>
            <field name="model_id" ref="model_hr_epp_request"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Solo puede ver las líneas de sus propias solicitudes EPP -->
        <record id="hr_epp_request_line_portal_rule" model="ir.rule">
            <field name="name">HR EPP Request Line: Portal User - Own Request Lines Only</field>
            <field name="model_id" ref="model_hr_epp_request_line"/>
            <field name="domain_force">[('request_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Puede ver y crear sus propios certificados laborales -->
        <record id="hr_labor_certificate_history_portal_rule" model="ir.rule">
            <field name="name">HR Labor Certificate History: Portal User - Own Certificates Only</field>
            <field name="model_id" ref="model_hr_labor_certificate_history"/>
            <field name="domain_force">[('contract_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User: Puede ver tipos de ausencia (lectura general) -->
        <record id="hr_leave_type_portal_rule" model="ir.rule">
            <field name="name">HR Leave Type: Portal User - All Active Types</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_type"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

    </data>
</odoo>