<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form del Wizard -->
        <record id="view_hr_labor_certificate_wizard_form" model="ir.ui.view">
            <field name="name">hr.labor.certificate.wizard.form</field>
            <field name="model">hr.labor.certificate.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Certificados Laborales">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,preview,done"/>
                    </header>
                    <sheet>
                        <!-- Estado: Configuración -->
                        <group invisible="state != 'draft'">
                            <group string="Configuración General">
                                <field name="company_id" readonly="1"/>
                                <field name="date_generation"/>
                                <field name="action_type" widget="radio"/>
                            </group>
                            <group string="Destinatario (Opcional)">
                                <field name="info_to" placeholder="Ej: A quien interese"/>
                                <field name="partner_id" placeholder="Seleccione un tercero..."/>
                            </group>
                        </group>

                        <!-- Estilo del Certificado -->
                        <group invisible="state != 'draft'" string="Estilo del Certificado">
                            <group>
                                <field name="use_template_style"/>
                                <field name="certificate_style" widget="radio"
                                       invisible="use_template_style"
                                       options="{'horizontal': true}"/>
                            </group>
                            <group>
                                <div class="alert alert-light" role="alert">
                                    <strong>Estilos disponibles:</strong>
                                    <ul class="mb-0 small">
                                        <li><strong>Clásico:</strong> Azul/verde tradicional</li>
                                        <li><strong>Moderno:</strong> Gradientes púrpura</li>
                                        <li><strong>Formal:</strong> Dorado/negro ejecutivo</li>
                                        <li><strong>Minimalista:</strong> Blanco y negro</li>
                                        <li><strong>Elegante:</strong> Vinotinto sofisticado</li>
                                        <li><strong>Corporativo:</strong> Azul institucional</li>
                                    </ul>
                                </div>
                            </group>
                        </group>

                        <group invisible="state != 'draft'">
                            <group string="Modo de Selección" colspan="2">
                                <field name="selection_mode" widget="radio"/>
                            </group>
                        </group>

                        <!-- Filtros según modo de selección -->
                        <group invisible="state != 'draft' or selection_mode not in ['department', 'all']">
                            <group string="Filtrar por Departamento"
                                   invisible="selection_mode != 'department'">
                                <field name="department_ids" widget="many2many_tags" nolabel="1"
                                       placeholder="Seleccione departamentos..."/>
                            </group>
                        </group>

                        <group invisible="state != 'draft' or selection_mode != 'job'">
                            <group string="Filtrar por Cargo">
                                <field name="job_ids" widget="many2many_tags" nolabel="1"
                                       placeholder="Seleccione cargos..."/>
                            </group>
                        </group>

                        <group invisible="state != 'draft' or selection_mode != 'manual'">
                            <group string="Selección Manual de Contratos" colspan="2">
                                <field name="contract_ids" widget="many2many" nolabel="1">
                                    <list>
                                        <field name="employee_id"/>
                                        <field name="name"/>
                                        <field name="department_id"/>
                                        <field name="job_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </group>
                        </group>

                        <group invisible="state != 'draft'">
                            <group>
                                <field name="include_inactive"/>
                            </group>
                            <group>
                                <div class="alert alert-info" role="alert">
                                    <strong>Contratos a procesar:</strong>
                                    <field name="contract_count" class="oe_inline"/>
                                </div>
                            </group>
                        </group>

                        <!-- Estado: Vista Previa -->
                        <group invisible="state != 'preview'">
                            <group string="Vista Previa de Contratos" colspan="2">
                                <field name="preview_html" nolabel="1" colspan="2"/>
                            </group>
                        </group>

                        <!-- Estado: Completado -->
                        <group invisible="state != 'done'">
                            <div class="alert alert-success" role="alert">
                                <h4>Certificados Generados Exitosamente</h4>
                                <p>Se generaron <strong><field name="contract_count" class="oe_inline"/></strong> certificados laborales.</p>
                            </div>
                        </group>
                    </sheet>
                    <footer>
                        <!-- Botones estado draft -->
                        <button name="action_preview" type="object" string="Vista Previa"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"
                                invisible="state not in ['draft', 'preview']"/>

                        <!-- Botones estado preview -->
                        <button name="action_back" type="object" string="Volver"
                                class="btn-secondary" invisible="state != 'preview'"/>
                        <button name="action_generate_certificates" type="object"
                                string="Generar Certificados" class="btn-primary"
                                invisible="state != 'preview'"
                                confirm="¿Está seguro de generar los certificados para los contratos seleccionados?"/>

                        <!-- Botones estado done -->
                        <button name="action_open_certificates" type="object"
                                string="Ver Certificados" class="btn-primary"
                                invisible="state != 'done'"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel"
                                invisible="state != 'done'"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Note: action_hr_labor_certificate_wizard moved to views/menus/certificates_actions.xml
             to ensure proper load order (must load before menus.xml) -->

    </data>
</odoo>
