<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Definición del Reporte de Solicitud EPP Formal -->
    <record id="action_report_epp_request_formal" model="ir.actions.report">
        <field name="name">Formato de Solicitud EPP</field>
        <field name="model">hr.epp.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_epp_request_formal_document</field>
        <field name="report_file">lavish_hr_employee.report_epp_request_formal_document</field>
        <field name="binding_model_id" ref="model_hr_epp_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Definición del Reporte de Solicitud Dotación Formal -->
    <record id="action_report_dotacion_request_formal" model="ir.actions.report">
        <field name="name">Formato de Solicitud Dotación</field>
        <field name="model">hr.epp.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_dotacion_request_formal_document</field>
        <field name="report_file">lavish_hr_employee.report_dotacion_request_formal_document</field>
        <field name="binding_model_id" ref="model_hr_epp_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Definición del Reporte de Correo/Transporte EPP -->
    <record id="action_report_epp_transport_slip" model="ir.actions.report">
        <field name="name">Formato de Correo/Transporte EPP</field>
        <field name="model">hr.epp.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_epp_transport_slip_document</field>
        <field name="report_file">lavish_hr_employee.report_epp_transport_slip_document</field>
        <field name="binding_model_id" ref="model_hr_epp_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Definición del Reporte de Firma de Recepción EPP -->
    <record id="action_report_epp_signature_receipt" model="ir.actions.report">
        <field name="name">Formato de Firma de Recepción EPP</field>
        <field name="model">hr.epp.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_epp_signature_receipt_document</field>
        <field name="report_file">lavish_hr_employee.report_epp_signature_receipt_document</field>
        <field name="binding_model_id" ref="model_hr_epp_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template del Reporte de Solicitud EPP -->
    <template id="report_epp_request_formal_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header del formato -->
                        <div class="text-center mb-4">
                            <h2>FORMATO DE SOLICITUD</h2>
                            <h3>ELEMENTOS DE PROTECCIÓN PERSONAL (EPP)</h3>
                        </div>

                        <!-- Información General -->
                        <table class="table table-bordered mb-4">
                            <tr>
                                <td class="text-end" width="25%"><strong>Número de Solicitud:</strong></td>
                                <td width="25%"><span t-field="o.name"/></td>
                                <td class="text-end" width="25%"><strong>Fecha de Solicitud:</strong></td>
                                <td width="25%"><span t-field="o.request_date"/></td>
                            </tr>
                            <tr>
                                <td class="text-end"><strong>Tipo:</strong></td>
                                <td colspan="3">
                                    <span t-if="o.type == 'epp'">EPP - Elementos de Protección Personal</span>
                                    <span t-if="o.type == 'dotacion'">Dotación - Uniformes</span>
                                </td>
                            </tr>
                        </table>

                        <!-- Información del Empleado -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Información del Solicitante</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%"><strong>Nombre Completo:</strong></td>
                                    <td width="75%" colspan="3"><span t-field="o.employee_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end"><strong>Identificación:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.identification_id"/></td>
                                    <td class="text-end" width="25%"><strong>Cargo:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.job_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end"><strong>Departamento:</strong></td>
                                    <td><span t-field="o.employee_id.department_id.name"/></td>
                                    <td class="text-end"><strong>Área de Trabajo:</strong></td>
                                    <td><span t-field="o.employee_id.work_location_id"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Items Solicitados -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Elementos Solicitados</h4>
                            <table class="table table-bordered table-sm">
                                <thead class="table-secondary">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>Descripción del Elemento</th>
                                        <th class="text-center">Tipo</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-center">Talla</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="index" t-value="1"/>
                                    <tr t-foreach="o.line_ids" t-as="line">
                                        <td class="text-center"><t t-out="index"/></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-center">
                                            <span t-if="line.item_type == 'helmet'">Casco</span>
                                            <span t-if="line.item_type == 'gloves'">Guantes</span>
                                            <span t-if="line.item_type == 'glasses'">Gafas</span>
                                            <span t-if="line.item_type == 'mask'">Mascarilla</span>
                                            <span t-if="line.item_type == 'vest'">Chaleco</span>
                                            <span t-if="line.item_type == 'boots'">Botas</span>
                                            <span t-if="line.item_type == 'shirt'">Camisa</span>
                                            <span t-if="line.item_type == 'pants'">Pantalón</span>
                                            <span t-if="line.item_type == 'shoes'">Zapatos</span>
                                            <span t-if="line.item_type == 'other'">Otro</span>
                                        </td>
                                        <td class="text-center"><span t-field="line.item_type"/></td>
                                        <td class="text-center"><span t-field="line.quantity"/></td>
                                        <td class="text-center"><span t-field="line.size"/></td>
                                        <t t-set="index" t-value="index + 1"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Justificación -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Justificación</h4>
                            <div style="min-height: 80px; border: 1px solid #dee2e6; padding: 10px;">
                                <span t-field="o.notes"/>
                            </div>
                        </div>

                        <!-- Información de Entrega -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Información de Entrega</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%"><strong>Lugar de Entrega:</strong></td>
                                    <td width="75%">
                                        <span t-if="o.delivery_location == 'office'">Oficina Principal</span>
                                        <span t-if="o.delivery_location == 'warehouse'">Almacén</span>
                                        <span t-if="o.delivery_location == 'worksite'">Sitio de Trabajo</span>
                                        <span t-if="o.delivery_location == 'other'">Otro</span>
                                        <span t-if="o.delivery_location_detail"> - <t t-out="o.delivery_location_detail"/></span>
                                        <span t-field="o.delivery_location"/><span t-if="o.delivery_location_detail"> - <t t-out="o.delivery_location_detail"/></span>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Firmas -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid black; padding-top: 5px; margin-top: 80px;">
                                    <strong>Firma del Solicitante</strong><br/>
                                    <span t-field="o.employee_id.name"/><br/>
                                    <small>Fecha: <span t-field="o.request_date"/></small>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid black; padding-top: 5px; margin-top: 80px;">
                                    <strong>Aprobado por</strong><br/>
                                    <span t-field="o.approved_by.name"/><br/>
                                    <small>Fecha: <span t-field="o.approved_date"/></small>
                                </div>
                            </div>
                        </div>

                        <!-- Pie de página -->
                        <div class="text-center mt-4" style="font-size: 10px; color: #666;">
                            <p>Este documento es un formato oficial de solicitud de Elementos de Protección Personal (EPP)</p>
                            <p>Número de Solicitud: <span t-field="o.name"/> | Estado: <span t-field="o.state"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Template del Reporte de Solicitud Dotación -->
    <template id="report_dotacion_request_formal_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header del formato -->
                        <div class="text-center mb-4">
                            <h2>FORMATO DE SOLICITUD</h2>
                            <h3>DOTACIÓN Y UNIFORMES</h3>
                        </div>

                        <!-- Información General -->
                        <table class="table table-bordered mb-4">
                            <tr>
                                <td class="text-end" width="25%"><strong>Número de Solicitud:</strong></td>
                                <td width="25%"><span t-field="o.name"/></td>
                                <td class="text-end" width="25%"><strong>Fecha de Solicitud:</strong></td>
                                <td width="25%"><span t-field="o.request_date"/></td>
                            </tr>
                            <tr>
                                <td class="text-end"><strong>Periodo de Dotación:</strong></td>
                                <td colspan="3">
                                    <span t-if="o.configuration_id"><t t-out="o.configuration_id.name"/></span>
                                    <span t-else="">Dotación Trimestral</span>
                                </td>
                            </tr>
                        </table>

                        <!-- Información del Empleado -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Información del Empleado</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%"><strong>Nombre Completo:</strong></td>
                                    <td width="75%" colspan="3"><span t-field="o.employee_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end"><strong>Identificación:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.identification_id"/></td>
                                    <td class="text-end" width="25%"><strong>Cargo:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.job_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end"><strong>Departamento:</strong></td>
                                    <td><span t-field="o.employee_id.department_id.name"/></td>
                                    <td class="text-end"><strong>Fecha de Ingreso:</strong></td>
                                    <td><span t-field="o.employee_id.contract_id.date_start"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Tallas del Empleado -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Tallas Registradas</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%"><strong>Talla Camisa/Suéter:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.shirt_size"/></td>
                                    <td class="text-end" width="25%"><strong>Talla Pantalón:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.pants_size"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end"><strong>Talla Zapatos:</strong></td>
                                    <td colspan="3"><span t-field="o.employee_id.shoe_size"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Items de Dotación -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Elementos de Dotación</h4>
                            <table class="table table-bordered table-sm">
                                <thead class="table-secondary">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>Descripción del Artículo</th>
                                        <th class="text-center">Tipo</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-center">Talla</th>
                                        <th class="text-center">Recibido</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="index" t-value="1"/>
                                    <tr t-foreach="o.line_ids" t-as="line">
                                        <td class="text-center"><t t-out="index"/></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-center">
                                            <span t-if="line.item_type == 'shirt'">Camisa/Suéter</span>
                                            <span t-if="line.item_type == 'pants'">Pantalón</span>
                                            <span t-if="line.item_type == 'shoes'">Zapatos</span>
                                            <span t-if="line.item_type == 'vest'">Chaleco</span>
                                            <span t-if="line.item_type == 'other'">Otro</span>
                                        </td>
                                        <td class="text-center"><span t-field="line.item_type"/></td>
                                        <td class="text-center"><span t-field="line.quantity"/></td>
                                        <td class="text-center"><span t-field="line.size"/></td>
                                        <td class="text-center">☐</td>
                                        <t t-set="index" t-value="index + 1"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Observaciones -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Observaciones</h4>
                            <div style="min-height: 60px; border: 1px solid #dee2e6; padding: 10px;">
                                <span t-field="o.delivery_notes"/>
                            </div>
                        </div>

                        <!-- Información de Entrega -->
                        <div class="mb-4">
                            <h4 class="bg-light p-2">Entrega y Recepción</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%"><strong>Fecha Programada:</strong></td>
                                    <td width="25%"><span t-field="o.delivery_date"/></td>
                                    <td class="text-end" width="25%"><strong>Lugar:</strong></td>
                                    <td width="25%">
                                        <span t-if="o.delivery_location == 'office'">Oficina Principal</span>
                                        <span t-if="o.delivery_location == 'warehouse'">Almacén</span>
                                        <span t-if="o.delivery_location == 'worksite'">Sitio de Trabajo</span>
                                        <span t-if="o.delivery_location == 'other'">Otro</span>
                                    </td>
                                    <td width="25%"><span t-field="o.delivery_location"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Firmas -->
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; padding-top: 5px; margin-top: 80px;">
                                    <strong>Solicitado por</strong><br/>
                                    <span t-field="o.employee_id.name"/><br/>
                                    <small>Fecha: <span t-field="o.request_date"/></small>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; padding-top: 5px; margin-top: 80px;">
                                    <strong>Aprobado por</strong><br/>
                                    <span t-field="o.approved_by.name"/><br/>
                                    <small>Fecha: <span t-field="o.approved_date"/></small>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; padding-top: 5px; margin-top: 80px;">
                                    <strong>Entregado por</strong><br/>
                                    _________________________<br/>
                                    <small>Fecha: _______________</small>
                                </div>
                            </div>
                        </div>

                        <!-- Declaración -->
                        <div class="mt-4 p-3" style="border: 1px solid #dee2e6; background-color: #f8f9fa;">
                            <p style="font-size: 11px; margin: 0;">
                                <strong>DECLARACIÓN:</strong> Declaro que recibí los elementos de dotación descritos anteriormente
                                en buen estado y me comprometo a hacer uso adecuado de los mismos conforme a las políticas de la empresa.
                            </p>
                        </div>

                        <!-- Pie de página -->
                        <div class="text-center mt-4" style="font-size: 10px; color: #666;">
                            <p>Este documento es un formato oficial de solicitud y entrega de Dotación y Uniformes</p>
                            <p>Número de Solicitud: <span t-field="o.name"/> | Estado: <span t-field="o.state"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Template del Formato de Correo/Transporte EPP -->
    <template id="report_epp_transport_slip_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif;">
                        <!-- Header compacto para transporte -->
                        <div style="border: 3px solid #000; padding: 15px; margin-bottom: 20px;">
                            <div class="text-center">
                                <h2 style="margin: 0; font-size: 24px;"><strong>FORMATO DE CORREO/TRANSPORTE</strong></h2>
                                <h3 style="margin: 5px 0; font-size: 18px;">ELEMENTOS DE PROTECCIÓN PERSONAL (EPP)</h3>
                            </div>

                            <table class="table table-borderless mt-3" style="font-size: 14px;">
                                <tr>
                                    <td width="50%"><strong>Número de Solicitud:</strong> <span t-field="o.name"/></td>
                                    <td width="50%" class="text-end"><strong>Fecha:</strong> <span t-field="o.request_date"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Información del Destinatario -->
                        <div style="border: 2px solid #000; padding: 15px; margin-bottom: 20px;">
                            <h4 style="background-color: #e9ecef; padding: 8px; margin: -15px -15px 15px -15px; font-size: 16px;">
                                <strong>DESTINATARIO / PARA:</strong>
                            </h4>
                            <table class="table table-borderless" style="font-size: 14px;">
                                <tr>
                                    <td width="25%"><strong>Nombre:</strong></td>
                                    <td width="75%"><span t-field="o.employee_id.name" style="font-size: 16px;"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Identificación:</strong></td>
                                    <td><span t-field="o.employee_id.identification_id"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Cargo:</strong></td>
                                    <td><span t-field="o.employee_id.job_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Departamento:</strong></td>
                                    <td><span t-field="o.employee_id.department_id.name"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Lugar de Entrega -->
                        <div style="border: 2px solid #000; padding: 15px; margin-bottom: 20px; background-color: #fffacd;">
                            <h4 style="margin: 0 0 10px 0; font-size: 16px;">
                                <strong>📍 LUGAR DE ENTREGA:</strong>
                            </h4>
                            <p style="font-size: 18px; margin: 0;">
                                <strong>
                                    <span t-if="o.delivery_location == 'office'">OFICINA PRINCIPAL</span>
                                    <span t-if="o.delivery_location == 'warehouse'">ALMACÉN</span>
                                    <span t-if="o.delivery_location == 'worksite'">SITIO DE TRABAJO</span>
                                    <span t-if="o.delivery_location == 'other'">OTRO</span>
                                </strong>
                                <strong><span t-field="o.delivery_location"/></strong>
                            </p>
                            <p t-if="o.delivery_location_detail" style="font-size: 14px; margin: 5px 0 0 0;">
                                <strong>Detalles:</strong> <span t-field="o.delivery_location_detail"/>
                            </p>
                            <p t-if="o.delivery_address" style="font-size: 14px; margin: 5px 0 0 0;">
                                <strong>Dirección:</strong> <span t-field="o.delivery_address"/>
                            </p>
                        </div>

                        <!-- Listado de Elementos -->
                        <div style="border: 2px solid #000; padding: 15px; margin-bottom: 20px;">
                            <h4 style="background-color: #e9ecef; padding: 8px; margin: -15px -15px 15px -15px; font-size: 16px;">
                                <strong>ELEMENTOS A TRANSPORTAR:</strong>
                            </h4>
                            <table class="table table-bordered" style="font-size: 13px;">
                                <thead style="background-color: #dee2e6;">
                                    <tr>
                                        <th class="text-center" width="10%">#</th>
                                        <th width="50%">Descripción</th>
                                        <th class="text-center" width="15%">Cantidad</th>
                                        <th class="text-center" width="15%">Talla</th>
                                        <th class="text-center" width="10%">✓</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="index" t-value="1"/>
                                    <tr t-foreach="o.line_ids" t-as="line">
                                        <td class="text-center"><strong><t t-out="index"/></strong></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-center"><span t-field="line.quantity"/></td>
                                        <td class="text-center"><span t-field="line.size"/></td>
                                        <td class="text-center">☐</td>
                                        <t t-set="index" t-value="index + 1"/>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Instrucciones -->
                        <div style="border: 2px solid #000; padding: 15px; margin-bottom: 20px; background-color: #f8f9fa;">
                            <h4 style="margin: 0 0 10px 0; font-size: 14px;"><strong>⚠️ INSTRUCCIONES IMPORTANTES:</strong></h4>
                            <ul style="font-size: 12px; margin: 0; padding-left: 20px;">
                                <li>Verificar la identidad del destinatario antes de la entrega</li>
                                <li>Confirmar que todos los elementos estén en buen estado</li>
                                <li>Obtener firma del empleado al momento de la entrega</li>
                                <li>Verificar las tallas antes de entregar</li>
                                <li>Reportar cualquier novedad inmediatamente</li>
                            </ul>
                        </div>

                        <!-- Firmas -->
                        <div class="row" style="margin-top: 40px;">
                            <div class="col-6 text-center">
                                <div style="border-top: 2px solid #000; padding-top: 10px; margin-top: 60px;">
                                    <strong style="font-size: 14px;">ENTREGADO POR</strong><br/>
                                    <span style="font-size: 12px;">Nombre y Firma</span><br/>
                                    <small>Fecha: __________________</small>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top: 2px solid #000; padding-top: 10px; margin-top: 60px;">
                                    <strong style="font-size: 14px;">TRANSPORTADO POR</strong><br/>
                                    <span style="font-size: 12px;">Nombre y Firma</span><br/>
                                    <small>Fecha: __________________</small>
                                </div>
                            </div>
                        </div>

                        <!-- Código de barras simulado -->
                        <div class="text-center mt-4" style="border-top: 2px dashed #999; padding-top: 15px;">
                            <p style="font-size: 10px; margin: 0;">
                                <strong>Solicitud:</strong> <span t-field="o.name"/> |
                                <strong>Tipo:</strong> <span t-if="o.type == 'epp'">EPP</span><span t-if="o.type == 'dotacion'">Dotación</span>
                            </p>
                            <p style="font-size: 9px; margin: 5px 0 0 0; color: #666;">
                                Este documento debe acompañar los elementos durante su transporte
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Template del Formato de Firma de Recepción EPP -->
    <template id="report_epp_signature_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="text-center mb-4" style="border-bottom: 3px solid #000; padding-bottom: 15px;">
                            <h2 style="margin: 0;">ACTA DE RECEPCIÓN</h2>
                            <h3 style="margin: 5px 0;">ELEMENTOS DE PROTECCIÓN PERSONAL (EPP) Y DOTACIÓN</h3>
                        </div>

                        <!-- Información del Documento -->
                        <table class="table table-bordered mb-4">
                            <tr>
                                <td class="text-end" width="25%" style="background-color: #e9ecef;"><strong>Número de Acta:</strong></td>
                                <td width="25%"><span t-field="o.name"/></td>
                                <td class="text-end" width="25%" style="background-color: #e9ecef;"><strong>Fecha de Emisión:</strong></td>
                                <td width="25%"><span t-field="o.request_date"/></td>
                            </tr>
                            <tr>
                                <td class="text-end" style="background-color: #e9ecef;"><strong>Tipo de Elementos:</strong></td>
                                <td colspan="3">
                                    <span t-if="o.type == 'epp'">EPP - Elementos de Protección Personal</span>
                                    <span t-if="o.type == 'dotacion'">Dotación - Uniformes y Vestuario</span>
                                </td>
                            </tr>
                        </table>

                        <!-- Datos del Empleado -->
                        <div class="mb-4">
                            <h4 class="bg-dark text-white p-2">DATOS DEL EMPLEADO QUE RECIBE</h4>
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%" style="background-color: #f8f9fa;"><strong>Nombre Completo:</strong></td>
                                    <td width="75%" colspan="3"><span t-field="o.employee_id.name" style="font-size: 16px;"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end" style="background-color: #f8f9fa;"><strong>Documento de Identidad:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.identification_id"/></td>
                                    <td class="text-end" width="25%" style="background-color: #f8f9fa;"><strong>Cargo:</strong></td>
                                    <td width="25%"><span t-field="o.employee_id.job_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="text-end" style="background-color: #f8f9fa;"><strong>Departamento:</strong></td>
                                    <td><span t-field="o.employee_id.department_id.name"/></td>
                                    <td class="text-end" style="background-color: #f8f9fa;"><strong>Centro de Trabajo:</strong></td>
                                    <td><span t-field="o.employee_id.work_location_id"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Elementos Recibidos -->
                        <div class="mb-4">
                            <h4 class="bg-dark text-white p-2">ELEMENTOS RECIBIDOS</h4>
                            <table class="table table-bordered table-sm">
                                <thead class="table-secondary">
                                    <tr>
                                        <th class="text-center" width="8%">#</th>
                                        <th width="40%">Descripción del Elemento</th>
                                        <th class="text-center" width="12%">Código/Ref</th>
                                        <th class="text-center" width="10%">Cantidad</th>
                                        <th class="text-center" width="10%">Talla</th>
                                        <th class="text-center" width="10%">Estado</th>
                                        <th class="text-center" width="10%">Conforme</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="index" t-value="1"/>
                                    <tr t-foreach="o.line_ids" t-as="line">
                                        <td class="text-center"><strong><t t-out="index"/></strong></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-center">
                                            <span t-if="line.product_id" t-field="line.product_id.default_code"/>
                                            <span t-else="">-</span>
                                        </td>
                                        <td class="text-center"><span t-field="line.quantity"/></td>
                                        <td class="text-center"><span t-field="line.size"/></td>
                                        <td class="text-center">
                                            <div style="border: 1px solid #000; padding: 2px; min-height: 25px;">
                                                <!-- Espacio para marcar estado -->
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div style="font-size: 20px;">☐ Sí  ☐ No</div>
                                        </td>
                                        <t t-set="index" t-value="index + 1"/>
                                    </tr>
                                </tbody>
                            </table>
                            <p style="font-size: 11px; font-style: italic; margin-top: 5px;">
                                <strong>Estado:</strong> N = Nuevo | B = Buen Estado | R = Requiere Cambio
                            </p>
                        </div>

                        <!-- Observaciones -->
                        <div class="mb-4">
                            <h4 class="bg-secondary text-white p-2">OBSERVACIONES Y COMENTARIOS</h4>
                            <div style="border: 1px solid #dee2e6; min-height: 100px; padding: 10px;">
                                <span t-field="o.notes"/>
                            </div>
                        </div>

                        <!-- Declaración de Responsabilidad -->
                        <div class="mb-4 p-3" style="border: 3px solid #000; background-color: #fffacd;">
                            <h5 style="text-align: center; margin: 0 0 10px 0;"><strong>DECLARACIÓN DE RESPONSABILIDAD</strong></h5>
                            <p style="font-size: 12px; text-align: justify; margin: 0;">
                                Yo, <strong><span t-field="o.employee_id.name"/></strong>, identificado(a) con cédula de ciudadanía No.
                                <strong><span t-field="o.employee_id.identification_id"/></strong>, declaro que:
                            </p>
                            <ol style="font-size: 11px; margin: 10px 0; padding-left: 25px;">
                                <li>He recibido los elementos de protección personal y/o dotación descritos en este documento.</li>
                                <li>Los elementos recibidos se encuentran en buen estado y son apropiados para las funciones que desempeño.</li>
                                <li>Me comprometo a hacer uso adecuado y responsable de estos elementos.</li>
                                <li>Es mi responsabilidad mantener y cuidar estos elementos durante su vida útil.</li>
                                <li t-if="o.type == 'epp'">Conozco y acepto que el uso de EPP es obligatorio en las áreas y actividades que lo requieran.</li>
                                <li>En caso de pérdida, daño o deterioro por uso inadecuado, asumo la responsabilidad correspondiente.</li>
                                <li>Me comprometo a reportar cualquier novedad o necesidad de reemplazo oportunamente.</li>
                            </ol>
                        </div>

                        <!-- Información de Entrega -->
                        <div class="mb-4">
                            <table class="table table-bordered">
                                <tr>
                                    <td class="text-end" width="25%" style="background-color: #f8f9fa;"><strong>Fecha de Entrega:</strong></td>
                                    <td width="25%">______________________</td>
                                    <td class="text-end" width="25%" style="background-color: #f8f9fa;"><strong>Hora:</strong></td>
                                    <td width="25%">______________________</td>
                                </tr>
                                <tr>
                                    <td class="text-end" style="background-color: #f8f9fa;"><strong>Lugar de Entrega:</strong></td>
                                    <td colspan="3">
                                        <span t-if="o.delivery_location == 'office'">Oficina Principal</span>
                                        <span t-if="o.delivery_location == 'warehouse'">Almacén</span>
                                        <span t-if="o.delivery_location == 'worksite'">Sitio de Trabajo</span>
                                        <span t-if="o.delivery_location == 'other'">Otro</span>
                                        <span t-if="o.delivery_location_detail"> - <t t-out="o.delivery_location_detail"/></span>
                                        <span t-field="o.delivery_location"/><span t-if="o.delivery_location_detail"> - <t t-out="o.delivery_location_detail"/></span>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Firmas -->
                        <div class="row mt-5">
                            <div class="col-6">
                                <div class="text-center">
                                    <div style="border: 2px solid #000; height: 100px; margin-bottom: 10px; background-color: #f8f9fa;">
                                        <p style="margin-top: 35px; color: #999;">Espacio para Firma</p>
                                    </div>
                                    <div style="border-top: 2px solid #000; padding-top: 10px;">
                                        <strong>EMPLEADO QUE RECIBE</strong><br/>
                                        <span t-field="o.employee_id.name"/><br/>
                                        <span t-field="o.employee_id.identification_id"/><br/>
                                        <small>Fecha: _____________________</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <div style="border: 2px solid #000; height: 100px; margin-bottom: 10px; background-color: #f8f9fa;">
                                        <p style="margin-top: 35px; color: #999;">Espacio para Firma</p>
                                    </div>
                                    <div style="border-top: 2px solid #000; padding-top: 10px;">
                                        <strong>ENTREGADO POR</strong><br/>
                                        <span t-field="o.approved_by.name"/><br/>
                                        Cargo: _______________________<br/>
                                        <small>Fecha: _____________________</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Huella Digital (Opcional) -->
                        <div class="row mt-4">
                            <div class="col-6">
                                <div class="text-center">
                                    <div style="border: 2px dashed #999; height: 80px; padding: 10px;">
                                        <small style="color: #999;">Huella Digital - Empleado</small><br/>
                                        <small style="color: #999;">(Opcional)</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center">
                                    <div style="border: 2px dashed #999; height: 80px; padding: 10px;">
                                        <small style="color: #999;">Huella Digital - Testigo</small><br/>
                                        <small style="color: #999;">(Opcional)</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pie de Página -->
                        <div class="text-center mt-4" style="border-top: 2px solid #000; padding-top: 10px;">
                            <p style="font-size: 10px; margin: 0;">
                                <strong>IMPORTANTE:</strong> Este documento debe ser archivado en el expediente del empleado.
                            </p>
                            <p style="font-size: 9px; margin: 5px 0 0 0; color: #666;">
                                Número de Acta: <span t-field="o.name"/> |
                                Fecha de Emisión: <span t-field="o.request_date"/> |
                                Estado: <span t-field="o.state"/>
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
