<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reporte de Acta de Entrega EPP/Dotación -->
    <record id="action_report_epp_delivery" model="ir.actions.report">
        <field name="name">Acta de Entrega EPP/Dotación</field>
        <field name="model">hr.epp.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_epp_delivery</field>
        <field name="report_file">lavish_hr_employee.report_epp_delivery</field>
        <field name="print_report_name">'Acta de Entrega - %s' % (object.name)</field>
    </record>

    <template id="report_epp_delivery">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="text-center mb-4">
                            <h2>ACTA DE ENTREGA</h2>
                            <h3>
                                <t t-if="o.type == 'epp'">ELEMENTOS DE PROTECCIÓN PERSONAL</t>
                                <t t-else="">DOTACIÓN DE UNIFORMES</t>
                            </h3>
                        </div>
                        
                        <!-- Información del Acta -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>No. Acta:</strong> <span t-field="o.name"/>
                            </div>
                            <div class="col-6 text-right">
                                <strong>Fecha:</strong> <span t-field="o.delivery_date" t-if="o.delivery_date"/>
                                <span t-field="o.request_date" t-if="not o.delivery_date"/>
                            </div>
                        </div>
                        
                        <!-- Información del Empleado -->
                        <div class="panel panel-default mb-4">
                            <div class="panel-heading">
                                <h4>Datos del Empleado</h4>
                            </div>
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-6">
                                        <p><strong>Nombre:</strong> <span t-field="o.employee_id.name"/></p>
                                        <p><strong>Identificación:</strong> <span t-field="o.employee_id.identification_id"/></p>
                                        <p><strong>Cargo:</strong> <span t-field="o.employee_id.job_id.name"/></p>
                                    </div>
                                    <div class="col-6">
                                        <p><strong>Departamento:</strong> <span t-field="o.employee_id.department_id.name"/></p>
                                        <p><strong>Centro de Costo:</strong> <span t-field="o.employee_id.analytic_account_id.name" t-if="o.employee_id.analytic_account_id"/></p>
                                        <p><strong>Ubicación:</strong> 
                                            <t t-if="o.delivery_location == 'office'">Oficina Principal</t>
                                            <t t-elif="o.delivery_location == 'warehouse'">Almacén</t>
                                            <t t-elif="o.delivery_location == 'worksite'">Sitio de Trabajo</t>
                                            <t t-else=""><span t-field="o.delivery_location_detail"/></t>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Items Entregados -->
                        <div class="panel panel-default mb-4">
                            <div class="panel-heading">
                                <h4>Elementos Entregados</h4>
                            </div>
                            <div class="panel-body">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Item</th>
                                            <th>Descripción</th>
                                            <th>Cantidad</th>
                                            <th>Talla</th>
                                            <th>Observaciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.line_ids" t-as="line">
                                            <td>
                                                <t t-if="line.item_type == 'shirt'">Camisa/Suéter</t>
                                                <t t-elif="line.item_type == 'pants'">Pantalón</t>
                                                <t t-elif="line.item_type == 'shoes'">Zapatos</t>
                                                <t t-elif="line.item_type == 'helmet'">Casco</t>
                                                <t t-elif="line.item_type == 'gloves'">Guantes</t>
                                                <t t-elif="line.item_type == 'glasses'">Gafas</t>
                                                <t t-elif="line.item_type == 'mask'">Mascarilla</t>
                                                <t t-elif="line.item_type == 'vest'">Chaleco</t>
                                                <t t-elif="line.item_type == 'boots'">Botas</t>
                                                <t t-else="">Otro</t>
                                            </td>
                                            <td><span t-field="line.name"/></td>
                                            <td><span t-field="line.quantity"/></td>
                                            <td><span t-field="line.size"/></td>
                                            <td><span t-field="line.notes"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                        <!-- Ubicación de Inventario -->
                        <t t-if="o.location_id">
                            <div class="panel panel-default mb-4">
                                <div class="panel-heading">
                                    <h4>Información de Inventario</h4>
                                </div>
                                <div class="panel-body">
                                    <p><strong>Ubicación EPP:</strong> <span t-field="o.location_id.complete_name"/></p>
                                    <t t-if="o.picking_id">
                                        <p><strong>Movimiento de Inventario:</strong> <span t-field="o.picking_id.name"/></p>
                                        <p><strong>Estado:</strong> 
                                            <t t-if="o.picking_id.state == 'done'">
                                                <span class="badge badge-success">Completado</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge badge-warning" t-field="o.picking_id.state"/>
                                            </t>
                                        </p>
                                    </t>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Compromisos -->
                        <div class="panel panel-default mb-4">
                            <div class="panel-heading">
                                <h4>Compromisos del Empleado</h4>
                            </div>
                            <div class="panel-body">
                                <p>El empleado se compromete a:</p>
                                <ul>
                                    <li>Usar adecuadamente los elementos entregados durante la jornada laboral</li>
                                    <li>Mantener en buen estado los elementos recibidos</li>
                                    <li>Informar inmediatamente sobre pérdida o deterioro</li>
                                    <li>Devolver los elementos al terminar el contrato laboral</li>
                                    <t t-if="o.type == 'epp'">
                                        <li>Utilizar los EPP según las normas de seguridad establecidas</li>
                                        <li>No modificar o alterar los elementos de protección</li>
                                    </t>
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Notas -->
                        <t t-if="o.delivery_notes">
                            <div class="panel panel-default mb-4">
                                <div class="panel-heading">
                                    <h4>Observaciones</h4>
                                </div>
                                <div class="panel-body">
                                    <p t-field="o.delivery_notes"/>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Firmas -->
                        <div class="row mt-5">
                            <div class="col-5">
                                <t t-if="o.signature">
                                    <img t-att-src="'data:image/png;base64,%s' % o.signature.decode('utf-8')" 
                                         style="max-height: 100px;"/>
                                    <br/>
                                </t>
                                <div style="border-top: 1px solid black; margin-top: 60px;">
                                    <p class="mt-2">
                                        <strong>Recibí Conforme</strong><br/>
                                        <span t-field="o.employee_id.name"/><br/>
                                        C.C. <span t-field="o.employee_id.identification_id"/><br/>
                                        <t t-if="o.signed_date">
                                            Fecha: <span t-field="o.signed_date" t-options='{"widget": "date"}'/>
                                        </t>
                                    </p>
                                </div>
                            </div>
                            <div class="col-2"></div>
                            <div class="col-5">
                                <div style="border-top: 1px solid black; margin-top: 60px;">
                                    <p class="mt-2">
                                        <strong>Entregado por</strong><br/>
                                        Departamento de Recursos Humanos<br/>
                                        <span t-field="o.company_id.name"/>
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Historial de Entregas Anteriores -->
                        <t t-if="o.employee_id.epp_request_ids.filtered(lambda r: r.state == 'delivered' and r.id != o.id)">
                            <div class="mt-4" style="font-size: 10px;">
                                <p><strong>Historial de Entregas Anteriores:</strong></p>
                                <ul>
                                    <t t-foreach="o.employee_id.epp_request_ids.filtered(lambda r: r.state == 'delivered' and r.id != o.id)[:3]" t-as="req">
                                        <li>
                                            <span t-field="req.name"/> - 
                                            <span t-field="req.delivery_date"/>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>