<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paper format para notificacion de cambio salarial -->
        <record id="paperformat_change_wage" model="report.paperformat">
            <field name="name">Formato Notificacion Cambio Salarial</field>
            <field name="default" eval="False"/>
            <field name="format">Letter</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">25</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">15</field>
            <field name="margin_right">15</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">20</field>
            <field name="dpi">90</field>
        </record>

        <!-- Accion de reporte -->
        <record id="action_report_change_wage" model="ir.actions.report">
            <field name="name">Notificacion Cambio Salarial</field>
            <field name="model">hr.contract.change.wage</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lavish_hr_employee.report_change_wage_template</field>
            <field name="report_file">lavish_hr_employee.report_change_wage_template</field>
            <field name="paperformat_id" ref="paperformat_change_wage"/>
            <field name="print_report_name">'Cambio_Salarial_%s_%s' % (object.employee_id.name, object.date_start)</field>
            <field name="binding_model_id" ref="model_hr_contract_change_wage"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
