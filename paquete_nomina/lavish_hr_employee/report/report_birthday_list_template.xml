<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_birthday_list_document">
        <t t-call="web.html_container">
            <t t-foreach="inside_foreach_docs or docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', Arial, sans-serif;">

                        <!-- Encabezado -->
                        <div style="text-align: center; margin-bottom: 25px; padding: 15px; background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); border-radius: 8px;">
                            <h2 style="color: white; margin: 0; font-size: 20px; letter-spacing: 1px;">
                                LISTA DE CUMPLEANOS
                            </h2>
                        </div>

                        <!-- Iterar por cada mes -->
                        <t t-foreach="o.get_month()" t-as="m">
                            <div style="margin-bottom: 25px; padding: 15px; border: 1px solid #e0e0e0; border-radius: 8px;">
                                <!-- Encabezado del mes -->
                                <div style="margin-bottom: 15px; padding: 10px 15px; background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%); border-radius: 6px;">
                                    <h3 style="color: white; margin: 0; font-size: 16px;">
                                        <span t-out="o.get_name_month(m)"/>
                                    </h3>
                                </div>

                                <!-- Tabla de cumpleanos -->
                                <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
                                    <thead>
                                        <tr style="background: #f8f9fa;">
                                            <th style="padding: 10px; text-align: left; border-bottom: 2px solid #9b59b6; width: 25%;">
                                                Compania
                                            </th>
                                            <th style="padding: 10px; text-align: left; border-bottom: 2px solid #9b59b6; width: 15%;">
                                                Identificacion
                                            </th>
                                            <th style="padding: 10px; text-align: left; border-bottom: 2px solid #9b59b6; width: 40%;">
                                                Nombre
                                            </th>
                                            <th style="padding: 10px; text-align: center; border-bottom: 2px solid #9b59b6; width: 20%;">
                                                Fecha Cumpleanos
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="total_employees" t-value="0"/>
                                        <tr t-foreach="sorted(o.get_info_birthday(m), key=lambda x: x.birthday.day)" t-as="info"
                                            style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 8px;">
                                                <span t-out="info.company_id.name"/>
                                            </td>
                                            <td style="padding: 8px;">
                                                <span t-out="info.identification_id"/>
                                            </td>
                                            <td style="padding: 8px;">
                                                <span t-out="info.name"/>
                                            </td>
                                            <td style="padding: 8px; text-align: center;">
                                                <span style="background: #e74c3c; color: white; padding: 3px 10px; border-radius: 12px; font-size: 11px;">
                                                    <span t-out="o.get_date_text(info.birthday,0,1)"/>
                                                </span>
                                                <t t-set="total_employees" t-value="total_employees + 1"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                    <tfoot>
                                        <tr style="background: #f8f9fa;">
                                            <td colspan="3" style="padding: 10px; text-align: right; font-weight: bold;">
                                                TOTAL <span t-out="o.get_name_month(m)"/>:
                                            </td>
                                            <td style="padding: 10px; text-align: center;">
                                                <span style="background: #9b59b6; color: white; padding: 5px 15px; border-radius: 15px; font-weight: bold;">
                                                    <span t-out="total_employees"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </t>

                        <!-- Pie de pagina -->
                        <div style="margin-top: 30px; padding-top: 10px; border-top: 1px solid #e0e0e0; font-size: 9px; color: #999; text-align: center;">
                            Documento generado automaticamente -
                            <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_birthday_list">
        <t t-foreach="docs" t-as="o">
            <t t-set="inside_foreach_docs" t-value="o"/>
            <t t-call="lavish_hr_employee.report_birthday_list_document"/>
        </t>
    </template>
</odoo>
