<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reporte de Traslados de Inventario -->
    <record id="action_report_batch_stock_moves" model="ir.actions.report">
        <field name="name">Traslados de Inventario (Lote)</field>
        <field name="model">hr.epp.batch</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lavish_hr_employee.report_batch_stock_moves_template</field>
        <field name="report_file">lavish_hr_employee.report_batch_stock_moves_template</field>
        <field name="binding_model_id" ref="model_hr_epp_batch"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_us"/>
    </record>

    <!-- Template -->
    <template id="report_batch_stock_moves_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="batch">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif;">

                        <!-- ENCABEZADO -->
                        <div class="text-center" style="margin-bottom: 30px; border-bottom: 3px solid #2c3e50; padding-bottom: 15px;">
                            <h2 style="color: #2c3e50; font-size: 18pt; font-weight: bold; margin: 0;">
                                REPORTE DE TRASLADOS DE INVENTARIO
                            </h2>
                            <h4 style="color: #7f8c8d; font-size: 14pt; margin: 5px 0;">
                                <t t-out="batch.name"/>
                            </h4>
                        </div>

                        <!-- INFO GENERAL -->
                        <div class="row" style="margin-bottom: 25px;">
                            <div class="col-6">
                                <table style="width: 100%; font-size: 11pt;">
                                    <tr>
                                        <td style="padding: 5px; width: 35%;"><strong>Empresa:</strong></td>
                                        <td style="padding: 5px;"><t t-out="batch.company_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 5px;"><strong>Tipo:</strong></td>
                                        <td style="padding: 5px;"><t t-out="batch.batch_type"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 5px;"><strong>Total Empleados:</strong></td>
                                        <td style="padding: 5px;"><t t-out="batch.total_employees"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table style="width: 100%; font-size: 11pt;">
                                    <tr>
                                        <td style="padding: 5px; width: 35%;"><strong>Fecha Lote:</strong></td>
                                        <td style="padding: 5px;">
                                            <t t-out="batch.batch_date" t-options="{'widget': 'date'}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 5px;"><strong>Estado:</strong></td>
                                        <td style="padding: 5px;"><t t-out="batch.state"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 5px;"><strong>Bodega Origen:</strong></td>
                                        <td style="padding: 5px;">
                                            <t t-out="batch.default_location_id.name or 'Multiple'"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- MOVIMIENTOS DE STOCK AGRUPADOS -->
                        <h4 style="color: #2c3e50; font-size: 14pt; border-bottom: 2px solid #95a5a6; padding-bottom: 5px;">
                            Movimientos de Inventario (Agrupados por Producto)
                        </h4>

                        <t t-set="all_moves" t-value="batch.request_ids.mapped('stock_move_ids')"/>

                        <t t-if="all_moves">
                            <table class="table table-sm table-bordered" style="font-size: 10pt; margin-top: 15px;">
                                <thead style="background-color: #34495e; color: white;">
                                    <tr>
                                        <th style="padding: 10px; width: 8%; text-align: center;">No.</th>
                                        <th style="padding: 10px; width: 35%;">Producto</th>
                                        <th style="padding: 10px; width: 12%; text-align: center;">Cantidad</th>
                                        <th style="padding: 10px; width: 20%;">Desde</th>
                                        <th style="padding: 10px; width: 15%;">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="move_counter" t-value="0"/>
                                    <t t-foreach="all_moves" t-as="move">
                                        <t t-set="move_counter" t-value="move_counter + 1"/>
                                        <tr>
                                            <td style="padding: 8px; text-align: center;">
                                                <t t-out="move_counter"/>
                                            </td>
                                            <td style="padding: 8px;">
                                                <strong><t t-out="move.product_id.name"/></strong><br/>
                                                <small style="color: #7f8c8d;">
                                                    <t t-out="move.name"/>
                                                </small>
                                            </td>
                                            <td style="padding: 8px; text-align: center;">
                                                <strong style="font-size: 12pt;">
                                                    <t t-out="'%.0f' % move.product_uom_qty"/>
                                                </strong>
                                                <t t-out="move.product_uom.name"/>
                                            </td>
                                            <td style="padding: 8px; font-size: 9pt;">
                                                <t t-out="move.location_id.complete_name"/>
                                            </td>
                                            <td style="padding: 8px; text-align: center;">
                                                <t t-if="move.state == 'done'">
                                                    <span style="background-color: #27ae60; color: white; padding: 3px 8px; border-radius: 3px; font-size: 9pt;">
                                                        Completado
                                                    </span>
                                                </t>
                                                <t t-elif="move.state == 'assigned'">
                                                    <span style="background-color: #f39c12; color: white; padding: 3px 8px; border-radius: 3px; font-size: 9pt;">
                                                        Asignado
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <span style="background-color: #95a5a6; color: white; padding: 3px 8px; border-radius: 3px; font-size: 9pt;">
                                                        <t t-out="move.state"/>
                                                    </span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot style="background-color: #ecf0f1;">
                                    <tr>
                                        <td colspan="2" style="padding: 10px; text-align: right;">
                                            <strong>TOTAL MOVIMIENTOS:</strong>
                                        </td>
                                        <td style="padding: 10px; text-align: center;">
                                            <strong><t t-out="len(all_moves)"/></strong>
                                        </td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="alert alert-warning" style="margin-top: 20px;">
                                No hay movimientos de stock para este lote
                            </div>
                        </t>

                        <!-- NOTAS -->
                        <t t-if="batch.notes">
                            <div style="margin-top: 30px;">
                                <h5 style="color: #2c3e50;">Notas:</h5>
                                <div style="background-color: #f8f9fa; padding: 15px; border-left: 4px solid #3498db;">
                                    <t t-out="batch.notes"/>
                                </div>
                            </div>
                        </t>

                        <!-- FIRMAS -->
                        <div class="row" style="margin-top: 100px;">
                            <div class="col-4 text-center">
                                <div style="border-top: 2px solid #2c3e50; padding-top: 5px;">
                                    <strong>Responsable Almacén</strong>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 2px solid #2c3e50; padding-top: 5px;">
                                    <strong>Coordinador SST</strong>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 2px solid #2c3e50; padding-top: 5px;">
                                    <strong>Jefe de Personal</strong>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
