<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_employee.SalaryHistoryField">
        <div class="o_salary_history_container">
            <!-- Header con titulo y boton de agregar -->
            <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa fa-line-chart text-primary"/>
                    <span class="fw-bold">Evolucion Salarial</span>
                    <t t-if="state.records.length > 0">
                        <span class="badge bg-secondary rounded-pill">
                            <t t-esc="state.records.length"/> version(es)
                        </span>
                    </t>
                </div>
                <button class="btn btn-sm btn-primary"
                        t-on-click="onAddRecord"
                        title="Registrar cambio de salario">
                    <i class="fa fa-plus me-1"/> Nuevo Cambio
                </button>
            </div>

            <!-- Loading -->
            <t t-if="state.loading">
                <div class="text-center p-4">
                    <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                    <p class="text-muted mt-2 mb-0">Cargando historial...</p>
                </div>
            </t>

            <!-- Sin registros -->
            <t t-elif="state.records.length === 0">
                <div class="text-muted p-4 text-center border rounded-3 bg-light">
                    <div class="o_empty_timeline mb-3">
                        <div class="o_empty_circle mx-auto"/>
                    </div>
                    <i class="fa fa-history fa-3x mb-3 d-block opacity-25"/>
                    <h6 class="mb-1">Sin historial de cambios</h6>
                    <small>Registre el primer cambio salarial para comenzar el seguimiento</small>
                </div>
            </t>

            <!-- Timeline Visual de registros -->
            <t t-else="">
                <!-- Resumen de evolucion -->
                <t t-if="state.records.length > 1">
                    <div class="o_salary_summary mb-3 p-2 bg-light rounded-3 border">
                        <div class="row text-center">
                            <div class="col-4">
                                <small class="text-muted d-block">Salario Inicial</small>
                                <strong class="text-secondary">
                                    <t t-esc="formatCurrency(state.records[state.records.length - 1].wage)"/>
                                </strong>
                            </div>
                            <div class="col-4">
                                <i class="fa fa-long-arrow-right fa-2x text-muted opacity-50 my-2"/>
                            </div>
                            <div class="col-4">
                                <small class="text-muted d-block">Salario Actual</small>
                                <strong class="text-success">
                                    <t t-esc="formatCurrency(state.records[0].wage)"/>
                                </strong>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Timeline con circulos -->
                <div class="o_salary_timeline">
                    <t t-foreach="state.records" t-as="record" t-key="record.id">
                        <div t-attf-class="o_salary_timeline_item {{ record_index === 0 ? 'o_timeline_current' : '' }}"
                             t-on-click="() => this.onClickRecord(record)">

                            <!-- Circulo grande con numero de version -->
                            <div class="o_timeline_node">
                                <div t-attf-class="o_timeline_circle {{ record.difference >= 0 ? 'o_positive' : 'o_negative' }} {{ record_index === 0 ? 'o_current' : '' }}">
                                    <span class="o_version_number">
                                        V<t t-esc="state.records.length - record_index"/>
                                    </span>
                                </div>
                                <div class="o_timeline_line" t-if="record_index &lt; state.records.length - 1"/>
                            </div>

                            <!-- Contenido del cambio -->
                            <div class="o_timeline_content">
                                <!-- Fecha y estado -->
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="o_timeline_date fw-bold">
                                        <i class="fa fa-calendar-o me-1 opacity-50"/>
                                        <t t-esc="formatDateValue(record.date_start)"/>
                                    </span>
                                    <t t-if="record_index === 0">
                                        <span class="badge bg-primary">Actual</span>
                                    </t>
                                    <t t-if="getStateBadge(record.state)">
                                        <span t-attf-class="badge {{ getStateBadge(record.state).class }}">
                                            <t t-esc="getStateBadge(record.state).label"/>
                                        </span>
                                    </t>
                                </div>

                                <!-- Salarios con flecha -->
                                <div class="o_salary_change d-flex align-items-center gap-2 mb-2">
                                    <span class="o_salary_old text-secondary text-decoration-line-through">
                                        <t t-esc="formatCurrency(record.wage_old)"/>
                                    </span>
                                    <i class="fa fa-arrow-right text-muted"/>
                                    <span class="o_salary_new fw-bold text-success fs-5">
                                        <t t-esc="formatCurrency(record.wage)"/>
                                    </span>
                                </div>

                                <!-- Badges de diferencia y motivo -->
                                <div class="d-flex flex-wrap gap-1 align-items-center">
                                    <!-- Diferencia -->
                                    <span t-attf-class="badge {{ getDifferenceClass(record.difference) }} d-flex align-items-center gap-1">
                                        <i t-attf-class="fa {{ record.difference >= 0 ? 'fa-arrow-up' : 'fa-arrow-down' }}"/>
                                        <t t-esc="getDifferenceSign(record.difference)"/><t t-esc="formatCurrency(Math.abs(record.difference))"/>
                                        (<t t-esc="getDifferenceSign(record.difference_percentage)"/><t t-esc="Math.abs(record.difference_percentage || 0).toFixed(1)"/>%)
                                    </span>

                                    <!-- Motivo -->
                                    <t t-if="record.reason">
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa fa-tag me-1 opacity-50"/>
                                            <t t-esc="getReasonLabel(record.reason)"/>
                                        </span>
                                    </t>

                                    <!-- Origen -->
                                    <t t-if="getOriginBadge(record.origin_type)">
                                        <span t-attf-class="badge {{ getOriginBadge(record.origin_type).class }}">
                                            <t t-esc="getOriginBadge(record.origin_type).label"/>
                                        </span>
                                    </t>

                                    <!-- Cargo si cambio -->
                                    <t t-if="record.job_id">
                                        <span class="badge bg-info text-white">
                                            <i class="fa fa-briefcase me-1"/>
                                            <t t-esc="record.job_id[1]"/>
                                        </span>
                                    </t>
                                </div>
                            </div>

                            <!-- Boton eliminar -->
                            <div class="o_timeline_actions">
                                <button class="btn btn-sm btn-outline-danger rounded-circle"
                                        t-on-click="(ev) => this.onDeleteRecord(record, ev)"
                                        title="Eliminar este cambio">
                                    <i class="fa fa-trash-o"/>
                                </button>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>

</templates>
