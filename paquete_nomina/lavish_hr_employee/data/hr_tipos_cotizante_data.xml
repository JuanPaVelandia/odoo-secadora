<odoo>

    <data noupdate="1">
        <!-- =================================================================
             TIPOS DE COTIZANTE - PILA Colombia 2025
             Resolucion 000467 de 2025, Decreto 1406 de 1999
             ================================================================= -->

        <!-- 01 - Dependiente (xml_id existente: hr_tipo_cotizante_0111) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0111">
            <field name="code">01</field>
            <field name="name">Dependiente</field>
            <field name="description">Trabajador dependiente vinculado mediante contrato laboral. Incluye trabajadores del sector privado y publico con relacion de subordinacion.</field>
            <field name="aplicacion_practica">Empleados con contrato a termino fijo o indefinido. Personal administrativo, operativo, profesionales en nomina. Es el tipo mas comun en empresas.</field>
            <field name="referencia_normativa">Decreto 1406 de 1999, Art. 1</field>
        </record>

        <!-- 02 - Servicio domestico (xml_id existente: hr_tipo_cotizante_0115) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0115">
            <field name="code">02</field>
            <field name="name">Servicio domestico</field>
            <field name="description">Trabajador del servicio domestico que labora en hogares realizando oficios del hogar.</field>
            <field name="aplicacion_practica">Empleadas domesticas, nineras, conductores de familia, jardineros de casa. El empleador es persona natural (hogar).</field>
            <field name="referencia_normativa">Ley 1595 de 2012, Convenio OIT 189</field>
        </record>

        <!-- 03 - Independiente (xml_id existente: hr_tipo_cotizante_0116) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0116">
            <field name="code">03</field>
            <field name="name">Independiente</field>
            <field name="description">Trabajador independiente que cotiza por cuenta propia sin relacion laboral de dependencia.</field>
            <field name="aplicacion_practica">Contratistas por prestacion de servicios, profesionales independientes, comerciantes. Cotizan sobre el 40% de sus ingresos mensuales.</field>
            <field name="referencia_normativa">Ley 100 de 1993, Art. 15</field>
        </record>

        <!-- 12 - Aprendiz SENA etapa lectiva - SOLO ARL (xml_id existente: hr_tipo_cotizante_0113) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0113">
            <field name="code">12</field>
            <field name="name">Aprendiz SENA etapa lectiva</field>
            <field name="description">Aprendiz del SENA en etapa lectiva. Solo cotiza a Riesgos Laborales (ARL). NO cotiza salud ni pension.</field>
            <field name="aplicacion_practica">Estudiantes SENA en formacion teorica (etapa lectiva). Se liquidan UNICAMENTE en Planilla K. Solo pagan ARL sobre 1 SMMLV.</field>
            <field name="referencia_normativa">Ley 789 de 2002, Art. 30. Planilla K - Estudiantes</field>
        </record>

        <!-- 19 - Aprendiz SENA etapa productiva (xml_id existente: hr_tipo_cotizante_0114) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0114">
            <field name="code">19</field>
            <field name="name">Aprendiz SENA etapa productiva</field>
            <field name="description">Aprendiz SENA en etapa productiva o practicante universitario. Cotiza salud (EPS) y riesgos (ARL). NO cotiza pension.</field>
            <field name="aplicacion_practica">Aprendices en practica empresarial, practicantes universitarios. IBC: apoyo de sostenimiento (75%-100% SMMLV). Salud al 12.5%, ARL segun riesgo.</field>
            <field name="referencia_normativa">Ley 789 de 2002, Art. 30; Decreto 933 de 2003</field>
        </record>

        <!-- 20 - Estudiante Ley 789/2002 - SOLO ARL (xml_id existente: hr_tipo_cotizante_0121) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0121">
            <field name="code">20</field>
            <field name="name">Estudiante Ley 789/2002</field>
            <field name="description">Estudiantes que realizan practicas o pasantias segun Ley 789/2002. Solo cotiza a Riesgos Laborales (ARL).</field>
            <field name="aplicacion_practica">Pasantes, estudiantes en practicas curriculares obligatorias. Se liquidan en Planilla K. Solo ARL, no hay aporte a salud ni pension.</field>
            <field name="referencia_normativa">Ley 789 de 2002, Art. 30. Planilla K - Estudiantes</field>
        </record>

        <!-- 21 - Estudiante posgrado salud (xml_id existente: hr_tipo_cotizante_0122) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0122">
            <field name="code">21</field>
            <field name="name">Estudiante posgrado salud</field>
            <field name="description">Estudiantes de postgrado en area de la salud (residentes medicos). Aporte especial de salud.</field>
            <field name="aplicacion_practica">Residentes medicos en hospitales universitarios. La IPS o universidad aporta a salud. Regimen especial de aportes.</field>
            <field name="referencia_normativa">Ley 1917 de 2018, Art. 7</field>
        </record>

        <!-- 22 - Profesor/Independiente agremiado (xml_id existente: hr_tipo_cotizante_0123) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0123">
            <field name="code">22</field>
            <field name="name">Independiente agremiado</field>
            <field name="description">Trabajador independiente afiliado a traves de agremiacion o asociacion autorizada.</field>
            <field name="aplicacion_practica">Taxistas, transportadores, vendedores informales agremiados. La asociacion realiza el aporte colectivo. Base: 1 SMMLV minimo.</field>
            <field name="referencia_normativa">Decreto 3615 de 2005</field>
        </record>

        <!-- 51 - Trabajador tiempo parcial (xml_id existente: hr_tipo_cotizante_0125) -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_0125">
            <field name="code">51</field>
            <field name="name">Trabajador tiempo parcial</field>
            <field name="description">Trabajador dependiente con jornada inferior a la maxima legal, cotiza proporcionalmente.</field>
            <field name="aplicacion_practica">Empleados medio tiempo, jornada reducida. IBC minimo: proporcion del SMMLV segun horas. Semana: al menos 24 horas.</field>
            <field name="referencia_normativa">Decreto 2616 de 2013</field>
        </record>

        <!-- NUEVOS TIPOS (no existian antes) -->

        <!-- 23 - Estudiante aporte voluntario -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_23">
            <field name="code">23</field>
            <field name="name">Estudiante aporte voluntario</field>
            <field name="description">Estudiante de tiempo completo que realiza aportes voluntarios al sistema de seguridad social.</field>
            <field name="aplicacion_practica">Estudiantes universitarios que desean acumular semanas de pension voluntariamente. Aporte sobre 1 SMMLV.</field>
            <field name="referencia_normativa">Decreto 3615 de 2005</field>
        </record>

        <!-- 30 - Dependiente entidad promotora -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_30">
            <field name="code">30</field>
            <field name="name">Dependiente entidad promotora</field>
            <field name="description">Trabajador dependiente de entidad promotora de salud (EPS).</field>
            <field name="aplicacion_practica">Empleados de EPS que tienen regimen especial de aportes. Tratamiento similar al dependiente pero con particularidades.</field>
            <field name="referencia_normativa">Ley 100 de 1993</field>
        </record>

        <!-- 31 - Cooperado o precooperativa -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_31">
            <field name="code">31</field>
            <field name="name">Cooperado o precooperativa</field>
            <field name="description">Trabajador asociado a cooperativa de trabajo asociado o precooperativa.</field>
            <field name="aplicacion_practica">Miembros de cooperativas de trabajo asociado. La cooperativa actua como aportante. Base minimo 1 SMMLV.</field>
            <field name="referencia_normativa">Decreto 2800 de 2003</field>
        </record>

        <!-- 52 - Beneficiario UPC adicional -->
        <record model="hr.tipo.cotizante" id="hr_tipo_cotizante_52">
            <field name="code">52</field>
            <field name="name">Beneficiario UPC adicional</field>
            <field name="description">Cotizante que realiza aporte adicional para beneficiario que supera el tope de cobertura.</field>
            <field name="aplicacion_practica">Cuando un beneficiario mayor de 25 años o con condiciones especiales requiere UPC adicional. Aporte complementario.</field>
            <field name="referencia_normativa">Acuerdo 260 de 2004 CNSSS</field>
        </record>

        <!-- NOTA: Tipos de empleado ahora usan employee_type nativo de Odoo -->
        <!-- Valores disponibles: employee, student, trainee, contractor, freelance -->

        <!-- =================================================================
             SUBTIPOS DE COTIZANTE - PILA Colombia 2025
             Resolucion 000467 de 2025
             ================================================================= -->

        <!-- 00 - Sin subtipo/Ninguno (xml_id existente: hr_subtipo_cotizante_0116) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0116">
            <field name="code">00</field>
            <field name="name">Sin subtipo</field>
            <field name="description">Cotizante sin condicion especial. Aplica aportes completos a salud y pension segun su tipo de cotizante.</field>
            <field name="aplicacion_practica">La mayoria de empleados dependientes tipo 01. Cotizante estandar sin exenciones ni condiciones especiales.</field>
            <field name="referencia_normativa">Resolucion 000467 de 2025</field>
            <field name="not_contribute_pension" eval="False"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 01 - Pensionado vejez activo dependiente (xml_id existente: hr_subtipo_cotizante_0110) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0110">
            <field name="code">01</field>
            <field name="name">Pensionado vejez activo dependiente</field>
            <field name="description">Pensionado por vejez que continua laborando como dependiente. Exento de aportar a pension. Aporta solo a salud y ARL.</field>
            <field name="aplicacion_practica">Jubilado con pension de vejez que es contratado como empleado. No aporta el 4% de pension empleado ni el 12% empleador.</field>
            <field name="referencia_normativa">Ley 797 de 2003, Art. 4; Decreto 758 de 1990</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 02 - Pensionado vejez activo independiente (xml_id existente: hr_subtipo_cotizante_0111) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0111">
            <field name="code">02</field>
            <field name="name">Pensionado vejez activo independiente</field>
            <field name="description">Pensionado por vejez que trabaja como independiente. Exento de aportar a pension. Aporta solo a salud.</field>
            <field name="aplicacion_practica">Jubilado con pension de vejez que trabaja por cuenta propia o presta servicios. No aporta a pension, solo salud 12.5%.</field>
            <field name="referencia_normativa">Ley 797 de 2003, Art. 4</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 03 - No obligado pension por edad (xml_id existente: hr_subtipo_cotizante_0112) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0112">
            <field name="code">03</field>
            <field name="name">No obligado pension por edad</field>
            <field name="description">Cotizante que por su edad (hombres 60+, mujeres 55+ segun regimen) no esta obligado a aportar pension. Aporta salud.</field>
            <field name="aplicacion_practica">Trabajador mayor que cumplia edad pension antes de Ley 100 o con regimen de transicion. No aporta pension.</field>
            <field name="referencia_normativa">Ley 100 de 1993, Art. 36 (Regimen transicion)</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 04 - Requisitos cumplidos pension (xml_id existente: hr_subtipo_cotizante_0113) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0113">
            <field name="code">04</field>
            <field name="name">Requisitos cumplidos pension</field>
            <field name="description">Cotizante que cumplio requisitos para pension (edad y semanas) pero aun no se ha pensionado. Exento de aportar pension.</field>
            <field name="aplicacion_practica">Trabajador con 1300 semanas y edad cumplida, tramitando pension. Se exonera de aporte pension mientras sale resolucion.</field>
            <field name="referencia_normativa">Decreto 1406 de 1999, Art. 4</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 05 - Indemnizacion sustitutiva (xml_id existente: hr_subtipo_cotizante_0114) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0114">
            <field name="code">05</field>
            <field name="name">Indemnizacion sustitutiva</field>
            <field name="description">Cotizante a quien se le reconocio indemnizacion sustitutiva de pension (devolucion de aportes). No aporta pension.</field>
            <field name="aplicacion_practica">Persona que no alcanzo semanas y recibio devolucion de saldos. Si vuelve a trabajar, no aporta pension.</field>
            <field name="referencia_normativa">Ley 100 de 1993, Art. 37</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 06 - Regimen exceptuado pension (xml_id existente: hr_subtipo_cotizante_0115) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_0115">
            <field name="code">06</field>
            <field name="name">Regimen exceptuado pension</field>
            <field name="description">Cotizante perteneciente a regimen pensional exceptuado (Fuerzas Militares, Policia, Ecopetrol, Magisterio antes 2004).</field>
            <field name="aplicacion_practica">Militar, policia o maestro con regimen exceptuado que tiene otro trabajo. Solo aporta salud, no pension.</field>
            <field name="referencia_normativa">Ley 100 de 1993, Art. 279</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

        <!-- 07 - Extranjero no obligado pension (NUEVO) -->
        <record model="hr.subtipo.cotizante" id="hr_subtipo_cotizante_07">
            <field name="code">07</field>
            <field name="name">Extranjero no obligado pension</field>
            <field name="description">Extranjero con visa temporal que acredita cobertura de pension en su pais de origen. Solo aporta salud y ARL en Colombia.</field>
            <field name="aplicacion_practica">Expatriado con certificado de cobertura pensional de su pais. Descuenta 4% salud empleado pero no pension.</field>
            <field name="referencia_normativa">Decreto 1406 de 1999, Art. 4; Convenios bilaterales seguridad social</field>
            <field name="not_contribute_pension" eval="True"/>
            <field name="not_contribute_eps" eval="False"/>
        </record>

