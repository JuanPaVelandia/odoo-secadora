<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="email_template_change_wage" model="mail.template">
            <field name="name">Cambio Salarial: Notificacion al Empleado</field>
            <field name="model_id" ref="lavish_hr_employee.model_hr_contract_change_wage"/>
            <field name="email_from">{{ (object.contract_id.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.employee_id.work_email or object.employee_id.private_email }}</field>
            <field name="subject">Notificacion de Cambio Salarial - {{ object.employee_id.name }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-size: 14px;">
                    <p style="margin: 0px; padding: 0px;">
                        Estimado(a) <strong t-out="object.employee_id.name">Empleado</strong>,
                    </p>
                    <br/>
                    <p>
                        Por medio del presente, le comunicamos que a partir del
                        <strong t-out="format_date(object.date_start, date_format='d MMMM Y')">fecha</strong>,
                        su salario basico mensual sera ajustado.
                    </p>
                    <br/>
                    <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%; max-width: 500px;">
                        <tr style="background-color: #f5f5f5;">
                            <td><strong>Concepto</strong></td>
                            <td style="text-align: right;"><strong>Valor</strong></td>
                        </tr>
                        <tr>
                            <td>Salario Anterior</td>
                            <td style="text-align: right;" t-out="format_amount(object.wage_old, object.contract_id.company_id.currency_id)">0</td>
                        </tr>
                        <tr>
                            <td><strong>Nuevo Salario</strong></td>
                            <td style="text-align: right;"><strong t-out="format_amount(object.wage, object.contract_id.company_id.currency_id)">0</strong></td>
                        </tr>
                        <tr>
                            <td>Incremento</td>
                            <td style="text-align: right;">
                                <t t-out="format_amount(object.difference, object.contract_id.company_id.currency_id)">0</t>
                                (<t t-out="'%.2f' % object.difference_percentage">0</t>%)
                            </td>
                        </tr>
                    </table>
                    <br/>
                    <t t-if="object.reason">
                        <p>
                            <strong>Motivo del cambio:</strong>
                            <t t-if="object.reason == 'annual_update'">Actualizacion anual</t>
                            <t t-elif="object.reason == 'promotion'">Promocion</t>
                            <t t-elif="object.reason == 'performance'">Desempeno</t>
                            <t t-elif="object.reason == 'adjustment'">Ajuste general</t>
                            <t t-elif="object.reason == 'legal'">Ajuste por normativa legal</t>
                            <t t-elif="object.reason == 'market_adjustment'">Ajuste al mercado</t>
                            <t t-elif="object.reason == 'other'"><t t-out="object.other_reason or 'Otro'"/></t>
                            <t t-else=""><t t-out="object.reason"/></t>
                        </p>
                    </t>
                    <br/>
                    <p>Las demas condiciones de su contrato de trabajo permanecen sin modificacion.</p>
                    <br/>
                    <p>Atentamente,</p>
                    <p><strong t-out="object.contract_id.company_id.name">Empresa</strong></p>
                    <br/>
                    <p style="font-size: 12px; color: #888;">
                        Este es un mensaje automatico. Por favor no responda a este correo.
                    </p>
                </div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('lavish_hr_employee.action_report_change_wage'))]"/>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>
