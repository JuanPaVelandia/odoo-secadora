<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Secuencia para Lotes de EPP -->
        <record id="seq_hr_epp_batch" model="ir.sequence">
            <field name="name">Lote EPP</field>
            <field name="code">hr.epp.batch</field>
            <field name="prefix">BATCH-EPP-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Secuencia para Lotes de Dotación -->
        <record id="seq_hr_dotacion_batch" model="ir.sequence">
            <field name="name">Lote Dotación</field>
            <field name="code">hr.dotacion.batch</field>
            <field name="prefix">BATCH-DOT-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Secuencia para Lotes de Exámenes Médicos -->
        <record id="seq_hr_medical_batch" model="ir.sequence">
            <field name="name">Lote Exámenes Médicos</field>
            <field name="code">hr.medical.batch</field>
            <field name="prefix">BATCH-MED-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
