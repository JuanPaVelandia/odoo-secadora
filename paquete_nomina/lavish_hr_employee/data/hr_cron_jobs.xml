<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron: Enviar recordatorios de vencimiento de certificados médicos -->
    <record id="cron_hr_medical_send_reminders" model="ir.cron">
        <field name="name">Enviar Recordatorios de Certificados Médicos</field>
        <field name="model_id" ref="model_hr_medical_certificate"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_expiry_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">5</field>
    </record>

    <!-- Cron: Generar renovaciones automáticas de certificados médicos -->
    <record id="cron_hr_medical_auto_renewal" model="ir.cron">
        <field name="name">Generar Renovaciones Automáticas de Certificados</field>
        <field name="model_id" ref="model_hr_medical_certificate"/>
        <field name="state">code</field>
        <field name="code">model.cron_auto_generate_renewals()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>

    <!-- Cron: Generar solicitudes EPP/Dotación automáticamente desde configuraciones -->
    <record id="cron_hr_epp_auto_generation" model="ir.cron">
        <field name="name">Generar Solicitudes EPP/Dotación Automáticamente</field>
        <field name="model_id" ref="model_hr_epp_configuration"/>
        <field name="state">code</field>
        <field name="code">model.cron_auto_generate_requests()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">15</field>
    </record>

    <!-- Cron: Actualizar estado de acuerdos con proveedores -->
    <record id="cron_hr_epp_provider_agreement_status" model="ir.cron">
        <field name="name">Actualizar Estado de Acuerdos con Proveedores</field>
        <field name="model_id" ref="model_hr_epp_provider_agreement"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_agreement_status()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">20</field>
    </record>

</odoo>
