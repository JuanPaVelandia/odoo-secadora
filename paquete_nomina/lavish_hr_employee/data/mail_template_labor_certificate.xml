<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Template de correo para envío de certificado laboral -->
        <record id="email_template_labor_certificate" model="mail.template">
            <field name="name">Certificado Laboral: Envío al Empleado</field>
            <field name="model_id" ref="lavish_hr_employee.model_hr_labor_certificate_history"/>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.employee_id.work_email or object.employee_id.private_email }}</field>
            <field name="subject">Certificado Laboral - {{ object.employee_id.name }} - {{ object.sequence }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-size: 14px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
    <!-- Header -->
    <table border="0" cellpadding="0" cellspacing="0" style="width: 100%; background-color: #875A7B; padding: 20px 0;">
        <tr>
            <td align="center">
                <h2 style="color: #ffffff; margin: 0;">Certificado Laboral</h2>
            </td>
        </tr>
    </table>

    <!-- Body -->
    <table border="0" cellpadding="0" cellspacing="0" style="width: 100%; padding: 30px 20px;">
        <tr>
            <td>
                <p style="margin-bottom: 20px;">
                    Estimado(a) <strong t-out="object.employee_id.name">Empleado</strong>,
                </p>

                <p style="margin-bottom: 20px;">
                    Por medio del presente, le hacemos entrega de su certificado laboral solicitado.
                </p>

                <!-- Información del certificado -->
                <table border="0" cellpadding="10" cellspacing="0"
                       style="width: 100%; background-color: #f8f9fa; border-radius: 8px; margin-bottom: 20px;">
                    <tr>
                        <td style="width: 40%; color: #666; font-weight: bold;">Número de Certificado:</td>
                        <td t-out="object.sequence">CLG/000001</td>
                    </tr>
                    <tr>
                        <td style="color: #666; font-weight: bold;">Fecha de Generación:</td>
                        <td t-out="format_date(object.date_generation, date_format='d MMMM Y')">01 enero 2024</td>
                    </tr>
                    <tr t-if="object.info_to">
                        <td style="color: #666; font-weight: bold;">Dirigido a:</td>
                        <td t-out="object.info_to">A quien interese</td>
                    </tr>
                    <tr t-if="object.partner_id">
                        <td style="color: #666; font-weight: bold;">Destinatario:</td>
                        <td t-out="object.partner_id.name">Nombre del tercero</td>
                    </tr>
                </table>

                <p style="margin-bottom: 20px;">
                    Encontrará adjunto a este correo el archivo PDF del certificado laboral.
                </p>

                <p style="margin-bottom: 20px;">
                    Si tiene alguna pregunta o requiere información adicional, no dude en contactarnos.
                </p>

                <p style="margin-top: 30px;">
                    Cordialmente,<br/>
                    <strong t-out="object.company_id.name">Nombre de la Empresa</strong>
                </p>
            </td>
        </tr>
    </table>

    <!-- Footer -->
    <table border="0" cellpadding="0" cellspacing="0"
           style="width: 100%; background-color: #f8f9fa; padding: 20px; border-top: 1px solid #e0e0e0;">
        <tr>
            <td align="center" style="font-size: 12px; color: #666;">
                <p style="margin: 0;">
                    <strong t-out="object.company_id.name">Empresa</strong><br/>
                    <span t-if="object.company_id.street" t-out="object.company_id.street">Dirección</span>
                    <span t-if="object.company_id.city">, <t t-out="object.company_id.city">Ciudad</t></span><br/>
                    <span t-if="object.company_id.phone">Tel: <t t-out="object.company_id.phone">Teléfono</t></span>
                    <span t-if="object.company_id.email"> | <t t-out="object.company_id.email">email@empresa.com</t></span>
                </p>
                <p style="margin: 10px 0 0 0; font-size: 11px; color: #999;">
                    Este correo fue generado automáticamente. Por favor no responda a este mensaje.
                </p>
            </td>
        </tr>
    </table>
</div>
            </field>
            <!-- COMENTADO: Reporte se asociará automáticamente cuando se cree -->
            <!-- <field name="report_template_ids" eval="[(4, ref('lavish_hr_employee.report_certificacion_laboral_action'))]"/> -->
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
