            <field name="type_partner">employee</field>
        </record>

        <!-- Línea 27: Segundo Apellido -->
        <record id="conf_certificate_line_27" model="hr.conf.certificate.income">
            <field name="sequence">27</field>
            <field name="calculation">info</field>
            <field name="type_partner">employee</field>
        </record>

        <!-- Línea 28: Primer Nombre -->
        <record id="conf_certificate_line_28" model="hr.conf.certificate.income">
            <field name="sequence">28</field>
            <field name="calculation">info</field>
            <field name="type_partner">employee</field>
        </record>

        <!-- Línea 29: Otros Nombres -->
        <record id="conf_certificate_line_29" model="hr.conf.certificate.income">
            <field name="sequence">29</field>
            <field name="calculation">info</field>
            <field name="type_partner">employee</field>
        </record>

        <!-- Líneas de Fechas -->
        <!-- Línea 30: Fecha inicial -->
        <record id="conf_certificate_line_30" model="hr.conf.certificate.income">
            <field name="sequence">30</field>
            <field name="calculation">start_date_year</field>
        </record>

        <!-- Línea 31: Fecha final -->
        <record id="conf_certificate_line_31" model="hr.conf.certificate.income">
            <field name="sequence">31</field>
            <field name="calculation">end_date_year</field>
        </record>

        <!-- Línea 32: Fecha expedición -->
        <record id="conf_certificate_line_32" model="hr.conf.certificate.income">
            <field name="sequence">32</field>
            <field name="calculation">date_issue</field>
        </record>

    </data>
</odoo>
