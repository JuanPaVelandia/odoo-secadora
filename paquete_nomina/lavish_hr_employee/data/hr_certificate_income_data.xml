        <record id="conf_certificate_line_53" model="hr.conf.certificate.income">
            <field name="sequence">53</field>
            <field name="calculation">sum_rule</field>
            <field name="type_partner">employee</field>
        </record>

        <!-- Línea 54: Total aportes (suma) -->
        <record id="conf_certificate_line_54" model="hr.conf.certificate.income">
            <field name="sequence">54</field>
            <field name="calculation">sum_sequence</field>
            <field name="sequence_list_sum">50,51,52,53</field>
        </record>

        <!-- Líneas de Retenciones -->
        <!-- Línea 55: Retención en la fuente -->
        <record id="conf_certificate_line_55" model="hr.conf.certificate.income">
            <field name="sequence">55</field>
            <field name="calculation">sum_rule</field>
            <field name="type_partner">employee</field>
        </record>

        <!-- Líneas de Información del Retenedor (Compañía) -->
        <!-- Línea 5: NIT Compañía -->
        <record id="conf_certificate_line_5" model="hr.conf.certificate.income">
            <field name="sequence">5</field>
            <field name="calculation">info</field>
            <field name="type_partner">company</field>
        </record>

        <!-- Línea 11: Razón Social -->
        <record id="conf_certificate_line_11" model="hr.conf.certificate.income">
            <field name="sequence">11</field>
            <field name="calculation">info</field>
            <field name="type_partner">company</field>
        </record>

