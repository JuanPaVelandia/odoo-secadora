<odoo>
    <data>
        <!-- Formulario Reglas salariales - ajustes-->
        <record id="view_lavish_hr_employee_form_salary_rule" model="ir.ui.view">
            <field name="name">hr.salary.rule.lavish.hr.employee.form.inherit</field>
            <field name="model">hr.salary.rule</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_payroll.hr_salary_rule_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='condition_python']" position="attributes">
                    <attribute name="widget">ace</attribute>
                    <attribute name="options">{'mode': 'python'}</attribute>
                </xpath>
                <xpath expr="//field[@name='amount_python_compute']" position="attributes">
                    <attribute name="widget">ace</attribute>
                    <attribute name="options">{'mode': 'python'}</attribute>
                </xpath>
                <xpath expr="//field[@name='amount_python_compute']" position="after">
                    <div class="alert alert-info mt16" role="alert" style="margin-top:10px;">
                        <h6><i class="fa fa-info-circle"/> Variables Disponibles en Contexto Python</h6>
                        <p style="margin-bottom:8px; font-size:12px;">Estas son las variables que puedes usar directamente en el código de la regla:</p>

                        <table class="table table-sm table-bordered" style="font-size:11px; margin-bottom:0;">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:25%">Variable</th>
                                    <th style="width:20%">Tipo</th>
                                    <th>Ejemplo de Uso (Campos Reales)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>employee</code></td>
                                    <td>hr.employee</td>
                                    <td>
                                        <code>employee.name</code> - Nombre completo<br/>
                                        <code>employee.identification_id</code> - Cédula<br/>
                                        <code>employee.work_email</code> - Email corporativo<br/>
                                        <code>employee._prima(localdict, categories, date_from, date_to)</code>
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>contract</code></td>
                                    <td>hr.contract</td>
                                    <td>
                                        <code>contract.wage</code> - Salario básico<br/>
                                        <code>contract.transporte</code> - Auxilio transporte<br/>
                                        <code>contract.tipo_salario</code> - 'ordinario' o 'integral'<br/>
                                        <code>contract.date_start</code> - Fecha inicio contrato
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>payslip</code></td>
                                    <td>hr.payslip</td>
                                    <td>
                                        <code>payslip.date_from</code> - Fecha inicio nómina<br/>
                                        <code>payslip.date_to</code> - Fecha fin nómina<br/>
                                        <code>payslip.struct_id.name</code> - Tipo de nómina<br/>
                                        <code>payslip.company_id.name</code> - Compañía
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>categories</code></td>
                                    <td>CategoryCollection</td>
                                    <td>
                                        <code>categories.get('BASIC').total</code> - Total categoría BASIC<br/>
                                        <code>categories.get_total(['DEV_SALARIAL'])</code> - Devengos salariales<br/>
                                        <code>categories['HEYREC'].rules</code> - Reglas de horas extra
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>rules</code></td>
                                    <td>RulesCollection</td>
                                    <td>
                                        <code>rules.get('BASIC').total</code> - Total salario básico<br/>
                                        <code>rules.get('IBD').extra_data.get('ibc_final', 0)</code> - IBC<br/>
                                        <code>rules.filter_rules(base_prima=True)</code> - Reglas base prima
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>worked_days</code></td>
                                    <td>dict</td>
                                    <td>
                                        <code>worked_days.get('WORK100').number_of_days</code> - Días trabajados<br/>
                                        <code>worked_days.get('WORK100').number_of_hours</code> - Horas trabajadas<br/>
                                        <code>worked_days.get('VAC').number_of_days</code> - Días de vacaciones
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>inputs</code></td>
                                    <td>dict</td>
                                    <td>
                                        <code>inputs.get('COMISION').amount</code> - Comisiones<br/>
                                        <code>inputs.get('BONIFICACION').amount</code> - Bonificaciones<br/>
                                        <code>inputs.get('PRESTAMO').amount</code> - Descuento préstamo
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>annual_parameters</code></td>
                                    <td>hr.annual.parameters</td>
                                    <td>
                                        <code>annual_parameters.smmlv_monthly</code> - Salario mínimo<br/>
                                        <code>annual_parameters.transportation_assistance_monthly</code> - Aux. transporte<br/>
                                        <code>annual_parameters.value_porc_health_employee</code> - % Salud
                                    </td>
                                </tr>
                                <tr>
                                    <td><code>localdict</code></td>
                                    <td>dict</td>
                                    <td>
                                        Diccionario completo con todas las variables: <code>localdict['employee']</code>,
                                        <code>localdict['contract']</code>, <code>localdict['categories']</code>, etc.
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <p style="margin:8px 0 0 0; font-size:11px;">
                            <strong>Nota:</strong> El resultado debe asignarse a <code>result</code>, <code>cantidad</code> y <code>rate</code>.
                        </p>

                        <details style="margin-top:10px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#e3f2fd; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-code"/> Ejemplo 1: Sumar total de categoría DEV_SALARIAL
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#aed581; padding:8px; border-radius:3px;">
# Obtener total de categoría DEV_SALARIAL
dev_salarial = categories.get_total('DEV_SALARIAL')

result = dev_salarial
cantidad = 30
rate = 100</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#fff3e0; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-filter"/> Ejemplo 2: Sumar reglas específicas con filtros
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#81d4fa; padding:8px; border-radius:3px;">
# Sumar varias reglas filtrando por códigos
total, cant, rate_val, html = employee._calculate_total_from_rules(
    localdict=localdict,
    categories=categories,
    filters={
        'rules': ['BASIC', 'HEYREC', 'COMIS'],  # Solo estas reglas
        'exclude_rules': ['PRESTAMO']  # Excluir préstamos
    }
)

result = total
cantidad = cant
rate = rate_val</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#e8f5e9; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-file-text-o"/> Ejemplo 3: Obtener datos del contrato
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#a5d6a7; padding:8px; border-radius:3px;">
# Salario básico del contrato
salario = contract.wage

# Auxilio de transporte
aux_transporte = contract.transporte

# Tipo de salario (ordinario o integral)
es_integral = contract.tipo_salario == 'integral'

# Usar en cálculo
if es_integral:
    result = salario * 0.30  # 30% factor prestacional
else:
    result = salario

cantidad = 30
rate = 100</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#f3e5f5; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-calculator"/> Ejemplo 4: Usar datos de regla IBD ya calculada
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#ce93d8; padding:8px; border-radius:3px;">
# Obtener datos de la regla IBD (Ingreso Base Deducción)
ibd_rule = rules.get('IBD')

if ibd_rule:
    # Total de IBD
    total_ibd = ibd_rule.total

    # Datos extra guardados por IBD
    ibc_final = ibd_rule.extra_data.get('ibc_final', 0)
    vac_monto = ibd_rule.extra_data.get('vac_monto', 0)
    vac_dias = ibd_rule.extra_data.get('vac_dias', 0)

    # Usar en cálculo (ejemplo: salud empleado)
    result = total_ibd + ibc_final - vac_monto
    cantidad = 30
    rate = 4.0  # 4% salud empleado
else:
    result = 0
    cantidad = 0
    rate = 0</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#fff9c4; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-calendar"/> Ejemplo 5: Obtener valores del mes anterior
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#ffeb3b; padding:8px; border-radius:3px;">
# Obtener valor de regla IBC del mes anterior
ibc_anterior = employee._get_value_from_previous_month(
    payslip=payslip,
    rule_code='IBC',
    months_back=1  # 1 mes atrás
)

# O total de categoría del mes anterior
dev_anterior = employee._get_value_from_previous_month(
    payslip=payslip,
    category_code='DEV',
    months_back=1
)

result = ibc_anterior
cantidad = 30
rate = 100</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#ffebee; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-clock-o"/> Ejemplo 6: Calcular días en rango de fechas
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#ef9a9a; padding:8px; border-radius:3px;">
# Calcular días entre dos fechas
from datetime import datetime

fecha_inicio = payslip.date_from
fecha_fin = payslip.date_to

# Días totales del período
dias_periodo = (fecha_fin - fecha_inicio).days + 1

# Calcular proporcional
result = (contract.wage / 30) * dias_periodo
cantidad = dias_periodo
rate = (dias_periodo / 30) * 100</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#e0f7fa; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-list"/> Ejemplo 7: Acceder a regla ya calculada
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#80deea; padding:8px; border-radius:3px;">
# Obtener regla BASIC ya calculada
basic_rule = rules.get('BASIC')

if basic_rule:
    # Acceder a sus valores
    valor_basic = basic_rule.total
    dias_basic = basic_rule.quantity

    # Calcular 15% del salario básico
    result = valor_basic * 0.15
    cantidad = dias_basic
    rate = 15.0
else:
    result = 0
    cantidad = 0
    rate = 0</code>
                            </div>
                        </details>

                        <details style="margin-top:8px;">
                            <summary style="cursor:pointer; padding:6px; background-color:#fce4ec; border-radius:3px; font-weight:bold; font-size:12px;">
                                <i class="fa fa-briefcase"/> Ejemplo 8: Usar días trabajados (worked_days)
                            </summary>
                            <div style="padding:8px; background-color:#f5f5f5; margin-top:5px; font-size:11px;">
                                <code style="display:block; white-space:pre; font-family:monospace; background:#263238; color:#f48fb1; padding:8px; border-radius:3px;">
# Obtener días trabajados del registro WORK100
if 'WORK100' in worked_days:
    dias = worked_days['WORK100'].number_of_days
else:
    dias = 30

# Calcular salario proporcional
result = (contract.wage / 30) * dias
cantidad = dias
rate = (dias / 30) * 100</code>
                            </div>
                        </details>
                    </div>
                </xpath>

                <xpath expr="//form[1]/sheet[1]/group[1]" position="attributes">
                    <attribute name="row">8</attribute>
                    <attribute name="string">Master</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
                    <group colspan="12">
                        <group string="Naturaleza">
                            <field name="dev_or_ded" widget="radio" />
                            <field name="afecta_totales" widget="radio"/>
                            <field name="deduction_applies_bonus"
                                invisible="dev_or_ded != 'deduccion'" />
                            <field name="is_leave" />
                            <field name="is_recargo" />
                        </group>
                        <group string="Tipos de conceptos">
                            <field name="type_concepts" />
                            <field name="account_tax_id" />
                            <field name="aplicar_cobro"
                               invisible="type_concepts not in  ['ley','novedad']" />
                            <field name="modality_value" widget="radio" />
                            <field name="novedad_ded" widget="radio" />
                        </group>
                        <group string="Tipos Detalle">
                            <!-- employee_type_domain: lista separada por comas (ej: employee,contractor) -->
                            <field name="employee_type_domain" placeholder="employee,contractor,freelance"/>
                            <field name="process" />
                            <field name="proyectar_nom" />
                            <field name="proyectar_ret" />
                            <field name="deduct_deductions" widget="radio"
                               invisible="is_leave ==  False" />
                        </group>
                    </group>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                    <page string="Conf. Adicional" name="conf_aditional">
                        <group>
                            <group name="base_prestaciones" string="Bases de Prestaciones">
                                <div class="o_form_label">Parametrización independiente por contexto: provisión vs liquidación.</div>
                                <separator string="Provisiones" colspan="2"/>
                                <field name="base_prima_provision" string="Prima"/>
                                <field name="base_cesantias_provision" string="Cesantías"/>
                                <field name="base_intereses_cesantias_provision" string="Intereses Cesantías"/>
                                <field name="base_vacaciones_provision" string="Vacaciones"/>
                                <field name="base_vacaciones_dinero_provision" string="Vacaciones Dinero"/>
                                <separator string="Liquidaciones" colspan="2"/>
                                <field name="base_prima_liquidacion" string="Prima"/>
                                <field name="base_cesantias_liquidacion" string="Cesantías"/>
                                <field name="base_intereses_cesantias_liquidacion" string="Intereses Cesantías"/>
                                <field name="base_vacaciones_liquidacion" string="Vacaciones"/>
                                <field name="base_vacaciones_dinero_liquidacion" string="Vacaciones Dinero"/>
                                <field name="base_compensation" string="Base Indemnización"/>
                                <field name="base_auxtransporte_tope" string="Base Aux. Transporte (tope)"/>
                                <field name="excluir_auxtransporte_tope" string="Excluir Aux. Transporte (tope)"/>
                                <separator string="Clasificacion para Promedio" colspan="2"/>
                                <field name="es_auxilio_transporte" />
                                <div colspan="2" class="alert alert-info" role="alert" style="margin-top:5px; font-size:11px;">
                                    <strong>Nota:</strong> Para el calculo de prestaciones con auxilio variable:<br/>
                                    - Los conceptos de categoria <strong>AUX</strong> seran tratados automaticamente como auxilio de transporte.<br/>
                                    - Los conceptos marcados como "Es Auxilio de Transporte" tambien seran tratados como auxilio.<br/>
                                    - Los conceptos de categoria <strong>BASIC</strong> se tratan como sueldo fijo.<br/>
                                    Cuando modality_aux=variable, el auxilio se promedia como concepto variable (igual que comisiones).
                                </div>
                            </group>
                            <group name="base_seguridad_social" string="Seguridad Social (IBC)">
                                <field name="base_seguridad_social" string="Incluir en IBC"
                                       help="Actívalo para sumar este concepto a la base de Seguridad Social (IBC). Si no está marcado, no se incluye en el IBC."/>
                                <field name="base_arl" />
                                <field name="base_parafiscales" />
                                <field name="base_horas_extras" />
                                <field name="excluir_seguridad_social" />
                                <field name="excluir_40_porciento_ss" />
                                <separator string="Salario Integral" colspan="2"/>
                                <field name="aplica_factor_integral" />
                                <div colspan="2" class="alert alert-warning" role="alert" style="margin-top:5px; font-size:11px;">
                                    <strong>Factor 70% Salario Integral (Art. 132 CST):</strong><br/>
                                    - La categoría <strong>BASIC</strong> aplica el factor 70% automáticamente.<br/>
                                    - Marcar este campo para otros conceptos que también deben aplicar el 70%.<br/>
                                    - <strong>NO marcar</strong> para: comisiones, bonificaciones, horas extras.<br/>
                                    <em>Ejemplo: Sal. Integral $10M (70%) + Comisiones $2M (100%) = IBC $9M</em>
                                </div>
                            </group>
                        </group>
                        <group>
                            <group name="opciones_calculo" string="Opciones de Calculo">
                                <field name="rounding_method" />
                                <field name="descontar_suspensiones"
                                       string="Descontar Ausencias No Pagadas"
                                       help="Si está activo, esta regla descuenta días de ausencias no pagadas (licencia no remunerada, sanción, ausencia injustificada) en su cálculo."/>
                                <field name="liquidar_con_base" />
                            </group>
                            <group name="opciones_retencion" string="Retencion y Proyeccion">
                                <field name="excluir_ret" />
                                <field name="is_projectable_rtf" />
                            </group>
                        </group>
                        <group>
                            <group name="reportes" string="Reportes y Archivos">
                                <field name="short_name" />
                                <field name="display_days_worked" />
                                <field name="not_include_flat_payment_file" />
                            </group>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//page[@name='display']" position="after">
                    <page string="Contabilidad" name="accounting-ext">
                        <field name="salary_rule_accounting" nolabel="1">
                            <list string="Configuracion" editable="bottom">
                                <field name="department_id" />
                                <field name="company_id" />
                                <field name="work_location_id" />
                                <field name="third_debit" />
                                <field name="debit_account_id" />
                                <field name="third_credit" />
                                <field name="credit_account_id" />
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Vista de lista mejorada -->
        <record id="view_lavish_hr_salary_rule_list" model="ir.ui.view">
            <field name="name">hr.salary.rule.lavish.list</field>
            <field name="model">hr.salary.rule</field>
            <field name="inherit_id" ref="hr_payroll.hr_salary_rule_list"/>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-info">type_concepts == 'novedad'</attribute>
                    <attribute name="decoration-success">type_concepts == 'sueldo' or type_concepts == 'prestacion'</attribute>
                    <attribute name="decoration-warning">type_concepts == 'provision'</attribute>
                    <attribute name="decoration-danger">type_concepts == 'consolidacion' or type_concepts == 'tributaria'</attribute>
                    <attribute name="decoration-muted">not active</attribute>
                </xpath>
                <xpath expr="//field[@name='sequence']" position="attributes">
                    <attribute name="column_invisible">False</attribute>
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='struct_id']" position="attributes">
                    <attribute name="column_invisible">False</attribute>
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="type_concepts" optional="show"/>
                    <field name="dev_or_ded" optional="show"/>
                    <field name="process" optional="hide"/>
                    <field name="modality_value" optional="hide"/>
                    <field name="aplicar_cobro" optional="hide"/>
                    <field name="condition_select" optional="hide"/>
                    <field name="amount_select" optional="hide"/>
                    <field name="is_leave" optional="hide"/>
                    <field name="is_recargo" optional="hide"/>
                    <field name="base_seguridad_social" optional="hide"/>
                    <field name="base_prima" optional="hide"/>
                    <field name="base_cesantias" optional="hide"/>
                    <field name="base_intereses_cesantias" optional="hide"/>
                    <field name="base_vacaciones" optional="hide"/>
                    <field name="appears_on_payslip" optional="hide"/>
                    <field name="active" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- Vista de busqueda mejorada -->
        <record id="view_lavish_hr_salary_rule_search" model="ir.ui.view">
            <field name="name">hr.salary.rule.lavish.search</field>
            <field name="model">hr.salary.rule</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_rule_filter"/>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <!-- Campos de busqueda adicionales -->
                <xpath expr="//field[@name='struct_id']" position="after">
                    <field name="type_concepts"/>
                    <field name="dev_or_ded"/>
                    <field name="process"/>
                    <field name="short_name"/>
                </xpath>

                <!-- Filtros rapidos -->
                <xpath expr="//filter[@name='archived']" position="before">
                    <separator/>
                    <!-- Naturaleza -->
                    <filter string="Devengos" name="filter_devengos" domain="[('dev_or_ded', '=', 'devengo')]"/>
                    <filter string="Deducciones" name="filter_deducciones" domain="[('dev_or_ded', '=', 'deduccion')]"/>
                    <separator/>
                    <!-- Proceso -->
                    <filter string="Nomina" name="filter_nomina" domain="[('process', '=', 'nomina')]"/>
                    <filter string="Vacaciones" name="filter_vacaciones" domain="[('process', '=', 'vacaciones')]"/>
                    <filter string="Prima" name="filter_prima_proc" domain="[('process', '=', 'prima')]"/>
                    <filter string="Cesantias" name="filter_cesantias_proc" domain="[('process', '=', 'cesantias')]"/>
                    <filter string="Liquidacion" name="filter_liquidacion" domain="[('process', '=', 'contrato')]"/>
                    <separator/>
                    <!-- Tipo concepto -->
                    <filter string="Sueldo" name="filter_sueldo" domain="[('type_concepts', '=', 'sueldo')]"/>
                    <filter string="Fijo contrato" name="filter_contrato_type" domain="[('type_concepts', '=', 'contrato')]"/>
                    <filter string="Ley/Ausencias" name="filter_ley" domain="[('type_concepts', '=', 'ley')]"/>
