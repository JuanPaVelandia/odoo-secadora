<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Tree de Configuración de Certificado -->
    <record id="view_hr_certificate_income_header_tree" model="ir.ui.view">
        <field name="name">hr.certificate.income.header.tree</field>
        <field name="model">hr.certificate.income.header</field>
        <field name="arch" type="xml">
            <list string="Configuración de Certificados" create="1" edit="1" delete="1">
                <field name="name"/>
                <field name="year"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="uvt_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="configuration_complete" widget="boolean_toggle"/>
                <field name="missing_items_count"
                       invisible="configuration_complete"
                       decoration-warning="missing_items_count > 0"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Vista Form de Configuración de Certificado -->
    <record id="view_hr_certificate_income_header_form" model="ir.ui.view">
        <field name="name">hr.certificate.income.header.form</field>
        <field name="model">hr.certificate.income.header</field>
        <field name="arch" type="xml">
            <form string="Configuración de Certificado de Ingresos y Retenciones">
                <header>
                    <button name="action_load_default_configuration"
                            type="object"
                            string="Cargar Configuración por Defecto"
                            class="btn-primary"
                            invisible="line_ids"/>
                    <button name="action_open_wizard"
                            type="object"
                            string="Generar Certificados"
                            class="btn-primary"
                            invisible="not configuration_complete"/>
                    <button name="action_compute_from_parameters"
                            type="object"
                            string="Actualizar desde Parámetros Anuales"
                            class="btn-secondary"/>
                    <button name="action_view_configuration_status"
                            type="object"
                            string="Ver Estado de Configuración"
                            invisible="configuration_complete"/>
                    <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_configuration_status"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                invisible="configuration_complete">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="missing_items_count"/>
                                </span>
                                <span class="o_stat_text">Items Faltantes</span>
                            </div>
                        </button>
                        <button name="action_view_configuration_status"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                invisible="not configuration_complete">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value text-success">
                                    <i class="fa fa-check" title="Completo"></i> Completo
                                </span>
                                <span class="o_stat_text">Configuración</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="ej: Certificado 2025"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información Básica">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="year"/>
                            <field name="form_number"/>
                            <field name="issue_date"/>
                        </group>
                        <group string="Valores UVT">
                            <field name="uvt_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="patrimony_uvt"/>
                            <field name="income_uvt"/>
                            <field name="currency_id" column_invisible="1"/>
                        </group>
                    </group>

                    <group>
                        <group string="Valores en COP">
                            <field name="patrimony_cop" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="income_cop" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                        </group>
                        <group string="Estado">
                            <field name="configuration_complete" widget="boolean_toggle"/>
                            <field name="description"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Líneas de Configuración" name="lines">
                            <field name="line_ids">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="sequence" width="80px"/>
                                    <field name="calculation" width="150px"/>
                                    <field name="type_partner"
                                           invisible="calculation not in ['info']"
                                           optional="show"/>
                                    <field name="information_fields_id"
                                           invisible="calculation not in ['info']"
                                           optional="show"/>
                                    <field name="related_field_id"
                                           invisible="calculation not in ['info'] or not information_fields_relation"
                                           optional="hide"/>
                                    <field name="salary_rule_id"
                                           widget="many2many_tags"
                                           invisible="calculation not in ['sum_rule']"
                                           optional="show"/>
                                    <field name="origin_severance_pay"
                                           invisible="calculation not in ['sum_rule']"
                                           optional="hide"/>
                                    <field name="sequence_list_sum"
                                           invisible="calculation not in ['sum_sequence']"
                                           optional="show"/>
                                    <field name="accumulated_previous_year"
                                           widget="boolean_toggle"
                                           optional="hide"/>
                                    <field name="is_configured"
                                           widget="boolean_toggle"
                                           readonly="1"/>
                                    <field name="information_fields_relation" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Configuración Contable" name="accounting">
                            <group>
                                <group string="Cuentas Contables">
                                    <field name="account_ids"
                                           widget="many2many_tags"
                                           domain="[('company_ids', 'in', [company_id])]"
                                           options="{'no_create': True}"/>
                                </group>
                                <group string="Diarios Excluidos">
                                    <field name="excluded_journal_ids"
                                           widget="many2many_tags"
                                           domain="[('company_id', '=', company_id)]"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Plantilla HTML" name="template">
                            <div class="alert alert-info" role="alert">
                                <i class="fa fa-info-circle" title="Informacion"></i>
                                <strong>Instrucciones:</strong> Use {valNN} para valores dinámicos, donde NN es el número de secuencia (ej: {val36}, {val37}).
                                <br/>
                                Variables especiales: {year}, {uvt_4500}, {uvt_1400}
                            </div>
                            <field name="report_template" widget="html" options="{'style-inline': true}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Search de Configuración -->
    <record id="view_hr_certificate_income_header_search" model="ir.ui.view">
        <field name="name">hr.certificate.income.header.search</field>
        <field name="model">hr.certificate.income.header</field>
        <field name="arch" type="xml">
            <search string="Buscar Configuración">
                <field name="name" string="Nombre"/>
                <field name="year" string="Año"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <filter string="Activas" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactivas" name="inactive" domain="[('active', '=', False)]"/>

                <separator/>

                <filter string="Configuración Completa" name="complete"
                        domain="[('configuration_complete', '=', True)]"/>
                <filter string="Configuración Incompleta" name="incomplete"
                        domain="[('configuration_complete', '=', False)]"/>

                <separator/>

                <filter string="Año Actual" name="current_year"
                        domain="[('year', '=', context_today().year)]"/>
                <filter string="Año Anterior" name="previous_year"
                        domain="[('year', '=', context_today().year - 1)]"/>

                <group name="group_by">
                    <filter string="Año" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Estado" name="group_complete" context="{'group_by': 'configuration_complete'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción para Configuración de Certificados -->
    <record id="action_hr_certificate_income_header" model="ir.actions.act_window">
        <field name="name">Configuración de Certificados</field>
        <field name="res_model">hr.certificate.income.header</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear Nueva Configuración de Certificado
            </p>
            <p>
                Configure los parámetros para generar certificados de ingresos y retenciones.
                <br/>
                Defina las reglas salariales, campos de información y plantilla HTML.
            </p>
        </field>
    </record>

    <!-- Vista Tree de Líneas de Configuración -->
    <record id="view_hr_conf_certificate_income_tree" model="ir.ui.view">
        <field name="name">hr.conf.certificate.income.tree</field>
        <field name="model">hr.conf.certificate.income</field>
        <field name="arch" type="xml">
            <list string="Líneas de Configuración" create="1" edit="1" delete="1">
                <field name="sequence"/>
                <field name="name"/>
                <field name="calculation"/>
                <field name="salary_rule_id" widget="many2many_tags" optional="hide"/>
                <field name="account_ids" widget="many2many_tags" optional="hide"/>
                <field name="salary_rule_category_ids" widget="many2many_tags" optional="hide"/>
                <field name="exclude_payroll_entries" widget="boolean_toggle" optional="hide"/>
                <field name="severance_paid_previous_year" widget="boolean_toggle" optional="hide"/>
                <field name="is_configured" widget="boolean_toggle"/>
                <field name="header_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Vista Form de Líneas de Configuración -->
    <record id="view_hr_conf_certificate_income_form" model="ir.ui.view">
        <field name="name">hr.conf.certificate.income.form</field>
        <field name="model">hr.conf.certificate.income</field>
        <field name="arch" type="xml">
            <form string="Línea de Configuración">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_hr_certificate_income_header)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-cog">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver Configuración</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información Básica">
                            <field name="header_id"/>
                            <field name="sequence"/>
                            <field name="calculation"/>
                            <field name="is_configured" widget="boolean_toggle"/>
                        </group>
                        <group string="Configuración Específica">
                            <field name="type_partner"
                                   invisible="calculation not in ['info']"/>
                            <field name="accumulated_previous_year"
                                   widget="boolean_toggle"
                                   invisible="calculation not in ['sum_rule']"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Campo de Información"
                              name="info_field"
                              invisible="calculation not in ['info']">
                            <group>
                                <group>
                                    <field name="information_fields_id"
                                           domain="[('model_id.model', 'in', ['hr.employee','res.partner','hr.contract'])]"/>
                                    <field name="information_fields_relation"/>
                                    <field name="related_field_id"
                                           invisible="not information_fields_relation"
                                           domain="[('model_id.model', '=', information_fields_relation)]"/>
                                </group>
                            </group>
                        </page>

                        <page string="Reglas Salariales"
                              name="salary_rules"
                              invisible="calculation not in ['sum_rule']">
                            <group>
                                <field name="salary_rule_id"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>
                                <field name="origin_severance_pay"/>
                            </group>
                        </page>

                        <page string="Suma de Secuencias"
                              name="sum_sequence"
                              invisible="calculation not in ['sum_sequence']">
                            <group>
                                <field name="sequence_list_sum"
                                       placeholder="Ej: 36,37,38,39,40"/>
                                <p class="text-muted">
                                    Ingrese los números de secuencia separados por coma
                                </p>
                            </group>
                        </page>

                        <page string="Configuración Contable" name="accounting">
                            <group>
                                <group string="Cuentas Contables">
                                    <field name="account_ids"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"/>
                                    <field name="account_move_type"/>
                                    <p class="text-muted">
                                        Dejar vacío para usar las cuentas del encabezado
                                    </p>
                                </group>
                                <group string="Filtros de Movimientos">
                                    <field name="move_state_filter"/>
                                    <field name="exclude_payroll_entries" widget="boolean_toggle"/>
                                    <field name="excluded_journal_ids"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>
                            <group>
                                <group string="Dominio Personalizado">
                                    <field name="account_move_domain"
                                           placeholder="[('ref', 'ilike', 'PREFIX')]"/>
                                    <p class="text-muted">
                                        Dominio Odoo para filtrar movimientos contables adicionales
                                    </p>
                                </group>
                            </group>
                        </page>

                        <page string="Categorías y Cesantías" name="categories">
                            <group>
                                <group string="Categorías de Reglas Salariales">
                                    <field name="salary_rule_category_ids"
                                           widget="many2many_tags"
                                           options="{'no_create': True, 'color_field': 'color'}"/>
                                    <p class="text-muted">
                                        Asociar categorías de reglas salariales para cálculo automático por categoría
                                    </p>
                                </group>
                                <group string="Configuración de Cesantías">
                                    <field name="severance_paid_previous_year"
                                           widget="boolean_toggle"
                                           invisible="calculation not in ['sum_rule', 'sum_sequence']"/>
                                    <p class="text-muted" invisible="calculation not in ['sum_rule', 'sum_sequence']">
                                        Marcar si las cesantías fueron pagadas el año anterior
                                    </p>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menús -->
    <menuitem id="menu_hr_certificate_income_root"
              name="Certificados de Ingreso"
              parent="hr.menu_hr_root"
              sequence="60"/>

    <menuitem id="menu_hr_certificate_income_configuration"
              name="Configuración"
              parent="menu_hr_certificate_income_root"
              sequence="10"/>

    <menuitem id="menu_hr_certificate_income_header"
              name="Configuración de Certificados"
              parent="menu_hr_certificate_income_configuration"
              action="action_hr_certificate_income_header"
              sequence="10"/>

</odoo>
