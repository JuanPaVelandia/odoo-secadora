<odoo>
    <data>
        <!-- =================================================================
             TIPOS DE COTIZANTE - Segun PILA Colombia 2025
             ================================================================= -->
        <record id="action_hr_tipo_cotizante" model="ir.actions.act_window">
            <field name="name">Tipos de Cotizante PILA</field>
            <field name="res_model">hr.tipo.cotizante</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear Tipo de Cotizante
                </p>
                <p>Los tipos de cotizante definen la categoria del trabajador segun la normativa PILA.</p>
            </field>
        </record>

        <record model="ir.ui.view" id="list_hr_tipo_cotizante">
            <field name="name">hr.tipo.cotizante.list</field>
            <field name="model">hr.tipo.cotizante</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code" string="Codigo"/>
                    <field name="name" string="Nombre"/>
                    <field name="description" string="Descripcion" optional="show"/>
                    <field name="aplicacion_practica" string="Aplicacion Practica" optional="show"/>
                    <field name="referencia_normativa" string="Normativa" optional="hide"/>
                    <field name="active" column_invisible="1"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="form_hr_tipo_cotizante">
            <field name="name">hr.tipo.cotizante.form</field>
            <field name="model">hr.tipo.cotizante</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="code" placeholder="Codigo (ej: 01)"/> -
                                <field name="name" placeholder="Nombre del tipo"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Descripcion PILA">
                                <field name="description" nolabel="1" placeholder="Descripcion segun normativa PILA..."/>
                            </group>
                            <group string="Aplicacion Practica">
                                <field name="aplicacion_practica" nolabel="1" placeholder="Ejemplos de uso practico..."/>
                            </group>
                        </group>
                        <group>
                            <field name="referencia_normativa" placeholder="Ej: Decreto 1406 de 1999"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- =================================================================
             SUBTIPOS DE COTIZANTE - Segun PILA Colombia 2025
             ================================================================= -->
        <record id="action_hr_subtipo_cotizante" model="ir.actions.act_window">
            <field name="name">SubTipos de Cotizante PILA</field>
            <field name="res_model">hr.subtipo.cotizante</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear SubTipo de Cotizante
                </p>
                <p>Los subtipos definen condiciones especiales del cotizante (pensionado, extranjero, etc.)</p>
            </field>
        </record>

        <record model="ir.ui.view" id="list_hr_subtipo_cotizante">
            <field name="name">hr.subtipo.cotizante.list</field>
            <field name="model">hr.subtipo.cotizante</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code" string="Codigo"/>
                    <field name="name" string="Nombre"/>
                    <field name="description" string="Descripcion" optional="show"/>
                    <field name="aplicacion_practica" string="Aplicacion Practica" optional="show"/>
                    <field name="not_contribute_pension" string="No Aporta Pension"/>
                    <field name="not_contribute_eps" string="No Aporta Salud"/>
                    <field name="referencia_normativa" string="Normativa" optional="hide"/>
                    <field name="active" column_invisible="1"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="form_hr_subtipo_cotizante">
            <field name="name">hr.subtipo.cotizante.form</field>
            <field name="model">hr.subtipo.cotizante</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="code" placeholder="Codigo (ej: 00)"/> -
                                <field name="name" placeholder="Nombre del subtipo"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Aportes">
                                <field name="not_contribute_pension"/>
                                <field name="not_contribute_eps"/>
                            </group>
                            <group string="Referencia">
                                <field name="referencia_normativa" placeholder="Ej: Resolucion 000467 de 2025"/>
                            </group>
                        </group>
                        <group>
                            <group string="Descripcion PILA">
                                <field name="description" nolabel="1" placeholder="Descripcion segun normativa PILA..."/>
                            </group>
                            <group string="Aplicacion Practica">
                                <field name="aplicacion_practica" nolabel="1" placeholder="Ejemplos de uso practico..."/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- TIPOS DE FALTAS -->
        <record id="action_hr_type_faults" model="ir.actions.act_window">
            <field name="name">Tipos de faltas</field>
            <field name="res_model">hr.types.faults</field>
            <field name="view_mode">list</field>
            <field name="domain">[]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crear Tipo de de falta
                </p>
            </field>
        </record>

        <record model="ir.ui.view" id="list_hr_type_faults">
            <field name="name">list hr type faults</field>
            <field name="model">hr.types.faults</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name" required="1"/>
                    <field name="description" required="1"/>
                </list>
            </field>
        </record>

        <!-- PARAMETRIZACION COTIZANTES -->
        <record model="ir.actions.act_window" id="action_hr_parameterization_of_contributors">
            <field name="name">Parametrización Cotizantes</field>
            <field name="res_model">hr.parameterization.of.contributors</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.ui.view" id="hr_parameterization_of_contributors_list">
            <field name="name">hr parameterization of contributors list</field>
            <field name="model">hr.parameterization.of.contributors</field>
            <field name="arch" type="xml">
                <list>
                    <field name="type_of_contributor"/>
                    <field name="contributor_subtype"/>
                </list>
            </field>
        </record>

        <record id="hr_parameterization_of_contributors_form" model="ir.ui.view">
            <field name="name">hr parameterization of contributors form</field>
            <field name="model">hr.parameterization.of.contributors</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="type_of_contributor"/>
                            <field name="contributor_subtype"/>
                        </group>
                        <group colspan="4">
                            <group string="Requiere entidad EPS:">
                                <field name="liquidates_eps_company"/>
                                <field name="liquidated_eps_employee"/>
                            </group>
                            <group string="Requiere entidad pensión:">
                                <field name="liquidated_company_pension"/>
                                <field name="liquidate_employee_pension"/>
                                <field name="liquidates_solidarity_fund"/>
                            </group>
                            <group colspan="6">
                                <group string="Requiere entidad ARL:">
                                    <field name="liquidated_arl"/>
                                </group>
                                <br/>
                                <br/>
                                <group string="Requiere entidad caja de compensación:">
                                    <field name="liquidated_compensation_fund"/>
                                </group>
                                <br/>
                                <br/>
                                <group string="Las entidades se toman de forma automática en caso de ser necesario:">
                                    <field name="liquidated_aux_transport"/>
                                    <field name="liquidated_sena"/>
                                    <field name="liquidated_icbf"/>
                                </group>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>