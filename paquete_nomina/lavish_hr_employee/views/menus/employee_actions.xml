<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- MENU ROOT - Información Empleados (bajo menú Empleados de Nómina) -->
        <menuitem id="menu_root"
                  name="Información Empleados"
                  parent="hr_payroll.menu_hr_payroll_employees"
                  sequence="50"/>

        <!-- EMPLOYEE ACTIONS AND MENUS -->

        <record model="ir.actions.act_window" id="action_report_print_badge_template">
                    <field name="name">Configuración plantilla carnet</field>
                    <field name="res_model">report.print.badge.template</field>
                    <field name="view_mode">list,form</field>
                </record>

        <record model="ir.actions.server" id="action_server_hr_employee_report_curriculum">
                    <field name="name">Generar informe configurable hoja de vida</field>
                    <field name="model_id" ref="model_hr_employee"/>
                    <field name="state">code</field>
                    <field name="code">
                        action = env['hr.employee'].browse(env.context['id']).open_hr_employee_report_curriculum()
                    </field>
                </record>

        <record id="action_hr_employee_report_curriculum" model="ir.actions.act_window">
                    <field name="name">Informe configurable hoja de vida</field>
                    <field name="res_model">hr.employee.report.curriculum</field>
                    <field name="view_mode">form</field>
                    <field name="target">new</field>
                </record>

        <record model="ir.actions.act_window" id="hr_employee_sanctions_action">
                    <field name="name">Sanciones empleados</field>
                    <field name="res_model">hr.employee.sanctions</field>
                    <field name="view_mode">list,form</field>
                </record>

        <record id="rule_hr_employee_sanctions_company" model="ir.rule">
                    <field name="name">Permisos compañia Sanciones empleados</field>
                    <field name="model_id" ref="model_hr_employee_sanctions"/>
                    <field name="domain_force">['|',('employee_id.company_id','=',False),('employee_id.company_id', 'in',company_ids)]
                    </field>
                </record>

        <record id="action_hr_employee_benefits_history" model="ir.actions.act_window">
                    <field name="name">Historico Prestaciones Sociales</field>
                    <field name="res_model">hr.employee.benefits.history</field>
                    <field name="view_mode">list,form,pivot,graph</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">
                            Historico de prestaciones sociales por empleado
                        </p>
                    </field>
                </record>

        <menuitem id="menu_hr_employee_benefits_history"
                          name="Historico Prestaciones"
                          parent="hr_payroll.menu_hr_payroll_payslips"
                          action="action_hr_employee_benefits_history"
                          sequence="25"/>

        <!-- ================================================================== -->
        <!-- DEPENDIENTES DEL EMPLEADO -->
        <!-- ================================================================== -->
        <record id="action_hr_employee_dependents" model="ir.actions.act_window">
            <field name="name">Dependientes del Empleado</field>
            <field name="res_model">hr.employee.dependents</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo dependiente
                </p>
                <p>
                    Gestione los dependientes de los empleados (hijos, cónyuge, padres, etc.)
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_employee_dependents"
                  name="Dependientes"
                  parent="lavish_hr_employee.menu_root"
                  action="action_hr_employee_dependents"
                  sequence="30"/>

        <!-- ================================================================== -->
        <!-- DOCUMENTOS DEL EMPLEADO -->
        <!-- ================================================================== -->
        <record id="action_hr_employee_documents" model="ir.actions.act_window">
            <field name="name">Documentos del Empleado</field>
            <field name="res_model">hr.employee.documents</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo documento
                </p>
                <p>
                    Gestione los documentos de los empleados (certificados, contratos, etc.)
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_employee_documents"
                  name="Documentos"
                  parent="lavish_hr_employee.menu_root"
                  action="action_hr_employee_documents"
                  sequence="40"/>

        <!-- ================================================================== -->
        <!-- SINDICATOS -->
        <!-- ================================================================== -->
        <record id="action_hr_employee_labor_union" model="ir.actions.act_window">
            <field name="name">Sindicatos de Empleados</field>
            <field name="res_model">hr.employee.labor.union</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear una afiliación sindical
                </p>
                <p>
                    Gestione las afiliaciones sindicales de los empleados.
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_employee_labor_union"
                  name="Sindicatos"
                  parent="lavish_hr_employee.menu_root"
                  action="action_hr_employee_labor_union"
                  sequence="50"/>

        <!-- ================================================================== -->
        <!-- BIRTHDAY LIST - Action and View (must be here to load before menus.xml) -->
        <!-- ================================================================== -->
        <record model="ir.actions.act_window" id="action_hr_employee_report_birthday">
            <field name="name">Listado de cumpleaños</field>
            <field name="res_model">hr.birthday.tree</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="hr_employee_report_birthday_form" model="ir.ui.view">
            <field name="name">Listado de cumpleaños</field>
            <field name="model">hr.birthday.tree</field>
            <field name="arch" type="xml">
                <form string="Listado de cumpleaños">
                    <group>
                        <group>
                            <field name="company" widget="many2many_tags"/>
                            <field name="month"/>
                        </group>
                        <group>
                            <field name="active_employee"/>
                            <field name="show_dependent"/>
                        </group>
                    </group>
                    <footer>
                        <button name="generate_report" string="Generar PDF" type="object" class="oe_highlight"/>
                        <button name="generate_birthday_excel" string="Generar EXCEL" type="object" class="oe_highlight"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
