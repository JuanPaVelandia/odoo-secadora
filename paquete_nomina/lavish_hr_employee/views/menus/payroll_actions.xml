<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PAYROLL ACTIONS AND MENUS -->

        <record id="lavish_menu_action_types_entities" model="ir.actions.act_window">
                    <field name="name">Tipos de entidades</field>
                    <field name="res_model">hr.contribution.register</field>
                    <field name="view_mode">list</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">Crear Tipo de entidad
                        </p>
                    </field>
                </record>

        <record id="lavish_menu_action_employee_entities" model="ir.actions.act_window">
                    <field name="name">Entidades</field>
                    <field name="res_model">hr.employee.entities</field>
                    <field name="view_mode">list,form</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">Crear Entidad
                        </p>
                    </field>
                </record>

        <record model="ir.actions.act_window" id="action_hr_salary_history_report">
                    <field name="name">Historico salarial</field>
                    <field name="res_model">hr.salary.history.report</field>
                    <field name="target">new</field>
                    <field name="view_mode">form</field>
                </record>

        <record id="action_hr_tipo_cotizante" model="ir.actions.act_window">
                    <field name="name">Tipos de Cotizante PILA</field>
                    <field name="res_model">hr.tipo.cotizante</field>
                    <field name="view_mode">list,form</field>
                    <field name="domain">[]</field>
                    <field name="context">{'search_default_active': 1}</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            Crear Tipo de Cotizante
                        </p>
                        <p>Los tipos de cotizante definen la categoria del trabajador segun la normativa PILA.</p>
                    </field>
                </record>

        <record id="action_hr_subtipo_cotizante" model="ir.actions.act_window">
                    <field name="name">SubTipos de Cotizante PILA</field>
                    <field name="res_model">hr.subtipo.cotizante</field>
                    <field name="view_mode">list,form</field>
                    <field name="domain">[]</field>
                    <field name="context">{'search_default_active': 1}</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            Crear SubTipo de Cotizante
                        </p>
                        <p>Los subtipos definen condiciones especiales del cotizante (pensionado, extranjero, etc.)</p>
                    </field>
                </record>

        <record id="action_hr_type_faults" model="ir.actions.act_window">
                    <field name="name">Tipos de faltas</field>
                    <field name="res_model">hr.types.faults</field>
                    <field name="view_mode">list</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">Crear Tipo de de falta
                        </p>
                    </field>
                </record>

        <record model="ir.actions.act_window" id="action_hr_parameterization_of_contributors">
                    <field name="name">Parametrización Cotizantes</field>
                    <field name="res_model">hr.parameterization.of.contributors</field>
                    <field name="view_mode">list,form</field>
                </record>

        <record id="lavish_menu_action_contract_risk" model="ir.actions.act_window">
                    <field name="name">Riesgos profesionales</field>
                    <field name="res_model">hr.contract.risk</field>
                    <field name="view_mode">list</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">Crear Riesgos Profesional
                        </p>
                    </field>
                </record>

        <record id="lavish_menu_action_lavish_economic_activity_level_risk" model="ir.actions.act_window">
                    <field name="name">Actividad económica por nivel de riesgo</field>
                    <field name="res_model">lavish.economic.activity.level.risk</field>
                    <field name="view_mode">list</field>
                </record>

        <record id="lavish_menu_action_annual_parameters" model="ir.actions.act_window">
                    <field name="name">Parámetros anuales</field>
                    <field name="res_model">hr.annual.parameters</field>
                    <field name="view_mode">list,form</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="oe_view_nocontent_create">Crear Parámetro anual
                        </p>
                    </field>
                </record>

        <record id="action_hr_company_working_hours" model="ir.actions.act_window">
                    <field name="name">Horas Laborales</field>
                    <field name="res_model">hr.company.working.hours</field>
                    <field name="view_mode">kanban,list,form</field>
                    <field name="context">{}</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            Crear un nuevo registro de horas laborales
                        </p>
                        <p>
                            Configure las horas laborales máximas según la Ley 2101 de 2021
                            que establece una reducción gradual de la jornada laboral en Colombia.
                        </p>
                    </field>
                </record>

        <menuitem id="menu_hr_company_working_hours" 
                        name="Horas Laborales" 
                        parent="hr.menu_human_resources_configuration" 
                        action="action_hr_company_working_hours" 
                        sequence="100" 
                        groups="hr.group_hr_manager"/>

        <record id="action_lavish_retirement_severance_pay" model="ir.actions.act_window">
                    <field name="name">Carta retiro de cesantías</field>
                    <field name="res_model">lavish.retirement.severance.pay</field>
                    <field name="view_mode">form</field>
                    <field name="target">new</field>
                </record>

        <record id="action_hr_indicador_especial_pila" model="ir.actions.act_window">
                    <field name="name">Indicadores Especiales PILA</field>
                    <field name="res_model">hr.indicador.especial.pila</field>
                    <field name="view_mode">list,form</field>
                    <field name="context">{'active_test': False}</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            Crear un indicador especial PILA
                        </p>
                        <p>
                            Configure las tarifas especiales de pension y salud segun el tipo de cotizante
                            (Alto Riesgo, Senadores, CTI, Aviadores, etc.)
                        </p>
                    </field>
                </record>

        <menuitem id="menu_hr_indicador_especial_pila"
                          name="Indicadores Especiales PILA"
                          parent="hr.menu_human_resources_configuration"
                          action="action_hr_indicador_especial_pila"
                          sequence="15"/>

        <!-- ================================================================== -->
        <!-- PRIORIDAD DE DEDUCCIONES -->
        <!-- ================================================================== -->
        <record id="view_hr_deduction_priority_tree" model="ir.ui.view">
            <field name="name">hr.deduction.priority.tree</field>
            <field name="model">hr.deduction.priority</field>
            <field name="arch" type="xml">
                <list string="Prioridad de Deducciones" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="salary_rule_id"/>
                    <field name="category_id" optional="show"/>
                    <field name="rule_code" optional="show"/>
                    <field name="is_mandatory" widget="boolean_toggle"/>
                    <field name="is_active" widget="boolean_toggle"/>
                    <field name="priority_type" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_hr_deduction_priority_form" model="ir.ui.view">
            <field name="name">hr.deduction.priority.form</field>
            <field name="model">hr.deduction.priority</field>
            <field name="arch" type="xml">
                <form string="Prioridad de Deducción">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="display_name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Configuración">
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="salary_rule_id"/>
                                <field name="category_id"/>
                                <field name="rule_code"/>
                            </group>
                            <group string="Opciones">
                                <field name="is_mandatory" widget="boolean_toggle"/>
                                <field name="is_active" widget="boolean_toggle"/>
                                <field name="priority_type" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <group string="Notas">
                            <field name="notes" nolabel="1" placeholder="Observaciones..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_deduction_priority_search" model="ir.ui.view">
            <field name="name">hr.deduction.priority.search</field>
            <field name="model">hr.deduction.priority</field>
            <field name="arch" type="xml">
                <search string="Buscar Prioridades">
                    <field name="name"/>
                    <field name="rule_code"/>
                    <field name="salary_rule_id"/>
                    <filter string="Obligatorias" name="mandatory" domain="[('is_mandatory', '=', True)]"/>
                    <filter string="Activas" name="active" domain="[('is_active', '=', True)]"/>
                    <separator/>
                        <filter string="Tipo" name="group_type" context="{'group_by': 'priority_type'}"/>
                        <filter string="Obligatoria" name="group_mandatory" context="{'group_by': 'is_mandatory'}"/>
                </search>
            </field>
        </record>

        <record id="hr_deduction_priority_action" model="ir.actions.act_window">
            <field name="name">Prioridad de Deducciones</field>
            <field name="res_model">hr.deduction.priority</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_deduction_priority_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configurar prioridad de deducciones
                </p>
                <p>
                    Defina el orden en que se aplican las deducciones cuando
                    se alcanza el límite del 50% de devengos (Art. 149 CST).
                </p>
                <p>
                    Las deducciones obligatorias (Seguridad Social, Retención)
                    siempre se descuentan primero.
                </p>
            </field>
        </record>

    </data>
</odoo>
