<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- CERTIFICATES ACTIONS AND MENUS -->

        <record id="ir_seq_hr_labor_certificate_history" model="ir.sequence">
                    <field name="name">Certificados Laborales Generados</field>
                    <field name="code">hr.labor.certificate.history.seq</field>
                    <field name="prefix">CLG/</field>
                    <field name="padding">6</field>
                    <field name="number_increment">1</field>
                    <field name="use_date_range">True</field>
                    <field name="number_next_actual">1</field>
                    <field name="implementation">standard</field>
                </record>

        <record id="action_hr_labor_certificate_history" model="ir.actions.act_window">
                    <field name="name">Historial de Certificados Laborales</field>
                    <field name="res_model">hr.labor.certificate.history</field>
                    <field name="view_mode">list,form</field>
                    <field name="context">{
                        'search_default_filter_generated': 1,
                    }</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            No hay certificados laborales generados
                        </p>
                        <p>
                            Puede generar certificados laborales desde los contratos de los empleados
                            o usando el asistente de generación masiva.
                        </p>
                    </field>
                </record>

        <record id="action_generate_labor_certificate_from_contract" model="ir.actions.server">
                    <field name="name">Generar Certificado Laboral</field>
                    <field name="model_id" ref="hr_contract.model_hr_contract"/>
                    <field name="binding_model_id" ref="hr_contract.model_hr_contract"/>
                    <field name="binding_view_types">form,list</field>
                    <field name="state">code</field>
                    <field name="code">
        if records:
            action = {
                'type': 'ir.actions.act_window',
                'name': 'Generar Certificado Laboral',
                'res_model': 'hr.labor.certificate.wizard',
                'view_mode': 'form',
                'target': 'new',
                'context': {
                    'default_selection_mode': 'manual',
                    'default_contract_ids': [(6, 0, records.ids)],
                    'default_company_id': records[0].company_id.id,
                },
            }
                    </field>
                </record>

        <record id="action_labor_certificate_template" model="ir.actions.act_window">
                    <field name="name">Configuración plantilla certificado laboral</field>
                    <field name="res_model">hr.labor.certificate.template</field>
                    <field name="view_mode">list,form</field>
                    <field name="domain">[]</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            Crear Configuración de plantilla de certificado laboral
                        </p>
                        <p>Configure aquí la plantilla para generar certificados laborales de sus empleados.</p>
                    </field>
                </record>

        <!-- Action for Labor Certificate Wizard (moved here to load before menus.xml) -->
        <record id="action_hr_labor_certificate_wizard" model="ir.actions.act_window">
            <field name="name">Generar Certificados Laborales</field>
            <field name="res_model">hr.labor.certificate.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{
                'default_selection_mode': 'all',
            }</field>
        </record>

        <!-- ================================================================== -->
        <!-- CERTIFICADOS DE INGRESOS Y RETENCIONES -->
        <!-- ================================================================== -->
        <record id="action_hr_certificate_income_header" model="ir.actions.act_window">
            <field name="name">Certificados de Ingresos y Retenciones</field>
            <field name="res_model">hr.certificate.income.header</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo certificado de ingresos
                </p>
                <p>
                    Configure aquí los certificados de ingresos y retenciones para la generación de reportes tributarios.
                </p>
            </field>
        </record>

        <!-- Parent menu for Certificate Income -->
        <menuitem id="menu_hr_certificate_income_root"
                  name="Certificados de Ingresos"
                  parent="hr_payroll.menu_hr_payroll_employees"
                  sequence="43"/>

        <menuitem id="menu_hr_certificate_income_header"
                  name="Configuración Certificados"
                  parent="menu_hr_certificate_income_root"
                  action="action_hr_certificate_income_header"
                  sequence="10"/>

        <!-- ================================================================== -->
        <!-- CONFIGURACIÓN DE LÍNEAS DE CERTIFICADO -->
        <!-- ================================================================== -->
        <record id="action_hr_conf_certificate_income" model="ir.actions.act_window">
            <field name="name">Líneas de Certificado de Ingresos</field>
            <field name="res_model">hr.conf.certificate.income</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear una línea de certificado
                </p>
                <p>
                    Configure las líneas que componen el certificado de ingresos y retenciones.
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_conf_certificate_income"
                  name="Líneas de Certificado"
                  parent="menu_hr_certificate_income_root"
                  action="action_hr_conf_certificate_income"
                  sequence="20"/>

    </data>
</odoo>
