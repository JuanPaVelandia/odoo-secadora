<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- MEDICAL ACTIONS AND MENUS -->

        <!-- Menu raíz Medical/SST -->
        <menuitem id="menu_hr_medical_root"
                  name="Medicina y SST"
                  parent="hr_payroll.menu_hr_payroll_employees"
                  sequence="70"/>

        <record id="action_hr_medical_certificate_expiring" model="ir.actions.act_window">
                <field name="name">Certificados por Vencer</field>
                <field name="res_model">hr.medical.certificate</field>
                <field name="view_mode">list,form</field>
                <field name="domain">[('expiry_status', 'in', ['warning', 'critical'])]</field>
                <field name="context">{'search_default_group_by_employee': 1}</field>
                <field name="help" type="html">
                    <p class="o_view_nocontent_empty_folder">
                        No hay certificados próximos a vencer
                    </p>
                    <p>
                        Aquí aparecerán los certificados que estén por vencer en los próximos 30 días.
                    </p>
                </field>
            </record>

        <record id="action_hr_medical_certificate_expired" model="ir.actions.act_window">
                <field name="name">Certificados Vencidos</field>
                <field name="res_model">hr.medical.certificate</field>
                <field name="view_mode">list,form</field>
                <field name="domain">[('expiry_status', '=', 'expired')]</field>
                <field name="context">{'search_default_group_by_employee': 1}</field>
                <field name="help" type="html">
                    <p class="o_view_nocontent_empty_folder">
                        No hay certificados vencidos
                    </p>
                    <p>
                        Los certificados vencidos requieren renovación inmediata.
                    </p>
                </field>
            </record>

        <menuitem id="menu_hr_medical_certificate_expiring"
                      name="Por Vencer"
                      parent="lavish_hr_employee.menu_hr_medical_root"
                      action="action_hr_medical_certificate_expiring"
                      sequence="15"/>

        <menuitem id="menu_hr_medical_certificate_expired"
                      name="Vencidos"
                      parent="lavish_hr_employee.menu_hr_medical_root"
                      action="action_hr_medical_certificate_expired"
                      sequence="16"/>

        <!-- HR MEDICAL CERTIFICATE TYPE ACTION -->
        <record id="action_hr_medical_certificate_type" model="ir.actions.act_window">
                <field name="name">Tipos de Certificado Médico</field>
                <field name="res_model">hr.medical.certificate.type</field>
                <field name="view_mode">list,form</field>
                <field name="context">{'search_default_filter_categories': 1}</field>
                <field name="help" type="html">
                    <p class="o_view_nocontent_smiling_face">
                        No hay tipos de certificado configurados
                    </p>
                    <p>
                        Define los tipos de certificados médicos (Aptitud, Alturas, Periódico, etc.)
                    </p>
                </field>
            </record>

        <menuitem id="menu_hr_medical_certificate_type"
                      name="Tipos de Certificado"
                      parent="lavish_hr_employee.menu_hr_sst_config"
                      action="action_hr_medical_certificate_type"
                      sequence="50"
                      groups="hr.group_hr_manager"/>

        <!-- Cron para actualizar estados de certificados médicos -->
        <record id="cron_update_medical_certificate_states" model="ir.cron">
                <field name="name">Actualizar Estados de Certificados Médicos</field>
                <field name="model_id" ref="lavish_hr_employee.model_hr_medical_certificate"/>
                <field name="state">code</field>
                <field name="code">model.cron_update_certificate_states()</field>
                <field name="interval_number">1</field>
                <field name="interval_type">days</field>
                <field name="active" eval="True"/>
            </record>

    </data>
</odoo>
