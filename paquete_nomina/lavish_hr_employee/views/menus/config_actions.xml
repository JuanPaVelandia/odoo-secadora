<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- CONFIG ACTIONS AND MENUS -->

        <record id="action_hr_salary_rule_accounting" model="ir.actions.act_window">
                    <field name="name">Configuraciones Contables</field>
                    <field name="res_model">hr.salary.rule.accounting</field>
                    <field name="view_mode">list,form</field>
                    <field name="help" type="html">
                        <p class="o_view_nocontent_smiling_face">
                            ¡Cree su primera configuración contable!
                        </p>
                        <p>
                            Las configuraciones contables definen qué cuentas débito y crédito 
                            usar para cada regla salarial en la contabilización de nómina.
                        </p>
                        <p>
                            El sistema usa prioridades para determinar qué configuración aplicar
                            según el empleado, puesto, departamento o compañía.
                        </p>
                    </field>
                </record>

    </data>
</odoo>
