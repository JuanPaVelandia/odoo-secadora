<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.actions.act_window" id="action_hr_salary_history_report">
            <field name="name">Historico salarial</field>
            <field name="res_model">hr.salary.history.report</field>
            <field name="target">new</field>
            <field name="view_mode">form</field>
        </record>

        <record id="hr_salary_history_report_form" model="ir.ui.view">
            <field name="name">hr.salary.history.report.form</field>
            <field name="model">hr.salary.history.report</field>
            <field name="arch" type="xml">
                <form string="Historico salarial">
                    <sheet>
                        <group string="Filtros">
                            <group>
                                <field name="date_start"/>
                            </group>
                            <group>
                                <field name="date_end"/>
                            </group>
                        </group>
                        <group>
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="contract_active"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="generate_excel" string="Generar Excel" type="object" class="oe_highlight"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>