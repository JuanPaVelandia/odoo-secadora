<odoo>
    <data>

        <record id="ir_seq_hr_contract" model="ir.sequence">
            <field name="name">RRHH Contratos Empleados</field>
            <field name="code">hr.contract.seq</field>
            <field name="prefix">CTO/</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="number_next_actual">1</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Formulario de contratos - ajustes -->
        <record id="view_lavish_hr_employee_form_contract" model="ir.ui.view">
            <field name="name">hr.contract.lavish.hr.employee.form.inherit</field>
            <field name="model">hr.contract</field>
            <field name="priority">20</field>
            <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/header[1]/field[@name='state']" position="before">
                    <button string="Activar" name="action_state_open" invisible="state != 'draft'" type="object"/>
                    <button string="Finalizar por liquidar" name="action_state_finished" type="object" invisible="state != 'open'"/>
                    <button string="Cancelar" name="action_state_cancel" type="object"/>
                    <button string="Certificado Laboral" name="generate_labor_certificate" type="object"/>
                    <button name="generate_report_severance" type="object" string="Carta retiro de cesantías"/>
                </xpath>
                <xpath expr="//group[@name='top_info_left']" position="attributes">
                    
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//group[@name='top_info_right']" position="attributes">
                    
                    <attribute name="invisible">1</attribute>
                </xpath>
                <field name="name" position="after">
                    <br/>
                    <field name="sequence" force_save="1" readonly="1"/></field>
                <xpath expr="//form[1]/header[1]/field[@name='state']" position="attributes">
                    
                    <attribute name="options">{}</attribute>
                    <attribute name="force_save">True</attribute>
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='active']" position="before">
                    <field name="view_inherit_employee" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='department_id']" position="after"/>
                <xpath expr="//field[@name='job_id']" position="attributes">
                    <attribute name="readonly">True</attribute>
                    <attribute name="force_save">True</attribute>
                </xpath>
                <xpath expr="//group" position="after">
                    <group>
                        <group string="Datos de contrato" col="2" class="text-start" style="border:1px solid black; padding:5px; border-radius:10px">
                            <field name="employee_id" widget="many2one_avatar_employee" options="{'relation': 'hr.employee.public'}"/>
                            <field name="department_id" groups="!hr_contract.group_hr_contract_manager" options="{'no_open': True, 'no_create': True}"/>
                            <field name="department_id" groups="hr_contract.group_hr_contract_manager"/>
                            <field name="job_id" groups="!hr_contract.group_hr_contract_manager" options="{'no_open': True, 'no_create': True}"/>
                            <field name="job_id" groups="hr_contract.group_hr_contract_manager"/>
                            <field name="date_start" string="Fecha Inicio de contracto"/>
                            <field name="contract_category" invisible="1"/>
                            <field name="date_end" string="Fecha Fin de contracto" required="contract_category not in ['indefinido', 'obra', 'agropecuario', False]"/>
                            <field name="trial_date_start"/>
                            <field name="trial_date_end"/>
                            <field name="retirement_date" readonly="1" force_save="1"/>
                            <field name="company_country_id" invisible="1"/>
                            <field name="country_code" invisible="1"/>
                            <field name="contract_type_icon_html" widget="html"/>
                            <field name="contract_type_id" options="{'no_create': True}"
                                   domain="[('country_id', '=', company_country_id)]"
                                   help="Tipo de contrato segun Ley 2466/2025. Determina prestaciones sociales, indemnizacion y derechos laborales."/>
                            <field name="subcontract_type" help="Subtipo aplicable para contratos por obra o labor."/>
                            <field name="employee_type" invisible="1"/>
                            <field name="modality_salary" widget="selection_badge"/>
                            <field name="modality_aux"/>
                            <field name="only_wage"/>
                            <field name="dev_aux"/>
                            <field name="method_schedule_pay" widget="radio"/>
                            <field name="risk_id"/>
                            <field name="economic_activity_level_risk_id" domain="[('risk_class_id','=',risk_id)]"/>
                        </group>
                        <group string="Configuracion del Empleado" col="2" class="text-start" style="border:1px solid black; padding:5px; border-radius:10px">
                            <field name="ley_2101" class="fa fa-arrow-down red" widget="boolean_toggle"/>
                            <field name="not_pay_auxtransportation" class="fa fa-forward red" widget="boolean_toggle"/>
                            <field name="remote_work_allowance" class="fa fa-home red" widget="boolean_toggle"/>
                            <field name="minimum_wage" class="fa fa-minus red" widget="boolean_toggle"/>
                            <field name="not_validate_top_auxtransportation" class="fa fa-check red" widget="boolean_toggle"/>
                            <field name="not_pay_overtime" class="fa fa-hourglass  red" widget="boolean_toggle"/>
                            <field name="pay_auxtransportation" widget="boolean_toggle"/>
                            <field name="full_auxtransportation_settlement" widget="boolean_toggle"/>
                            <field name="proyectar_fondos" widget="boolean_toggle"/>
                            <field name="proyectar_ret" widget="boolean_toggle"/>
                            <field name="parcial" class="fa fa-clock-o" widget="boolean_toggle"/>
                            <field name="factor" invisible="not parcial"/>
                            <field name="use_manual_days" class="fa fa-calendar-check-o" widget="boolean_toggle" invisible="not parcial and not subcontract_type"/>
                            <field name="manual_days" invisible="not use_manual_days"/>
                        </group>
                        <group string="Aprendizaje / SENA" col="2" class="text-start" style="border:1px solid black; padding:5px; border-radius:10px"
                               invisible="contract_category != 'aprendizaje'">
                            <field name="code_sena" help="Codigo del programa de formacion SENA"/>
                            <field name="apr_prod_date" help="Fecha en que el aprendiz pasa de etapa lectiva a productiva. Afecta el calculo de la cuota de sostenimiento."/>
                            <field name="apprentice_stage" widget="selection_badge" help="Etapa actual: Lectiva (75% SMMLV) o Productiva (100% SMMLV) segun Ley 2466/2025"/>
                            <field name="apprentice_wage" readonly="1" widget="monetary" help="Cuota de sostenimiento calculada automaticamente segun la etapa y el SMMLV vigente"/>
                        </group>
                        <group string="Tipo Cotizante PILA" col="2" class="text-start" style="border:1px solid black; padding:5px; border-radius:10px">
                            <field name="tipo_cotizante_id" options="{'no_create': True}" help="Tipo de cotizante para la Planilla Integrada de Liquidacion de Aportes (PILA). Se configura automaticamente segun el tipo de contrato."/>
                            <field name="tipo_cotizante_code" invisible="1"/>
                            <field name="partial_hours_weekly" invisible="not parcial and tipo_cotizante_code != '51'" help="Horas semanales para tiempo parcial. Jornada completa = 48 horas. Minimo para tipo 51 = 24 horas."/>
                            <field name="partial_wage_computed" readonly="1" widget="monetary" invisible="not parcial and tipo_cotizante_code != '51'" help="Salario proporcional calculado segun las horas semanales trabajadas."/>
                        </group>
                        <group decoration-it="1" string="Ultimos Saldo de Provisiones, Usar para casos de una primera implementación en odoo o Cambio de metodo de provision " class="text-start" style="border:1px solid black; padding:5px; border-radius:10px">
                            <field name="date_prima"/>
                            <field name="u_prima"/>
                            <field name="date_cesantias"/>
                            <field name="u_cesantias"/>
                            <field name="date_vacaciones"/>
                            <field name="u_vacaciones"/>
                        </group>
                    </group>
                    <group string="Otros Datos">
                        <field name="company_country_id" invisible="1"/>
                        <field name="country_code" invisible="1"/>
                        <field name="hr_responsible_id"/>
                        <field name="structure_type_id" groups="!hr_contract.group_hr_contract_manager" domain="['|', ('country_id', '=', False), ('country_id', '=', company_country_id)]" options="{'no_open': True, 'no_create': True}"/>
                        <field name="structure_type_id" groups="hr_contract.group_hr_contract_manager" domain="['|', ('country_id', '=', False), ('country_id', '=', company_country_id)]"/>
                        <field name="calendar_mismatch" invisible="1"/>
                        <label for="resource_calendar_id"/>
                        <div id="resource_calendar_warning" class="d-flex align-items-center">
                                <field name="resource_calendar_id" groups="!hr_contract.group_hr_contract_manager" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="resource_calendar_id" groups="hr_contract.group_hr_contract_manager" required="1"/>
                                <widget name="contract_warning_tooltip" invisible="not calendar_mismatch or state != 'open'"/>
                        </div>
                        <div class="alert alert-info mt-2" role="alert">
                            <p><i class="fa fa-info-circle" title="Informacion"/> <strong>Generar Calendario Automático:</strong></p>
                            <p class="mb-0">
                                <small>
                                    Puede generar un calendario de trabajo automáticamente desde:<br/>
                                    <strong>Recursos Humanos → Configuración → Horas Laborales</strong><br/>
                                    Configure el horario semanal (con almuerzo y días laborales) y use el botón <strong>"Generar Calendario de Trabajo"</strong>
                                </small>
                            </p>
                        </div>
                    </group>
                </xpath>
                <xpath expr="//field[@name='job_id']" position="after"/>
                <xpath expr="//field[@name='date_end']" position="after">
                    <field name="retirement_date" readonly="1" force_save="1"/>
                </xpath>
                <xpath expr="//page[@name='information']//group[@name='salary']//field[@name='wage']" position="attributes">
                    <attribute name="readonly">True</attribute>
                    <attribute name="force_save">True</attribute>
                </xpath>
                <!-- Historial Salarial - dentro del page Salary Information -->
                <xpath expr="//page[@name='information']//group[@name='salary_info']" position="before">
                    <group string="Historial de Cambios Salariales" class="mb-3">
                        <field name="change_wage_ids" nolabel="1" colspan="2"
                               context="{'default_contract_id': id, 'default_wage_old': wage, 'default_job_id': job_id, 'default_department_id': department_id, 'default_tipo_cotizante_id': tipo_cotizante_id}">
                            <list string="Cambios Salariales" editable="bottom"
                                  decoration-success="reason in ['promotion', 'performance']"
                                  decoration-info="reason in ['annual_update', 'adjustment']"
                                  decoration-warning="reason in ['legal', 'collective']"
                                  decoration-muted="reason == 'start'"
                                  decoration-danger="difference &lt; 0">
                                <field name="date_start" string="Fecha"/>
                                <field name="wage_old" string="Anterior" readonly="1"/>
                                <field name="wage" string="Nuevo"/>
                                <field name="difference" string="Dif." readonly="1"/>
                                <field name="difference_percentage" string="% Var." readonly="1"/>
                                <field name="reason" string="Motivo"/>
                                <field name="job_id" string="Cargo" optional="show"/>
                                <field name="department_id" string="Depto." optional="show"/>
                                <field name="tipo_cotizante_id" string="Tipo PILA" optional="show"/>
                                <field name="state" string="Estado" widget="badge"
                                       decoration-info="state == 'draft'"
                                       decoration-success="state == 'approved'"/>
                                <field name="tipo_coti_id" string="Tipo Emp." optional="hide"/>
                                <field name="subtipo_coti_id" string="Subtipo" optional="hide"/>
                                <field name="origin_type" string="Origen" optional="hide"/>
                                <button name="action_approve" type="object" string="Aprobar"
                                        icon="fa-check" class="btn-link text-success"
                                        invisible="state != 'draft'"/>
                            </list>
                        </field>
                    </group>
                </xpath>

                <!-- Campos adicionales despues del salario -->
                <xpath expr="//page[@name='information']//group[@name='salary']" position="after">
                    <group string="Datos Salariales Adicionales" col="4">
                        <field name="date_last_wage" readonly="1" string="Fecha Ultimo Cambio"/>
                        <field name="wage_old" string="Salario Anterior" readonly="1"/>
                        <field name="fecha_ibc" string="Fecha IBC"/>
                        <field name="u_ibc" string="Valor IBC"/>
                    </group>
                </xpath>

                <!-- Hacer wage readonly -->

                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                    <page string="Devengos y Deducciones" name="dev_and_ded">
                        <div class="o_hr_skills_group d-flex flex-column">
                            <separator string="Conceptos por Tipo"/>
                        </div>
                        <field name="concepts_ids" nolabel="1" colspan="2" groups="hr.group_hr_user" context="{'default_employee_type': employee_type, 'default_contract_id': id}">
                            <list string="Deducciones o Devengos" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-warning="state == 'closed'" decoration-danger="state == 'cancel'">
                                <field name="employee_type" column_invisible="1"/>
                                <field name="contract_id" column_invisible="1"/>
                                <field name="input_id" required="1"/>
                                <field name="type_deduction" required="1"/>
                                <field name="type_emb" invisible="type_deduction != 'E'" required="type_deduction == 'E'"/>
                                <field name="amount_select"/>
                                <field name="amount" required="1"/>
                                <field name="modality_value" required="1"/>
                                <field name="period"/>
                                <field name="aplicar"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="partner_id" optional="show"/>
                                <field name="next_payment_date" optional="show"/>
                                <field name="balance" optional="show" sum="Total Pendiente"/>
                                <field name="state" widget="badge"/>
                                <button name="action_approve" type="object" string="Aprobar" icon="fa-check" invisible="state != 'draft'"/>
                                <button name="action_close" type="object" string="Cerrar" icon="fa-lock" invisible="state != 'done'"/>
                                <button name="action_cancel" type="object" string="Cancelar" icon="fa-times" invisible="state != 'done'"/>
                                <button name="view_simulation" type="object" string="Simular" icon="fa-calculator" invisible="state == 'draft'"/>
                                <button name="action_create_skip" type="object" string="Crear Salto" icon="fa-calendar-minus-o" invisible="state != 'done'"/>
                            </list>
                        </field>
                    </page>
                    <page string="Tributaria" name="tributaria">
                        <group>
                            <field name="retention_procedure" widget="radio"/>
                            <field name="fixed_value_retention_procedure" invisible="retention_procedure != 'fixed'"/>
                        </group>
                        <field name="deductions_rtf_ids" nolabel="1">
                            <list string="Deducciones Retencion en la Fuente" editable="bottom"
                                  decoration-danger="porcentaje_usado > 100"
                                  decoration-warning="porcentaje_usado > 80 and porcentaje_usado &lt;= 100"
                                  decoration-success="porcentaje_usado &lt;= 80">
                                <field name="input_id" help="Regla salarial de tipo tributaria que representa la deduccion. Ej: Intereses vivienda, Medicina prepagada, Dependientes"/>
                                <field name="date_start" help="Fecha desde la cual aplica el certificado o deduccion"/>
                                <field name="date_end" help="Fecha hasta la cual aplica el certificado o deduccion"/>
                                <field name="number_months" optional="hide" help="Numero de meses del certificado para calcular el valor mensualizado"/>
                                <field name="value_total" sum="Total Certificado" help="Valor total del certificado anual emitido por la entidad"/>
                                <field name="value_monthly" sum="Total Mensual" help="Valor mensualizado = Total / Meses. Este valor se aplica en cada nomina"/>
                                <field name="base_legal" optional="show" readonly="1" help="Articulo del Estatuto Tributario que establece el limite"/>
                                <field name="limite_pesos_mensual" optional="show" string="Limite $/Mes" readonly="1" help="Limite maximo mensual en pesos segun UVT vigente"/>
                                <field name="valor_acumulado_anio" optional="show" string="Acumulado Anio" readonly="1" help="Suma de deducciones aplicadas en nominas del anio fiscal actual"/>
                                <field name="porcentaje_usado" widget="progressbar" optional="show" help="Porcentaje del limite anual utilizado. Mayor a 80% muestra advertencia, mayor a 100% en rojo"/>
                                <field name="payslip_count" optional="show" string="Aplicaciones" readonly="1" help="Numero de nominas donde se ha aplicado esta deduccion"/>
                                <field name="last_payslip_date" optional="show" string="Ultima Nomina" readonly="1" help="Fecha de la ultima nomina donde se aplico esta deduccion"/>
                                <button name="action_view_payslip_lines" type="object" string="Ver Lineas" icon="fa-list-alt" help="Ver detalle de lineas de nomina donde se ha aplicado"/>
                            </list>
                        </field>
                    </page>
                    <page string="Modificaciones contractuales" name="modificaciones_contractuales">
                        <div class="d-flex gap-2 mb-3">
                            <button name="extend_contract" type="object" string="Prorrogar Contrato"
                                    class="btn btn-primary" icon="fa-expand"/>
                            <button name="%(lavish_hr_employee.action_hr_contractual_modifications)d"
                                    type="action" string="Ver Todas"
                                    class="btn btn-secondary" icon="fa-list"
                                    context="{'search_default_contract_id': id}"/>
                        </div>
                        <group>
                            <field name="contract_modification_history" nolabel="1" colspan="2"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- DEVENGOS & DEDUCCIONES VIEWS -->
        <record id="lavish_menu_action_contract_concepts" model="ir.actions.act_window">
            <field name="name">Devengos y Deducciones por Contrato</field>
            <field name="res_model">hr.contract.concepts</field>
            <field name="view_mode">list,form,search</field>
            <field name="context">{'search_default_active_concepts': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo concepto de nómina
                </p>
                <p>
                    Gestione los devengos y deducciones asociados a los contratos.
                </p>
            </field>
        </record>

        <!-- Vista Lista -->
        <record id="tree_contract_concepts" model="ir.ui.view">
            <field name="name">lavish.list.contract.concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <list string="Deducciones o Devengos" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-warning="state == 'closed'" decoration-danger="state == 'cancel'">
                    <field name="employee_id"/>
                    <field name="input_id"/>
                    <field name="type_deduction"/>
                    <field name="amount_select"/>
                    <field name="amount"/>
                    <field name="modality_value"/>
                    <field name="period"/>
                    <field name="aplicar"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="partner_id" optional="hide"/>
                    <field name="next_payment_date" optional="show"/>
                    <field name="balance" optional="show" sum="Total Pendiente"/>
                    <field name="accumulated_amount" optional="show" sum="Total Acumulado"/>
                    <field name="type_emb" column_invisible="1"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-warning="state == 'closed'" decoration-danger="state == 'cancel'"/>
                    <button name="action_approve" type="object" string="Aprobar" icon="fa-check" invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Cerrar" icon="fa-lock" invisible="state != 'done'"/>
                    <button name="action_cancel" type="object" string="Cancelar" icon="fa-times" invisible="state != 'done'"/>
                    <button name="view_simulation" type="object" string="Simular" icon="fa-calculator" invisible="state == 'draft'"/>
                    <button name="action_create_skip" type="object" string="Crear Salto" icon="fa-calendar-minus-o" invisible="state != 'done'"/>
                </list>
            </field>
        </record>

        <!-- Vista Formulario -->
        <record model="ir.ui.view" id="lavish_hr_employee.form_contract_concepts">
            <field name="name">lavish.form.contract.concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_approve" type="object" string="Aprobar" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_close" type="object" string="Cerrar" class="btn-warning" invisible="state != 'done'"/>
                        <button name="action_cancel" type="object" string="Cancelar" class="btn-danger" invisible="state != 'done'"/>
                        <button name="action_draft" type="object" string="Borrador" invisible="state == 'draft'"/>
                        <button name="action_force_double_payment" type="object" string="Pago Doble" class="btn-warning" invisible="state != 'done' or force_double_payment"/>
                        <button name="view_simulation" type="object" string="Simular" class="btn-info" invisible="state == 'draft'"/>
                        <button name="view_skips" type="object" string="Saltos" class="btn-secondary"/>
                        <button name="view_payslip_lines" type="object" string="Líneas" class="btn-secondary" invisible="accumulated_amount == 0"/>
                        <button name="action_create_skip" type="object" string="Crear Salto" class="btn-secondary" invisible="state != 'done'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done,closed,cancel"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button" options="{&quot;terminology&quot;: &quot;archive&quot;}"/>
                            </button>
                        </div>
                        
                        <widget name="web_ribbon" title="Cerrado" bg_color="bg-warning" invisible="state != 'closed'"/>
                        <widget name="web_ribbon" title="Cancelado" bg_color="bg-danger" invisible="state != 'cancel'"/>
                        
                        <div class="oe_title">
                            <h1>
                                <field name="display_name" readonly="1" class="text-break"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <label for="contract_id" string="Contrato"/>
                                <div class="o_row">
                                    <field name="contract_id" class="oe_inline" options="{'no_create': True}"/>
                                    <field name="employee_id" readonly="1" class="oe_inline"/>
                                </div>
                                <field name="employee_type" invisible="1"/>
                                <field name="sequence"/>
                                <label for="input_id" string="Regla Salarial"/>
                                <div class="o_row">
                                    <field name="input_id" domain="[('novedad_ded','=','cont')]" class="oe_inline"/>
                                    <field name="description" placeholder="Descripción..." class="oe_inline"/>
                                </div>
                                <field name="payroll_account_id" placeholder="Cuenta Contable..." options="{'no_create': True}"/>
                                <field name="show_voucher"/>
                            </group>
                            <group>
                                <label for="amount_select" string="Configuración de Valor"/>
                                <div class="o_row">
                                    <field name="amount_select" class="oe_inline"/>
                                    <field name="amount" class="oe_inline"/>
                                </div>
                                <field name="minimum_amount" invisible="amount_select != 'percentage'"/>
                                <field name="maximum_amount" invisible="amount_select != 'percentage'"/>
                                <field name="modality_value"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Configuración Principal">
                                <group>
                                    <group>
                                        <field name="type_deduction"/>
                                        <field name="period"/>
                                        <field name="aplicar"/>
                                        <field name="monthly_behavior"/>
                                        <field name="date_start"/>
                                        <field name="date_end"/>
                                        <field name="next_payment_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="simulation_text" nolabel="1" readonly="1" colspan="2" />
                                    </group>
                                </group>
                            </page>

                            <page string="Configuración Avanzada">
                                <group>
                                    <group string="Configuración de Días">
                                        <field name="descontar_dia_31"/>
                                        <field name="excluir_sabados"/>
                                        <field name="excluir_domingos"/>
                                        <field name="excluir_festivos"/>
                                    </group>
                                    <group string="Control de Estructuras">
                                        <field name="base_structure_only"/>
                                        <field name="payroll_structure_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    </group>
                                </group>
                            </page>
                            
                            <page string="Datos Adicionales" name="additional_data">
                                <group>
                                    <group string="Datos de Embargo" invisible="type_deduction != 'E'">
                                        <field name="type_emb"/>
                                        <field name="embargo_judged"/>
                                        <field name="embargo_process"/>
                                    </group>
                                    <group string="Información Adicional">
                                        <field name="partner_id" options="{'no_create': True}"/>
                                        <field name="attached" filename="attached_name" widget="binary"/>
                                        <field name="attached_name" invisible="1"/>
                                    </group>
                                </group>
                                
                                <group string="Notas y Observaciones">
                                    <field name="detail" nolabel="1" placeholder="Ingrese notas o comentarios adicionales..."/>
                                </group>
                            </page>
                            
                            <page string="Estadísticas y Control">
                                <group col="4">
                                    <group string="Totales" colspan="2">
                                        <field name="accumulated_amount" readonly="1"/>
                                        <field name="balance" readonly="1"/>
                                        <field name="total_paid" readonly="1"/>
                                        <field name="remaining_installments" readonly="1"/>
                                    </group>

                                    <group string="Control de Pagos" colspan="2">
                                        <label for="force_double_payment" string="Pago Doble"/>
                                        <div class="o_row">
                                            <field name="force_double_payment" class="oe_inline"/>
                                            <field name="double_payment_date" class="oe_inline" invisible="not force_double_payment" required="force_double_payment"/>
                                        </div>
                                        <field name="last_double_payment" readonly="1"/>
                                    </group>
                                </group>

                                <group string="Historial de Nóminas" invisible="not payslip_ids">
                                    <field name="payslip_ids" nolabel="1" readonly="1">
                                        <list>
                                            <field name="name"/>
                                            <field name="date_from"/>
                                            <field name="date_to"/>
                                            <field name="state"/>
                                            <field name="struct_id"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Vista Búsqueda -->
        <record id="search_contract_concepts" model="ir.ui.view">
            <field name="name">lavish.search.contract.concepts</field>
            <field name="model">hr.contract.concepts</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="contract_id"/>
                    <field name="employee_id"/>
                    <field name="input_id"/>
                    <field name="type_deduction"/>
                    <field name="partner_id"/>
                    <separator/>
                    <filter string="Conceptos Activos" name="active_concepts" 
                            domain="[('state', '=', 'done'), ('active', '=', True)]"/>
                    <filter string="Borradores" name="draft_concepts" 
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Cancelados" name="cancelled_concepts" 
                            domain="[('state', '=', 'cancel')]"/>
                    <filter string="Archivados" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter string="Primera Quincena" name="first_fortnight" 
                            domain="[('aplicar', '=', '15')]"/>
                    <filter string="Segunda Quincena" name="second_fortnight" 
                            domain="[('aplicar', '=', '30')]"/>
                    <separator/>
                    <filter string="Pago Doble Programado" name="double_payment" 
                            domain="[('force_double_payment', '=', True)]"/>
                    <group name="group_by">
                        <filter string="Empleado" name="employee" context="{'group_by': 'employee_id'}"/>
                        <filter string="Contrato" name="contract" context="{'group_by': 'contract_id'}"/>
                        <filter string="Tipo de Deducción" name="type_deduction" context="{'group_by': 'type_deduction'}"/>
                        <filter string="Estado" name="state" context="{'group_by': 'state'}"/>
                        <filter string="Período de Aplicación" name="aplicar" context="{'group_by': 'aplicar'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="form_contract_concept_skip" model="ir.ui.view">
            <field name="name">lavish.form.contract.concept.skip</field>
            <field name="model">hr.contract.concept.skip</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_approve" type="object" string="Aprobar" class="btn-primary" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <field name="concept_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="period_skip" readonly="state != 'draft'"/>
                            <field name="period_double"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="tree_contract_concept_skip" model="ir.ui.view">
            <field name="name">lavish.list.contract.concept.skip</field>
            <field name="model">hr.contract.concept.skip</field>
            <field name="arch" type="xml">
                <list string="Saltos de Conceptos" decoration-info="state == 'draft'" decoration-success="state == 'approved'">
                    <field name="name"/>
                    <field name="concept_id"/>
                    <field name="period_skip"/>
                    <field name="period_double"/>
                    <field name="state" widget="badge"/>
                    <button name="action_approve" type="object" string="Aprobar" icon="fa-check" invisible="state != 'draft'"/>
                </list>
            </field>
        </record>

        <record id="search_contract_concept_skip" model="ir.ui.view">
            <field name="name">lavish.search.contract.concept.skip</field>
            <field name="model">hr.contract.concept.skip</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="concept_id"/>
                    <field name="period_skip"/>
                    <separator/>
                    <filter string="Borradores" name="draft_skips" domain="[('state', '=', 'draft')]"/>
                    <filter string="Aprobados" name="approved_skips" domain="[('state', '=', 'approved')]"/>
                    <group name="group_by">
                        <filter string="Concepto" name="concept" context="{'group_by': 'concept_id'}"/>
                        <filter string="Estado" name="state" context="{'group_by': 'state'}"/>
                        <filter string="Período de Salto" name="period" context="{'group_by': 'period_skip:month'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>
