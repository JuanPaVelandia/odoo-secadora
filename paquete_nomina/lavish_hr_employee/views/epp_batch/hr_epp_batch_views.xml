<?xml version="1.0" encoding="utf-8"?>
                                    <odoo>
                                    <!-- ================================================================ -->
                                    <!-- VISTAS: LOTE DE ENTREGAS EPP/DOTACIÓN/EXÁMENES -->
                                    <!-- ================================================================ -->
                                    <!-- Vista Form -->
                                    <record id="view_hr_epp_batch_form" model="ir.ui.view">
                                    <field name="name">hr.epp.batch.form</field>
                                    <field name="model">hr.epp.batch</field>
                                    <field name="arch" type="xml">
                                    <form string="Lote de Entregas">
                                    <header>
                                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                                    <button name="action_start" string="Iniciar Proceso" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                                    <button name="action_deliver_all" string="Marcar Todas Entregadas" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                                    <button name="action_generate_requests" string="Generar Solicitudes" icon="fa-bolt" type="object" class="btn-primary" invisible="state != 'draft'"/>
                                    <button name="action_print_all" string="Imprimir Todos" icon="fa-print" type="object" invisible="state == 'draft'"/>
                                    <button name="action_download_all_zip" string="Descargar ZIP" icon="fa-file-archive-o" type="object" invisible="state == 'draft'"/>
                                    <button name="action_send_emails" string="Enviar Correos" icon="fa-envelope" type="object" invisible="state == 'draft'"/>
                                    <button name="action_cancel" string="Cancelar" type="object" invisible="state in ('delivered', 'cancelled')"/>
                                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,delivered"/>
                                    </header>
                                    <sheet>
                                    <div class="oe_button_box" name="button_box">
                                    <button class="oe_stat_button" type="object" name="action_generate_requests" icon="fa-users">
                                    <div class="o_stat_info">
                                    <field name="total_employees" class="o_stat_value"/>
                                    <span class="o_stat_text">Empleados</span>
                                    </div>
                                    </button>
                                    <button class="oe_stat_button" icon="fa-check-circle" style="color: green;">
                                    <div class="o_stat_info">
                                    <field name="requests_delivered" class="o_stat_value"/>
                                    <span class="o_stat_text">Entregadas</span>
                                    </div>
                                    </button>
                                    <button class="oe_stat_button" icon="fa-spinner" style="color: orange;">
                                    <div class="o_stat_info">
                                    <field name="requests_approved" class="o_stat_value"/>
                                    <span class="o_stat_text">En Proceso</span>
                                    </div>
                                    </button>
                                    <button class="oe_stat_button" icon="fa-file-o" style="color: gray;">
                                    <div class="o_stat_info">
                                    <field name="requests_draft" class="o_stat_value"/>
                                    <span class="o_stat_text">Borradores</span>
                                    </div>
                                    </button>
                                    </div>
                                    <div class="oe_title">
                                    <h1>
                                    <field name="name" readonly="1"/>
                                    </h1>
                                    </div>
                                    <!-- Barra de Progreso -->
                                    <div class="alert alert-info" role="alert" invisible="state == 'draft'">
                                    <div class="row align-items-center">
                                    <div class="col-4">
                                    <strong>Progreso del Lote:</strong>
                                    </div>
                                    <div class="col-4 text-center">
                                    <field name="progress_percentage" widget="progressbar"/>
                                    </div>
                                    <div class="col-4 text-end">
                                    <strong><field name="requests_delivered"/> / <field name="total_employees"/> entregadas</strong>
                                    </div>
                                    </div>
                                    </div>
                                    <group>
                                    <group name="main_info">
                                    <field name="batch_type" readonly="state != 'draft'"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    <field name="batch_date"/>
                                    <field name="delivery_planned_date"/>
                                    </group>
                                    <group name="stock_config">
                                    <label for="use_stock_location" string="Control de Inventario"/>
                                    <div>
                                    <field name="use_stock_location" readonly="state != 'draft'"/>
                                    <div class="text-muted small" invisible="not use_stock_location"> Generará movimientos de stock para control </div>
                                    </div>
                                    <field name="default_location_id" invisible="not use_stock_location" readonly="state != 'draft'" required="use_stock_location" options="{'no_create': True}"/>
                                    <field name="allow_employee_location" invisible="not use_stock_location" readonly="state != 'draft'"/>
                                    </group>
                                    </group>
                                    <notebook>
                                    <page name="requests" string="Solicitudes EPP/Dotación" invisible="batch_type == 'medical_exam'">
                                    <field name="request_ids" context="{'default_batch_id': id}">
                                    <list string="Solicitudes Generadas" editable="bottom" create="false" delete="false" decoration-success="state == 'delivered'" decoration-info="state == 'approved'" decoration-muted="state == 'cancelled'">
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="type"/>
                                    <field name="request_date"/>
                                    <field name="state" widget="badge" decoration-success="state == 'delivered'" decoration-warning="state == 'picking'" decoration-info="state == 'approved'"/>
                                    <button name="action_approve" string="Aprobar" type="object" icon="fa-check" invisible="state != 'draft'"/>
                                    <button name="action_deliver" string="Entregar" type="object" icon="fa-truck" invisible="state not in ('approved', 'picking')"/>
                                    <button name="action_print_delivery" string="Imprimir" type="object" icon="fa-print" invisible="state != 'delivered'"/>
                                    </list>
                                    </field>
                                    </page>
                                    <page name="certificates" string="Certificados Médicos" invisible="batch_type != 'medical_exam'">
                                    <field name="certificate_ids" context="{'default_batch_id': id}">
                                    <list string="Certificados Generados" decoration-success="state == 'valid'" decoration-warning="state == 'expiring'" decoration-danger="state == 'expired'">
                                    <field name="name"/>
                                    <field name="employee_id" widget="many2one_avatar_employee"/>
                                    <field name="certificate_type"/>
                                    <field name="provider_id"/>
                                    <field name="issue_date"/>
                                    <field name="expiry_date"/>
                                    <field name="result" widget="badge"/>
                                    <field name="state" widget="badge" decoration-success="state == 'valid'" decoration-warning="state == 'expiring'" decoration-danger="state == 'expired'"/>
                                    </list>
                                    </field>
                                    </page>
                                    <page name="notes" string="Notas">
                                    <field name="notes" placeholder="Notas u observaciones del lote..."/>
                                    </page>
                                    </notebook>
                                    </sheet>
                                    <chatter/>
                                    </form>
                                    </field>
                                    </record>
                                    <!-- Vista List -->
                                    <record id="view_hr_epp_batch_tree" model="ir.ui.view">
                                    <field name="name">hr.epp.batch.tree</field>
                                    <field name="model">hr.epp.batch</field>
                                    <field name="arch" type="xml">
                                    <list string="Lotes de Entregas" multi_edit="1" sample="1" decoration-success="state == 'delivered'" decoration-info="state == 'confirmed'" decoration-warning="state == 'in_progress'">
                                    <header>
                                    <button name="action_print_all" string="Imprimir Seleccionados" type="object"/>
                                    <button name="action_send_emails" string="Enviar Correos Masivos" type="object"/>
                                    </header>
                                    <field name="name"/>
                                    <field name="batch_type" widget="badge" decoration-primary="batch_type == 'epp'" decoration-info="batch_type == 'dotacion'" decoration-warning="batch_type == 'medical_exam'"/>
                                    <field name="batch_date"/>
                                    <field name="total_employees" sum="Total Empleados"/>
                                    <field name="requests_delivered" sum="Total Entregadas"/>
                                    <field name="progress_percentage" widget="progressbar"/>
                                    <field name="state" widget="badge" decoration-muted="state == 'draft'" decoration-info="state == 'confirmed'" decoration-warning="state == 'in_progress'" decoration-success="state == 'delivered'"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    </list>
                                    </field>
                                    </record>
                                    <!-- Vista Kanban -->
                                    <record id="view_hr_epp_batch_kanban" model="ir.ui.view">
                                    <field name="name">hr.epp.batch.kanban</field>
                                    <field name="model">hr.epp.batch</field>
                                    <field name="arch" type="xml">
                                    <kanban default_group_by="state" sample="1" class="o_kanban_mobile">
                                    <field name="name"/>
                                    <field name="batch_type"/>
                                    <field name="batch_date"/>
                                    <field name="total_employees"/>
                                    <field name="requests_delivered"/>
                                    <field name="progress_percentage"/>
                                    <field name="state"/>
                                    <templates>
                                    <t t-name="card">
                                    <main>
                                    <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                    <i class="fa fa-calendar" title="Calendario"/>
                                    <field name="batch_date"/>
                                    </div>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                    <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                    <a role="menuitem" type="object" name="action_print_all" class="dropdown-item">
                                    <i class="fa fa-print" title="Imprimir"/> Imprimir Todos </a>
                                    <a role="menuitem" type="object" name="action_download_all_zip" class="dropdown-item">
                                    <i class="fa fa-file-archive-o" title="Archivo ZIP"/> Descargar ZIP </a>
                                    <a role="menuitem" type="object" name="action_send_emails" class="dropdown-item">
                                    <i class="fa fa-envelope" title="Email"/> Enviar Correos </a>
                                    <div class="dropdown-divider"/>
                                    <a role="menuitem" type="edit" class="dropdown-item">
                                    <i class="fa fa-pencil" title="Editar"/> Editar </a>
                                    <a role="menuitem" type="delete" class="dropdown-item">
                                    <i class="fa fa-trash" title="Eliminar"/> Eliminar </a>
                                    </div>
                                    </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                    <field name="batch_type" widget="badge"/>
                                    <div class="row mt-2">
                                    <div class="col-12">
                                    <span class="badge bg-primary">
                                    <i class="fa fa-users" title="Usuarios"/>
                                    <field name="total_employees"/> empleados </span>
                                    </div>
                                    </div>
                                    <div class="row mt-2">
                                    <div class="col-12">
                                    <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-success" role="progressbar" >
                                    <t t-out="record.progress_percentage.value"/>% </div>
                                    </div>
                                    </div>
                                    </div>
                                    <div class="row mt-2">
                                    <div class="col-6">
                                    <small>
                                    <i class="fa fa-check-circle text-success" title="Confirmado"/>
                                    <field name="requests_delivered"/> Entregadas </small>
                                    </div>
                                    <div class="col-6">
                                    <small>
                                    <i class="fa fa-clock-o text-warning" title="Tiempo"/>
                                    <field name="requests_approved"/> En Proceso </small>
                                    </div>
                                    </div>
                                    </div>
                                    <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    </div>
                                    </div>
                                    </main>
                                    </t>
                                    </templates>
                                    </kanban>
                                    </field>
                                    </record>
                                    <!-- Vista Search -->
                                    <record id="view_hr_epp_batch_search" model="ir.ui.view">
                                    <field name="name">hr.epp.batch.search</field>
                                    <field name="model">hr.epp.batch</field>
                                    <field name="arch" type="xml">
                                    <search string="Buscar Lotes">
                                    <field name="name" string="Número de Lote"/>
                                    <field name="batch_type"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    <filter string="Borradores" name="draft" domain="[('state', '=', 'draft')]"/>
                                    <filter string="En Proceso" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                                    <filter string="Entregados" name="delivered" domain="[('state', '=', 'delivered')]"/>
                                    <separator/>
                                    <filter string="EPP" name="epp" domain="[('batch_type', '=', 'epp')]"/>
                                    <filter string="Dotación" name="dotacion" domain="[('batch_type', '=', 'dotacion')]"/>
                                    <filter string="Exámenes Médicos" name="medical" domain="[('batch_type', '=', 'medical_exam')]"/>
                                    <separator/>
                                    <filter string="Este Mes" name="this_month" domain="[('batch_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')), ('batch_date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                                    <group name="group_by">
                                    <filter string="Tipo" name="group_type" context="{'group_by': 'batch_type'}"/>
                                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                                    <filter string="Mes" name="group_month" context="{'group_by': 'batch_date:month'}"/>
                                    <filter string="Empresa" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                                    </group>
                                    </search>
                                    </field>
                                    </record>
                                    <!-- ================================================================ -->
                                    <!-- ACCIONES -->
                                    <!-- ================================================================ -->
                                    <!-- Acción: Todos los Lotes -->
                                    <record id="action_hr_epp_batch" model="ir.actions.act_window">
                                    <field name="name">Lotes de Entregas</field>
                                    <field name="res_model">hr.epp.batch</field>
                                    <field name="view_mode">kanban,list,form</field>
                                    <field name="domain">[]</field>
                                    <field name="context">{}</field>
                                    <field name="help" type="html">
                                    <p class="o_view_nocontent_smiling_face"> Crear lote de entregas masivas </p>
                                    <p> Los lotes permiten gestionar entregas de EPP/Dotación o exámenes médicos a múltiples empleados simultáneamente. </p>
                                    </field>
                                    </record>
                                    <!-- Acción: Lotes EPP -->
                                    <record id="action_hr_epp_batch_epp" model="ir.actions.act_window">
                                    <field name="name">Lotes de EPP</field>
                                    <field name="res_model">hr.epp.batch</field>
                                    <field name="view_mode">kanban,list,form</field>
                                    <field name="domain">[('batch_type', '=', 'epp')]</field>
                                    <field name="context">{'default_batch_type': 'epp'}</field>
                                    </record>
                                    <!-- Acción: Lotes Dotación -->
                                    <record id="action_hr_epp_batch_dotacion" model="ir.actions.act_window">
                                    <field name="name">Lotes de Dotación</field>
                                    <field name="res_model">hr.epp.batch</field>
                                    <field name="view_mode">kanban,list,form</field>
                                    <field name="domain">[('batch_type', '=', 'dotacion')]</field>
                                    <field name="context">{'default_batch_type': 'dotacion'}</field>
                                    </record>
                                    <!-- Acción: Lotes Exámenes Médicos -->
                                    <record id="action_hr_epp_batch_medical" model="ir.actions.act_window">
                                    <field name="name">Lotes de Exámenes Médicos</field>
                                    <field name="res_model">hr.epp.batch</field>
                                    <field name="view_mode">kanban,list,form</field>
                                    <field name="domain">[('batch_type', '=', 'medical_exam')]</field>
                                    <field name="context">{'default_batch_type': 'medical_exam'}</field>
                                    </record>
                                    <!-- ================================================================ -->
                                    <!-- MENÚS -->
                                    <!-- ================================================================ -->
                                    <menuitem id="menu_hr_epp_batch_root" name="Lotes de Entregas" parent="lavish_hr_employee.menu_hr_epp_dotacion" sequence="5"/>
                                    <menuitem id="menu_hr_epp_batch_epp" name="Lotes EPP" action="action_hr_epp_batch_epp" parent="menu_hr_epp_batch_root" sequence="10"/>
                                    <menuitem id="menu_hr_epp_batch_dotacion" name="Lotes Dotación" action="action_hr_epp_batch_dotacion" parent="menu_hr_epp_batch_root" sequence="20"/>
                                    <menuitem id="menu_hr_epp_batch_medical" name="Lotes Exámenes Médicos" action="action_hr_epp_batch_medical" parent="menu_hr_epp_batch_root" sequence="30"/>
                                    </odoo> 