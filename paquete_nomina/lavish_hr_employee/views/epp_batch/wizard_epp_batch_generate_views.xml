<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================ -->
    <!-- WIZARD: GENERAR SOLICITUDES/EXÁMENES MASIVOS                     -->
    <!-- ================================================================ -->

    <record id="view_wizard_epp_batch_generate_form" model="ir.ui.view">
        <field name="name">wizard.epp.batch.generate.form</field>
        <field name="model">wizard.epp.batch.generate</field>
        <field name="arch" type="xml">
            <form string="Generar Solicitudes/Exámenes">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <h5><i class="fa fa-filter" title="Filtro"></i>
                            <i class="fa fa-info-circle" title="Información"/> Asistente de Generación Masiva
                        </h5>
                        <p class="mb-0">
                            Seleccione los filtros para elegir qué empleados recibirán las solicitudes o exámenes médicos.
                        </p>
                    </div>

                    <group>
                        <group>
                            <field name="batch_id" invisible="1"/>
                            <field name="batch_type" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Modo de Selección de Empleados"/>

                    <group>
                        <field name="selection_mode" widget="radio"/>
                    </group>

                    <separator string="Filtros" invisible="selection_mode == 'all'"/>

                    <group invisible="selection_mode == 'all'">
                        <group>
                            <field name="department_ids" widget="many2many_tags"
                                   invisible="selection_mode not in ('department', 'filters')"
                                   required="selection_mode == 'department'"
                                   options="{'no_create': True, 'no_open': True}"/>

                            <field name="job_ids" widget="many2many_tags"
                                   invisible="selection_mode not in ('job', 'filters')"
                                   required="selection_mode == 'job'"
                                   options="{'no_create': True, 'no_open': True}"/>

                            <field name="employee_type"
                                   invisible="selection_mode != 'filters'"/>
                        </group>

                        <group>
                            <field name="employee_ids" widget="many2many_tags"
                                   invisible="selection_mode != 'manual'"
                                   required="selection_mode == 'manual'"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <separator string="Configuración a Aplicar"/>

                    <group>
                        <group name="config_epp">
                            <!-- Para EPP/Dotación -->
                            <field name="config_id"
                                   invisible="batch_type == 'medical_exam'"
                                   options="{'no_create': True}"
                                   help="Configuración de EPP/Dotación que define los items a entregar"/>
                        </group>

                        <group name="config_medical">
                            <!-- Para Exámenes Médicos -->
                            <field name="medical_exam_type"
                                   invisible="batch_type != 'medical_exam'"
                                   required="batch_type == 'medical_exam'"/>

                            <field name="medical_provider_id"
                                   invisible="batch_type != 'medical_exam'"
                                   required="batch_type == 'medical_exam'"
                                   options="{'no_create': True}"/>

                            <field name="certificate_validity_months"
                                   invisible="batch_type != 'medical_exam'"/>
                        </group>
                    </group>

                    <separator string="Vista Previa de Empleados Seleccionados"/>

                    <div class="alert alert-success" role="alert">
                        <div class="row align-items-center">
                            <div class="col-8">
                                <strong>
                                    <i class="fa fa-check-circle" title="Confirmado"/> Empleados encontrados con los filtros:
                                </strong>
                            </div>
                            <div class="col-4 text-end">
                                <h3 class="mb-0">
                                    <field name="employee_count" class="o_stat_value"/>
                                </h3>
                            </div>
                        </div>
                    </div>

                    <field name="employee_preview_ids" mode="kanban" nolabel="1">
                        <kanban create="false" delete="false" class="o_kanban_mobile">
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="work_email"/>

                            <templates>
                                <t t-name="card">
                                    <main>
                                        <div class="o_kanban_record_title">
                                            <strong><field name="name"/></strong>
                                        </div>
                                        <div class="o_kanban_record_subtitle text-muted">
                                            <div>
                                                <i class="fa fa-building" title="Empresa"/>
                                                <field name="department_id"/>
                                            </div>
                                            <div>
                                                <i class="fa fa-briefcase" title="Trabajo"/>
                                                <field name="job_id"/>
                                            </div>
                                            <div invisible="not work_email">
                                                <i class="fa fa-envelope" title="Email"/>
                                                <field name="work_email"/>
                                            </div>
                                        </div>
                                    </main>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </sheet>

                <footer>
                    <button name="action_generate" string="Generar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
