<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista Tree -->
        <record id="view_hr_indicador_especial_pila_tree" model="ir.ui.view">
            <field name="name">hr.indicador.especial.pila.tree</field>
            <field name="model">hr.indicador.especial.pila</field>
            <field name="arch" type="xml">
                <list string="Indicadores Especiales PILA">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="porc_pension_total"/>
                    <field name="porc_salud_total"/>
                    <field name="dias_vacaciones"/>
                    <field name="dias_prima"/>
                    <field name="dias_cesantias"/>
                    <field name="base_dias_prestaciones"/>
                    <field name="aplica_fsp"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Vista Form -->
        <record id="view_hr_indicador_especial_pila_form" model="ir.ui.view">
            <field name="name">hr.indicador.especial.pila.form</field>
            <field name="model">hr.indicador.especial.pila</field>
            <field name="arch" type="xml">
                <form string="Indicador Especial PILA">
                    <sheet>
                        <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                        <div class="oe_button_box" name="button_box">
                        </div>
                        <group>
                            <group string="Informacion General">
                                <field name="code"/>
                                <field name="name"/>
                                <field name="normativa"/>
                            </group>
                            <group string="Configuracion Especial">
                                <field name="aplica_fsp"/>
                                <field name="es_subsidiado"/>
                                <field name="porc_subsidio" invisible="not es_subsidiado"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Tarifas Pension" name="pension">
                                <group>
                                    <group string="Tarifa Total">
                                        <field name="porc_pension_total"/>
                                        <field name="porc_pension_adicional"/>
                                    </group>
                                    <group string="Distribucion">
                                        <field name="porc_pension_empleado"/>
                                        <field name="porc_pension_empresa"/>
                                    </group>
                                </group>
                                <div class="alert alert-info" role="alert">
                                    <strong>Nota:</strong> La tarifa empresa se calcula automaticamente como: Tarifa Total - Tarifa Empleado
                                </div>
                            </page>
                            <page string="Tarifas Salud" name="salud">
                                <group>
                                    <group string="Tarifa Total">
                                        <field name="porc_salud_total"/>
                                    </group>
                                    <group string="Distribucion">
                                        <field name="porc_salud_empleado"/>
                                        <field name="porc_salud_empresa"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Prestaciones Sociales" name="prestaciones">
                                <group string="Configuracion General">
                                    <group>
                                        <field name="base_dias_prestaciones"/>
                                    </group>
                                    <group>
                                        <field name="paga_auxilio_transporte"/>
                                        <field name="incluye_aux_transporte_prestaciones"/>
                                    </group>
                                </group>
                                <group string="Vacaciones">
                                    <group>
                                        <field name="paga_vacaciones"/>
                                        <field name="dias_vacaciones" invisible="not paga_vacaciones"/>
                                    </group>
                                    <group>
                                        <field name="base_dias_vacaciones" invisible="not paga_vacaciones"/>
                                    </group>
                                </group>
                                <group string="Prima de Servicios">
                                    <group>
                                        <field name="paga_prima"/>
                                        <field name="dias_prima" invisible="not paga_prima"/>
                                    </group>
                                    <group>
                                        <field name="base_dias_prima" invisible="not paga_prima"/>
                                    </group>
                                </group>
                                <group string="Cesantias">
                                    <group>
                                        <field name="paga_cesantias"/>
                                        <field name="dias_cesantias" invisible="not paga_cesantias"/>
                                    </group>
                                    <group>
                                        <field name="base_dias_cesantias" invisible="not paga_cesantias"/>
                                    </group>
                                </group>
                                <group string="Intereses de Cesantias">
                                    <group>
                                        <field name="paga_intereses_cesantias"/>
                                        <field name="porc_intereses_cesantias" invisible="not paga_intereses_cesantias"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Descripcion" name="descripcion">
                                <field name="descripcion" placeholder="Descripcion detallada del indicador especial y su normativa aplicable..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Accion -->
        <record id="action_hr_indicador_especial_pila" model="ir.actions.act_window">
            <field name="name">Indicadores Especiales PILA</field>
            <field name="res_model">hr.indicador.especial.pila</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'active_test': False}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un indicador especial PILA
                </p>
                <p>
                    Configure las tarifas especiales de pension y salud segun el tipo de cotizante
                    (Alto Riesgo, Senadores, CTI, Aviadores, etc.)
                </p>
            </field>
        </record>

        <!-- Menu item -->
        <menuitem id="menu_hr_indicador_especial_pila"
                  name="Indicadores Especiales PILA"
                  parent="hr.menu_human_resources_configuration"
                  action="action_hr_indicador_especial_pila"
                  sequence="15"/>
    </data>
</odoo>
