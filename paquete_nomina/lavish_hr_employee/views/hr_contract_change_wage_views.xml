<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ VISTAS DE CAMBIOS DE SALARIO ============ -->

    <!-- Vista Tree/List -->
    <record id="view_hr_contract_change_wage_tree" model="ir.ui.view">
        <field name="name">hr.contract.change.wage.tree</field>
        <field name="model">hr.contract.change.wage</field>
        <field name="arch" type="xml">
            <list string="Cambios de Salario"
                  default_order="date_start desc"
                  decoration-success="reason in ['promotion', 'performance'] and difference > 0"
                  decoration-info="reason in ['annual_update', 'adjustment']"
                  decoration-warning="reason in ['legal', 'collective']"
                  decoration-muted="reason == 'start'"
                  decoration-danger="difference &lt; 0"
                  editable="bottom"
                  multi_edit="1"
                  sample="1">

                <field name="employee_id" string="Empleado" readonly="1"/>
                <field name="contract_id" string="Contrato" readonly="1" optional="hide"/>
                <field name="date_start" string="Fecha Inicio"/>
                <field name="wage_old" string="Anterior" readonly="1"/>
                <field name="wage" string="Nuevo"/>
                <field name="difference" string="Dif." readonly="1"/>
                <field name="difference_percentage" string="% Var." readonly="1"/>
                <field name="reason" string="Motivo"/>
                <field name="job_id" string="Cargo" optional="show"/>
                <field name="department_id" string="Depto." optional="show"/>
                <field name="tipo_cotizante_id" string="Tipo PILA" optional="show"/>
                <field name="state" string="Estado" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'approved'" optional="show"/>
                <field name="tipo_coti_id" string="Tipo Emp." optional="hide"/>
                <field name="subtipo_coti_id" string="Subtipo" optional="hide"/>
                <field name="contract_category" string="Tipo Contrato" readonly="1" optional="hide"/>
                <field name="origin_type" string="Origen" optional="hide"/>
                <field name="apply_retroactive" string="Retroactivo" widget="boolean_toggle" optional="hide"/>
                <field name="company_id" string="Empresa" readonly="1" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_hr_contract_change_wage_form" model="ir.ui.view">
        <field name="name">hr.contract.change.wage.form</field>
        <field name="model">hr.contract.change.wage</field>
        <field name="arch" type="xml">
            <form string="Cambio de Salario">
                <header>
                    <button name="action_approve" type="object" string="Aprobar"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_draft" type="object" string="Volver a Borrador"
                            invisible="state != 'approved'"/>
                    <button name="action_print" type="object" string="Imprimir" icon="fa-print"/>
                    <button name="action_send_email" type="object" string="Enviar por Email" icon="fa-envelope"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved"/>
                </header>
                <sheet>
                    <!-- Ribbon para retroactivo -->
                    <widget name="web_ribbon" title="Retroactivo" bg_color="bg-warning"
                            invisible="not apply_retroactive"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informacion del Cambio">
                            <field name="contract_id"
                                   domain="[('employee_id', '!=', False), ('state', 'in', ['open', 'pending'])]"
                                   options="{'no_create': True}"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" options="{'no_create': True}"/>
                            <field name="date_start" required="1"/>
                            <field name="job_id" options="{'no_create': True}"/>
                        </group>

                        <group string="Informacion Salarial">
                            <field name="wage_old" readonly="1" force_save="1"/>
                            <field name="wage" required="1"/>
                            <field name="difference" readonly="1" force_save="1"/>
                            <field name="difference_percentage" readonly="1" force_save="1"/>
                        </group>
                    </group>

                    <group>
                        <group string="Informacion de Cotizante (momento del cambio)" col="4">
                            <field name="tipo_cotizante_id" options="{'no_create': True}"/>
                            <field name="tipo_coti_id" options="{'no_create': True}"/>
                            <field name="subtipo_coti_id" options="{'no_create': True}"/>
                            <field name="contract_category" readonly="1"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group>
                        <group string="Motivo del Cambio">
                            <field name="reason" required="1"/>
                            <field name="other_reason"
                                   invisible="reason != 'other'"
                                   required="reason == 'other'"
                                   placeholder="Especifique el motivo..."/>
                        </group>

                        <group string="Configuracion Retroactiva">
                            <field name="apply_retroactive" widget="boolean_toggle"/>
                            <field name="retroactive_date"
                                   required="apply_retroactive"
                                   invisible="not apply_retroactive"/>
                        </group>
                    </group>

                    <group string="Origen" invisible="origin_type == 'manual'">
                        <group>
                            <field name="origin_type" readonly="1"/>
                            <field name="salary_increase_id" readonly="1"
                                   invisible="origin_type != 'salary_increase'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Search -->
    <record id="view_hr_contract_change_wage_search" model="ir.ui.view">
        <field name="name">hr.contract.change.wage.search</field>
        <field name="model">hr.contract.change.wage</field>
        <field name="arch" type="xml">
            <search string="Buscar Cambios de Salario">
                <field name="employee_id" string="Empleado"/>
                <field name="contract_id" string="Contrato"/>
                <field name="department_id" string="Departamento"/>
                <field name="job_id" string="Cargo"/>
                <field name="reason" string="Motivo"/>
                <field name="tipo_cotizante_id" string="Tipo Cot. PILA"/>
                <field name="tipo_coti_id" string="Tipo Cot. Emp."/>
                <field name="subtipo_coti_id" string="Subtipo Cotizante"/>

                <separator/>

                <filter name="filter_draft" string="Borrador"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_approved" string="Aprobados"
                        domain="[('state', '=', 'approved')]"/>

                <separator/>

                <filter name="with_retroactive" string="Con Retroactivo"
                        domain="[('apply_retroactive', '=', True)]"/>

                <separator/>

                <filter name="current_month" string="Este Mes"
                        domain="[('date_start', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                                ('date_start', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="last_month" string="Mes Pasado"
                        domain="[('date_start', '&gt;=', (context_today() + relativedelta(months=-1, day=1)).strftime('%Y-%m-%d')),
                                ('date_start', '&lt;', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="current_year" string="Este Ano"
                        domain="[('date_start', '&gt;=', (context_today() + relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                ('date_start', '&lt;', (context_today() + relativedelta(years=1, month=1, day=1)).strftime('%Y-%m-%d'))]"/>

                <separator/>

                <filter name="increase" string="Aumentos"
                        domain="[('difference', '>', 0)]"/>
                <filter name="decrease" string="Disminuciones"
                        domain="[('difference', '&lt;', 0)]"/>

                <separator/>

                <filter name="promotion" string="Promociones"
                        domain="[('reason', '=', 'promotion')]"/>
                <filter name="annual" string="Actualizacion Anual"
                        domain="[('reason', '=', 'annual_update')]"/>
                <filter name="performance" string="Por Desempeno"
                        domain="[('reason', '=', 'performance')]"/>

                <group name="group_by">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Departamento" context="{'group_by': 'department_id'}"/>
                    <filter name="group_contract" string="Contrato" context="{'group_by': 'contract_id'}"/>
                    <filter name="group_job" string="Cargo" context="{'group_by': 'job_id'}"/>
                    <filter name="group_tipo_cotizante" string="Tipo Cot. PILA" context="{'group_by': 'tipo_cotizante_id'}"/>
                    <filter name="group_tipo_coti" string="Tipo Cot. Emp." context="{'group_by': 'tipo_coti_id'}"/>
                    <filter name="group_subtipo_coti" string="Subtipo Cotizante" context="{'group_by': 'subtipo_coti_id'}"/>
                    <filter name="group_reason" string="Motivo" context="{'group_by': 'reason'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'date_start:month'}"/>
                    <filter name="group_origin" string="Origen" context="{'group_by': 'origin_type'}"/>
                    <filter name="group_company" string="Empresa" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista Pivot -->
    <record id="view_hr_contract_change_wage_pivot" model="ir.ui.view">
        <field name="name">hr.contract.change.wage.pivot</field>
        <field name="model">hr.contract.change.wage</field>
        <field name="arch" type="xml">
            <pivot string="Analisis de Cambios Salariales" sample="1">
                <field name="employee_id" type="row"/>
                <field name="date_start" type="col" interval="month"/>
                <field name="wage" type="measure"/>
                <field name="difference" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Vista Graph -->
    <record id="view_hr_contract_change_wage_graph" model="ir.ui.view">
        <field name="name">hr.contract.change.wage.graph</field>
        <field name="model">hr.contract.change.wage</field>
        <field name="arch" type="xml">
            <graph string="Evolucion Salarial" type="line" sample="1">
                <field name="date_start" interval="month"/>
                <field name="wage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Accion principal -->
    <record id="action_hr_contract_change_wage" model="ir.actions.act_window">
        <field name="name">Cambios de Salario</field>
        <field name="res_model">hr.contract.change.wage</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_hr_contract_change_wage_search"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo cambio de salario
            </p>
            <p>
                Registre y gestione todos los cambios salariales de los empleados.
                Puede configurar cambios retroactivos y llevar un historico completo
                de las modificaciones salariales.
            </p>
        </field>
    </record>

    <!-- Menu bajo Nomina > Empleados (secuencia alta para estar al final) -->
    <menuitem id="menu_hr_contract_change_wage_root"
              name="Cambios Salariales"
              parent="hr_payroll.menu_hr_payroll_employees"
              sequence="90"/>

    <menuitem id="menu_hr_contract_change_wage_all"
              name="Historial de Cambios"
              parent="menu_hr_contract_change_wage_root"
              action="action_hr_contract_change_wage"
              sequence="10"/>

</odoo>
