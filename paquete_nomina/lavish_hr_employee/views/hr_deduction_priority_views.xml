<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- PRIORIDAD DE DEDUCCIONES - VISTAS                                  -->
    <!-- ================================================================== -->

    <!-- Vista List (Odoo 19) -->
    <record id="hr_deduction_priority_view_tree" model="ir.ui.view">
        <field name="name">hr.deduction.priority.tree</field>
        <field name="model">hr.deduction.priority</field>
        <field name="arch" type="xml">
            <list string="Prioridad de Deducciones" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="salary_rule_id" optional="show"/>
                <field name="category_id" optional="show"/>
                <field name="rule_code" optional="hide"/>
                <field name="is_mandatory" widget="boolean_toggle"/>
                <field name="priority_type" optional="hide"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="hr_deduction_priority_view_form" model="ir.ui.view">
        <field name="name">hr.deduction.priority.form</field>
        <field name="model">hr.deduction.priority</field>
        <field name="arch" type="xml">
            <form string="Prioridad de Deducción">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive" invisible="1">
                            <field name="is_active" widget="boolean_button" options='{"terminology": "active"}'/>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre de la prioridad..."/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Configuración">
                            <field name="sequence"/>
                            <field name="is_mandatory"/>
                            <field name="is_active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Aplica a">
                            <field name="salary_rule_id"/>
                            <field name="category_id"/>
                            <field name="rule_code"/>
                            <field name="priority_type" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="Notas">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Search -->
    <record id="hr_deduction_priority_view_search" model="ir.ui.view">
        <field name="name">hr.deduction.priority.search</field>
        <field name="model">hr.deduction.priority</field>
        <field name="arch" type="xml">
            <search string="Buscar Prioridades">
                <field name="name"/>
                <field name="rule_code"/>
                <field name="salary_rule_id"/>
                <field name="category_id"/>
                <separator/>
                <filter name="mandatory" string="Obligatorias" domain="[('is_mandatory', '=', True)]"/>
                <filter name="limitable" string="Limitables" domain="[('is_mandatory', '=', False)]"/>
                <separator/>
                <filter name="active" string="Activas" domain="[('is_active', '=', True)]"/>
                <filter name="inactive" string="Inactivas" domain="[('is_active', '=', False)]"/>
                <group name="group_by">
                    <filter name="group_mandatory" string="Obligatoria" context="{'group_by': 'is_mandatory'}"/>
                    <filter name="group_type" string="Tipo" context="{'group_by': 'priority_type'}"/>
                    <filter name="group_company" string="Compañía" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="hr_deduction_priority_action" model="ir.actions.act_window">
        <field name="name">Prioridad de Deducciones</field>
        <field name="res_model">hr.deduction.priority</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_deduction_priority_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configurar prioridad de deducciones
            </p>
            <p>
                Configure el orden en que se aplican las deducciones cuando
                el límite del 50% de devengos está activo (Art. 149 CST).
            </p>
            <p>
                <strong>Deducciones Obligatorias:</strong> Siempre se descuentan primero
                (Seguridad Social, Retención en la Fuente).
            </p>
            <p>
                <strong>Deducciones Limitables:</strong> Se aplican en orden de secuencia
                hasta alcanzar el límite del 50% de TOTALDEV.
            </p>
        </field>
    </record>

    <!-- Menú en Configuración de Nómina - TEMPORAL: Comentado hasta que se resuelva el parent -->
    <!--
    <menuitem id="menu_hr_deduction_priority"
              name="Prioridad Deducciones"
              parent="hr_payroll.menu_hr_payroll_configuration"
              action="hr_deduction_priority_action"
              sequence="45"/>
    -->

    <!-- Acción para crear prioridades por defecto (botón en servidor) -->
    <record id="hr_deduction_priority_create_defaults_action" model="ir.actions.server">
        <field name="name">Crear Prioridades por Defecto</field>
        <field name="model_id" ref="model_hr_deduction_priority"/>
        <field name="binding_model_id" ref="model_hr_deduction_priority"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
created = env['hr.deduction.priority'].create_default_priorities()
if created:
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Prioridades creadas',
            'message': f'Se crearon {len(created)} prioridades: {", ".join(created[:5])}{"..." if len(created) > 5 else ""}',
            'type': 'success',
            'sticky': False,
        }
    }
else:
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Sin cambios',
            'message': 'Las prioridades por defecto ya existen',
            'type': 'warning',
            'sticky': False,
        }
    }
        </field>
    </record>

</odoo>
