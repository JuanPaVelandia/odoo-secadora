<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Formulario para Solicitud de Préstamo -->
    <record id="view_hr_loan_request_form" model="ir.ui.view">
        <field name="name">hr.loan.request.form</field>
        <field name="model">hr.loan.request</field>
        <field name="arch" type="xml">
            <form string="Solicitud de Préstamo">
                <header>
                    <button name="action_request" string="Enviar Solicitud" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Aprobar" type="object"
                            class="oe_highlight" invisible="state != 'requested'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Rechazar" type="object"
                            invisible="state != 'requested'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_create_payroll_loan" string="Crear Préstamo de Nómina" type="object"
                            class="oe_highlight" invisible="state != 'approved' or loan_id"
                            groups="hr.group_hr_manager"/>
                    <button name="action_start_payment" string="Iniciar Pago" type="object"
                            invisible="state != 'approved' or not loan_id"
                            groups="hr.group_hr_manager"/>
                    <button name="action_mark_paid" string="Marcar como Pagado" type="object"
                            invisible="state != 'in_payment'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_cancel" string="Cancelar" type="object"
                            invisible="state in ('paid', 'cancelled')"
                            confirm="¿Está seguro que desea cancelar esta solicitud?"/>
                    <button name="action_draft" string="Volver a Borrador" type="object"
                            invisible="state not in ('cancelled', 'rejected')"
                            groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,requested,approved,in_payment,paid"/>
                </header>
                <sheet>
                    <!-- Smartbuttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payroll_loan" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="not loan_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Ver Préstamo</span>
                                <span class="o_stat_text">de Nómina</span>
                            </div>
                        </button>

                        <button name="action_view_payslips" type="object"
                                class="oe_stat_button" icon="fa-list-alt"
                                invisible="payslip_count == 0">
                            <field name="payslip_count" widget="statinfo" string="Nóminas"/>
                        </button>

                        <button name="action_view_leaves" type="object"
                                class="oe_stat_button" icon="fa-calendar-times-o"
                                invisible="leave_count == 0">
                            <field name="leave_count" widget="statinfo" string="Ausencias"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="loan_type"/>
                            <field name="request_date"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="approved_amount" widget="monetary"
                                   readonly="state != 'requested'"
                                   invisible="state == 'draft'"/>
                            <field name="installments"/>
                            <field name="installment_amount" widget="monetary" readonly="1"
                                   invisible="not approved_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- Sección de Configuración de Nómina -->
                    <group string="Configuración de Nómina" invisible="state not in ('approved', 'in_payment', 'paid')">
                        <group>
                            <field name="loan_category_id"
                                   options="{'no_create': True}"
                                   required="state == 'approved' and not loan_id"/>
                            <field name="loan_id" readonly="1"
                                   options="{'no_open': False}"
                                   invisible="not loan_id"/>
                        </group>
                        <group>
                            <field name="paid_installments" readonly="1" invisible="state != 'in_payment'"/>
                            <field name="balance" widget="monetary" readonly="1" invisible="state != 'in_payment'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Justificación">
                            <field name="justification" placeholder="Ingrese la justificación del préstamo..."/>
                        </page>

                        <page string="Documentos del Empleado" invisible="not employee_id">
                            <group string="Acciones Rápidas">
                                <group>
                                    <div class="o_row">
                                        <button name="action_view_payslips" type="object"
                                                string="Ver Nóminas"
                                                class="btn-primary"
                                                icon="fa-list-alt"
                                                invisible="payslip_count == 0"/>
                                        <button name="action_download_payslips_pdf" type="object"
                                                string="Descargar PDFs"
                                                class="btn-secondary"
                                                icon="fa-download"
                                                invisible="payslip_count == 0"/>
                                        <span invisible="payslip_count > 0" class="text-muted">
                                            No hay nóminas confirmadas
                                        </span>
                                    </div>
                                </group>
                                <group>
                                    <div class="o_row">
                                        <button name="action_view_leaves" type="object"
                                                string="Ver Ausencias"
                                                class="btn-primary"
                                                icon="fa-calendar-times-o"
                                                invisible="leave_count == 0"/>
                                        <span invisible="leave_count > 0" class="text-muted">
                                            No hay ausencias registradas
                                        </span>
                                    </div>
                                </group>
                            </group>

                            <separator string="Resumen"/>
                            <group>
                                <group>
                                    <field name="payslip_count" readonly="1" string="Total Nóminas"/>
                                    <field name="leave_count" readonly="1" string="Total Ausencias"/>
                                </group>
                            </group>
                        </page>

                        <page string="Información de Aprobación" invisible="state in ('draft', 'requested')">
                            <group>
                                <group>
                                    <field name="approver_id" readonly="1"/>
                                    <field name="approval_date" readonly="1" invisible="not approval_date"/>
                                </group>
                                <group>
                                    <field name="rejection_date" readonly="1" invisible="not rejection_date"/>
                                    <field name="rejection_reason" readonly="1" invisible="not rejection_reason"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                    <!-- Alerta informativa -->
                    <div class="alert alert-info" role="alert"
                         invisible="state != 'approved' or loan_id">
                        <i class="fa fa-info-circle me-2" title="Información"/>
                        <strong>Siguiente paso:</strong> Seleccione una categoría de préstamo y haga clic en
                        "Crear Préstamo de Nómina" para generar el préstamo que se descontará en la nómina.
                    </div>

                    <div class="alert alert-success" role="alert"
                         invisible="not loan_id">
                        <i class="fa fa-check-circle me-2" title="Confirmado"/>
                        <strong>Préstamo de nómina creado:</strong> El préstamo se descontará automáticamente
                        en las nóminas futuras según la configuración establecida.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista de Lista -->
    <record id="view_hr_loan_request_tree" model="ir.ui.view">
        <field name="name">hr.loan.request.tree</field>
        <field name="model">hr.loan.request</field>
        <field name="arch" type="xml">
            <list string="Solicitudes de Préstamo"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'requested'"
                  decoration-success="state in ('approved', 'paid')"
                  decoration-muted="state == 'cancelled'"
                  decoration-danger="state == 'rejected'">
                <field name="name" decoration-bf="1"/>
                <field name="request_date"/>
                <field name="employee_id"/>
                <field name="loan_type"/>
                <field name="amount" sum="Total Solicitado" widget="monetary"/>
                <field name="approved_amount" sum="Total Aprobado" widget="monetary" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="installments"/>
                <field name="loan_category_id" optional="hide"/>
                <field name="loan_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'requested'"
                       decoration-success="state in ('approved', 'paid')"
                       decoration-muted="state == 'cancelled'"
                       decoration-danger="state == 'rejected'"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Vista de Búsqueda -->
    <record id="view_hr_loan_request_search" model="ir.ui.view">
        <field name="name">hr.loan.request.search</field>
        <field name="model">hr.loan.request</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes de Préstamo">
                <field name="name" string="Número"/>
                <field name="employee_id" string="Empleado"/>
                <field name="loan_type" string="Tipo"/>
                <separator/>
                <filter string="Borradores" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Solicitadas" name="requested" domain="[('state','=','requested')]"/>
                <filter string="Aprobadas" name="approved" domain="[('state','=','approved')]"/>
                <filter string="En Pago" name="in_payment" domain="[('state','=','in_payment')]"/>
                <filter string="Pagadas" name="paid" domain="[('state','=','paid')]"/>
                <filter string="Rechazadas" name="rejected" domain="[('state','=','rejected')]"/>
                <filter string="Canceladas" name="cancelled" domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter string="Con Préstamo de Nómina" name="with_loan" domain="[('loan_id','!=',False)]"/>
                <filter string="Sin Préstamo de Nómina" name="without_loan" domain="[('loan_id','=',False)]"/>
                <separator/>
                <filter string="Mis Solicitudes" name="my_requests"
                        domain="[('employee_id.user_id','=',uid)]"/>
                <separator/>
                <filter string="Fecha Solicitud" name="filter_request_date" date="request_date"/>
                <filter string="Fecha Aprobación" name="filter_approval_date" date="approval_date"/>
                <separator/>
                <group name="group_by">
                    <filter string="Estado" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Empleado" name="group_employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Tipo de Préstamo" name="group_type" context="{'group_by':'loan_type'}"/>
                    <filter string="Categoría" name="group_category" context="{'group_by':'loan_category_id'}"/>
                    <filter string="Fecha Solicitud" name="group_request_date" context="{'group_by':'request_date'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by':'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de Ventana -->
    <record id="action_hr_loan_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de Préstamo</field>
        <field name="res_model">hr.loan.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_requested': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de préstamo
            </p>
            <p>
                Las solicitudes de préstamo permiten a los empleados solicitar préstamos desde el portal.
                Una vez aprobadas, se pueden convertir en préstamos de nómina para descuento automático.
            </p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_hr_loan_request"
              name="Solicitudes de Préstamo"
              parent="hr.menu_hr_root"
              action="action_hr_loan_request"
              sequence="60"/>

</odoo>
