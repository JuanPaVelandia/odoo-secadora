<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ACCIONES: SOLICITUDES EPP/DOTACION -->
    <record id="action_hr_epp_request_all" model="ir.actions.act_window">
        <field name="name">Todas las Solicitudes</field>
        <field name="res_model">hr.epp.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes registradas
            </p>
            <p>
                Haz clic en "Crear" para registrar una nueva solicitud de EPP o Dotación.
            </p>
        </field>
    </record>

    <!-- Solicitudes Pendientes -->
    <record id="action_hr_epp_request_pending" model="ir.actions.act_window">
        <field name="name">Solicitudes Pendientes</field>
        <field name="res_model">hr.epp.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', 'in', ['draft', 'requested', 'approved'])]</field>
        <field name="context">{'search_default_filter_draft': 1, 'search_default_filter_requested': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes pendientes
            </p>
        </field>
    </record>

    <!-- Solicitudes EPP -->
    <record id="action_hr_epp_request_epp" model="ir.actions.act_window">
        <field name="name">Elementos de Protección Personal</field>
        <field name="res_model">hr.epp.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'epp')]</field>
        <field name="context">{'default_type': 'epp', 'search_default_filter_epp': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de EPP
            </p>
            <p>
                Los EPP incluyen: cascos, guantes, gafas, mascarillas, botas, etc.
            </p>
        </field>
    </record>

    <!-- Solicitudes Dotación -->
    <record id="action_hr_epp_request_dotacion" model="ir.actions.act_window">
        <field name="name">Dotación de Uniformes</field>
        <field name="res_model">hr.epp.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'dotacion')]</field>
        <field name="context">{'default_type': 'dotacion', 'search_default_filter_dotacion': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de Dotación
            </p>
            <p>
                La dotación incluye: camisas, pantalones, zapatos, etc.
            </p>
        </field>
    </record>

    <record id="action_hr_epp_request_delivered" model="ir.actions.act_window">
        <field name="name">Entregas Realizadas</field>
        <field name="res_model">hr.epp.request</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', '=', 'delivered')]</field>
        <field name="context">{'search_default_filter_delivered': 1, 'search_default_group_employee': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay entregas registradas
            </p>
        </field>
    </record>

    <!-- ACCIONES: CERTIFICADOS MEDICOS -->

    <record id="action_hr_medical_certificate_all" model="ir.actions.act_window">
        <field name="name">Certificados Médicos</field>
        <field name="res_model">hr.medical.certificate</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay certificados médicos
            </p>
            <p>
                Registra exámenes médicos ocupacionales, certificados de aptitud, trabajo en alturas, etc.
            </p>
        </field>
    </record>

    <record id="action_hr_medical_certificate_valid" model="ir.actions.act_window">
        <field name="name">Certificados Vigentes</field>
        <field name="res_model">hr.medical.certificate</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="domain">[('state', 'in', ['valid', 'expiring'])]</field>
        <field name="context">{'search_default_group_employee': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay certificados vigentes
            </p>
        </field>
    </record>

    <record id="action_hr_medical_certificate_expiring" model="ir.actions.act_window">
        <field name="name">Certificados Por Vencer</field>
        <field name="res_model">hr.medical.certificate</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="domain">[('state', 'in', ['expiring', 'expired'])]</field>
        <field name="context">{'search_default_group_employee': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay certificados por vencer
            </p>
        </field>
    </record>

    <record id="action_hr_medical_certificate_scheduled" model="ir.actions.act_window">
        <field name="name">Exámenes Programados</field>
        <field name="res_model">hr.medical.certificate</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="domain">[('state', 'in', ['scheduled', 'in_process'])]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay exámenes programados
            </p>
        </field>
    </record>

    <!-- ACCIONES: CONFIGURACION -->

    <record id="action_hr_epp_configuration" model="ir.actions.act_window">
        <field name="name">Kits EPP/Dotación</field>
        <field name="res_model">hr.epp.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_active': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay kits configurados
            </p>
            <p>
                Define los kits estándar de EPP y Dotación con los items que se entregarán automáticamente.
            </p>
        </field>
    </record>

    <record id="action_hr_medical_provider" model="ir.actions.act_window">
        <field name="name">Proveedores de Salud</field>
        <field name="res_model">hr.medical.provider</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay proveedores registrados
            </p>
            <p>
                Registra clínicas, laboratorios y centros médicos para exámenes ocupacionales.
            </p>
        </field>
    </record>

    <record id="action_hr_medical_service" model="ir.actions.act_window">
        <field name="name">Servicios Médicos</field>
        <field name="res_model">hr.medical.service</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay servicios configurados
            </p>
            <p>
                Define los servicios médicos disponibles (exámenes de sangre, rayos X, audiometrías, etc.)
            </p>
        </field>
    </record>

    <record id="action_hr_medical_template" model="ir.actions.act_window">
        <field name="name">Plantillas de Exámenes</field>
        <field name="res_model">hr.medical.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay plantillas configuradas
            </p>
            <p>
                Crea plantillas de exámenes médicos predefinidas con servicios incluidos.
            </p>
        </field>
    </record>

    <!-- ESTRUCTURA DE MENUS -->

    <menuitem id="menu_hr_sst_root"
              name="Seguridad y Salud"
              parent="hr.menu_hr_root"
              sequence="40"
              groups="hr.group_hr_user"/>

    <menuitem id="menu_hr_epp_dotacion"
              name="EPP y Dotación"
              parent="menu_hr_sst_root"
              sequence="10"/>

    <menuitem id="menu_hr_epp_request_all"
              name="Todas las Solicitudes"
              parent="menu_hr_epp_dotacion"
              action="action_hr_epp_request_all"
              sequence="10"/>

    <menuitem id="menu_hr_epp_request_pending"
              name="Pendientes"
              parent="menu_hr_epp_dotacion"
              action="action_hr_epp_request_pending"
              sequence="20"/>

    <menuitem id="menu_hr_epp_request_epp"
              name="EPP"
              parent="menu_hr_epp_dotacion"
              action="action_hr_epp_request_epp"
              sequence="30"/>

    <menuitem id="menu_hr_epp_request_dotacion"
              name="Dotación"
              parent="menu_hr_epp_dotacion"
              action="action_hr_epp_request_dotacion"
              sequence="40"/>

    <menuitem id="menu_hr_epp_request_delivered"
              name="Entregas"
              parent="menu_hr_epp_dotacion"
              action="action_hr_epp_request_delivered"
              sequence="50"/>

    <menuitem id="menu_hr_medical"
              name="Salud Ocupacional"
              parent="menu_hr_sst_root"
              sequence="20"/>

    <menuitem id="menu_hr_medical_certificate_all"
              name="Certificados Médicos"
              parent="menu_hr_medical"
              action="action_hr_medical_certificate_all"
              sequence="10"/>

    <menuitem id="menu_hr_medical_certificate_valid"
              name="Vigentes"
              parent="menu_hr_medical"
              action="action_hr_medical_certificate_valid"
              sequence="20"/>

    <menuitem id="menu_hr_medical_certificate_expiring"
              name="Por Vencer"
              parent="menu_hr_medical"
              action="action_hr_medical_certificate_expiring"
              sequence="30"/>

    <menuitem id="menu_hr_medical_certificate_scheduled"
              name="Exámenes Programados"
              parent="menu_hr_medical"
              action="action_hr_medical_certificate_scheduled"
              sequence="40"/>

    <menuitem id="menu_hr_sst_config"
              name="Configuración SST"
              parent="menu_hr_sst_root"
              sequence="90"
              groups="hr.group_hr_manager"/>

    <menuitem id="menu_hr_epp_configuration"
              name="Kits EPP/Dotación"
              parent="menu_hr_sst_config"
              action="action_hr_epp_configuration"
              sequence="10"/>

    <menuitem id="menu_hr_medical_provider"
              name="Proveedores Médicos"
              parent="menu_hr_sst_config"
              action="action_hr_medical_provider"
              sequence="20"/>

    <menuitem id="menu_hr_medical_service"
              name="Servicios Médicos"
              parent="menu_hr_sst_config"
              action="action_hr_medical_service"
              sequence="30"/>

    <menuitem id="menu_hr_medical_template"
              name="Plantillas de Exámenes"
              parent="menu_hr_sst_config"
              action="action_hr_medical_template"
              sequence="40"/>
</odoo>