<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- MEDICAL VIEWS -->

        <!-- Inherit certificate form to add expiry status fields (these fields exist in the model) -->
        <record id="view_hr_medical_certificate_form_improved" model="ir.ui.view">
                <field name="name">hr.medical.certificate.form.improved</field>
                <field name="model">hr.medical.certificate</field>
                <field name="inherit_id" ref="lavish_hr_employee.view_hr_medical_certificate_form"/>
                <field name="arch" type="xml">

                    <!-- Agregar widget de estado de expiración -->
                    <field name="expiry_date" position="after">
                        <field name="days_to_expiry"/>
                        <field name="expiry_status" widget="badge"
                               decoration-success="expiry_status == 'valid'"
                               decoration-warning="expiry_status == 'warning'"
                               decoration-danger="expiry_status in ('critical', 'expired')"/>
                    </field>

                </field>
            </record>

        <record id="view_hr_medical_certificate_tree_improved" model="ir.ui.view">
                <field name="name">hr.medical.certificate.tree.improved</field>
                <field name="model">hr.medical.certificate</field>
                <field name="inherit_id" ref="lavish_hr_employee.view_hr_medical_certificate_list"/>
                <field name="arch" type="xml">
                    <field name="expiry_date" position="after">
                        <field name="days_to_expiry"/>
                        <field name="expiry_status" widget="badge"
                               decoration-success="expiry_status == 'valid'"
                               decoration-warning="expiry_status == 'warning'"
                               decoration-danger="expiry_status in ('critical', 'expired')"/>
                    </field>
                </field>
            </record>

        <!-- HR MEDICAL CERTIFICATE TYPE VIEWS -->

        <record id="view_hr_medical_certificate_type_form" model="ir.ui.view">
            <field name="name">hr.medical.certificate.type.form</field>
            <field name="model">hr.medical.certificate.type</field>
            <field name="arch" type="xml">
                <form string="Tipo de Certificado Medico">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Nombre"/>
                            <h1>
                                <field name="name" placeholder="Nombre del tipo"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Informacion General">
                                <field name="code"/>
                                <field name="parent_id" domain="[('parent_id', '=', False)]"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                            <group string="Configuracion">
                                <field name="validity_months"/>
                                <field name="renewal_alert_days"/>
                                <field name="is_mandatory"/>
                                <field name="requires_height_certification"/>
                            </group>
                        </group>
                        <group string="Descripcion">
                            <field name="description" nolabel="1" colspan="2"/>
                        </group>
                        <group string="Subtipos" invisible="parent_id">
                            <field name="child_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="validity_months"/>
                                    <field name="is_mandatory"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_medical_certificate_type_tree" model="ir.ui.view">
            <field name="name">hr.medical.certificate.type.tree</field>
            <field name="model">hr.medical.certificate.type</field>
            <field name="arch" type="xml">
                <list string="Tipos de Certificado Medico">
                    <field name="sequence" widget="handle"/>
                    <field name="complete_name"/>
                    <field name="code"/>
                    <field name="validity_months"/>
                    <field name="renewal_alert_days"/>
                    <field name="is_mandatory" widget="boolean_toggle"/>
                    <field name="requires_height_certification" widget="boolean_toggle"/>
                    <field name="is_category"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_hr_medical_certificate_type_search" model="ir.ui.view">
            <field name="name">hr.medical.certificate.type.search</field>
            <field name="model">hr.medical.certificate.type</field>
            <field name="arch" type="xml">
                <search string="Buscar Tipos de Certificado">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="parent_id"/>
                    <filter string="Categorias" name="filter_categories" domain="[('parent_id', '=', False)]"/>
                    <filter string="Tipos" name="filter_types" domain="[('parent_id', '!=', False)]"/>
                    <separator/>
                    <filter string="Obligatorios" name="filter_mandatory" domain="[('is_mandatory', '=', True)]"/>
                    <filter string="Trabajo en Alturas" name="filter_height" domain="[('requires_height_certification', '=', True)]"/>
                    <separator/>
                    <filter string="Activos" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Inactivos" name="filter_inactive" domain="[('active', '=', False)]"/>
                        <filter string="Categoria" name="group_parent" context="{'group_by': 'parent_id'}"/>
                </search>
            </field>
        </record>

    </data>
</odoo>
