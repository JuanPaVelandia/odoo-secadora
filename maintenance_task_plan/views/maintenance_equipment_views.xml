<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_equipment_form_inherit_task_plan" model="ir.ui.view">
        <field name="name">maintenance.equipment.form.inherit.task.plan</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <!-- Smart button for task plans -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_task_plans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks">
                    <field name="task_plan_count" string="Maint. Plans" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
