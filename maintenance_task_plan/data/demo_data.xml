<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Categorías demo -->
        <record id="demo_category_tractors" model="maintenance.equipment.category">
            <field name="name">Tractores</field>
        </record>

        <record id="demo_category_generators" model="maintenance.equipment.category">
            <field name="name">Generadores</field>
        </record>

        <!-- Equipos demo -->
        <record id="equipment_tractor_01" model="maintenance.equipment">
            <field name="name">Tractor John Deere 6120M</field>
            <field name="category_id" ref="demo_category_tractors"/>
        </record>

        <record id="equipment_generator_01" model="maintenance.equipment">
            <field name="name">Generador CAT DE220</field>
            <field name="category_id" ref="demo_category_generators"/>
        </record>

        <!-- Planes de tareas demo -->
        <record id="task_plan_oil_change" model="maintenance.task.plan">
            <field name="name">Cambio de aceite - Tractores</field>
            <field name="description">Procedimiento:
1. Calentar el motor por 5 minutos
2. Drenar el aceite usado
3. Reemplazar el filtro de aceite
4. Llenar con aceite nuevo (SAE 15W-40)
5. Verificar nivel de aceite
6. Encender motor, revisar fugas</field>
            <field name="counter_type_id" ref="counter_type_hour_meter"/>
            <field name="interval">200</field>
            <field name="category_id" ref="demo_category_tractors"/>
            <field name="equipment_ids" eval="[(4, ref('equipment_tractor_01'))]"/>
        </record>

        <record id="task_plan_filter_change" model="maintenance.task.plan">
            <field name="name">Cambio filtro de aire - Generadores</field>
            <field name="description">Procedimiento:
1. Apagar generador y esperar a que enfríe
2. Retirar tapa del filtro de aire
3. Retirar filtro viejo
4. Limpiar interior de la carcasa
5. Instalar filtro nuevo
6. Asegurar tapa
7. Encendido de prueba</field>
            <field name="counter_type_id" ref="counter_type_hour_meter"/>
            <field name="interval">500</field>
            <field name="category_id" ref="demo_category_generators"/>
            <field name="equipment_ids" eval="[(4, ref('equipment_generator_01'))]"/>
        </record>

    </data>
</odoo>
