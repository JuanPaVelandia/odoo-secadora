<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_update_counters_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.update.counters.wizard.form</field>
        <field name="model">maintenance.update.counters.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Counters">
                <group>
                    <field name="counter_type_id"/>
                </group>
                <field name="line_ids" nolabel="1">
                    <tree editable="bottom">
                        <field name="equipment_id" readonly="1"/>
                        <field name="current_reading" readonly="1"/>
                        <field name="new_reading"/>
                    </tree>
                </field>
                <footer>
                    <button string="Update" type="object" name="action_update"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_update_counters_wizard" model="ir.actions.act_window">
        <field name="name">Update Counters</field>
        <field name="res_model">maintenance.update.counters.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
