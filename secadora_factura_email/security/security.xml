<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Categoría de Facturas Email -->
        <record id="module_category_factura_email" model="ir.module.category">
            <field name="name">Facturas Email</field>
            <field name="description">Recepción y parseo de facturas electrónicas DIAN</field>
            <field name="sequence">21</field>
        </record>

        <!-- Privilegio de Facturas Email (agrupa los grupos bajo la categoría en Ajustes > Usuarios) -->
        <record id="res_groups_privilege_factura_email" model="res.groups.privilege">
            <field name="name">Facturas Email</field>
            <field name="category_id" ref="module_category_factura_email"/>
        </record>

        <!-- Grupo: Usuario de Facturas Email -->
        <record id="group_factura_email_usuario" model="res.groups">
            <field name="name">Facturas Email: Usuario</field>
            <field name="privilege_id" ref="res_groups_privilege_factura_email"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Grupo: Administrador de Facturas Email -->
        <record id="group_factura_email_admin" model="res.groups">
            <field name="name">Facturas Email: Administrador</field>
            <field name="privilege_id" ref="res_groups_privilege_factura_email"/>
            <field name="implied_ids" eval="[(4, ref('group_factura_email_usuario'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Regla multi-compañía -->
        <record id="rule_factura_email_company" model="ir.rule">
            <field name="name">Factura Email: multi-company</field>
            <field name="model_id" ref="model_secadora_factura_email"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
