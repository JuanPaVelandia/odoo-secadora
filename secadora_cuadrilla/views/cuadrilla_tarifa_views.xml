<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista Form de Tarifa -->
        <record id="view_cuadrilla_tarifa_form" model="ir.ui.view">
            <field name="name">secadora.cuadrilla.tarifa.form</field>
            <field name="model">secadora.cuadrilla.tarifa</field>
            <field name="arch" type="xml">
                <form string="Tarifa de Cuadrilla">
                    <sheet>
                        <group>
                            <group>
                                <field name="producto_id"/>
                                <field name="tarifa"/>
                            </group>
                            <group>
                                <field name="base_peso"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista List de Tarifa -->
        <record id="view_cuadrilla_tarifa_list" model="ir.ui.view">
            <field name="name">secadora.cuadrilla.tarifa.list</field>
            <field name="model">secadora.cuadrilla.tarifa</field>
            <field name="arch" type="xml">
                <list string="Tarifas de Cuadrilla" editable="bottom">
                    <field name="producto_id"/>
                    <field name="tarifa"/>
                    <field name="base_peso"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <!-- Vista Search de Tarifa -->
        <record id="view_cuadrilla_tarifa_search" model="ir.ui.view">
            <field name="name">secadora.cuadrilla.tarifa.search</field>
            <field name="model">secadora.cuadrilla.tarifa</field>
            <field name="arch" type="xml">
                <search string="Buscar Tarifas">
                    <field name="producto_id"/>
                    <filter name="filter_inactive" string="Archivadas" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Acción de ventana -->
        <record id="action_cuadrilla_tarifa" model="ir.actions.act_window">
            <field name="name">Tarifas de Cuadrilla</field>
            <field name="res_model">secadora.cuadrilla.tarifa</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cuadrilla_tarifa_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear una tarifa de cuadrilla
                </p>
                <p>
                    Configure la tarifa ($/kg) y base de peso para cada servicio
                    que realiza la cuadrilla.
                </p>
            </field>
        </record>

    </data>
</odoo>
