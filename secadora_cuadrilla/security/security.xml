<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Grupo: Usuario de Cuadrilla -->
        <record id="group_cuadrilla_usuario" model="res.groups">
            <field name="name">Usuario Cuadrilla</field>
            <field name="category_id" ref="bascula.module_category_bascula"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Grupo: Administrador de Cuadrilla -->
        <record id="group_cuadrilla_admin" model="res.groups">
            <field name="name">Administrador Cuadrilla</field>
            <field name="category_id" ref="bascula.module_category_bascula"/>
            <field name="implied_ids" eval="[(4, ref('group_cuadrilla_usuario'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- ====== Reglas Multi-Empresa ====== -->

        <record id="cuadrilla_tarifa_company_rule" model="ir.rule">
            <field name="name">Tarifa Cuadrilla: Multi-Company</field>
            <field name="model_id" ref="model_secadora_cuadrilla_tarifa"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="cuadrilla_liquidacion_company_rule" model="ir.rule">
            <field name="name">Liquidación Cuadrilla: Multi-Company</field>
            <field name="model_id" ref="model_secadora_cuadrilla_liquidacion"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="cuadrilla_liquidacion_linea_company_rule" model="ir.rule">
            <field name="name">Línea Liquidación Cuadrilla: Multi-Company</field>
            <field name="model_id" ref="model_secadora_cuadrilla_liquidacion_linea"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="cuadrilla_liquidacion_deduccion_company_rule" model="ir.rule">
            <field name="name">Deducción Liquidación Cuadrilla: Multi-Company</field>
            <field name="model_id" ref="model_secadora_cuadrilla_liquidacion_deduccion"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

    </data>
</odoo>
