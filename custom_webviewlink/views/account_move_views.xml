<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_webviewlink" model="ir.ui.view">
        <field name="name">account.move.form.webviewlink</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="x_webviewlink" widget="url" placeholder="https://drive.google.com/..."/>
            </xpath>
        </field>
    </record>
</odoo>
