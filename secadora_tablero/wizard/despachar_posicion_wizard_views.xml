<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_despachar_posicion_wizard_form" model="ir.ui.view">
            <field name="name">secadora.despachar.posicion.wizard.form</field>
            <field name="model">secadora.despachar.posicion.wizard</field>
            <field name="arch" type="xml">
                <form string="Despachar Posiciones">
                    <group>
                        <group>
                            <field name="sitio_id" readonly="1"/>
                            <field name="cliente_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="orden_servicio_id" readonly="1"/>
                            <field name="modalidad_salida" readonly="1"/>
                            <field name="tipo_empaque" widget="radio"
                                   invisible="modalidad_salida != 'bultos'"/>
                        </group>
                    </group>
                    <separator string="Posiciones"/>
                    <field name="posicion_ids" widget="many2many_checkboxes"/>
                    <separator string="Bultos Empacados"
                               invisible="modalidad_salida != 'bultos'"/>
                    <field name="linea_ids" invisible="modalidad_salida != 'bultos'">
                        <list editable="bottom">
                            <field name="producto_id"/>
                            <field name="producto_empaque_id"/>
                            <field name="cantidad_bultos"/>
                            <field name="peso_promedio"/>
                            <field name="peso_subtotal" sum="Total"/>
                            <field name="proveedor_empaque"/>
                        </list>
                    </field>
                    <group>
                        <group>
                            <field name="peso_total" readonly="1" string="Peso Posiciones (kg)"/>
                        </group>
                        <group invisible="modalidad_salida != 'bultos'">
                            <field name="peso_total_lineas" readonly="1"/>
                        </group>
                        <group invisible="modalidad_salida != 'bultos'">
                            <field name="diferencia_peso" readonly="1"
                                   decoration-danger="diferencia_peso &lt; 0"
                                   decoration-warning="diferencia_peso &gt; 0"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_despachar" string="Despachar" type="object"
                                class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
