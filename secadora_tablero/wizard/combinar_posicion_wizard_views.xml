<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_combinar_posicion_wizard_form" model="ir.ui.view">
            <field name="name">secadora.combinar.posicion.wizard.form</field>
            <field name="model">secadora.combinar.posicion.wizard</field>
            <field name="arch" type="xml">
                <form string="Combinar Posiciones de Arroz">
                    <group>
                        <field name="sitio_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="posicion_ids" widget="many2many_checkboxes"/>
                    </group>
                    <group>
                        <field name="peso_total" readonly="1"/>
                    </group>
                    <footer>
                        <button name="action_combinar" string="Combinar" type="object"
                                class="oe_highlight"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
