<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Grupo: Operador de Tablero -->
        <record id="group_tablero_operador" model="res.groups">
            <field name="name">Operador Tablero</field>
            <field name="category_id" ref="bascula.module_category_bascula"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Grupo: Administrador de Tablero -->
        <record id="group_tablero_admin" model="res.groups">
            <field name="name">Administrador Tablero</field>
            <field name="category_id" ref="bascula.module_category_bascula"/>
            <field name="implied_ids" eval="[(4, ref('group_tablero_operador'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>


        <!-- ====== Reglas Multi-Empresa ====== -->

        <!-- Posición de Arroz: Multi-Company -->
        <record id="posicion_arroz_company_rule" model="ir.rule">
            <field name="name">Posición Arroz: Multi-Company</field>
            <field name="model_id" ref="model_secadora_posicion_arroz"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- Movimiento de Arroz: Multi-Company -->
        <record id="movimiento_arroz_company_rule" model="ir.rule">
            <field name="name">Movimiento Arroz: Multi-Company</field>
            <field name="model_id" ref="model_secadora_movimiento_arroz"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>
