<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_embolsado_combo_form" model="ir.ui.view">
            <field name="name">secadora.embolsado.combo.form</field>
            <field name="model">secadora.embolsado.combo</field>
            <field name="arch" type="xml">
                <form string="Combo Tractor+Tolvo">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="Ej: Combo 1"/>
                                <field name="tractor_equipo_id"/>
                                <field name="tolvo_equipo_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="tara_vigente_kg"/>
                                <field name="tara_vigente_fecha"/>
                            </group>
                        </group>
                        <group>
                            <button name="action_registrar_tara"
                                    string="Registrar Tara"
                                    type="object"
                                    class="btn-primary"
                                    icon="fa-balance-scale"/>
                        </group>
                        <notebook>
                            <page string="Historial de Taras">
                                <field name="tara_ids" readonly="1">
                                    <list>
                                        <field name="fecha"/>
                                        <field name="peso_tara_kg"/>
                                        <field name="usuario_id"/>
                                        <field name="capturada_de_bascula"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notas">
                                <field name="notas"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_embolsado_combo_list" model="ir.ui.view">
            <field name="name">secadora.embolsado.combo.list</field>
            <field name="model">secadora.embolsado.combo</field>
            <field name="arch" type="xml">
                <list string="Combos Tractor+Tolvo">
                    <field name="name"/>
                    <field name="tractor_equipo_id"/>
                    <field name="tolvo_equipo_id"/>
                    <field name="tara_vigente_kg"/>
                    <field name="tara_vigente_fecha"/>
                </list>
            </field>
        </record>

        <record id="action_embolsado_combo" model="ir.actions.act_window">
            <field name="name">Combos Tractor+Tolvo</field>
            <field name="res_model">secadora.embolsado.combo</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cree el primer combo
                </p>
                <p>
                    Un combo es una pareja tractor+tolvo (equipos del módulo de
                    Mantenimiento). Las taras y los viajes de embolsado se
                    registran por combo.
                </p>
            </field>
        </record>

    </data>
</odoo>
