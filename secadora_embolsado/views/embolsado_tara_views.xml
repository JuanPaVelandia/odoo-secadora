<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_embolsado_tara_form" model="ir.ui.view">
            <field name="name">secadora.embolsado.tara.form</field>
            <field name="model">secadora.embolsado.tara</field>
            <field name="arch" type="xml">
                <form string="Tara de Combo">
                    <sheet>
                        <div class="alert alert-warning" role="alert" invisible="not esta_vencida">
                            <i class="fa fa-exclamation-triangle me-1"/>
                            Esta tara está vencida: vuelva a pesar el combo vacío.
                        </div>
                        <group>
                            <group>
                                <field name="combo_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <!-- Peso en vivo desde báscula (lectura Web Serial) -->
                                <field name="peso_vivo"
                                       widget="peso_embolsado_field"
                                       nolabel="1"
                                       colspan="2"/>
                                <field name="peso_tara_kg" style="font-size: 18px; font-weight: bold;"/>
                                <field name="fecha"/>
                                <field name="usuario_id"/>
                                <field name="capturada_de_bascula"/>
                                <field name="esta_vencida" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <button name="action_capturar_peso_bascula"
                                    string="Capturar peso de báscula"
                                    type="object"
                                    class="btn-primary"
                                    icon="fa-balance-scale"/>
                        </group>
                        <group>
                            <field name="notas"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_embolsado_tara_list" model="ir.ui.view">
            <field name="name">secadora.embolsado.tara.list</field>
            <field name="model">secadora.embolsado.tara</field>
            <field name="arch" type="xml">
                <list string="Taras">
                    <field name="combo_id"/>
                    <field name="peso_tara_kg"/>
                    <field name="fecha"/>
                    <field name="usuario_id" optional="show"/>
                    <field name="capturada_de_bascula" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_embolsado_tara_search" model="ir.ui.view">
            <field name="name">secadora.embolsado.tara.search</field>
            <field name="model">secadora.embolsado.tara</field>
            <field name="arch" type="xml">
                <search string="Taras">
                    <field name="combo_id"/>
                    <group>
                        <filter string="Combo" name="group_combo" context="{'group_by': 'combo_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_embolsado_tara" model="ir.actions.act_window">
            <field name="name">Taras de Combos</field>
            <field name="res_model">secadora.embolsado.tara</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Registre la primera tara
                </p>
                <p>
                    Pese el combo tractor+tolvo vacío con la frecuencia definida.
                    Cada viaje de embolsado usa la tara más reciente de su combo.
                </p>
            </field>
        </record>

    </data>
</odoo>
