<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form -->
        <record id="view_silobolsa_form" model="ir.ui.view">
            <field name="name">secadora.silobolsa.form</field>
            <field name="model">secadora.silobolsa</field>
            <field name="arch" type="xml">
                <form string="Silobolsa">
                    <header>
                        <button name="action_registrar_viaje"
                                string="Registrar Viaje"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'abierto'"/>
                        <button name="action_nuevo_analisis"
                                string="Nuevo Análisis"
                                type="object"/>
                        <button name="action_cerrar"
                                string="Cerrar Silobolsa"
                                type="object"
                                confirm="¿Cerrar esta silobolsa? No podrá recibir más viajes."
                                invisible="state != 'abierto'"/>
                        <button name="action_reabrir"
                                string="Reabrir"
                                type="object"
                                groups="secadora_embolsado.group_embolsado_admin"
                                invisible="state != 'cerrado'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_ver_analisis"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-flask">
                                <field name="analisis_count" widget="statinfo" string="Análisis"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="ubicacion"/>
                                <field name="variedad_id"/>
                                <field name="sitios_origen"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="peso_total_kg"/>
                                <field name="cantidad_viajes"/>
                                <field name="fecha_inicio"/>
                                <field name="fecha_fin_embolsado"/>
                                <field name="fecha_cierre" invisible="not fecha_cierre"/>
                                <field name="humedad_ultima"/>
                                <field name="stock_move_id" invisible="not stock_move_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Viajes">
                                <field name="viaje_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="fecha"/>
                                        <field name="combo_id"/>
                                        <field name="sitio_id"/>
                                        <field name="peso_lleno_kg"/>
                                        <field name="peso_tara_kg"/>
                                        <field name="peso_neto_kg" sum="Total Neto"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state == 'confirmado'"
                                               decoration-danger="state == 'cancelado'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Laboratorio">
                                <field name="analisis_lab_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="fecha_hora"/>
                                        <field name="seccion_silobolsa"/>
                                        <field name="humedad"/>
                                        <field name="impurezas"/>
                                        <field name="grano_partido"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state == 'confirmado'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notas">
                                <field name="notas"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- List -->
        <record id="view_silobolsa_list" model="ir.ui.view">
            <field name="name">secadora.silobolsa.list</field>
            <field name="model">secadora.silobolsa</field>
            <field name="arch" type="xml">
                <list string="Silobolsas">
                    <field name="name"/>
                    <field name="ubicacion" optional="show"/>
                    <field name="variedad_id" optional="show"/>
                    <field name="peso_total_kg" sum="Total Kg"/>
                    <field name="cantidad_viajes"/>
                    <field name="fecha_inicio"/>
                    <field name="fecha_fin_embolsado"/>
                    <field name="humedad_ultima" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'abierto'"
                           decoration-info="state == 'cerrado'"/>
                </list>
            </field>
        </record>

        <!-- Kanban (panel) -->
        <record id="view_silobolsa_kanban" model="ir.ui.view">
            <field name="name">secadora.silobolsa.kanban</field>
            <field name="model">secadora.silobolsa</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" quick_create="false">
                    <field name="name"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="card">
                            <div class="p-2">
                                <div class="d-flex justify-content-between">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="text-muted" t-if="record.ubicacion.raw_value">
                                    <i class="fa fa-map-marker me-1"/><field name="ubicacion"/>
                                </div>
                                <div class="mt-1" style="font-size: 18px; font-weight: bold;">
                                    <field name="peso_total_kg" widget="float" digits="[12,0]"/> kg
                                </div>
                                <div class="text-muted">
                                    <field name="cantidad_viajes"/> viajes
                                    <t t-if="record.humedad_ultima.raw_value">
                                        · <i class="fa fa-tint me-1"/><field name="humedad_ultima"/>%
                                    </t>
                                </div>
                                <div class="text-muted" t-if="record.fecha_inicio.raw_value">
                                    <i class="fa fa-calendar me-1"/>
                                    <field name="fecha_inicio" widget="date"/>
                                    <t t-if="record.fecha_fin_embolsado.raw_value">
                                        → <field name="fecha_fin_embolsado" widget="date"/>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </templates>
                    <field name="ubicacion"/>
                    <field name="peso_total_kg"/>
                    <field name="cantidad_viajes"/>
                    <field name="humedad_ultima"/>
                    <field name="fecha_inicio"/>
                    <field name="fecha_fin_embolsado"/>
                </kanban>
            </field>
        </record>

        <!-- Search -->
        <record id="view_silobolsa_search" model="ir.ui.view">
            <field name="name">secadora.silobolsa.search</field>
            <field name="model">secadora.silobolsa</field>
            <field name="arch" type="xml">
                <search string="Silobolsas">
                    <field name="name"/>
                    <field name="ubicacion"/>
                    <field name="variedad_id"/>
                    <filter string="Abiertas" name="filter_abiertas" domain="[('state', '=', 'abierto')]"/>
                    <filter string="Cerradas" name="filter_cerradas" domain="[('state', '=', 'cerrado')]"/>
                    <group>
                        <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Variedad" name="group_variedad" context="{'group_by': 'variedad_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_silobolsa" model="ir.actions.act_window">
            <field name="name">Silobolsas</field>
            <field name="res_model">secadora.silobolsa</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_filter_abiertas': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cree la primera silobolsa
                </p>
                <p>
                    Cada silobolsa acumula los viajes de embolsado y descuenta
                    una unidad del inventario al confirmarse el primer viaje.
                </p>
            </field>
        </record>

    </data>
</odoo>
